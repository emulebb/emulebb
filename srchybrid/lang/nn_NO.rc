    IDS_BIND_STATUS_ADDRESS_MISSING_FMT                        "Aktiv P2P-binding: Ethvert grensesnitt. Den lagrede bindingen IP mangler på alle live-grensesnitt: %s"
    IDS_BIND_RESTART_REQUIRED                                  "Omstart kreves: de nye bindingsinnstillingene trer i kraft først etter omstart av eMuleBB."
    IDS_BIND_RESTART_FALLBACK_DEFAULT                          "Omstart vil falle tilbake til standardgrensesnittet fordi det lagrede bindingsmålet er uløst."
    IDS_BIND_ADDRESS_INVALID_IPV4                              "BindAddr må være tom eller en gyldig IPv4-adresse."
