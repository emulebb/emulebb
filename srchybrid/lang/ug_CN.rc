    IDS_SEARCH_INFOTIP_SERVERS                                 "مۇلازىمېتىرلار"
    IDS_NO_MATCHING_ENTRY_FOUND                                "ماس كېلىدىغان تۈر تېپىلمىدى."
    IDS_FATAL_NO_RICHEDIT                                      "ئەجەللىك خاتالىق: باي تەھرىرلەش كونترول ئامبىرى تېپىلمىدى!"
    IDS_FATAL_KAD_UNICODE_TABLES                               "ئەجەللىك خاتالىق: Kademlia ئۈچۈن يۇنىكود ھەرپ جەدۋىلىنى يۈكلىيەلمىدى!"
    IDS_KAD_UNICODE_MAP_NOT_INITIALIZED                        "Kad يۇنىكود كىچىك ھەرپ-بەلگە خەرىتىسى دەسلەپكى قەدەمدە ئەمەس!"
    IDS_TWEAKS_TT_CONDITIONAL_TCP_ACCEPT                       "پەقەت پايدىلىق كۆرۈنگەندىلا كىرگەن TCP ئۇلىنىشىنى قوبۇل قىلىشنى ياخشى كۆرىدۇ.\r\n\r\nئۇلىنىش بېسىمىغا دىئاگنوز قويمىسىڭىز ئۇنى سۈكۈتتىكى ھالەتتە قويۇڭ."
    IDS_TWEAKS_TT_MAX_CON5_SEC                                 "ئەڭ يېڭى TCP ئۇلىنىشى eMuleBB بەش سېكۇنت ئىچىدە ئېچىلىشى مۇمكىن.\r\n\r\nLower قىممىتى Windows ۋە روتېرلاردا مۇلايىم. ئەگەر ئۇلىنىش پارتىلاش ھەرىكىتىنى تەڭشىمىسىڭىز ئۇنى سۈكۈتتىكى ئورۇنغا قويۇپ قويۇڭ."
    IDS_TWEAKS_TT_MAX_HALF_OPEN                                "يېرىم ئوچۇق چېگرا سىرتىدىكى TCP ئۇلىنىش سىنىقىنىڭ يۇقىرى چېكى.\r\n\r\nكۆپىنچە ماسلىشىشچانلىقى بار. TCP تەڭشەش مەسىلىسىنى تەكشۈرمىسىڭىز سۈكۈتتىكى تاللاش ئادەتتە توغرا تاللاش."
    IDS_TWEAKS_TT_CONNECTION_TIMEOUT                           "eMuleBB مەغلۇب بولۇشتىن ئىلگىرى يېڭى ئۇلىنىشنىڭ قانچىلىك ئىلگىرىلىشىنى ساقلايدۇ.\r\n\r\nShorter قىممىتى ئۆلۈك تورداشلاردىن تېز ئەسلىگە كېلىدۇ. ئۇزۇن قىممەت ئاستا تورلارغا تېخىمۇ بەرداشلىق بېرىدۇ. سۈكۈتتىكى قىممەت تەۋسىيە قىلىنىدۇ."
    IDS_TWEAKS_TT_DOWNLOAD_TIMEOUT                             "eMuleBB توختاپ قېلىشتىن بۇرۇن چۈشۈرۈش مەنبەسى قانچىلىك ۋاقىت بىكار تۇرالايدۇ.\r\n\r\nLower قىممىتى ئۆلۈك مەنبەلەرنى تېز تازىلايدۇ ، ئەمما ئىنتايىن تۆۋەن قىممەت ئاستا تورداشلارغا زىيان سالىدۇ. يايمىلارغا دىئاگنوز قويمىسىڭىز سۈكۈتتىكى ھالەتتە قويۇڭ."
    IDS_TWEAKS_TT_SERVER_KEEP_ALIVE_TIMEOUT                    "eMuleBB قانچە قېتىم باشقا بىكار مۇلازىمېتىر ئۇلىنىشىنى يېڭىلايدۇ.\r\n\r\nQZZ1XZQU مىنۇت. ساقلاشنى چەكلەش ئۈچۈن 0 نى تەڭشەڭ. ئەگەر سىز مەلۇم بىر مۇلازىمېتىر بىكار ئۈزۈش مەسىلىسىنى ھەل قىلمىسىڭىز ، سۈكۈتتىكى ھالەتنى تاشلاڭ."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_RESULTS                      "بىر ئىزدەش ئۈچۈن eD2K مۇلازىمېتىرىدىن تەلەپ قىلىنغان ئەڭ كۆپ نەتىجە.\r\n\r\nHigher قىممىتى تېخىمۇ كۆپ ھۆججەتلەرنى تاپالايدۇ ، ئەمما مۇلازىمېتىر خىزمىتى ۋە UI ئاۋازىنى ئاشۇرالايدۇ. ئەگەر ئالاھىدە سەۋەبىڭىز بولمىسا سۈكۈتتىكى ھالەتتە تۇرۇڭ."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_MORE_REQUESTS                "ئىز قوغلاش نەتىجىسىنىڭ ئەڭ كۆپ سانى eD2K ئىزدەشتىن eMuleBB تەلەپ قىلىدۇ.\r\n\r\nمۇتەئەسسىپ قىممەتلەر تەۋسىيە قىلىنىدۇ."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_TOTAL                        "Kad ھۆججىتىنى ئىزدەشنىڭ نىشان سانى.\r\n\r\nتېخىمۇ چوڭقۇر ئىزدەشنى خالىمىسىڭىز سۈكۈتتىكى ھالەتتە تۇرۇڭ."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_TOTAL                     "Kad ئاچقۇچلۇق سۆز ئىزدەشتىكى نىشان سانى.\r\n\r\nسۈكۈتتىكىسى ئادەتتە توغرا تەڭپۇڭلۇق."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_LIFETIME                     "بىر Kad ھۆججەت ئىزدە\r\n\r\nشنىڭ ئەڭ ئۇزۇن ئۆمرى سېكۇنتتا."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_LIFETIME                  "بىر Kad ئاچقۇچلۇق سۆز ئ\r\n\r\nىزدەش ئۆمرىنىڭ ئەڭ ئۇزۇن ئۆمرى سېكۇنت."
    IDS_TWEAKS_TT_GENERAL_ADVANCED                             "تور ، ھۆججەت ، كۆرسىتىش ياكى بىخەتەرلىك ئاستىدا تازا ماس كەل\r\n\r\nمەيدىغان ئادەتتىكى ئىلغار ھەرىكەتلەر."
    IDS_TWEAKS_TT_HIDDEN_FILE                                  "ئىلغار ھۆججەت بىر تەرەپ قىلىش ھەرىكىتى ، ئالدىن\r\n\r\nكۆرۈش ۋە ھۆججەت تارىخىغا مۇناسىۋەتلىك تاللاشلار."
    IDS_TWEAKS_TT_STORAGE_PERSISTENCE                          "ئىلغار دىسكا بوشلۇقىنى قوغداش ، ھۆججەت يوللاش ۋە مېتا سانلىق مەلۇماتتا چىڭ تۇرۇش تەڭشەكلىرى.\r\n\r\nبۇ ساقلاش بىخەتەرلىكى ۋە دىسكا- I / O سودىسىنىڭ ئاساسلىق گۇرۇپپىسى."
    IDS_TWEAKS_TT_HIDDEN_STARTUP                               "ئىلغار قوزغىتىش ھەرىكىتىنى ئەسلىگە كەلتۈرۈش ھەرىكىتى.\r\n\r\nبۇ تاللاشلار پەقەت eMuleBB قوزغالغاندا UI تاختىسىنىڭ قايتىپ كېلىشىگە تەسىر كۆرسىتىدۇ."
    IDS_TWEAKS_TT_HIDDEN_DISPLAY                               "ئىلغار كۆرسىتىش ، ۋەزىپە بالدىقى ، تەخسە ۋە كۆرۈنۈشلۈك ئۇچۇر تەڭشەكلىرى.\r\n\r\nبۇ تاللاشلار پەقەت تونۇشتۇرۇشنىلا ئۆزگەرتىدۇ ، يۆتكىلىش ھەرىكىتىنى ئەمەس."
    IDS_TWEAKS_TT_HIDDEN_SECURITY                              "تورداشلار ۋە ئۇچۇر بىر تەرەپ قىلىش ئۈچۈن ئىلغار سۈزۈش ۋە قوغداش تاللانمىلىرى.\r\n\r\nتەۋسىيە قىلىنغان سۈكۈتتىكى ئىقتىدار كۆپىنچە ئىشلەتكۈچىلەرگە ماس كېلىدۇ."
    IDS_TWEAKS_TT_LOGGING_GROUP                                "ئۈزلۈكسىز خاتىرىلەش ۋە دىئاگنوز قويۇش نەتىجىسىنى كونترول قىلىش.\r\n\r\nبۇ تەڭشەكلەرنىڭ كۆپىنچىسى پەقەت مەسىلىگە دىئاگنوز قويغاندا پايدىلىق."
    IDS_TWEAKS_TT_AUTO_TAKE_ED2K_LINKS                         "eMuleBB نى ed2k: // link.\r\n\r\nE نىڭ سۈكۈتتىكى بىر تەرەپ قىلغۇچىسى سۈپىتىدە تىزىملىتىدۇ. ئەگەر باشقا بىر قورال شۇ جەمئىيەتكە ئىگە بولسا ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_CREDIT_SYSTEM                                "يۈكلەش خېرىدارلىرىنى رەتكە تۇرغۇزغاندا نورمال eMule ئىناۋەتلىك سىستېمىسىنى ئىشلىتىدۇ.\r\n\r\nQZZ1XZQ تەۋسىيە قىلىنغان: قوزغىتىلغان. ئۇنى ھەل قىلىش ياكى قەستەن ماسلىشىش تەجرىبىسى ئۈچۈنلا چەكلەڭ."
    IDS_TWEAKS_TT_YOUR_HOSTNAME                                "ئىختىيارىي ئىسىم بەلگىسى eMuleBB يەرلىك كىملىك\r\n\r\n​​تېكىستى كۆرسىتىلگەن يەردە دوكلات قىلىدۇ."
    IDS_TWEAKS_TT_TXT_EDITOR                                   "eMuleBB خاتىرە ياكى ھاسىل قىلىنغان تېكىست چىقىرىش قاتارلىق تېكىست ھۆججەتلىرىنى ئاچقاندا ئىشلىتىلگەن بۇيرۇق.\r\n\r\nسۈكۈتتىكىسى notepad.exe."
    IDS_TWEAKS_TT_HIGHRES_TIMER                                "eMuleBB ئىجرا بولۇۋاتقاندا يۇقىرى ئېنىقلىقتىكى Windows ۋاقىت تەلەپ قىلىدۇ.\r\n\r\nبۇ بەزى سىستېمىلاردا ۋاقىتنى راۋانلاشتۇرالايدۇ ، ئەمما ئۇ توك ئىشلىتىشنى ئاشۇرۇشى مۇمكىن. eMuleBB نى ئۆزگەرتكەندىن كېيىن قايتا قوزغىتىڭ."
    IDS_TWEAKS_TT_ICH                                          "بۇزۇلغان چۈشۈرۈلگەن پارچىلارنى ئەقلىي ئىقتىدارلىق چىرىكلىك بىر تەرەپ قىلىشنى قوزغىتىدۇ.\r\n\r\nتەۋسىيە قىلىنغان: قوزغىتىلغان. ئۇ ئېھتىياجدىن ئېشىپ كېتىشنىڭ ئورنىغا بۇزۇلغان زاپچاسلارنىڭ ئىچىدىكى ياخشى سانلىق مەلۇماتلارنى ئەسلىگە كەلتۈرۈشكە ياردەم بېرىدۇ."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS                         "نورمال ئالدىن كۆرۈش بىخەتەرلىك تەكشۈرۈشى تولۇق قاندۇرۇشتىن بۇرۇن مېد\r\n\r\nىيا ئالدىن كۆرۈشنىڭ تەمىنلەنگەن ياكى تەمىنلەنمىگەنلىكىنى كونترول قىلىدۇ."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_DISABLED                "نورمال مۇتەئەسسىپ ئالدىن كۆرۈش قائىدىسىنى ئىشلىتىڭ."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_ALLOW                   "نورمال مېتا سانلىق مەلۇمات ۋە قويغۇچ تەكشۈرۈشىدىن ئۆتكەندىن كېيىن كىچىكرەك بۆلەكلەر بىلەن ئالدىن كۆرۈشكە يول قويۇڭ."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_FORCE                   "بىرىنچى بۆلەك يوقاپ كەتكەن تەقدىردىمۇ ئالدىن كۆرۈشنى تەمىنلەڭ.\r\n\r\nU پەقەت VLC غا ئوخشاش تولۇق بولمىغان تاراتقۇلارغا بەرداشلىق بېرەلەيدىغان قويغۇچلار بىلەنلا ئىشلىتىڭ."
    IDS_TWEAKS_TT_BEEP_ON_ERROR                                "eMuleBB مۇھىم خاتالىقلارنى دوكلات قىلغاندا سىستېما خاتالىق ئاۋازىنى قويالايدۇ.\r\n\r\nئەگەر ئاۋازلىق ئاگاھلاندۇرۇشلار دىققىتى چېچىلىدىغان بولسا ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_SHOW_COPY_ED2K_LINK_CMD                      "ھۆججەت مەزمۇنى تىزىملىكىنى ئۆزگەرتىپ ، ed2k ئۇلىنىش ھەرىكىتىنىڭ ئورنىغا بىۋاسىتە\r\n\r\nكۆچۈرۈش ed2k ئۇلىنىش بۇيرۇقىنى كۆرسىتىدۇ."
    IDS_TWEAKS_TT_SPARSE_PART_FILES                            "ھۆججەت سىستېمىسى ئۇلارنى قوللىغاندا قىسمەن ھۆججەتلەرگە شالاڭ ھۆججەتلەرنى ئىشلىتىدۇ.\r\n\r\nRecommended: NTFS دا قوزغىتىلغان دىسكا تەقسىملەشنى ئازايتىدۇ. ئاز ئۇچرايدىغان ھۆججەت ھەرىكىتى ھۆججەت سىستېمىسىغا مۇناسىۋەتلىك مەسىلە پەيدا قىلغاندىلا چەكلىنىدۇ."
    IDS_TWEAKS_TT_FULL_ALLOC                                   "چۈشۈرۈش باشلانغاندا دىسكىدىكى تولۇق نىشان ھۆججەتنىڭ چوڭ-كىچىكلىكىنى ئالدىن بەلگىلەيدۇ.\r\n\r\nتولۇق تەقسىملەشنى ياقتۇرمىسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_CONFIG                   "eMuleBB نىڭ سەپلىمە ھۆججىتىنى ساقلايدىغان ئاۋاز بوشلۇقىدا ساقلانغان ئەڭ تۆۋەن بوشلۇق.\r\n\r\nHard ئەڭ تۆۋەن:\r\n1 GiB. ئەگەر بۇ ئاۋاز ئۈنۈملۈك چەكتىن تۆۋەن بولسا ، eMuleBB بارلىق چۈشۈرۈشنى توختىتىدۇ ۋە .part.met ھۆججىتىنى دەرھال تېجەيدۇ."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_TEMP                     "ھەر بىر ھەجىمدىكى temp ھۆججىتىنى ساقلايدىغان ئەڭ تۆۋەن بوشلۇق.\r\n\r\nHard ئەڭ تۆۋەن:\r\n5 GiB. ئەگەر ھەر قانداق قوغدىلىدىغان ئاۋاز ئۈنۈملۈك چەكتىن تۆۋەن بولسا ، eMuleBB بارلىق چۈشۈرۈشنى توختىتىدۇ ۋە .part.met ھۆججىتىنى دەرھال تېجەيدۇ."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_INCOMING                 "ھەر بىر ھەجىمدە كەلگەن ھۆججەتلەرنى ساقلايدىغان ئەڭ تۆۋەن بوشلۇق ، كاتېگورىيەگە ماس كېلىدىغان مۇندەرىجىلەرنى ئۆز ئىچىگە ئالىدۇ.\r\n\r\nHard ئەڭ تۆۋەن: 5 GiB. ئەگەر كەلگەنلەر تەڭشەش ياكى temp بىلەن ئاۋازنى ھەمبەھىرلىسە ، بۇ ئاۋازنىڭ ئەڭ چوڭ چېكى غەلىبە قىلىدۇ ۋە بۇزۇلغاندا بارلىق چۈشۈرۈش توختىتىلىدۇ."
    IDS_TWEAKS_TT_PERF_LOG                                     "سىرتقى گرافىك قوراللىرى ئۈچۈن قەرەللىك يۈك بېسىش ۋە ئۈستىدىكى ئەۋرىشكىلەرنى يازىدۇ.\r\n\r\nOperator / debug ئىقتىدارى پەقەت. ھاسىل قىلىنغان ھۆججەتلەرنى ئاكتىپلىق بىلەن ئىستېمال قىلمىسىڭىز ئۇنى تاشلاڭ."
    IDS_TWEAKS_TT_COMMIT                                       "eMuleBB نىڭ قانچىلىك تاجاۋۇزچىلىق بىلەن Windows نى ساقلىغان ھۆججەت سانلىق مەلۇماتلىرىنى دىسكىغا چىقىرىشقا زورلايدىغانلىقىنى كونترول قىلىدۇ.\r\n\r\n«پەقەت تاقالغاندىلا» تەڭپۇڭ ھالەتتە بولىدۇ."
    IDS_TWEAKS_TT_COMMIT_NEVER                                 "ھۆججەتلەرنى OS دەرىجىلىك دىسكا ئېقىمىغا زورلىماي نورمال تاقاڭ.\r\n\r\nIZ O دىكى ئەڭ تېز ۋە ئەڭ يېنىك دىسكا."
    IDS_TWEAKS_TT_COMMIT_ON_SHUTDOWN                           "پەقەت eMuleBB تاقىلىپ قالغاندا OS دەرىجىلىك دىسكىنى قوزغىتىشنى زورلاڭ.\r\n\r\nR تەۋسىيە قىلىنغان سۈكۈت. ئۇ ھەر قېتىملىق تېجەش جەريانىدا ئارتۇقچە قىزىتىشقا مەجبۇرلىماي پاكىز چىقىشتا چىڭ تۇرۇش بىخەتەرلىكىنى ياخشىلايدۇ."
    IDS_TWEAKS_TT_COMMIT_ALWAYS                                "eMuleBB نىڭ ۋەدىگە يېقىن ياردەمچىسى ئىشلىتىدىغان ھەر\r\n\r\nبىر ساقلاش يولىغا OS دەرىجىلىك دىسكا ئېقىمىنى زورلاڭ."
    IDS_TWEAKS_TT_EXTRACT_META_DATA                            "eMuleBB ھۆججەتلەردىن خەتكۈچ ۋە مېدىيا ۋاقتى قاتارلىق مېتا سانلىق مەلۇماتلارنى چىقىرىدىغانلىقىنى كونترول قىلىدۇ.\r\n\r\nئەڭ يېنىك سايىلەشنى ئويلىسىڭىز ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_GEO_LOCATION_ENABLED                         "تورداشلارنىڭ IPs نى دۆلەت دەرىجىلىك ئورۇن ئۇچۇرىغا كۆرسىتىش ئۈچۈن ھەل قىلىدۇ.\r\n\r\nئېنىق ئۇچۇر. ئەگەر دۆلەت بايرىقىغا كۆڭۈل بۆلمىسىڭىز ياكى تەگلىك يېڭىلاشنى خالىمىسىڭىز ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_CLOSE_U_PN_P_PORTS                           "ئاپتوماتىك NAT خەرىتىسىنى ئىشلەتكەندە پاكىز چىقىشتا روتېر خەرىتىسىنى تاقايدۇ.\r\n\r\nQZZ1XZQ تەۋسىيە قىلىنغان: قوزغىتىلغان. خەرىتە سىز قالدۇرۇپ قويماقچى بولسىڭىزلا ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE                          "eMuleBB نىڭ ئاپتوماتىك NAT خەرىتىسىنى قانداق ئىجرا قىلىدىغانلىقىنى تاللايدۇ.\r\n\r\nQZZ1XZQ تەۋسىيە قىلىنغان: ئاپتوماتىك. ئۇ ئالدى بىلەن UPnP IGD نى سىنايدۇ ھەمدە ئېھتىياجلىق بولغاندا PCP / NAT-PMP غا قايتىدۇ."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_AUTOMATIC                "تەۋسىيە قىلىنغان ھالەت. ئاۋۋال UPnP IGD نى سىناپ بېقىڭ ، ئاندىن خەرىتە مەغلۇپ بولسا PCP / NAT-PMP غا قايتىڭ."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_IGD_ONLY                 "پەقەت UPnP IGD خەرىتىسىنى ئىشلىتىڭ. ئەگەر قاتتىق كلاسسىك UPnP ھەرىكىتىنى ئويلىسىڭىز بۇنى تاللاڭ."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_PCP_NAT_PMP_ONLY         "پەقەت PCP / NAT-PMP خەرىتىسىنى ئىشلىتىڭ. روتېر مۇھىتىڭىز ئۇنى ياخشى كۆرسىلا بۇنى تاللاڭ."
    IDS_TWEAKS_TT_FILE_BUFFER_TIME_LIMIT                       "eMuleBB ئۇنى دىسكىغا يۆتكەشتىن بۇرۇن بۇففېرلانغان ھۆججەت سانلىق مەلۇماتلىرىنىڭ ئەڭ چوڭ يېشى.\r\n\r\nتېخىمۇ يۇقىرى قىممەت دىسكا چىرىغىنى ئازايتالايدۇ. سۈكۈت ئادەتتە ياخشى مۇرەسسە."
    IDS_TWEAKS_TT_FILE_BUFFER_SIZE                             "چۈشۈرۈش سانلىق مەلۇماتلىرىنى دىسكىغا يۆتكەشتىن بۇرۇن ئىشلىتىلگەن ھەر بىر ھۆججەت يېزىش بۇففېرنىڭ چوڭ-كىچىكلىكى.\r\n\r\nئەگەر ئالاھىدە ساقلاش تەڭشىكىنى تەڭشىمىسىڭىز ئوتتۇراھال قىممەتنى ساقلاڭ."
    IDS_TWEAKS_TT_QUEUE_SIZE                                   "يۈكلەش كۈتۈش لىنىيىسىنىڭ نىشان چوڭلۇقى.\r\n\r\nكۆپىنچە ئىشلەتكۈچىلەر ئۈچۈن كۆڭۈلدىكى قىممەت تەۋسىيە قىلىنىدۇ."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LISTS                      "تىزىملىك ​​كۆرۈنۈشىدە ئىشلىتىلىدىغان ئىختىيارى چېسلا / ۋاقىت فورماتى.\r\n\r\nL نورمال سۈكۈتتىكى فورماتنى ئىشلىتىش ئۈچۈن بوش قويۇڭ. ئەگەر سىز بەلگىلىك ۋاقىت جەدۋىلى ئۇسلۇبىنى ئويلىسىڭىزلا ئۇنى ئۆزگەرتىڭ."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT                             "ئادەتتىكى ھۆججەت ۋە تورداشلارنىڭ تەپسىلاتلىرى ئىشلىتىدىغان ئىختىيارى چېسلا / ۋاقىت فورماتى.\r\n\r\nUses CTime فورماتلاش بەلگىسى. ئۇنى بوش قويماڭ. ئىناۋەتسىز بەلگىلەر قالايمىقان ۋاقىت تامغىسىنى ھاسىل قىلالايدۇ."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LOG                        "خاتىرە قۇر ۋە خاتىرە ھالىتىگە ئوخشاش خاسلاشتۇرۇلغان ۋاقىت / ۋاقىت فورماتى.\r\n\r\nUses CTime فورماتلاش بەلگىسى. ئىخچام ساقلاڭ ، شۇڭا خاتىرە قۇرلارنى ئوقۇغىلى بولىدۇ."
    IDS_TWEAKS_TT_ICON_FLASH_ON_NEW_MESSAGE                    "يېڭى پاراڭلىشىش ئۇچۇرى كەلگەندە تەخسە سىنبەلگىسىنى چاقنىتىدۇ.\r\n\r\nپەقەت ئۇقتۇرۇش مايىللىقى. eMuleBB كىچىكلىتىلگەندە ئۇچۇرلارنىڭ ئالاھىدە بولۇشىنى ئۈمىد قىلسىڭىز ئۇنى قوزغىتىڭ."
    IDS_TWEAKS_TT_INSPECT_ALL_FILE_TYPES                       "ئاۋازلىق ياكى سىنغا ئايرىلمىغان ھۆججەت تىپلىرىنى قىممەت باھالىق MediaInfo ئۇسلۇبىدىكى تەكشۈرۈش يولىنىمۇ ئىجرا قىلىڭ.\r\n\r\nE ئەگەر نورمال بولمىغان ياكى خاتا ھۆججەتلەرنى تەكشۈرمەكچى بولسىڭىز ، ئۇنى قوزغىتىڭ. ئۇنى قويۇپ بېرىش ئېھتىماللىقى بولغان ئاۋاز / سىن ھۆججىتىنىلا تەكشۈرۈپ ، تەگلىك تەكشۈرۈش خىزمىتىنى ئازايتىڭ."
    IDS_TWEAKS_TT_RE_BAR_TOOLBAR                               "تېخىمۇ ئاددىي بولغان قورالبالدىقىنىڭ ئورۇنلاشتۇرۇلۇشىنىڭ ئورنىغا كونا rebar ئۇسلۇبىدىكى ئاساسلىق قورال ستونىنى ئىشلىتىڭ.\r\n\r\nكۆپىنچە UI ئورۇنلاشتۇرۇش ئەۋزەللىكى. مىراس قورال ستونىنى كۆرسىتىشنى ياقتۇرسىڭىزلا ئۇنى قوزغىتىڭ."
    IDS_TWEAKS_TT_SHOW_UP_DOWN_ICON_IN_TASKBAR                 "ۋەزىپە بالدىقى ئۇقتۇرۇش رايونىدا بىرلەشتۈرۈلگەن يۈكلەش / چۈشۈرۈش نىسبىتى سىنبەلگىسىنى كۆرسىتىدۇ.\r\n\r\nئېنىق كۆرۈنۈش. ئەگەر تېخىمۇ پاكىز تەخسە رايونىنى ئويلىسىڭىز ئۇنى چەكلەڭ."
    IDS_ALWAYS_SHOW_TRAY_ICON                                  "ھەمىشە تەخسە سىنبەلگىسىنى كۆرسىتىڭ"
    IDS_TWEAKS_TT_ALWAYS_SHOW_TRAY_ICON                        "eMuleBB ئىجرا بولۇۋاتقان ۋاقىتتا eMuleBB\r\n\r\nسىنبەلگىسىنى Windows ئۇقتۇرۇش رايونىدا كۆرگىلى بولىدۇ."
    IDS_TWEAKS_TT_SHOW_VERTICAL_HOUR_MARKERS                   "ئۇزۇن مۇددەتلىك ستاتىستىكا گرافىكىدا سائەتلىك يېتەكچى بەلگىلەرنى سىزىدۇ.\r\n\r\nۋاقىتنى ئاساس قىلغان قاتناش ئەندىزىسىنى ئوقۇشقا پايدىلىق. گرافىك قالايمىقانلىقىنى ياقتۇرسىڭىز ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_FORCE_SPEEDS_TO_KB                           "زورلۇق نىسبىتى ئاپتوماتىك ھالدا چوڭراق ئورۇنلارغا كېڭەيتىشنىڭ ئورنىغا KB / s ئۇسلۇبىدىكى بىرلىكلەرنى ئىشلىتىشنى كۆرسىتىدۇ.\r\n\r\nE مۇقىم تونۇش ئورۇنلارنى ياقتۇرسىڭىز ئۇنى قوزغىتىڭ. تېخىمۇ كۆپ ئوقۇشقا بولىدىغان چوڭ سۈرئەتلىك كۆرسىتىش ئۈچۈن قويۇپ قويۇڭ."
    IDS_TWEAKS_TT_REARRANGE_KAD_SEARCH_KEYWORDS                "Kad ئاچقۇچلۇق سۆز ئىزدەش سۆزلىرىنى رەتلەپ ، تېخىمۇ پايدىلىق سوئال شەكلىنى سىناپ بېقىڭ.\r\n\r\nكېڭەيتىلگەن ئىزدەش-ھەرىكەت ئۆزگەرتىش. ئەگەر Kad ئىزدەش ھەرىكىتىنى قەستەن تەڭشىمىسىڭىز ئۇنى سۈكۈتتىكى ھالەتتە قويۇڭ."
    IDS_TWEAKS_TT_MESSAGE_FROM_VALID_SOURCES_ONLY              "تورداشلارنىڭ ئۇچۇرىنى قوبۇل قىلىدۇ ، ئۇ سىزنىڭ يۆتكىلىشىڭىزگە ئاللىقاچان ئۈنۈملۈك مەنبەلەرگە ئوخشايدۇ.\r\n\r\nتېخىمۇ قاتتىق ئۇچۇر سىياسىتىنى ئويلىسىڭىز ئۇنى قوزغىتىڭ."
    IDS_TWEAKS_TT_MAX_CHAT_HISTORY_LINES                       "ھەر بىر پاراڭ ياكى IRC قانال كۆرۈ\r\n\r\nنۈشىدە ساقلانغان تارىخ لىنىيىسىنىڭ ئەڭ كۆپ سانى."
    IDS_TWEAKS_TT_MAX_MESSAGE_SESSIONS                         "تورداشلارنىڭ ئۇچۇر سانى ئەڭ كۆپ بولغاندا بىرلا ۋاقىتتا ساقلاپ قېلىندى.\r\n\r\nسۈكۈتتىكىسى مۇتەئەسسىپ."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP                            "eMuleBB بىر تەرەپ قىلىنمىغان كاشىلاغا يولۇققاندا كاشىلا تۆكمە قىلىپ سېتىشنى كونترول قىلىدۇ.\r\n\r\nئۇلارنى پەقەت ئىشەنچلىك ئاچقۇچىلار بىلەن ئورتاقلىشىڭ."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_DISABLED                   "كاشىلا تۆكمە ھۆججىتى قۇرماڭ."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_PROMPT                     "كاشىلا كۆرۈلگەندە ئەخلەت ساندۇقى يېزىشتىن بۇرۇن سوراڭ."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_ALWAYS                     "ھادىسە يۈز بەرگەندە ئاپتوماتىك سوقۇلۇش ئەخلەتلىرىنى ھاسىل قىلىڭ. ئىشەنچلىك ماشىنىدا قايتا-قايتا سوقۇلۇش ھادىسىسىنى ھەل قىلىش ئۈچۈن\r\n\r\nBest."
    IDS_TWEAKS_TT_MAX_LOG_FILE_SIZE                            "KiB.\r\n\r\nUse 0 دىكى ھەر بىر دىسكىدىكى خاتىرە ھۆججەتنىڭ ئەڭ چوڭ چوڭلۇقى ئايلىنىش چەكلىمىسى يوق. ئىنتايىن چوڭ قىممەتلەر تېخىمۇ كۆپ تارىخنى ساقلايدۇ ، ئەمما تېخىمۇ كۆپ دىسكا بوشلۇقىنى خورىتىدۇ."
    IDS_TWEAKS_TT_MAX_LOG_BUFFER                               "KiB.\r\n\r\nHigher دىكى ئەڭ چوڭ ئىچكى ساقلىغۇچ خاتىرىسىنى كۆرۈش بۇففېر تېخىمۇ كۆپ كۆرۈنگەن خاتىرە تارىخىنى ساقلايدۇ ، ئەمما تېخىمۇ كۆپ ئىچكى ساقلىغۇچ ئىشلىتىدۇ ھەمدە ناھايىتى ئالدىراش خاتىرە كۆرۈنۈشلىرىنى ئاستىلىتىدۇ."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT                              "يېڭىدىن ئېچىلغان د\r\n\r\nىسكا خاتىرىسىدىكى ھۆججەتلەرگە ئىشلىتىلىدىغان كودلاش."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UNICODE                      "خاتىرىلەرنى UTF-16 يۇنىكود قىلىپ يېزىڭ. بۇ مىراسنىڭ سۈكۈتتىكى ھالىتى بولۇپ ، Windows تېكىستنى كەڭ كۆلەمدە ساقلايدۇ."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UTF8                         "خاتىرىلەرنى UTF-8 قىلىپ يېزىڭ. زامانىۋى UTF-8 تېكىست ھۆججىتىنى ئۈمىد قىلىدىغان قوراللارغا پايدىلىق."
    IDS_TWEAKS_TT_LOG2_DISK                                    "نورمال قوللىنىشچان خاتىرە خاتىرىسىنى دىسكىغا ساقلايدۇ ، ئۇنى پەقەت ئىچكى ساقلىغۇچتا ساقلايدۇ.\r\n\r\nتوختىماي خاتىرىلەشنى خالىمىسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT                         "ئىقتىدار خاتىرىلەش ئەۋرىشكىسىنىڭ چىقىرىش شەكلى.\r\n\r\nCSV قولدا تەكشۈرۈش ئەڭ ئاسان. MRTG MRTG ئۇسلۇبىدىكى كىرگۈزۈشنى ئۈمىد قىلىدىغان تۇتۇش قوراللىرى ئۈچۈن يان تەرەپ ھۆججەتلىرىنى يازىدۇ."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_CSV                     "ۋاقىت چەكلىمىسىدىكى يۈك يۈكى ۋە ئۈستۈنكى ئەۋرىشكىسى بىلەن بىر CSV ئىقتىدار خاتىرى ھۆججىتىنى يېزىڭ."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_MRTG                    "تەڭشەلگەن ئاساسى يولدىن ھاسىل بولغان MRTG ئۇسلۇبىدىكى سانلىق مەلۇمات ۋە ئۈستۈنكى يان تەرەپتىكى ھۆججەتلەرنى يېزىڭ."
    IDS_TWEAKS_TT_PERF_LOG_FILE                                "ئىقتىدار خاتىرىلەشنىڭ ئاساسى ھۆججەت يولى.\r\n\r\nL eMuleBB نىڭ سەپلىمە مۇندەرىجىسىدىكى سۈكۈتتىكى ھۆججەتنى ئىشلىتىشنى بوش قويۇڭ. MRTG ھالىتى بۇ يولدىن _ سانلىق مەلۇمات ۋە _ ئۈستى ھۆججەتلەرنى ھاسىل قىلىدۇ."
    IDS_TWEAKS_TT_PERF_LOG_INTERVAL                            "بىر نەچچە مىنۇتتا ئىقتىدار خاتىرىلەشنىڭ ئەۋرىشكە ئارىلىقى.\r\n\r\nShort ئارىلىقى ئىنچىكە گرافىكلارنى ھاسىل قىلىدۇ ، ئەمما تېخىمۇ كۆپ دىسكا يازىدۇ. 1..1440 نى ئىشلىتىڭ."
    IDS_TWEAKS_TT_VERBOSE_GROUP                                "چوڭقۇر چاتاقلارنى بىر تەرەپ قىلىش ئۈچۈن قوشۇمچە دىئاگنوز قويۇش خاتىرىسىنى كونترول قىلىش.\r\n\r\nبۇ تاللاشلار نورمال مەشغۇلات ئەمەس ، ھەل قىلىش ئۈچۈن. ئەگەر سىز مەلۇم بىر مەسىلىنى تەكشۈرمىسىڭىز ئۇلارنى تاشلاپ قويۇڭ."
    IDS_TWEAKS_TT_RESTORE_LAST_MAIN_WND_DLG                    "قوزغالغاندا ئەڭ ئاخىرقى تاللانغان ئاساسىي كۆزنەك بېتىنى ئەسلىگە كەلتۈرىدۇ.\r\n\r\nE ئەگەر eMuleBB نىڭ ئايرىلغان يېرىڭىزنى قايتا ئاچماقچى بولسىڭىز ئۇنى قوزغىتىڭ."
    IDS_TWEAKS_TT_RESTORE_LAST_LOG_PANE                        "قوزغالغاندا ئەڭ ئاخىرقى تاللانغان خاتىرە تاختىسىنى ئەسلىگە كەلتۈرىدۇ.\r\n\r\nخاتىرە خاتىرىسىدە ۋاقىت سەرپ قىلغان ئابونتلارغا قۇلايلىق تاللاش."
    IDS_TWEAKS_TT_KEEP_UNAVAILABLE_FIXED_SHARED_DIRS           "تىزىملىكتىكى قولدا تەڭشەلگەن مۇندەرىجىلەرنى ھازىر ئىشلەتكىلى بولمىسىمۇ ساقلايدۇ.\r\n\r\nئەگەر يوقاپ كەتكەن ھۆججەت قىسقۇچلارنىڭ تاجاۋۇزچىلىق بىلەن كېسىلىشىنى ئۈمىد قىلسىڭىز ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_PARTIALLY_PURGE_OLD_KNOWN_FILES              "داڭلىق ھۆججەتلەر تارىخىدىكى كونا تۈرلەرنى تېخىمۇ تاجاۋۇزچىلىق بىلەن تازىلاشقا يول قويىدۇ.\r\n\r\nCan ۋاقىتنىڭ ئۆتۈشىگە ئەگىشىپ قالايمىقانچىلىقنى ئازايتىدۇ ، ئەمما ئۇ كونا ھۆججەت تارىخىنى بالدۇرراق ئۇنتۇپ كېتىدۇ. ئورۇق تارىخقا ئېھتىياجلىق بولمىسىڭىز سۈكۈتتىن ئايرىڭ."
    IDS_TWEAKS_TT_DETECT_TCP_ERROR_FLOODER                     "تەكرارلانغان TCP خاتالىق پارتىلاشنى بايقايدۇ ، بۇ بەلكىم ھاقارەتلەنگەن ياكى بۇزۇلغان تورداشلارنى كۆرسىتىشى مۇمكىن.\r\n\r\nتەۋسىيە قىلىنغان: قوزغىتىلغان. يالغان ئاكتىپلارغا دىئاگنوز قويسىڭىزلا ئۇنى چەكلەڭ."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_INTERVAL_MINUTES           "TCP خاتالىق-كەلكۈننى بايقاشقا ئىشلىتىلىدىغان ۋاقىت كۆزنىكى.\r\n\r\nShorter كۆزنەكلىرى تېز ئىنكاس قايتۇرىدۇ. ئۇزۇن كۆزنەكلەر سەزگۈر ئەمەس. سۈكۈتتىكى قىممەت تەۋسىيە قىلىنىدۇ."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_THRESHOLD                  "كەلكۈن بىر تەرەپ قىلىشنى كەلتۈرۈپ چىقىرىدىغان ئارىلىقتىكى TCP خاتالىق سانى.\r\n\r\nLower قىممىتى تېخىمۇ قاتتىق. ئەگەر مۇھىتىڭىز زىيانسىز TCP خاتالىقلىرىنى پەيدا قىلغاندىلا ، ئۇنى كۆتۈرۈڭ."
    IDS_TWEAKS_TT_SHAREE_MULE                                  "eMuleBB نىڭ بۇ Windows ماشىنىسىدا ھەر بىر ئىشلەتك\r\n\r\nۈچى ھالىتىنى قانداق ساقلايدىغانلىقى ۋە ئورتاقلىشىدىغانلىقىنى كونترول قىلىدۇ."
    IDS_TWEAKS_TT_TCP_GROUP                                    "ئىلغار TCP ئۇلىنىش يېرىلىش ، ۋاقىت چەكلىمىسى ۋە ساقلاش كونتروللىرى.\r\n\r\nبۇ تەڭشەكلەر يۆتكىلىش چەكلىمىسىگە ئەمەس ، ئۇلىنىش ھەرىكىتىگە تەسىر كۆرسىتىدۇ. تور تەڭشەش مەسىلىسىگە دىئاگنوز قويمىسىڭىز سۈكۈتتىكى قىممەت تەۋسىيە قىلىنىدۇ."
    IDS_TWEAKS_TT_SEARCH_GROUP                                 "eMuleBB ۋە Kad.\r\n\r\nHigher قىممىتى قانچىلىك كەڭ ۋە قانچىلىك ۋاقىت ئىزدەيدۇ؟"
    IDS_TWEAKS_TT_SEARCH_ED2K_GROUP                            "مۇلازىمېتىرن\r\n\r\nى ئاساس قىلغان eD2K ئىزدەش چېكى."
    IDS_TWEAKS_TT_SEARCH_KAD_GROUP                             "Kad ئىزدەش\r\n\r\nكەڭلىكى ۋە ئۆمۈرلۈك كونتروللىرى."
    IDS_TWEAKS_TT_BROADBAND                                    "كەڭ بەلۋاغ ئۇسلۇبىدىكى يوللاش ھەرىكىتىنىڭ ئىلغار يۈكلەش-قايتا پايدىلىنىش ۋە ئۆچرەتتە نومۇر قويۇش سىياسىتى.\r\n\r\nبۇ تەڭشەكلەر مەقسەتلىك تەڭشەش ئۈچۈن. يۈكلەش ئادىللىقى ياكى ئوق ئوبوروتىنى تەڭشىمىسىڭىز ئۇلارنى سۈكۈتتىكى ھالەتتە قويۇڭ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_MAX_UPLOAD_CLIENTS             "كەڭ بەلۋاغلىق پىلانلىغۇچى ئاستىدا بىرلا ۋاقىتتا ئاكتىپ يوللاش خېرىدارلىرىغا يۇمشاق قالپاق.\r\n\r\nتۆۋەن قىممەتلەر تېخىمۇ ئاز ، كۈچلۈك ئورۇنلارنى ساقلايدۇ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_THRESHOLD                 "نىشاننىڭ ھەر بىر تورغا يوللاش نىسبىتىنىڭ تۆۋەنلىكى بىر نۇقتا ئاستا دەپ قارىلىدۇ.\r\n\r\nLower قىممىتى ئاجىز ئورۇنلارغا ئۇزۇنراق بەرداشلىق بېرىدۇ. تېخىمۇ يۇقىرى قىممەتلەر تۆۋەن دەرىجىدىكى ئورۇنلارنى تېخىمۇ ئاكتىپلىق بىلەن يىغىۋالىدۇ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_GRACE                     "eMuleBB قايتا پايدىلىنىشنى ئويلاشتىن بۇرۇن ، بىر ئورۇن ئاستا بوسۇغىنىڭ ئاستىدا قانچىلىك ۋاقىت ساقلىنىشى مۇمكىن.\r\n\r\nLonger مېھىر-شەپقىتى ئاجىز تورداشلارغا تېخىمۇ سەۋرچان قىسقا مېھىر-شەپقەت ئاجىز جايلارنى بالدۇرراق ئايلاندۇرىدۇ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_WARMUP                    "ئاستا-ئاستا بايقاشنى باشلاشتىن بۇرۇ\r\n\r\nن يېڭى يۈكلەش ئورنىنىڭ ئىسسىنىش ۋاقتى."
    IDS_TWEAKS_TT_UPLOAD_POLICY_ZERO_RATE_GRACE                "يوللاش سانلىق مەلۇماتلىرىنى ئاساسىي جەھەتتىن يەتكۈزمەيدىغان ئورۇنلارنىڭ ياخشىلىنىش ۋاقتى.\r\n\r\nLower قىممىتى ئۆلۈك ياكى توختاپ قالغان ئورۇنلارغا تېز ئىنكاس قايتۇرىدۇ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_COOLDOWN                       "يىغىۋېلىنغان ئاستا ئورۇن قانچىلىك ۋاقىت نورمال رىقابەتلىشىشتى\r\n\r\nن بۇرۇن ئۆچىرەتتە نومۇر ئېلىشتا جازاغا تارتىلىدۇ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BOOST                "تارىخى يۈكلەش نىسبىتى تۆۋەن ھۆججەتلەرنى تەلەپ قىلىدىغان خېرىدارلارغا قوشۇمچە ئۆچرەت نومۇرى قوشىدۇ.\r\n\r\nھازىرغا قەدەر ئازراق يۈكلەشنى تاپشۇرۇۋالغان ھۆججەتلەرنى ياقتۇرماقچى بولسىڭىز ، ئۇنى ئىشلىتىڭ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_THRESHOLD            "تۆۋەن نىسبەتتىكى ئۆچرەت نومۇرىنى يۇقىرى كۆتۈر\r\n\r\nۈشكە ئىشلىتىدىغان چۈشۈرۈش نىسبىتىنى تۆۋەنلىتىش."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BONUS                "تۆۋەن ئۈنۈملۈك قوزغىتىش قوزغالغاندا بې\r\n\r\nرىلگەن قوشۇمچە ئۈنۈملۈك ئۆچرەت نومۇرى."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_ID_DIVISOR                 "يوللاش ئۆچرەتتە نومۇر ئېلىش جەريانىدا LowID خېرىدارلىرىغا قوللىنىلغان جازا بۆلۈش.\r\n\r\nHigher قىممىتى LowID ئەۋزەللىكىنى تېخىمۇ شىددەت بىلەن تۆۋەنلىتىدۇ. قوشۇمچە LowID جازاسىنى چەكلەش ئۈچۈن 1 نى تەڭشەڭ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER               "eMuleBB بۇ ئورۇننى ئايلىنىشنى ئويلاشتىن بۇرۇن بىر يۈكلەش يىغىنىنىڭ قانچىلىك يۆتكىلىدىغانلىقىنى چەكلەيدۇ.\r\n\r\nRotation پەقەت باشقا خېرىدار بۇ ئورۇنغا ئېھتىياجلىق بولغاندا ئاندىن يۈز بېرىدۇ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_DISABLED      "يوللانغان يۈك مىقدارىغا ئاساسەن يۈكلەش يىغىنلىرىنى قايتا ئىشلەتمەڭ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT       "ھەر بىر يوللاش يىغىنىنى تەلەپ قىلىنغان ھۆججەت چوڭلۇقىدا چەكلەڭ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT_VALUE "يىغىننىڭ يۆتكىلىش چېكى ھۆججەت چوڭلۇقىنىڭ ئۈلۈشى قىلىپ تەڭشەلگەندە ئىشلىتىلگەن پىرسەنت."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B          "ھۆججەتنىڭ چوڭ-كىچىكلىكىگە قارىماي ھەر بىر يوللاش يىغىنىنى مۇقىم MiB مىقدارى بىلەن چەكلەڭ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B_VALUE    "يىغىننىڭ يۆتكىلىش چېكى مۇقىم چوڭلۇقتا تەڭشەلگەندە ئىشلىتىلگەن مۇتلەق MiB مىقدارى."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TIME_LIMIT             "eMuleBB دىن بۇرۇن بىر قېتىم يوللاشنىڭ ئەڭ يۇقىرى ۋاقتى ۋاقىتنى چەكلەشنى چە\r\n\r\nكلەش ئۈچۈن ئوقنى ئايلاندۇرۇشنى ئويلىشىدۇ."
    IDS_TWEAKS_TT_A4_AF_SAVE_CPU                               "CPU ۋاقتىنى تېجەش ئۈچۈن قايتا-قايتا A4AF (باشقا ھۆججەت تەلەپ قىلىندى) مەنبە تەكشۈرۈشىنى ئازايتىدۇ.\r\n\r\nئالدىراش خېرىدارلارغا پايدىلىق."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_NEVER                      "ھۆججەتلەردىن مېتا سانلىق مەلۇماتنى چىقارماڭ.\r\n\r\nLightest تاللاش. تەگلىك مېتا سانلىق مەلۇمات تەكشۈرۈشىنى خالىمىسىڭىز ئىشلىتىڭ."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_ID3_LIB                    "پەقەت MPEG ئاۋاز ھۆججىتىنىڭ ID3 كۈتۈپخانىس\r\n\r\nى يولى ئارقىلىق مېتا سانلىق مەلۇماتنى چىقىرىڭ."
    IDS_TWEAKS_TT_PREVIEW_ON_ICON_DBL_CLK                      "ھۆججەت سىنبەلگىسىنى قوش چېكىش ئادەتتىكى سۈكۈتتىكى ھەرىكەتنىڭ ئورنىغا ئالدىن كۆرۈشنى ئاچىدۇ.\r\n\r\nپەقەت UI خىزمەت ئېقىمى مايىللىقى."
    IDS_TWEAKS_TT_EXTRA_PREVIEW_WITH_MENU                      "ئالدىن كۆرۈش بۇيرۇقىنى مەخسۇس ئالدىن كۆرۈش مەشغۇلات تىزىملىكى ئارقىلىق كۆرسىتىدۇ ، پەق\r\n\r\nەت ئاددىي بىۋاسىتە ئالدىن كۆرۈش ھەرىكىتىنى ئاشكارىلاشنىڭ ئورنىغا."
    IDS_TWEAKS_TT_SHOW_ACTIVE_DOWNLOADS_BOLD                   "چۈشۈرۈش تىزىملىكىدە دادىللىق بىلەن چۈشۈرۈشنى ئاكتىپلىق بىلەن سىزىدۇ.\r\n\r\nئېنىق كۆرۈنۈش. ئەگەر ئاكتىپ تۈرلەرنىڭ تېخىمۇ ئېنىق كۆرۈنۈشىنى ئۈمىد قىلسىڭىز ئۇنى قوزغىتىڭ."
    IDS_TWEAKS_TT_USE_SYSTEM_FONT_FOR_MAIN_CONTROLS            "ئاساسلىق Windows UI خەت نۇسخىسىنى eMuleBB نىڭ ئىختىيارى خەت نۇسخىسىنىڭ ئورنىغا ئاساسلىق كونترول ۋە تىزىملىك ​​كۆرۈنۈشلىرى ئۈچۈن ئىشلىتىڭ.\r\n\r\nئەگەر يەرلىك كۆرۈنۈشلۈك تېكىستنى ياقتۇرسىڭىز ياكى سىستېما خەت تەڭشىكىڭىزگە تېخىمۇ ماسلىشىشقا ئېھتىياجلىق بولسىڭىز."
    IDS_TWEAKS_TT_FILTER_LANI_PS                               "شەخسىي / LAN دائىرىسىدىكى مۇلازىمېتىر ۋە خېرىدارلارنىڭ ئادرېسىغا پەرۋا قىلمايدۇ.\r\n\r\nتەۋسىيە قىلىنغان: قوزغىتىلغان. بۇ ئاممىۋى توردىكى دائىملىق تورداشلارنىڭ ئادرېسىنى ئىشلىتىشكە ئۇرۇنۇشتىن ساقلىنىدۇ."
    IDS_TWEAKS_TT_GEO_LOCATION_CHECK_DAYS                      "eMuleBB قانچە قېتىم يېڭىلانغان جۇغراپىيىلىك سانلىق مەلۇمات ئامبىرىنىڭ مەزمۇنىنى تەكشۈرىدۇ.\r\n\r\nSet 0 ئاپتوماتىك يېڭىلاش تەكشۈرۈشىنى چەكلەيدۇ. چوڭ قىممەت تەگلىك يېڭىلاش پائالىيىتىنى ئازايتىدۇ."
    IDS_TWEAKS_TT_VERBOSE                                      "تۆۋەندىكى پېئىل خاتىرىلەش كونتروللۇقىنىڭ ئاساسلىق ئالماشتۇرۇشى.\r\n\r\nنورمال ئىشلىتىشكە ماس كېلىدۇ. پەقەت مەلۇم بىر مەسىلىنى تەكشۈرگەندە ئاندىن قوزغىتىڭ."
    IDS_TWEAKS_TT_FULL_VERBOSE                                 "پېئىل خاتىرىلەش ئىقتىدارى قوزغىتىلغاندا تولۇق ئىشلىتىشكە بولىدىغان پېئىل ئىزلىرىنى خاتىرىلەيدۇ.\r\n\r\nبۇ ناھايىتى شاۋقۇن-سۈرەنگە ئايلىنىپ ، پەقەت فوكۇسلانغان مەسىلىنى ھەل قىلىشقىلا ئىشلىتىلىدۇ."
    IDS_TWEAKS_TT_LOG_LEVEL                                    "دىئاگنوز قويۇش خاتىرىسى\r\n\r\nچىقىرىشنىڭ Verbosity بوسۇغىسى."
    IDS_TWEAKS_TT_DEBUG2_DISK                                  "دىسكىغا دىئاگنوز قويۇش نەتىجىسى\r\n\r\nنى ۋاقىتلىق ساقلاشنىڭ ئورنىغا يازىدۇ."
    IDS_TWEAKS_TT_DEBUG_SOURCE_EXCHANGE                        "مەنبە مەنبە ئالماشتۇرۇش مۇناسىۋەتلىك بوغچا ۋە قارارلارنى خاتىرىلەيدۇ.\r\n\r\nئالاھىدە دىئاگنوز قويۇش ئۇسۇلى. مەنبە بايقاش ھەرىكىتىنى ھەل قىلغاندا ئاندىن قوزغىتىڭ."
    IDS_TWEAKS_TT_LOG_BANNED_CLIENTS                           "تورداشلارنىڭ چەكلەنگ\r\n\r\nەنلىكى ۋە نېمىشقا خاتىرىلەنگەنلىكى خاتىرىلىنىدۇ."
    IDS_TWEAKS_TT_LOG_RATING_DESC_RECEIVED                     "خاتىرىلەر ھۆججەتلەرنىڭ ئىزاھاتى ، چۈشەندۈرۈشى ۋە دەرىجىسىنى تاپشۇرۇۋالغان.\r\n\r\nمېتا سانلىق مەلۇمات ئېقىمىنى يېشىشكە پايدىلىق ، ئەمما ئادەتتە لازىم ئەمەس."
    IDS_TWEAKS_TT_LOG_SECURE_IDENT                             "بىخەتەر سالاھىيەت دەلىللەش ۋە مۇناسىۋەتلىك كىملىك ​​تەكشۈرۈش خاتىرىسىنى خاتىرىلەيدۇ.\r\n\r\nئىشەنچ / دەلىللەش كاشىلىنى بىر تەرەپ قىلىشقا پايدىلىق."
    IDS_TWEAKS_TT_LOG_FILTERED_I_PS                            "IP سۈزگۈچ ياكى لوگىكىلىق تورداشلارنىڭ ياكى مۇلازىمېتىرنىڭ ئادرېسىغا سەل قارىغاندىكى خاتىرىلەر.\r\n\r\nبەزى تورداشلارنىڭ نېمە ئۈچۈن رەت قىلىنغانلىقىغا دىئاگنوز قويۇشقا پايدىلىق."
    IDS_TWEAKS_TT_LOG_FILE_SAVING                              "خاتىرىلەنگەن ھۆججەتلەر ، ئىناۋەتلىكلەر ۋە مۇناسىۋەتلىك\r\n\r\nھالەت قاتارلىق مۇقىم سانلىق مەلۇماتلارنى تېجەيدۇ."
    IDS_TWEAKS_TT_LOG_A4_AF                                    "خاتىرىلەش A4AF (باشقا ھۆججەت تەلەپ قىلىندى) مەنبە قايتا تەقسىملەش پائالىيىتى.\r\n\r\nئالاھىدە چۈشۈرۈش-باشقۇرغۇچىغا دىئاگنوز قويۇش تاللانمىسى."
    IDS_TWEAKS_TT_LOG_UL_DL_EVENTS                             "يۈكلەش-چۈشۈرۈش ۋە چۈشۈرۈش-پائا\r\n\r\nلىيەت ھايات مۇساپىسىنىڭ ئۆزگىرىشىنى خاتىرىلەيدۇ."
    IDS_TWEAKS_TT_U_PN_P                                       "كىرىش ئېغىزىنىڭ ئاپتو\r\n\r\nماتىك يېتەكلەش ئېغىزى خەرىتىلەش تەڭشىكى."
    IDS_TWEAKS_TT_SHAREE_MULE_MULTI_USER                       "ھەر بىر Windows ئىشلەتكۈچى ئايرىم eMuleBB سەپلىمىسى ۋە ئايرىم چۈشۈرۈش ھالىتىگە ئېرىشىدۇ.\r\n\r\nئىشلەتكۈچىلەر eMuleBB سانلىق مەلۇماتلىرىنى ئورتاقلاشماسلىقى كېرەك بولغان ئورتاق كومپيۇتېرلارغا ئەڭ ماس كېلىدۇ."
    IDS_TWEAKS_TT_SHAREE_MULE_PUBLIC_USER                      "بارلىق Windows ئىشلەتكۈچىلەر ئوخشاش eMuleBB سەپلىمىسى ۋە چۈشۈرۈشتىن ئورتاق بەھىرلىنىدۇ.\r\n\r\nئەگەر ماشىنا قەستەن ئورتاق eMuleBB ھالىتىنى ئورتاقلاشقان بولسا ، بۇنى ئىشلىتىڭ."
    IDS_TWEAKS_TT_SHAREE_MULE_OLD_STYLE                        "كونا مۇندەرىجە ئورۇنلاشتۇرۇشىنى ئىشلىتىپ پروگرامما مۇندەرىجىسىدە تەڭشەش ۋە چۈشۈرۈشنى ساقلاڭ.\r\n\r\nLegacy ماسلىشىش ھالىتى پەقەت. ئۇ ئادەتتە زامانىۋى Windows دىكى ئەڭ كۆڭۈلدىكىدەك تاللاش ئەمەس."
    IDS_CONNECTION_TT_AUTOCONNECT                              "eMuleBB قوزغالغاندا قوزغىتىلغان تورنى ئاپتوماتىك قوزغىتىدۇ.\r\n\r\nھەر قېتىملىق يىغىننى قولدا ئۇلىماقچى بولسىڭىزلا ئۇنى چەكلەڭ."
    IDS_CONNECTION_TT_RECONN                                   "ئۈزۈلۈپ قالغان ياكى مەغلۇپ بولغاندىن كېيىن مۇلازىمېتىر ئۇلىنىشىنى قايتۇرىدۇ.\r\n\r\nتەۋسىيە قىلىنغان: ئەگەر eD2K مۇلازىمېتىر تورىنى ئىشلەتسىڭىز قوزغىتىلغان. مۇلازىمېتىر تورى چەكلەنگەندە ھېچقانداق ئۈنۈمى بولمايدۇ."
    IDS_CONNECTION_TT_SHOWOVERHEAD                             "يۆتكىلىش نىسبىتى ۋە ستاتىستىكىسىدا كېلىشىم ئۈستىنى ئايرىم كۆرسىتىدۇ.\r\n\r\nئاددىيراق يۈك بېسىش سانلىرىنى ياقتۇرسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_CONNECTION_TT_PORT                                     "ئاساسلىق خېرىدارلار ئۇلىنىشى ئۈچۈن ئىشلىتىلىدىغان ئاساسلىق TCP ئېغىزى.\r\n\r\nئۇنى ئۆزگەرتكەندىن كېيىن ئۇلىنىشنى قايتا سىناڭ."
    IDS_CONNECTION_TT_UDPPORT                                  "UDP ئېغىزى Kad ۋە باشقا\r\n\r\nUDP ياردەم قىلىدىغان ئىقتىدارلارغا ئىشلىتىلىدۇ."
    IDS_CONNECTION_TT_MAXSOURCEPERFILE                         "eMuleBB نىڭ يىراق مۇساپىلىك مەنبەلەردە قانچىلىك يىراق مۇساپىلىك ساقلىنىدىغانلىقى ئۈچۈن قاتتىق چەك.\r\n\r\nئوتتۇراھال قىممەتنى ئىشلىتىڭ ، ئەگەر ئۇنى يۇقىرى كۆتۈرۈشنىڭ كونكرېت سەۋەبى بولمىسا."
    IDS_CONNECTION_TT_MAXCON                                   "بىرلا ۋاقىتتا ئۇلىنىشنىڭ يۇقىرى چېكى eMuleBB ئوچۇق ھالەتتە بولۇشى مۇمكىن.\r\n\r\nHigher قىممىتى ئاپتوماتىك ياخشى ئەمەس. ئەگەر سىز مەلۇم تور چەكلىمىسىگە دىئاگنوز قويمىسىڭىز ، بۇنى تەڭشەلگەن سۈكۈتتىكى ئورۇنغا قويۇپ قويۇڭ."
    IDS_CONNECTION_TT_DOWNLOAD_CAP                             "KiB / s دىكى تۆۋەنكى ئېقىن سىغىمىڭىز.\r\n\r\neMule بۇنى سىيرىلغۇچ ۋە كەڭ بەلۋاغ كەڭلىكى قارارىنىڭ يۇقىرى پايدىلىنىش ماتېرىيالى سۈپىتىدە ئىشلىتىدۇ."
    IDS_CONNECTION_TT_UPLOAD_CAP                               "KiB / s دىكى يۇقىرى ئېقىن سىغىمىڭىز.\r\n\r\neMule بۇنى يۈكلەشنى كونترول قىلىشنىڭ يۇقىرى پايدىلىنىش ماتېرىيالى سۈپىتىدە ئىشلىتىدۇ."
    IDS_CONNECTION_TT_NETWORK_ED2_K                            "كلاسسىك eD2K مۇلازىمېتىر تورىنى قوزغىتىدۇ.\r\n\r\nقەستەن Kad مەشغۇلات قىلىشنى خالايدىغان بولسىڭىزلا ئۇنى چەكلەڭ."
    IDS_CONNECTION_TT_NETWORK_KADEMLIA                         "Kad تارقىتىلغان تورنى قوزغىتىدۇ.\r\n\r\nتەۋسىيە قىلىنغان: زامانىۋى ئىشلىتىشكە ئىشلىتىلىدۇ. ئۇ UDP ئېغىزىنىڭ قوزغىتىلىشىنى تەلەپ قىلىدۇ."
    IDS_CONNECTION_TT_PREF_UPNPONSTART                         "تەڭشەلگەن TCP ۋە UDP ئېغىزلىرىنى قوزغاتقاندا ئاپتوماتىك NAT ئېغىزى خەرىتىسىنى سىنايدۇ.\r\n\r\nئېغىزلارنى قولدا يوللىسىڭىز ئۇنى چەكلەڭ."
    IDS_CONNECTION_TT_RANDOMIZE_PORTS_ON_STARTUP               "ئاپتوماتىك پورت خەرىتىسى ئىجرا قىلىنىشتىن بۇ\r\n\r\nرۇن قوزغالغاندا يېڭى TCP ۋە UDP ئاڭلاش ئېغىزلىرىنى تاللايدۇ."
    IDS_CONNECTION_TT_UDPDISABLE                               "eMuleBB نىڭ UDP ئېغىزىنى چەكلەيدۇ ، شۇڭلاشقا Kad تورىغا\r\n\r\nئوخشاش UDP غا تايىنىدىغان ئىقتىدارلارنى ئىناۋەتسىز قىلىدۇ."
    IDS_CONNECTION_TT_STARTTEST                                "ھازىر تەڭشەلگەن TCP ۋە UDP ئېغىزلىرىنىڭ\r\n\r\nسىرتقى ئۇلىنىش سىنىقىنى قوزغىتىدۇ."
    IDS_CONNECTION_TT_BIND_INTERFACE                           "ئىختىيارىي Windows تور كۆرۈنمە يۈزى P2P ئۇلىنىش ئېغىزىغا ئىشلىتىلىدۇ.\r\n\r\nMatch ماسلاشتۇرغۇچ نومۇرى ئەمەس ، دوستانە كۆرۈنمە يۈزى ئىسمى بىلەن. ئۆزگەرتىش قايتا قوزغىتىلغاندىن كېيىن كۈچكە ئىگە بولىدۇ."
    IDS_CONNECTION_TT_BIND_ADDRESS                             "ئىختىيارىي IPv4\r\n\r\nئادرېسى P2P ئۇلاش ئېغىزىغا ئىشلىتىلىدۇ."
    IDS_WEBSERVER_TT_WEBBINDADDR                               "ئىچىگە ئورۇنلاشتۇرۇلغان WebServer ۋە REST API.\r\n\r\nL نىڭ يەرلىك باغلىنىش ئادرېسى ئۇنى قۇرۇق قويۇڭ ياكى 0.0.0.0 قىلىپ بارلىق كۆرۈنمە يۈزىنى ئاڭلاڭ. ئەگەر سىز ئاڭلىغان مۇلازىمەتنى قەستەن چەكلىمەكچى بولسىڭىز ، مەلۇم IPv4 بەلگىلىڭ."
    IDS_WEBSERVER_TT_WSAPIKEY                                  "Plaintext REST API كۇنۇپكىسى خېرىدارلار X-API-Key ماۋزۇسىدا ئىشلىتىلىدۇ.\r\n\r\nبۇ ئاچقۇچ بارلارنىڭ تولۇق API زىيارەت ھوقۇقى بار."
    IDS_WEBSERVER_TT_WSUPNP                                    "UPnP ياكى PCP / NAT-PMP قوزغىتىلغاندا WebSer\r\n\r\nver ئېغىزى ئۆزلۈكىدىن NAT خەرىتىسىنى ئۆز ئىچىگە ئالىدۇ."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD                          "MiB.\r\n\r\nU دىكى WebServer تەرىپىدىن قوبۇل قىلىنغان ئەڭ چوڭ يەككە ھۆججەت يوللاش چوڭلۇقى نورمال يىراقتىن كونترول قىلىش ئۈچۈن ئازراق قىممەت ئىشلىتىڭ. ئىشەنچلىك تور خېرىدارلىرى تېخىمۇ چوڭ ھۆججەتلەرنى يۈكلەشكە ئېھتىياجلىق بولغاندىلا ئاندىن ئۇنى ئۆستۈرۈڭ."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD_LBL                      "MiB.\r\n\r\nU دىكى WebServer تەرىپىدىن قوبۇل قىلىنغان ئەڭ چوڭ يەككە ھۆججەت يوللاش چوڭلۇقى نورمال يىراقتىن كونترول قىلىش ئۈچۈن ئازراق قىممەت ئىشلىتىڭ. ئىشەنچلىك تور خېرىدارلىرى تېخىمۇ چوڭ ھۆججەتلەرنى يۈكلەشكە ئېھتىياجلىق بولغاندىلا ئاندىن ئۇنى ئۆستۈرۈڭ."
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS                             "ئىختىيارىي بەلگە بىلەن ئايرىلغان IPv4 خېرىدارلىرى ئۈچۈن WebServer ئىجازەت تىزىملىكى.\r\n\r\nمىسال: 127.0.0.1; 192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS_LBL                         "ئىختىيارىي بەلگە بىلەن ئايرىلغان IPv4 خېرىدارلىرى ئۈچۈن WebServer ئىجازەت تىزىملىكى.\r\n\r\nمىسال: 127.0.0.1; 192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWHILEVFUNC                         "ئىجرا قىلىش ھالىتىنى تېخىمۇ كەسكىن ئۆزگەرتەلەيدىغان يۇقىرى دەرىجىلىك مەمۇرىي تور ھەرىكەتلىرىگە يول قويىدۇ.\r\n\r\nتەۋسىيە قىلىنغان: ئەگەر ئىشەنچلىك باشقۇرغۇچى خېرىدارلارنىڭ بۇ ھەرىكەتلىرىگە ئېنىق ئېھتىياجلىق بولمىسىڭىز ، بۇنى توختىتىڭ."
    IDS_WEBSERVER_TT_WEB_HTTPS                                 "سەپلەنگەن گۇۋاھنامە ۋە ئاچقۇچ ئارقىلىق Web\r\n\r\nUI ۋە REST API دىن HTTPS غا مۇلازىمەت قىلىدۇ."
    IDS_NOTIFY_TT_CB_TBN_USESOUND                              "ۋەزىپە بالدىقى ئۇقتۇرۇشى ئۈچۈن ئىختىيارى WAV ھۆججىتىنى قويالايسىز.\r\n\r\nئەگەر ئۈن-تىنسىز قاڭقىش ياكى سۆزلەش يېتەرلىك بولسا ئۇنى قويۇپ قويۇڭ."
    IDS_NOTIFY_TT_CB_TBN_USESPEECH                             "نۇتۇق ماتورى بولغاندا ۋەزىپە بالدىقى ئ\r\n\r\nۇقتۇرۇشى ئۈچۈن تېكىستتىن سۆزگە ئىشلىتىلىدۇ."
    IDS_NOTIFY_TT_CB_TBN_POP_ALWAYS                            "كەلگەن ھەر بىر پاراڭلىشىش ئۇچۇرىدا پەقەت بىرىنچى ئۇچۇرنىڭ ئورنىغا بىر سەكرىمە كۆزنەكنى كۆرسىتىدۇ.\r\n\r\nئىز قوغلاش پاراڭلىرىنىڭ جىم تۇرۇشىنى خالىمىسىڭىز ئۇنى قوزغىتىڭ. QZZ1XZQ"
    IDS_NOTIFY_TT_CB_TBN_USEWINDOWSTOAST                       "ئىختىيارى eMuleBB سەكرىمە ئورنىنىڭ\r\n\r\nئورنىغا Windows توست ئۇقتۇرۇشىنى ئىشلىتىڭ."
    IDS_NOTIFY_TT_TBN_DISPLAYMODE                              "eMuleBB نىڭ قاڭقىش كۆزنىكىدە كۆرسىتىلگەن ئۇقتۇرۇشنى قانداق كۆرسىتىدىغانلىقىنى تاللايدۇ.\r\n\r\nWindows توستى كۆڭۈلدىكى. ئەگەر Windows توست ئۇقتۇرۇشىنى رەت قىلسا ، eMuleBB باشقۇرغۇچى سۈپىتىدە ئىجرا قىلىۋاتقان ۋاقىتتا ، eMuleBB كلاسسىك تەخسە شارغا قايتىپ كېلىدۇ."
    IDS_NOTIFY_TT_CB_ENABLENOTIFICATIONS                       "تەڭشەلگەن ۋەقەلەرنىڭ سىرتقا چىقىپ\r\n\r\nكەتكەن ئېلېكترونلۇق خەت ئۇقتۇرۇشىنى قوزغىتىدۇ."
    IDS_NOTIFY_TT_SMTPSERVER                                   "ئېلېكترونلۇق خەت ئۇقتۇرۇشى ئىشلىتىدىغان SMTP مۇلازىمېتىر سەپلىمىسىنى ئاچىدۇ.\r\n\r\nY پەقەت ئېلېكترونلۇق خەت ئۇقتۇرۇشى قوزغىتىلغاندىلا بۇنىڭغا ئېھتىياجلىق بولىسىز."
