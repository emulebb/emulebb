    IDS_PPG_DIRECTORIES_TT_INCFILES                            "تاماملانغان چۈشۈرۈشنىڭ ئاساسلىق كىرىش مۇندەرىجىسى.\r\n\r\nيېتەرلىك بوش بوشلۇق بىلەن مۇقىم يەرلىك يولنى ئىشلىتىڭ. ئەگەر ئۇ يەردە تەييار ھۆججەتلەرنى ھەقىقىي خالىمىسىڭىز ۋاقىتلىق ياكى يۆتكىگىلى بولىدىغان ئورۇنلاردىن ساقلىنىڭ."
    IDS_PPG_DIRECTORIES_TT_TEMPFILES                           "قىسمەن ھۆججەتلەر ، ھاشاراتلار ۋە يۆتكەش ھالىتى ئۈچۈن خىزمەت مۇندەرىجىسى تىزىملىكى.\r\n\r\nبۇ يوللار چۈشۈرۈش جەريانىدا ئىجرا بولۇشى كېرەك. يۆتكىگىلى بولىدىغان ياكى ئىشەنچسىز تور يولىدا تېز يەرلىك دىسكىلار تەۋسىيە قىلىنىدۇ."
    IDS_PPG_DIRECTORIES_TT_SHARESELECTOR                       "eMuleBB يەرلىك ھۆججەت قىسقۇچنى باشقا خېرىدارلارغا ھەمبەھىرلەيدۇ.\r\n\r\nپۈتۈن قوزغاتقۇچ قاتارلىق كەڭ يىلتىزلاردىن ساقلىنىڭ."
    IDS_PPG_DISPLAY_TT_MINTRAY                                 "eMuleBB نى ۋەزىپە بالدىقىغا قويۇپ قويماي ، تەخسىگە كىچىكلىتىدۇ.\r\n\r\nھەمىشە تەڭشەشكە پايدىلىق. نورمال ۋەزىپە بالدىقى ھەرىكىتىنى ياقتۇرسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_PPG_DISPLAY_TT_TOOLTIPDELAY                            "UI قورال قوراللىرى كۆرۈنۈشتىن بۇرۇن كېچىكىش.\r\n\r\nسۈكۈتتىكى دائىرە ئادەتتە ياخشى مۇرەسسە."
    IDS_PPG_DISPLAY_TT_SHOWRATEONTITLE                         "نۆۋەتتىكى كۆزنەكنىڭ چۈشۈرۈش ۋە چۈشۈرۈش نىسبىتىنى ئاساسلىق كۆزنەك ماۋزۇسىدا كۆرسىتىدۇ. eMuleBB ئارقا سۇپىدا تۇرغاندا ،\r\n\r\nU پايدىلىق ، سىز يەنىلا تېز سۈرئەتتە قاراشنى ئويلايسىز."
    IDS_PPG_DISPLAY_TT_STORESEARCHES                           "يېقىنقى ئىزدەش ئاتالغۇلىرىنى\r\n\r\nساقلايدۇ ، شۇڭا كېيىن قايتا ئىشلەتكىلى بولىدۇ."
    IDS_PPG_DISPLAY_TT_WIN7_TASKBARGOODIES                     "قوللايدىغان يەردە Windows ۋەزىپە بالدىقىنىڭ ئىلگى\r\n\r\nرىلىشى ۋە مۇناسىۋەتلىك قاپنىڭ بىر گەۋدىلىشىشىنى قوزغىتىدۇ."
    IDS_PPG_FILES_TT_PF_TIMECALC                               "چۈشۈرۈش ئۈچۈن تېخىمۇ تەپسىلىي قالغان ۋاقىت ھېسابلاشنى ئىشلىتىڭ.\r\n\r\nتەۋسىيە قىلىنغان: ئەگەر مۇقىم ETA مۆلچەرىنى ئويلىسىڭىز قوزغىتىلغان. كونا ئاددىي ھېسابلاشنى ياقتۇرسىڭىزلا ئۇنى چەكلەڭ."
    IDS_PPG_FILES_TT_PREVIEWPRIO                               "كىنو كۆرۈش بۆلەكلىرىنى ئالدىنقى ئورۇنغا قويىدۇ ، شۇڭا قىسمەن چۈشۈرۈلگەن تاراتقۇلار ئالدىن كۆرگىلى بولىدۇ.\r\n\r\nسىن چۈشۈرۈشكە پايدىلىق. ئەگەر نېيترال ئۇششاق زاكاز قىلىشنى ياقتۇرسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_PPG_FILES_TT_WATCHCB                                   "Ed2k ئۇلانمىسىنىڭ چاپلاش تاختىسىنى كۆرىدۇ ۋە ئۇلارنى بىر تەرەپ قىلىش تەكلىپىنى بېرىدۇ.\r\n\r\nئەگەر eMuleBB چاپلاش تاختىسىنى كۆرۈشنى خالىمىسىڭىز ئۇنى چەكلەڭ."
    IDS_PPG_FILES_TT_FNCLEANUP                                 "چۈشۈرۈلگەن ھۆججەت نامىنى تەڭشەلگ\r\n\r\nەن قائىدىلەر بويىچە ئاپتوماتىك تازىلاڭ."
    IDS_PPG_FILES_TT_STARTNEXTFILE                             "باشقا بىر چۈشۈرۈش ئاخىرلاشقاندا ياكى توختاپ قالغان\r\n\r\nدا كېيىنكى ئۆچرەتتىكى ھۆججەتنى ئاپتوماتىك قوزغىتىدۇ."
    IDS_PPG_FILES_TT_RUNONFILECOMPLETE                         "ھۆججەت مۇۋەپپەقىيەتلىك تاماملىنىپ ساقلانغاندىن كېيىن ئىجرا قىلغىلى بولىدۇ.\r\n\r\nبۇ سۈكۈتتىكى ھالەتتە چەكلىنىدۇ. بۇ پروگرامما Windows قېپىسىز بىۋاسىتە قوزغىتىلغان."
    IDS_PPG_FILES_TT_FILECOMPLETEARGS                          "قوللايدىغان بەلگە: %F تولۇق يول ، %D مۇندەرىجىسى ، %N ھۆججەت ئىسمى ، %H ھۆججەت ھەش ، %S چوڭلۇقى بايت ، %C تۈرى.\r\n\r\nQZZ6XZQ ۋە %F. مۇھىت ئۆزگەرگۈچى مىقدار كېڭەيتىلمەيدۇ. %D"
    IDS_PPG_GENERAL_TT_ONLINESIG                               "eMule ھالىتىنى ئوقۇيدىغان سىرتقى بەت ، قوليازما ياكى كىچىك قوراللار ئۈچۈن مىراس ھالەت ھۆججىتى onlinesig.dat يازىدۇ.\r\n\r\nئەگەر ئۇ ھۆججەتنى باشقا جايدا ئاكتىپلىق بىلەن ئىستېمال قىلمىسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_PPG_GENERAL_TT_BRINGTOFOREGROUND                       "بىر تەرەپ قىلىنغان ed2k ئۇلىنىشى ياكى شۇنىڭغا ئوخشاش تاشقى ھەرىكەت ئەپنى نىشانلىغاندا eMuleBB نى ئالدىنقى ئورۇنغا ئېلىپ كېلىدۇ.\r\n\r\nتەگلىك بىر تەرەپ قىلىشنى ياقتۇرسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_PPG_GENERAL_TT_CHECK4_UPDATE                           "تەڭشەلگەن ئارىلىق ئۆتۈپ كەتكەندە GitHub قوزغالغانلىقىنى تەكشۈرۈپ ، يېڭ\r\n\r\nى eMuleBB بولىقى بولغاندا ئاندىن ئاگاھلاندۇرىدۇ."
    IDS_PPG_GENERAL_TT_PREVENTSTANDBY                          "eMuleBB ئۇلانغان ياكى ئۇزۇن ۋاقىت چۈشۈرۈش ، يوللاش ، Kad ۋە مۇلازىمېتىر يىغىنلىرى ئۈزۈلۈپ قالغاندا سىستېما ئۇيقۇسىنى توسىدۇ.\r\n\r\nئېكران يەنىلا نورمال ئېتىلىدۇ. بۇ تاللانمىنى چەكلەش نورمال Windows ئۇيقۇ سىياسىتىنى دەرھال ئەسلىگە كەلتۈرىدۇ."
    IDS_PPG_GENERAL_TT_WEBSVEDIT                               "UI.\r\n\r\nY دىن ياردەمچى ئىزدەش ھەرىكەتلىرى ئىشلىتىدىغان تەڭشەلگەن تور مۇلازىمەت تىزىملىكىنى تەھرىرلەڭ ، بۇ سىرتقى ئىزدەش تۈرلىرىنى خاسلاشتۇرماقچى ياكى رېمونت قىلماقچى بولسىڭىز ، ئادەتتە بۇنىڭغا ئېھتىياجلىق بولىسىز."
    IDS_PPG_GENERAL_TT_ED2_KFIX                                "Windows ed2k ئۇلىنىشنى تىزىملىتىڭ ، شۇڭا توركۆرگۈ ۋە\r\n\r\nshell ed2k ئۇلانمىلىرى eMuleBB دا قايتا ئېچىلىدۇ."
    IDS_PPG_GENERAL_TT_STARTMIN                                "باش كۆزنەكنى دەرھال ئېچىشنىڭ ئورنىغا eMuleBB ئەڭ تۆۋەن چەككە چۈشۈرۈلىدۇ.\r\n\r\nئادەتتە UI نى دەرھال تەكشۈرمەكچى بولسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_PPG_GENERAL_TT_STARTWIN                                "تىزىملاتقۇچىلار eMuleBB نى نۆۋ\r\n\r\nەتتىكى ئىشلەتكۈچى ئۈچۈن Windows دىن باشلايدۇ."
    IDS_PPG_IRC_TT_IRC_USECHANFILTER                           "IRC قانال تىزىملىكىنى تەلەپ قىلغاندا قانال ئىسمى ۋە ئەڭ تۆۋەن ئىشلەتكۈچى سۈزگۈچنى ئىشلىتىڭ. تىزىملىك ​​ئاپتوماتىك تارايماقچى بولسىڭىز ئۇنى قوزغىتىڭ.\r\n\r\nھەمىشە تولۇق قانال تىزىملىكىنى ئېلىشنى چەكلەڭ."
    IDS_PPG_IRC_TT_IRC_USEPERFORM                              "IRC.\r\n\r\nغا ئۇلانغاندىن كېيىن ئىجرا قوليازمىسىنى ئىجرا قىلىدۇ. ئۇنى ئاپتوماتىك ئۇلىنىش ياكى IRC بۇيرۇقلىرى ئۈچۈن ئىشلىتىڭ. ئەگەر ئىجرا قىلىش قوليازمىسىنى ساقلاپ قالمىسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_PPG_IRC_TT_IRC_NAME_BOX                                "IRC قانال تىزىملىكى ئۈچۈن سۈزگۈچ تېكىستى.\r\n\r\nO قانال سۈزگۈچ قوزغىتىلغاندا بۇ تېكىستكە ماس كېلىدىغان قاناللار ساقلىنىدۇ."
    IDS_PPG_IRC_TT_IRC_MINUSER_BOX                             "IRC قانال تىزىملىكى سۈزگۈچ كۆرسەتكەن قاناللارنىڭ ئەڭ تۆۋەن ئىشلەتكۈچى سانى.\r\n\r\n0 نى ئىشلىتىپ چوڭ-كىچىك بولۇشىدىن قەتئىينەزەر قاناللارنى ساقلاڭ."
    IDS_PPG_MESSAGES_TT_MSGONLYFRIENDS                         "دوستلىرىڭىز تىزىملىكىدىكى ئىشلەتكۈچىلەرنىڭ بىۋاسىتە ئۇچۇرلىرىنىلا قوبۇل قىلىدۇ. ئەگەر ناھايىتى جىمجىت پاراڭلىشىشنى ئويلىسىڭىز ،\r\n\r\nتەۋسىيە قىلىنىدۇ. ئەگەر يەنىلا ئادەتتىكى خېرىدارلارنىڭ ئۇچۇرىنى ئويلىسىڭىز ئۇنى قويۇپ قويۇڭ."
    IDS_PPG_MESSAGES_TT_ADVSPAMFILTER                          "تېخىمۇ كۈچلۈك ئۇچۇر ئەخلەت سۈزگۈچ يولىنى قوزغىتىدۇ.\r\n\r\nئۇ سۈزگۈچ سۈزگۈچ ئۈچۈن پاراڭلاشقۇچىلار بىلەن بىللە ئىشلەيدۇ."
    IDS_PPG_MESSAGES_TT_USECAPTCHAS                            "نامەلۇم خېرىدارلار پاراڭلىشىشنى تاماملاشتىن بۇرۇن تۇتقۇن قىلىش تەلىپىنى تەلەپ قىلىدۇ.\r\n\r\nپاراڭ ئەخلەت خەتلىرىگە قارشى. ئىلغار ئەخلەت سۈزگۈچ بىلەن بىللە ئەڭ ياخشى ئىشلىتىلىدۇ."
    IDS_PPG_MESSAGES_TT_COMMENTFILTER                          "تەڭشەلگەن سۈزگۈچ ئاتالغۇلىرىنى ئۆز ئىچىگە ئالغان ھۆججەت باھالىرىنى توسىدۇ.\r\n\r\nU a '|' ئاتالغۇلار ئارىسىدىكى ئايرىغۇچ. داڭلىق ئەخلەت سۆزلەر ياكى ئاۋارىچىلىك ئەندىزىسىگە پايدىلىق."
    IDS_PPG_PROXY_TT_ENABLEPROXY                               "يوللار سەپلەنگەن ۋاكالەتچى ئارقىلىق چېگرا سىرتىغا ئۇلىنىشنى قوللايدۇ.\r\n\r\nبىۋاسىتە ئۇلىنىش تېخىمۇ ئاددىي ۋە ئادەتتە تېخىمۇ تېز بولىدۇ."
    IDS_PPG_PROXY_TT_PROXYTYPE                                 "ۋاكالەتچى مۇلازىمېتىرىڭىز كۈتكەن ۋاكالەتچى كېلىشىمنى تاللايدۇ.\r\n\r\nۋاكالەتچى تەمىنلىگەن ئېنىق تىپنى ئىشلىتىڭ. خاتا تىپ ئادەتتە ئۇلىنىش مەغلۇبىيىتىنى كۆرسىتىدۇ."
    IDS_PPG_PROXY_TT_PROXYNAME                                 "ۋاكالەتچى مۇلازىمېتىرنىڭ مۇلازىمېتىر ئىسمى ياكى IP ئادرېسى.\r\n\r\nخاتا ساھىبجامال بارلىق ۋاكالەتچى قاتناشنىڭ مەغلۇپ بولىدىغانلىقىنى كۆرسىتىدۇ."
    IDS_PPG_PROXY_TT_PROXYPORT                                 "ۋاكالەتچى مۇلازىمېتىرنىڭ ئاڭلاش ئېغىزى.\r\n\r\nۋاكالەتچى تەلەپ قىلغان ئېنىق ئېغىزنى ئىشلىتىڭ. ئادەتتىكى SOCKS كۆڭۈلدىكى قىممىتى توغرا ئەمەس."
    IDS_PPG_PROXY_TT_ENABLEAUTH                                "ۋاكالەتچى دەلىللەشنى تەلەپ قىلغاندا ۋاكالەتچى ئىش\r\n\r\nلەتكۈچى ئىسمى ۋە پارول كىنىشكىسىنى ئەۋەتىدۇ."
    IDS_PPG_PROXY_TT_USERNAME_A                                "ۋاكالەتچى ھېسابات ئىشلەتكۈچى ئىسمى.\r\n\r\nL ۋاكالەتچىڭىز ئېنىق دەلىللەشنى تەلەپ قىلمىسىلا ئۇنى بوش قويۇڭ."
    IDS_PPG_SCHEDULER_TT_ENABLE                                "ۋاقىت جەدۋىلىنى قوزغىتىدۇ ، شۇڭا ۋاقىتقا ئاساسەن قائىدىلەر تەڭشەكلەرنى ئاپتوماتىك ئۆزگەرتەلەيدۇ.\r\n\r\nL ئەگەر سىز كەڭ بەلۋاغ كەڭلىكى ، ئۇلىنىش ياكى سەھىپىلەرنى ئاكتىپ ئىشلەتمىسىڭىز ئۇنى ئۆچۈرۈۋېتىڭ."
    IDS_PPG_SCHEDULER_TT_CHECKNOENDTIME                        "تاللانغان ۋاقىت جەدۋىلىنى توختاتماي ئىجرا قىلىدۇ.\r\n\r\nئۇنى تاق يۆنىلىشلىك ھالەت ئۆزگەرتىش ئۈچۈن ئىشلىتىڭ ، باشقا ۋاقىت جەدۋىلى ئۇلارنى بېسىپ ئۆتمىگۈچە ئاكتىپ ھالەتتە تۇرۇشى كېرەك."
    IDS_PPG_SCHEDULER_TT_APPLY                                 "تەھرىرلەنگەن تەپسىلاتلارنى نۆۋەتتىكى تاللانغان ۋاقىت جەدۋىلىگە قوللىنىدۇ.\r\n\r\nبۇ قۇرنىڭ كۈن ، ۋاقىت ياكى ھەرىكەت تىزىملىكىنى ئۆزگەرتكەندىن كېيىن بۇنى ئىشلىتىڭ."
    IDS_PPG_SECURITY_TT_USESECIDENT                            "خېرىدارلارنىڭ ئىناۋەتلىك سالاھىيىتىنى بۇزۇشنى قىيىنلاشتۇرغاندا قوللىغاندا بىخەتەر پەرقلەندۈرۈشنى ئىشلىتىدۇ.\r\n\r\nتەۋسىيە قىلىنغان: قوزغىتىلغان. ئۇنى چەكلەش پەقەت كىملىك ​​ئىشەنچىسىنى تۆۋەنلىتىدۇ ، ناھايىتى ئاز پايدىلىق."
    IDS_PPG_SECURITY_TT_FILTERSERVERBYIPFILTER                 "كۆرۈنگەن مۇلازىمېتىر تىزىملىكىگە IP سۈزگۈچنى قوللىنى\r\n\r\nدۇ ، شۇڭا سۈزۈلگەن مۇلازىمېتىرلار يوشۇرۇن ياكى ئۆچۈرۈلىدۇ."
    IDS_PPG_SECURITY_TT_UPDATEURL                              "يېڭىلانغان IP سۈزگۈچ تىزىملىكىنى چۈشۈرگەندە ئىشلىتىلىدىغان مەنبە URL.\r\n\r\nU پەقەت ئىشەنچلىك تەمىنلىگۈچىنى ئىشلىتىڭ. ئاپتوماتىك يېڭىلاش بۇ URL نى قايتا ئىشلىتىدۇ ھەمدە چۈشۈرۈش ئىناۋەتسىز بولسا سۈزگۈچنى ساقلاڭ."
    IDS_PPG_SECURITY_TT_AUTOUPDATE_IPFILTER                    "يېڭىلاش ئارىلىقى توشقاندىن كېيىن تەڭشەلگ\r\n\r\nەن IP سۈزگۈچ URL نى ئاپتوماتىك تەكشۈرۈپ تۇرىدۇ."
    IDS_PPG_SECURITY_TT_IPFILTERPERIOD                         "ئاپتوماتىك IP سۈزگۈچ يېڭىلاش سىنىقى ئارىسىدىكى كۈن سانى.\r\n\r\nرۇخسەت قىلىنغان ۋاقىت: 1 كۈندىن 365 كۈنگىچە. مەغلۇپ بولغان ئۇرۇنۇشلار تەمىنلىگۈچى تېپىلمىغاندا قايتا ئايلىنىشتىن ساقلىنىش ئۈچۈن ھېسابلىنىدۇ."
    IDS_PPG_SECURITY_TT_SEESHARE1                              "يىراقتىكى خېرىدار ئۇنى قوللىغاندا كۆپچىلىكنىڭ ئورتاق بەھرىلىنىدىغان ھۆججەتلىرىڭىزنى كۆرۈشىگە يول قويىدۇ.\r\n\r\nMost رۇخسەت تاللانمىسى. ئورتاق بەھرىلىنىدىغان تىزىملىكىڭىزنى كەڭ كۆلەمدە ئاشكارىلاشقا راھەت بولغاندىلا ئىشلىتىڭ."
    IDS_PPG_SECURITY_TT_SEESHARE2                              "دوستلىرىڭىزنىڭ ئورتاق بەھرىلىنىدىغان ھۆججەتلىرىڭىزنى كۆرۈشىگە يول قويىدۇ. ئەگەر ئېنىق ئىشەنچلىك ئالاقىنى قوللاشنى ئويلىسىڭىز ،\r\n\r\nتەڭپۇڭلاشتۇرۇلغان مەخپىيەتلىك تاللىشى."
    IDS_PPG_SECURITY_TT_SEESHARE3                              "يىراقتىكى خېرىدارلارنىڭ ئورتاق ھۆججەت تىزىملىكىڭىزنى كۆرۈشىنىڭ ئالدىنى ئالىدۇ. ئورتاق بەھرىلىنىدىغان ھۆججەتلەرنى كۆرۈشتىكى ئەڭ قاتتىق مەخپىيەتلىك مەيدانىنى ئويلىسىڭىز ،\r\n\r\nتەۋسىيە قىلىنىدۇ."
    IDS_PPG_SECURITY_TT_ENABLEOBFUSCATION                      "يىراقتىكى تەرەپمۇ ئۇنى قوللىغاندا كېلىشىمنىڭ توغرىلىنىشىنى ياقتۇرىدۇ.\r\n\r\nR تەۋسىيە قىلىنغان: قوزغىتىلغان. ئۇ پەقەت چەكلەش سىياسىتىگە زورلىمايلا چەكلەش تورىغا ياردەم بېرەلەيدۇ."
    IDS_PPG_SECURITY_TT_ONLYOBFUSCATED                         "نورمال ئۇلىنىشلارنى قوبۇل قىلىشنىڭ ئورنىغا ئۇششاق ئۇلىنىشنى تەلەپ قىلىدۇ.\r\n\r\nئەگەر تور مۇھىتىڭىز ھەقىقەتەن ئېھتىياجلىق بولسا بۇنى ئىشلىتىڭ. ئۇ ئۇلىنىش ۋە تورداشلارنىڭ ئالاقىسىنى ئازايتالايدۇ."
    IDS_PPG_SECURITY_TT_SEARCHSPAMFILTER                       "سۈزگۈچلەر UI.\r\n\r\nR نى تەۋسىيە قىلىشتىن بۇرۇن ئىزدەش نەتىجىسىدىكى ئەخلەت خەتلەرنى سۈزۈپ بېرىدۇ: نورمال ئاممىۋى تورنى ئىشلىتىشكە بولىدۇ."
    IDS_PPG_SECURITY_TT_CHECK_FILE_OPEN                        "مەخسۇس زىيارەت قىلىشنى تەلەپ قىلىدىغان مەشغۇلاتتىن بۇرۇن چۈشۈرۈلگەن ياكى قۇلۇپلانغان ھالەتتىكى ھۆججەتلەرنى تەكشۈرۈڭ.\r\n\r\nR تەۋسىيە قىلىنغان: بىخەتەرلىك تەكشۈرۈشىدىن ئاتلاپ كېتىشنىڭ كونكرېت سەۋەبى بولمىسا."
    IDS_PPG_SERVER_TT_AUTOSERVER                               "ئۇلانغان خېرىدارلار ۋە باشقا ئىشەنچلىك مەنبەلەردىن مۇلازىمېتىر تىزىملىكىنى ئاپتوماتىك يېڭىلايدۇ.\r\n\r\nConvenient ، ئەمما ئۇ ۋاقىتنىڭ ئۆتۈشىگە ئەگىشىپ تىزىملىكنىڭ يۆتكىلىشىگە يول قويىدۇ. ئەگەر قاتتىق ئەگرى سىزىقلىق مۇلازىمېتىر تىزىملىكىنى ياقتۇرسىڭىز ئۇنى چەكلەڭ."
    IDS_PPG_SERVER_TT_UPDATESERVERCONNECT                      "ئۇلانغان مۇلازىمېتىرلارنىڭ تىزىملىكىڭىزگە قوشۇمچە مۇلازىمېتىرلارنى ئېلان قىلىشىغا يول قويىدۇ.\r\n\r\nئەگەر تېخىمۇ قاتتىق قولدا ئىشلىتىشنى ياقتۇرسىڭىز ئۇنى چەكلەڭ."
    IDS_PPG_SERVER_TT_UPDATESERVERCLIENT                       "خېرىدارلارنىڭ مۇلازىمېتىر ئادرېسىڭىزنى مۇلازىمېتىر تىزىملىكىڭىزگە قوشۇشىغا يول قويىدۇ.\r\n\r\nMost ئىشلەتكۈچىلەر بۇنىڭغا ئېھتىياتچانلىق بىلەن مۇئامىلە قىلىشى كېرەك. مۇلازىمېتىر تىزىملىكىنىڭ سۈپىتىنى تېخىمۇ قاتتىق كونترول قىلماقچى بولسىڭىز ئۇنى چەكلەڭ."
    IDS_PPG_SERVER_TT_SAFESERVERCONNECT                        "نۇرغۇن كاندىداتلارغا ئالدىراشنىڭ ئورنىغا تېخىمۇ ئېھتىياتچان مۇلازىمېتىر ئۇلىنىش ئىستراتېگىيىسىنى قوللىنىدۇ.\r\n\r\nتەۋسىيە قىلىنغان: مۇقىملىقنى قوزغىتىش. قەستەن تېخىمۇ تاجاۋۇزچىلىق ئۇلىنىش ئۇسۇلىنى ئويلىسىڭىزلا ئۇنى چەكلەڭ."
