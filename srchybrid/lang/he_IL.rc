    IDS_PPG_DIRECTORIES_TT_INCFILES                            "ספרייה נכנסת ראשית להורדות שהושלמו.\r\n\r\nהשתמש בנתיב מקומי יציב עם מספיק מקום פנוי. הימנע ממיקומים זמניים או ניתנים להסרה, אלא אם כן אתה באמת רוצה שם קבצים גמורים."
    IDS_PPG_DIRECTORIES_TT_TEMPFILES                           "רשימת ספריות עבודה עבור קבצי חלקים, גיבוב ומצב העברה.\r\n\r\nנתיבים אלה חייבים להישאר זמינים בזמן שההורדות פועלות. דיסקים מקומיים מהירים מומלצים על פני נתיבי רשת נשלפים או לא אמינים."
    IDS_PPG_DIRECTORIES_TT_SHARESELECTOR                       "בוחר אילו תיקיות מקומיות eMuleBB משתף עם לקוחות אחרים.\r\n\r\nשתף רק את הספריות שאתה מתכוון לפרסם. הימנע משורשים רחבים כגון כונן שלם."
    IDS_PPG_DISPLAY_TT_MINTRAY                                 "ממזער eMuleBB למגש במקום להשאיר אותו בשורת המשימות.\r\n\r\nשימושי עבור הגדרות תמיד. השאר אותו כבוי אם אתה מעדיף התנהגות רגילה של שורת המשימות."
    IDS_PPG_DISPLAY_TT_TOOLTIPDELAY                            "עיכוב לפני\r\n\r\nש טווח ברירת המחדל הוא בדרך כלל פשרה טובה."
    IDS_PPG_DISPLAY_TT_SHOWRATEONTITLE                         "מציג את שיעורי ההעלאה וההורדה הנוכחיים בכותרת החלון הראשי.\r\n\r\nשימושי כאשר eMuleBB נשאר ברקע ואתה עדיין רוצה מבט מהיר."
    IDS_PPG_DISPLAY_TT_STORESEARCHES                           "שומר מונחי חיפוש אחרונים כך שניתן יהיה לעשות בהם שימוש חוזר מאוחר יותר.\r\n\r\nמומלץ: מופעל אלא אם אתה רוצה ספציפית שלא תשמור היסטוריית חיפושים."
    IDS_PPG_DISPLAY_TT_WIN7_TASKBARGOODIES                     "מאפשר התקדמות בשורת המשימות Windows ושילוב מעטפת קשור כאשר נתמך.\r\n\r\nמומלץ: מופעל ב-Windows המודרנית, אלא אם כן אתה רוצה נוכחות מעטפת מינימלית יותר."
    IDS_PPG_FILES_TT_PF_TIMECALC                               "משתמש בחישוב הזמן הנותר המפורט יותר להורדות.\r\n\r\nמומלץ: מופעל אם אתה רוצה הערכות זמן יציבות יותר. השבת אותו רק אם אתה מעדיף את החישוב הפשוט הישן יותר."
    IDS_PPG_FILES_TT_PREVIEWPRIO                               "נותן עדיפות לנתחי תצוגה מקדימה של סרטים כך שמדיה שהורדה חלקית הופכת לניתנת לתצוגה מקדימה מוקדם יותר.\r\n\r\nשימושי להורדות וידאו. השאר את זה אם אתה מעדיף סדר נתחים ניטרלי."
    IDS_PPG_FILES_TT_WATCHCB                                   "צופה בלוח לקישורי ed2k ומציע לטפל בהם.\r\n\r\nנוח אם אתה מוסיף הורדות מדפדפנים הרבה. השבת אותו אם אינך רוצה ש-eMuleBB צופה בלוח."
    IDS_PPG_FILES_TT_FNCLEANUP                                 "מנקה שמות קבצים שהורדו באופן אוטומטי בהתאם לכללים שהוגדרו.\r\n\r\nמומלץ: מופעל אם אתה רוצה שמות קבצים סופיים עקביים יותר ללא ניקוי ידני."
    IDS_PPG_FILES_TT_STARTNEXTFILE                             "מפעיל את הקובץ הבא בתור אוטומטית כאשר הורדה נוספת מסתיימת או מושהית.\r\n\r\nמומלץ: מופעל אם אתה משתמש בתורים מושהים כדי לשלוט בכמה קבצים יפעלו בו-זמנית."
    IDS_PPG_FILES_TT_RUNONFILECOMPLETE                         "מפעיל קובץ הפעלה לאחר שקובץ הושלם ונשמר בהצלחה.\r\n\r\nזה מושבת כברירת מחדל. התוכנית מופעלת ישירות ללא מעטפת Windows."
    IDS_PPG_FILES_TT_FILECOMPLETEARGS                          "אסימונים נתמכים: נתיב מלא %F, ספריית %D, שם קובץ %N, גיבוב קובץ %H, בייטים בגודל %S, קטגוריית %C.\r\n\r\nמשתני סביבה אינם מורחבים. %F %D"
    IDS_PPG_GENERAL_TT_ONLINESIG                               "כותב את קובץ המצב הישן onlinesig.dat עבור דפים חיצוניים, סקריפטים או ווידג'טים שקוראים את סטטוס eMule.\r\n\r\nזה אינו משפר את מהירות ההעברה או הרשת. השאר אותו כבוי אלא אם כן אתה צורך את הקובץ הזה באופן פעיל איפשהו."
    IDS_PPG_GENERAL_TT_BRINGTOFOREGROUND                       "מביא את eMuleBB לקדמת הבמה כאשר קישור ed2k שטופל או פעולה חיצונית דומה ממקדים את האפליקציה.\r\n\r\nהפעל זאת אם ברצונך שהקישורים יחשפו את eMuleBB באופן מיידי. השאר את זה אם אתה מעדיף טיפול ברקע."
    IDS_PPG_GENERAL_TT_CHECK4_UPDATE                           "בודק GitHub משתחרר בעת האתחול כאשר חלף המרווח המוגדר ומתריע רק כאשר חבילת eMuleBB חדשה יותר זמינה.\r\n\r\nהשאר אותו כבוי לאתחול שקט, או הפעל אותו אם אתה רוצה בדיקת עדכונים תקופתית."
    IDS_PPG_GENERAL_TT_PREVENTSTANDBY                          "חוסם את שנת המערכת בזמן ש-eMuleBB מחובר או מעביר, כך שהורדות, העלאות, Kad והפעלות שרת ארוכות אינן מופרעות.\r\n\r\nהתצוגה עדיין יכולה לכבות כרגיל. השבתת אפשרות זו משחזרת מיד את מדיניות השינה הרגילה של Windows."
    IDS_PPG_GENERAL_TT_WEBSVEDIT                               "עורך את רשימת שירותי האינטרנט המוגדרים המשמשי\r\n\r\nם לפעולות עוזר כגון חיפושי אינטרנט מהממשק המשתמש."
    IDS_PPG_GENERAL_TT_ED2_KFIX                                "מתקן את רישום הקישור Windows ed2k כך שקישורי ed2k של הדפדפן והמעטפת ייפתחו שוב ב-eMuleBB.\r\n\r\nהשתמש בו כאשר קישורי ed2k מפסיקים להפעיל את eMuleBB או נגנבו על ידי לקוח אחר."
    IDS_PPG_GENERAL_TT_STARTMIN                                "הפעלת eMuleBB ממוזערת במקום לפתוח את החלון הראשי מיד.\r\n\r\nשימושי לאתחול ללא השגחה. השאר את זה אם אתה בדרך כלל רוצה לבדוק את ממשק המשתמש מיד."
    IDS_PPG_GENERAL_TT_STARTWIN                                "רושם את eMuleBB כדי להתחיל עם Windows עבור המשתמש הנוכחי.\r\n\r\nאפשר את זה רק במחשבים שבהם eMuleBB אמור לפעול באופן מתמשך ברקע."
    IDS_PPG_IRC_TT_IRC_USECHANFILTER                           "מחיל את שם הערוץ ואת מסנן המשתמש המינימלי בעת בקשה לרשימת ערוצים IRC.\r\n\r\nהפעל זאת אם ברצונך שהרשימה תצטמצם אוטומטית. השבת אותו כדי להביא תמיד את רשימת הערוצים המלאה."
    IDS_PPG_IRC_TT_IRC_USEPERFORM                              "מפעיל את הסקריפט 'ביצוע' לאחר התחברות ל-IRC.\r\n\r\nהשתמש בו עבור חיבורים אוטומטיים או פקודות IRC. עזוב את זה אם אינך שומר על תסריט ביצוע."
    IDS_PPG_IRC_TT_IRC_NAME_BOX                                "טקסט סינון עבור רשימת הערוצים IRC.\r\n\r\nרק ערוצים התואמים לטקסט זה נשמרים כאשר מסנן הערוצים מופעל."
    IDS_PPG_IRC_TT_IRC_MINUSER_BOX                             "ספירת משתמשים מינימלית עבור ערוצים המוצגים על ידי מסנן רשימת הערוצים IRC.\r\n\r\nהעלה אותה כדי להסתיר ערוצים זעירים. השתמש ב-0 כדי לשמור ערוצים ללא קשר לגודל."
    IDS_PPG_MESSAGES_TT_MSGONLYFRIENDS                         "מקבל הודעות ישירות רק ממשתמשים ברשימת החברים שלך.\r\n\r\nמומלץ אם אתה רוצה הגדרת צ'אט שקטה מאוד. השאר את זה אם אתה עדיין רוצה הודעות מלקוחות רגילים."
    IDS_PPG_MESSAGES_TT_ADVSPAMFILTER                          "מאפשר את נתיב מסנן הספאם החזק יותר של הודעות.\r\n\r\nמומלץ: מופעל לשימוש רגיל ברשת ציבורית. זה עובד יחד עם קפטצ'ים של צ'אט לסינון מחמיר יותר."
    IDS_PPG_MESSAGES_TT_USECAPTCHAS                            "דורש אתגר captcha לפני שלקוחות לא ידועים יכולים להשלים שיחת צ'אט.\r\n\r\nמועיל נגד צ'אט דואר זבל. מומלץ להשתמש יחד עם מסנן הספאם המתקדם."
    IDS_PPG_MESSAGES_TT_COMMENTFILTER                          "חוסם הערות לקבצים המכילים את מונחי הסינון המוגדרים.\r\n\r\nהשתמש ב-'|' מפריד בין מונחים. טוב למילות ספאם ידועות או לדפוסים מטרידים."
    IDS_PPG_PROXY_TT_ENABLEPROXY                               "נתיבים נתמכים בחיבורים יוצאים דרך ה-proxy המוגדר.\r\n\r\nהפעל אותו רק אם אתה מפעיל את eMuleBB בכוונה מאחורי פרוקסי. חיבורים ישירים הם פשוטים יותר ובדרך כלל מהירים יותר."
    IDS_PPG_PROXY_TT_PROXYTYPE                                 "בוחר את פרוטוקול ה-proxy המצופה משרת ה-proxy שלך.\r\n\r\nהשתמש בסוג המדויק שסופק על ידי מפעיל ה-proxy; הסוג הלא נכון פירושו בדרך כלל כשלי חיבור מיידיים."
    IDS_PPG_PROXY_TT_PROXYNAME                                 "שם מארח או כתובת IP של שרת ה-proxy.\r\n\r\nהזן בדיוק את נקודת הקצה שסופקה על ידי שירות ה-proxy שלך. מארח שגוי פירושו שכל תעבורת פרוקסי תיכשל."
    IDS_PPG_PROXY_TT_PROXYPORT                                 "יציאת האזנה של שרת ה-proxy.\r\n\r\nהשתמש ביציאה המדויקת הנדרשת על ידי ה-proxy. ברירת המחדל הנפוצה של SOCKS אינה מובטחת להיות נכונות."
    IDS_PPG_PROXY_TT_ENABLEAUTH                                "שולח אישורי פרוקסי עם שם משתמש וס\r\n\r\nיסמה כאשר ה-proxy דורש אימות."
    IDS_PPG_PROXY_TT_USERNAME_A                                "שם משתמש של חשבון Proxy.\r\n\r\nהשאר אותו ריק אלא אם ה-proxy שלך דורש גישה מאומתת במפורש."
    IDS_PPG_SCHEDULER_TT_ENABLE                                "מאפשר את המתזמן כך שכללים מבוססי זמן יכולים לשנות הגדרות באופן אוטומטי.\r\n\r\nהשאר אותו כבוי אלא אם אתה משתמש באופן פעיל ברוחב פס, חיבור או קטגוריות מתוזמנות."
    IDS_PPG_SCHEDULER_TT_CHECKNOENDTIME                        "מפעיל את כניסת לוח הזמנים שנבחרה ללא זמן עצירה.\r\n\r\nהשתמש בו לשינויי מצב חד-כיווני שאמורים להישאר פעילים עד שלוח זמנים אחר יעקוף אותם."
    IDS_PPG_SCHEDULER_TT_APPLY                                 "מחיל את הפרטים הערוכים על ערך לוח הזמנים שנבחר כעת.\r\n\r\nהשתמש בזה לאחר שינוי היום, השעה או רשימת הפעולות עבור אותה שורה."
    IDS_PPG_SECURITY_TT_USESECIDENT                            "משתמש בזיהוי מאובטח כאשר הוא נתמך כדי להפוך את זהויות האשראי של הלקוח לקשות יותר לזייף.\r\n\r\nמומלץ: מופעל. השבתתו רק מפחיתה את אמון הזהות ולעתים רחוקות היא שימושית."
    IDS_PPG_SECURITY_TT_FILTERSERVERBYIPFILTER                 "מחיל את מסנן IP על רשימת השרתים הגלויים כך ששרתים מסוננים יוסתרו או יוסרו.\r\n\r\nמומלץ: מופעל אם אתה מסתמך על מסנן IP להגיינת שרתים כמו גם סינון עמיתים."
    IDS_PPG_SECURITY_TT_UPDATEURL                              "כתובת ה-URL של מקור המשמשת בעת הורדת רשימות מסנן IP מרעננות.\r\n\r\nהשתמש בספק מהימן בלבד. עדכונים אוטומטיים עושים שימוש חוזר בכתובת האתר הזו ושומרים את המסנן הקיים אם ההורדה לא חוקית."
    IDS_PPG_SECURITY_TT_AUTOUPDATE_IPFILTER                    "בודק את כתובת ה-URL המוגדרת של המסנן IP באופן אוטומטי לאחר האתחול כאשר מרווח העדכון מגיע.\r\n\r\nמומלץ: מושבת, אלא אם כן אתה סומך על הספק ומעוניין לרענן את המסנן ללא פעולה ידנית."
    IDS_PPG_SECURITY_TT_IPFILTERPERIOD                         "מספר הימים בין ניסיונות עדכון אוטומטי של מסנן IP.\r\n\r\nטווח מותר: 1 עד 365 ימים. ניסיונות כושלים עדיין נספרים כדי למנוע לולאות ניסיון חוזר כאשר ספק אינו זמין."
    IDS_PPG_SECURITY_TT_SEESHARE1                              "מאפשר לכולם לגלוש בקבצים המשותפים שלך כאשר הלקוח המרוחק תומך בכך.\r\n\r\nהאפשרות המתירנית ביותר. השתמש בו רק אם אתה מרגיש בנוח לחשוף את הרשימה המשותפת שלך בצורה רחבה."
    IDS_PPG_SECURITY_TT_SEESHARE2                              "מאפשר רק לחברים לגלוש בקבצים המשותפים שלך.\r\n\r\nבחירת פרטיות מאוזנת אם אתה עדיין רוצה תמיכה בגלישה עבור אנשי קשר מהימנים במפורש."
    IDS_PPG_SECURITY_TT_SEESHARE3                              "מונע מלקוחות מרוחקים לגלוש ברשימת הקבצים המשותפים שלך.\r\n\r\nמומלץ אם אתה רוצה את עמדת הפרטיות המחמירה ביותר עבור גלישה בקבצים משותפים."
    IDS_PPG_SECURITY_TT_ENABLEOBFUSCATION                      "מעדיף ערפול פרוטוקול כאשר הצד המרוחק תומך בו גם.\r\n\r\nמומלץ: מופעל. זה יכול לעזור ברשתות מגבילות מבלי לכפות מדיניות של ערפול בלבד."
    IDS_PPG_SECURITY_TT_ONLYOBFUSCATED                         "דורש חיבורים מעורפלים במקום לקבל חיבורים רגילים.\r\n\r\nהשתמש בזה רק אם סביבת הרשת שלך באמת זקוקה לכך. זה יכול להפחית את הקישוריות ואת טווח ההגעה של עמיתים."
    IDS_PPG_SECURITY_TT_SEARCHSPAMFILTER                       "מסנן דואר זבל ברור מתוצאות חיפוש לפני שהן עומסות את ממשק המשתמש.\r\n\r\nמומלץ: מופעל לשימוש רגיל ברשת ציבורית."
    IDS_PPG_SECURITY_TT_CHECK_FILE_OPEN                        "בודק מצב פתוח/נעול של קבצים שהורדו לפני פעולות הדורשות גישה בלעדית.\r\n\r\nמומלץ: מופעל אלא אם יש לך סיבה ספציפית לדלג על בדיקת הבטיחות."
    IDS_PPG_SERVER_TT_AUTOSERVER                               "מעדכן אוטומטית את רשימת השרתים מלקוחות מחוברים וממקורות מהימנים אחרים.\r\n\r\nנוח, אך גם מאפשר לרשימה להיסחף לאורך זמן. השבת אותו אם אתה מעדיף רשימת שרתים סטטית שנקבעה היטב."
    IDS_PPG_SERVER_TT_UPDATESERVERCONNECT                      "מאפשר לשרתים מחוברים לפרסם שרתים נוספים ברשימה שלך.\r\n\r\nנוח, אבל זה יכול להגדיל את הרשימה עם ערכים בעלי ערך נמוך. השבת אותו אם אתה מעדיף אוצרות ידנית מחמירה יותר."
    IDS_PPG_SERVER_TT_UPDATESERVERCLIENT                       "מאפשר ללקוחות לתרום כתובות שרת לרשימת השרתים שלך.\r\n\r\nרוב המשתמשים צריכים להתייחס לזה בזהירות. השבת אותו אם אתה רוצה שליטה הדוקה יותר על איכות רשימת השרתים."
    IDS_PPG_SERVER_TT_SAFESERVERCONNECT                        "משתמש באסטרטגיית חיבור שרת זהירה יותר במקום למהר בין מועמדים רבים.\r\n\r\nמומלץ: מופעל ליציבות. השבת אותו רק אם אתה רוצה בכוונה גישת חיבור אגרסיבית יותר."
    IDS_PPG_SERVER_TT_SMARTIDCHECK                             "מבצע את בדיקת LowID החכמה לפני שמחליטים שהנגישות שלך בצד השרת גרועה.\r\n\r\nמומלץ: מופעל. זה נמנע מכמה מסקנות שגויות LowID במהלך תנאי רשת חולפים."
    IDS_PPG_SERVER_TT_SCORE                                    "משתמש בסדרי עדיפויות של שרתים בעת בחירה והזמנת שרתים.\r\n\r\nמומלץ: מופעל אם אתה שומר על תת-קבוצה מועדפת של שרתים ורוצה ש-eMuleBB יעדיף אותם."
    IDS_PPG_SERVER_TT_SERVERRETRIES                            "כמה ניסיונות חיבור כושלים עלול שרת לצבור לפני ש-eMuleBB מתייחס אליו כמת.\r\n\r\nערכים נמוכים יותר גוזרים שרתים גרועים מהר יותר; ערכים גבוהים יותר סלחניים יותר להפסקות חולפות."
