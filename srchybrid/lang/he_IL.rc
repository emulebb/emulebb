    IDS_KAD_UNICODE_MAP_NOT_INITIALIZED                        "מפת תווים קטנה של Kad Unicode לא אותחלה!"
    IDS_TWEAKS_TT_CONDITIONAL_TCP_ACCEPT                       "מעדיף לקבל חיבורי TCP נכנסים רק כשהם נראים שימושיים.\r\n\r\nהתאמה מתקדמת של עיצוב תעבורה. השאר אותו כברירת מחדל אלא אם כן אתה מאבחן לחץ חיבור."
    IDS_TWEAKS_TT_MAX_CON5_SEC                                 "המספר המרבי של חיבורי TCP חדשים eMuleBB עשוי להיפתח בתוך חמש שניות.\r\n\r\nהערכים הנמוכים יותר עדינים יותר ל-Windows ולנתבים. השאר אותו ליד ברירת המחדל אלא אם כן אתה מכוון את התנהגות פרצי החיבור."
    IDS_TWEAKS_TT_MAX_HALF_OPEN                                "גבול עליון לניסיונות חיבור יוצאים TCP פתוחים למחצה.\r\n\r\nבעיקר אמצעי הגנה לתאימות. ברירת המחדל היא בדרך כלל הבחירה הנכונה אלא אם כן אתה חוקר בעיות התקנה של TCP."
    IDS_TWEAKS_TT_CONNECTION_TIMEOUT                           "כמה זמן eMuleBB ממתין לחיבור חדש כדי להתקדם לפני שהוא מחשיב אותו ככשל.\r\n\r\nערכים קצרים יותר מתאוששים מהר יותר מעמיתים מתים; ערכים ארוכים יותר סובלניים יותר לרשתות איטיות. ערכי ברירת מחדל מומלצים."
    IDS_TWEAKS_TT_DOWNLOAD_TIMEOUT                             "כמה זמן מקור הורדה עשוי להישאר פעיל לפני ש-eMuleBB מפיל אותו כשהוא נתקע.\r\n\r\nערכים נמוכים יותר מנקים מקורות מתים מהר יותר, אבל ערכים נמוכים מאוד יכולים לפגוע בעמיתים איטיים. השאר את ברירת המחדל אלא אם כן אתה מאבחן דוכנים."
    IDS_TWEAKS_TT_SERVER_KEEP_ALIVE_TIMEOUT                    "באיזו תדירות eMuleBB מרענן חיבור שרת לא פעיל אחרת.\r\n\r\nהשתמש בדקות. הגדר 0 כדי להשבית את Keepalives. השאר את ברירת המחדל אלא אם אתה פותר בעיה ספציפית של ניתוק שרת ללא פעיל."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_RESULTS                      "מספר מקסימלי של תוצאות המבוקש משרת eD2K עבור חיפוש אחד.\r\n\r\nערכים גבוהים יותר יכולים למצוא קבצים נוספים אך להגביר את עבודת השרת ורעש ממשק המשתמש. הישאר קרוב לברירת המחדל אלא אם יש לך סיבה ספציפית."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_MORE_REQUESTS                "מספר מקסימלי של דפי תוצאות מעקב eMuleBB בקשות מחיפוש eD2K.\r\n\r\nערכים גבוהים יותר יכולים למשוך יותר תוצאות אך לעלות יותר תעבורת שרת וזמן. ערכים שמרניים מומלצים."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_TOTAL                        "מספר יעד של תוצאות עבור חיפושי קבצים Kad.\r\n\r\nערכים גבוהים יותר מחפשים בצורה רחבה יותר אך שומרות על חיפושי Kad בחיים יותר. הישאר קרוב לברירת המחדל אלא אם כן אתה רוצה חיפושים מעמיקים יותר."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_TOTAL                     "מספר יעד של תוצאות עבור חיפושי מילות מפתח Kad.\r\n\r\nערכים גבוהים יותר יכולים למצוא התאמות נוספות אך להגביר את עומס השאילתות Kad ורעש ממשק המשתמש. ברירת המחדל היא בדרך כלל האיזון הנכון."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_LIFETIME                     "משך חיים מרבי של חיפוש קובץ Kad אחד בשניות.\r\n\r\nהעלה אותו רק אם אתה רוצה בכוונה חיפושים ארוכים יותר של Kad."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_LIFETIME                  "משך חיים מרבי של חיפוש מילת מפתח Kad אחד בשניות.\r\n\r\nתאריכים ארוכים יותר עשויים למצוא תוצאות מאוחרות יותר אך להגביר את פעילות החיפוש ברקע."
    IDS_TWEAKS_TT_GENERAL_ADVANCED                             "התנהגות כללית מתקדמת שאינה מתאימה באופן נקי תחת רשת, קובץ, תצוגה או אבטחה.\r\n\r\nרוב המשתמשים צריכים להשאיר אותם ליד ברירת המחדל שלהם."
    IDS_TWEAKS_TT_HIDDEN_FILE                                  "התנהגות מתקדמת של טיפול בקבצים, בדיקת תצוגה מקדימה ואפשרויות הקשורות להיסטוריית קבצים.\r\n\r\nהגדרות אלו מעצבות את האופן שבו eMuleBB מתייחס לקבצים, לא כמה שטח דיסק הוא שומרת."
    IDS_TWEAKS_TT_STORAGE_PERSISTENCE                          "הגדרות מתקדמות של הגנה על שטח דיסק, אחסון קבצים והתמדה של מטא נתונים.\r\n\r\nזוהי הקבוצה העיקרית לבטיחות אחסון וחילופי דיסק-I/O."
    IDS_TWEAKS_TT_HIDDEN_STARTUP                               "התנהגות שחזור הפעלה מתקדמת.\r\n\r\nאפשרויות אלו משפיעות רק על אילו חלוניות ממשק משתמש חוזרות כאשר eMuleBB מופעל."
    IDS_TWEAKS_TT_HIDDEN_DISPLAY                               "הגדרות תצוגה מתקדמות, שורת משימות, מגש ומידע חזותי.\r\n\r\nאפשרויות אלו משנות מצגת בלבד, לא התנהגות העברה."
    IDS_TWEAKS_TT_HIDDEN_SECURITY                              "אפשרויות סינון והגנה מתקדמות לטיפול מחמיר יותר עם עמיתים והודעות.\r\n\r\nברירות מחדל מומלצות מתאימות לרוב המשתמשים."
    IDS_TWEAKS_TT_LOGGING_GROUP                                "בקרות רישום ויציאות אבחון מתמשכות.\r\n\r\nרוב ההגדרות הללו שימושיות רק בעת אבחון בעיה."
    IDS_TWEAKS_TT_AUTO_TAKE_ED2K_LINKS                         "רושם את eMuleBB כמטפל ברירת המחדל עבור ed2k:// links.\r\n\r\nהפעל אותו אם מחשב זה אמור לפתוח קישורי ed2k ב-eMuleBB באופן אוטומטי. השבת אותו אם כלי אחר צריך להיות הבעלים של השיוך הזה."
    IDS_TWEAKS_TT_CREDIT_SYSTEM                                "משתמש במערכת האשראי eMule הרגילה בעת דירוג לקוחות העלאה.\r\n\r\nמומלץ: מופעל. השבת אותו רק עבור ניפוי באגים או ניסויי תאימות מכוונים."
    IDS_TWEAKS_TT_YOUR_HOSTNAME                                "תווית שם מארח אופציונלית eMuleBB מדווחת היכן מוצג טקסט הזהות המקומית שלך.\r\n\r\nהשאר אותו ריק אלא אם אתה רוצה לתת שם למופע זה בכוונה."
    IDS_TWEAKS_TT_TXT_EDITOR                                   "הפקודה משמשת כאשר eMuleBB פותחת קבצי טקסט כגון יומנים או פלט טקסט שנוצר.\r\n\r\nהשתמש בנתיב מלא אם העורך אינו ב-PATH. ברירת המחדל היא notepad.exe."
    IDS_TWEAKS_TT_HIGHRES_TIMER                                "מבקש טיימר Windows ברזולוציה גבוהה בזמן ש-eMuleBB פועל.\r\n\r\nזה יכול להפוך את התזמון לחלק יותר במערכות מסוימות, אבל זה עשוי להגביר את השימוש בחשמל. הפעל מחדש את eMuleBB לאחר שינויו."
    IDS_TWEAKS_TT_ICH                                          "מאפשר טיפול מושכל בשחיתות עבור נתחים שהורדו פגומים.\r\n\r\nמומלץ: מופעל. זה עוזר לשחזר נתונים טובים בתוך חלקים פגומים במקום להוריד מחדש יותר מהנדרש."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS                         "קובע אם תצוגה מקדימה של מדיה מוצעת לפני שבדיקות\r\n\r\nהבטיחות הרגילות של התצוגה המקדימה מסופקות במלואן."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_DISABLED                "השתמש בכללי התצוגה המקדימה השמרנית הרגילים."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_ALLOW                   "אפשר תצוגה מקדימה עם בלוקים זמינים קטנים יותר לאחר שהמטא נתונים הרגילים ובדיקות השחקנים עוברות."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_FORCE                   "הצע תצוגה מקדימה גם כאשר הבלוק הראשון חסר.\r\n\r\nהשתמש רק עם נגנים שיכולים לסבול מדיה לא שלמה, כגון VLC."
    IDS_TWEAKS_TT_BEEP_ON_ERROR                                "משמיע את צליל שגיאת המערכת כאשר eMuleBB מדווח על שגיאות חשובות.\r\n\r\nשימושי לפתרון בעיות ללא השגחה. השבת אותו אם התראות קוליות מסיחות את הדעת."
    IDS_TWEAKS_TT_SHOW_COPY_ED2K_LINK_CMD                      "משנה את תפריטי ההקשר של הקובץ כדי להציג פקודת העתק ed2k Link ישירה במקום הפעולה הרגילה Show ed2k Link.\r\n\r\nהפעל זאת אם העתקת קישורים היא זרימת העבודה הרגילה שלך."
    IDS_TWEAKS_TT_SPARSE_PART_FILES                            "משתמש בקבצים דלילים עבור קבצי חלקים כאשר מערכת הקבצים תומכת בהם.\r\n\r\nמומלץ: מופעל ב-NTFS כדי להפחית הקצאת דיסק מראש. השבת רק אם התנהגות קבצים דלילה גורמת לבעיה ספציפית למערכת הקבצים."
    IDS_TWEAKS_TT_FULL_ALLOC                                   "מקצים מראש את גודל קובץ היעד המלא בדיסק כאשר ההורדות מתחילות.\r\n\r\nיכול להפחית את הפיצול, אך הוא שומר מקום באופן מיידי ועולה יותר עבודה בדיסק. השאר את זה, אלא אם כן אתה מעדיף הקצאה מלאה מראש."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_CONFIG                   "שטח פנוי מינימלי שמור באמצעי האחסון המארח את קובצי התצורה של eMuleBB.\r\n\r\nמינימום: 1 GiB. אם נפח זה יורד מתחת למגבלה האפקטיבית, eMuleBB מפסיק את כל ההורדות ומיד שומר קבצי .part.met.\r\nאם התצורה חולקת אמצעי אחסון עם זמני או נכנסים, ההגבלה הגדולה ביותר בנפח זה מנצחת."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_TEMP                     "מינימום מקום פנוי שמור בכל נפח המארח קבצים זמניים.\r\n\r\nמינימום: 5 GiB. אם נפח מוגן כלשהו יורד מתחת למגבלה האפקטיבית שלו, eMuleBB מפסיק את כל ההורדות ומיד שומר קבצי .part.met.\r\nאם הזמנית חולקת אמצעי אחסון עם הגדרות תצורה או נכנסות, ההגבלה הגדולה ביותר בנפח זה מנצחת."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_INCOMING                 "שטח פנוי מינימלי שמור בכל נפח המארח קבצים נכנסים, כולל ספריות נכנסות ספציפיות לקטגוריות.\r\n\r\nמינימום: 5 GiB. אם נכנסים חולקים אמצעי אחסון עם תצורה או טמפ', המגבלה הגדולה ביותר בנפח זה מנצחת וכל ההורדות יופסקות כאשר היא נפרצת."
    IDS_TWEAKS_TT_PERF_LOG                                     "כותב מטען תקופתי ודגימות תקורה עבור כלי גרף חיצוניים.\r\n\r\nתכונת מפעיל/ניפוי באגים בלבד. השאר אותו כבוי אלא אם כן אתה צורך באופן פעיל את הקבצים שנוצרו."
    IDS_TWEAKS_TT_COMMIT                                       "שולט באיזו אגרסיביות eMuleBB מאלץ את Windows לשטוף את נתוני הקבצים השמורים אל הדיסק. הגדרות\r\n\r\nSafer מפחיתות את הסיכון לאובדן קריסה אך עולות יותר קלט/פלט של דיסק. 'רק בעת כיבוי' הוא ברירת המחדל המאוזנת."
    IDS_TWEAKS_TT_COMMIT_NEVER                                 "סגור קבצים בדרך כלל מבלי ל\r\n\r\nכפות על שטיפה של דיסק ברמת מערכת ההפעלה."
    IDS_TWEAKS_TT_COMMIT_ON_SHUTDOWN                           "כפה שטיפה של דיסק ברמת מערכת ההפעלה רק בזמן ש-eMuleBB נסגרת.\r\n\r\nברירת מחדל מומלצת. זה משפר את בטיחות ההתמדה ביציאה נקייה מבלי לאלץ שטיפות נוספות במהלך כל שמירה."
    IDS_TWEAKS_TT_COMMIT_ALWAYS                                "כפה שטיפה של דיסק ברמת מערכת ההפעלה בכל נתי\r\n\r\nב שמירה המשתמש ב-commit-close helper של eMuleBB."
    IDS_TWEAKS_TT_EXTRACT_META_DATA                            "שולט אם eMuleBB מחלץ מטא נתונים כגון תגים ומשך מדיה מקבצים.\r\n\r\nהשבת אותו אם אתה רוצה את הסריקה הקלה ביותר."
    IDS_TWEAKS_TT_GEO_LOCATION_ENABLED                         "פותר עמיתים של IP לנתוני מיקום ברמת המדינה לתצוגה.\r\n\r\nמידע בלבד. השבת אותו אם לא אכפת לך מדגלי מדינות או לא רוצה רענון רקע."
    IDS_TWEAKS_TT_CLOSE_U_PN_P_PORTS                           "סוגר מיפויי נתב ביציאה נקייה כאשר נעשה שימוש במיפוי NAT ​​אוטומטי.\r\n\r\nמומלץ: מופעל. השבת אותו רק אם אתה רוצה בכוונה שהמיפויים יישארו מאחור."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE                          "בוחר כיצד eMuleBB מבצע מיפוי NAT ​​אוטומטי.\r\n\r\nמומלץ: אוטומטי. זה מנסה קודם את UPnP IGD ונופל בחזרה ל-PCP/NAT-PMP במידת הצורך."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_AUTOMATIC                "מצב מומלץ. נסה תחילה את UPnP IGD, ואז חזור ל-PCP/NAT-PMP אם המיפוי נכשל."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_IGD_ONLY                 "השתמש רק במיפוי UPnP IGD. בחר זאת אם אתה רוצה התנהגות קלאסית לחלוטין של UPnP."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_PCP_NAT_PMP_ONLY         "השתמש רק במיפוי PCP/NAT-PMP. בחר זאת רק אם סביבת הנתב שלך מעדיפה זאת בבירור."
    IDS_TWEAKS_TT_FILE_BUFFER_TIME_LIMIT                       "הגיל המרבי של נתוני קבצים מאוחסנים לפני ש-eMuleBB שוטף אותם לדיסק.\r\n\r\nערכים נמוכים יותר מפחיתים נתונים בסיכון במהלך קריסות. ערכים גבוהים יותר יכולים להפחית את נטישת הדיסק. ברירת המחדל היא בדרך כלל פשרה טובה."
    IDS_TWEAKS_TT_FILE_BUFFER_SIZE                             "גודל של מאגר הכתיבה לכל קובץ בשימוש לפני שטיפת נתוני הורדה לדיסק.\r\n\r\nמאגרים גדולים יותר יכולים להפחית את פעילות הדיסק, אך הם מגדילים את השימוש בזיכרון ומעכבים כתיבה. שמור על ערכים מתונים אלא אם כן אתה מכוון להגדרת אחסון ספציפית."
    IDS_TWEAKS_TT_QUEUE_SIZE                                   "גודל היעד של תור ההעלאה הממתין.\r\n\r\nערכים גבוהים יותר מאפשרים ליותר לקוחות לחכות, אך הם מוסיפים שימוש בזיכרון ותקורה לניהול. ערכי ברירת מחדל מומלצים לרוב המשתמשים."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LISTS                      "פורמט תאריך/שעה מותאם אישית בשימוש בתצוגות רשימה.\r\n\r\nהשאר אותו ריק כדי להשתמש בעיצוב ברירת המחדל הרגיל. שנה אותו רק אם אתה רוצה סגנון חותמת זמן מותאם אישית ספציפי."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT                             "פורמט תאריך/שעה מותאם אישית בשימוש על ידי תצוגות כלליות של קבצים ופרטי עמיתים.\r\n\r\nמשתמש באסימוני עיצוב של CTime. שמור אותו לא ריק; אסימונים לא חוקיים יכולים לייצר חותמות זמן מבלבלות."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LOG                        "פורמט תאריך/שעה מותאם אישית בשימוש בשורות יומן ופלט סטטוס דמוי יומן.\r\n\r\nמשתמש באסימוני עיצוב של CTime. שמור אותו תמציתי כדי ששורות יומן יישארו קריאות."
    IDS_TWEAKS_TT_ICON_FLASH_ON_NEW_MESSAGE                    "מהבהב בסמל המגש כשמגיעה הודעת צ'אט חדשה.\r\n\r\nהעדפת הודעה גרידא. הפעל את זה אם אתה רוצה שהודעות יבלוט בזמן ש-eMuleBB ממוזער."
    IDS_TWEAKS_TT_INSPECT_ALL_FILE_TYPES                       "הפעל גם את נתיב הבדיקה היקר בסגנון MediaInfo עבור סוגי קבצים שאינם כבר מסווגים כשמע או וידאו.\r\n\r\nהפעל אותו אם אתה רוצה בדיקה עשירה יותר של מידע קבצים עבור קבצים חריגים או מתויגים שגויים. השאר את זה כדי לבדוק רק קובצי אודיו/וידאו סבירים ולהפחית את עבודת בדיקת הרקע."
    IDS_TWEAKS_TT_RE_BAR_TOOLBAR                               "משתמש במיכל סרגל הכלים הראשי בסגנון סרגל גב במקום בפריסת סרגל הכלים הפשוטה יותר.\r\n\r\nבעיקר העדפת פריסת ממשק משתמש. השאר אותו מופעל רק אם אתה מעדיף את מצגת סרגל הכלים מדור קודם."
    IDS_TWEAKS_TT_SHOW_UP_DOWN_ICON_IN_TASKBAR                 "מציג את סמל קצב העלאה/הורדה משולב באזור ההודעות של שורת המשימות.\r\n\r\nויזואלי לחלוטין. השבת אותו אם אתה רוצה אזור מגש נקי יותר."
    IDS_ALWAYS_SHOW_TRAY_ICON                                  "הצג תמיד את סמל המגש"
    IDS_TWEAKS_TT_ALWAYS_SHOW_TRAY_ICON                        "שומר על סמל eMuleBB גלוי באזור ההודעות Windows בזמן ש-eMuleBB פועל.\r\n\r\nהודעות בלון מגש קלאסי ומזעור למגש עדיין יכולות לאלץ את סמל המגש גלוי כאשר זה מושבת."
    IDS_TWEAKS_TT_SHOW_VERTICAL_HOUR_MARKERS                   "מצייר סמני מדריך לפי שעה בגרפים סטטיסטיים ארוכי טווח.\r\n\r\nשימושי לקריאת דפוסי תנועה מבוססי זמן. השבת אותו אם אתה מעדיף פחות עומס גרפים."
    IDS_TWEAKS_TT_FORCE_SPEEDS_TO_KB                           "מאלץ תצוגות קצב להשתמש ביחידות בסגנון KB/s במקום לשנות קנה מידה אוטומטי ליחידות גדולות יותר.\r\n\r\nהפעל זאת אם אתה מעדיף יחידות מוכרות קבועות. השאר אותו כבוי לצגים קריאים יותר במהירות גדולה."
    IDS_TWEAKS_TT_REARRANGE_KAD_SEARCH_KEYWORDS                "מסדר מחדש את מונחי החיפוש של מילות מפתח Kad כדי לנסות תחילה צורת שאילתה שימושית יותר.\r\n\r\nהתאמה מתקדמת של התנהגות חיפוש. השאר אותו כברירת מחדל אלא אם כן אתה מכוון את התנהגות החיפוש של Kad בכוונה."
    IDS_TWEAKS_TT_MESSAGE_FROM_VALID_SOURCES_ONLY              "מקבל הודעות רק מעמיתים שכבר נראים כמו מקורות חוקיים להעברות שלך.\r\n\r\nהגנה חזקה יותר על פרטיות/דואר זבל, אבל זה יכול לחסום מגע לא רצוי. הפעל את זה אם אתה רוצה מדיניות הודעות מחמירה יותר."
    IDS_TWEAKS_TT_MAX_CHAT_HISTORY_LINES                       "המספר המרבי של שורות היסטוריה נשמרות לצ'אט או לצפייה בערוץ IRC.\r\n\r\nערכים גבוהים יותר שומרים על הקשר רב יותר אך משתמשים יותר בזיכרון ויכולים להפוך צ'אטים עמוסים לאט יותר להצגה."
    IDS_TWEAKS_TT_MAX_MESSAGE_SESSIONS                         "המספר המרבי של הפעלות של הודעות עמיתים נשמר בבת אחת.\r\n\r\nערכים גבוהים יותר שומרים על יותר שיחות זמינות, אך הם מגדילים את השימוש בזיכרון. ברירת המחדל היא שמרנית."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP                            "שולט על יצירת dump קריסה כאשר eMuleBB נתקל בקריסה לא מטופלת.\r\n\r\ndump dumps של Crash עוזרים לאבחן כשלים קשים אך יכולים להכיל זיכרון תהליך. שתף אותם רק עם מפתחים מהימנים."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_DISABLED                   "אל תיצור קבצי dump של קריסה."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_PROMPT                     "שאל לפני כתיבת dump קריסה כאשר מתרחשת קריסה."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_ALWAYS                     "צור dump של קריסה באופ\r\n\r\nן אוטומטי כאשר מתרחשת קריסה."
    IDS_TWEAKS_TT_MAX_LOG_FILE_SIZE                            "גודל מקסימלי של כל קובץ יומן רישום בדיסק ב-KiB.\r\n\r\nUse 0 ללא הגבלת סיבוב. ערכים גדולים מאוד שומרים יותר היסטוריה אבל צורכים יותר שטח דיסק."
    IDS_TWEAKS_TT_MAX_LOG_BUFFER                               "מאגר מקסימלי של תצוגת יומן בזיכרון ב-KiB.\r\n\r\nערכים גבוהים יותר שומרים על היסטוריית יומן גלויה יותר אך משתמשים יותר בזיכרון ויכולים להאט תצוגות יומן עמוסות מאוד."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT                              "קידוד המשמש עבור קבצי יומן יומן שנפתחו לאחרונה בדיסק.\r\n\r\nשינוי זה בזמן שהיומנים כבר פתוחים נמשך, אך נעשה שימוש בפורמט החדש לאחר פתיחת קובץ היומן מחדש או הפעלה מחדש של eMuleBB."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UNICODE                      "כתוב יומנים בתור UTF-16 Unicode. זוהי ברירת המחדל מדור קודם ומשמרת טקסט Windows באופן נרחב."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UTF8                         "כתוב יומנים בתור UTF-8. שימושי עבור כלים המצפים לקבצי טקסט מודרניים מסוג UTF-8."
    IDS_TWEAKS_TT_LOG2_DISK                                    "כותב את יומן היישום הרגיל לדיסק במקום לשמור אותו בזיכרון בלבד.\r\n\r\nשימושי עבור איתור באגים ושימוש ארוך טווח ללא השגחה, אך הוא מוסיף כתיבה בדיסק. השאר אותו כבוי אלא אם כן אתה רוצה יומנים מתמשכים."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT                         "פורמט פלט עבור דוגמאות רישום ביצועים.\r\n\r\nCSV הוא הקל ביותר לבדיקה ידנית. MRTG כותב קבצי Sidecar עבור כלי גרף המצפים לקלט בסגנון MRTG."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_CSV                     "כתוב קובץ יומן ביצועים CSV אחד עם עומס חותמת זמן ודוגמאות תקורה."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_MRTG                    "כתוב נתונים בסגנון MRTG וקבצי צדדיים עיליים הנגזרים מנתיב הבסיס המוגדר."
    IDS_TWEAKS_TT_PERF_LOG_FILE                                "נתיב בסיס לקובץ רישום ביצועים.\r\n\r\nהשאר אותו ריק כדי להשתמש בקובץ ברירת המחדל בספריית התצורה של eMuleBB. מצב MRTG גוזר מנתיב זה _data ו-_overhead."
    IDS_TWEAKS_TT_PERF_LOG_INTERVAL                            "מרווח דגימה עבור רישום ביצועים בדקות.\r\n\r\nמרווחים קצרים יוצרים גרפים עדינים יותר אך יותר כתיבה בדיסק. השתמש ב-1..1440."
    IDS_TWEAKS_TT_VERBOSE_GROUP                                "בקרות רישום אבחנתיות נוספות לפתרון בעיות עמוקות.\r\n\r\nאפשרויות אלו מיועדות לאיפוי באגים, לא לפעולה רגילה. עזוב אותם אלא אם כן אתה חוקר נושא ספציפי."
    IDS_TWEAKS_TT_RESTORE_LAST_MAIN_WND_DLG                    "משחזר את דף החלון הראשי האחרון שנבחר בהפעלה.\r\n\r\nהפעל אותו אם אתה רוצה ש-eMuleBB ייפתח מחדש מהמקום שבו הפסקת."
    IDS_TWEAKS_TT_RESTORE_LAST_LOG_PANE                        "משחזר את חלונית היומן שנבחרה לאחרונה בהפעלה.\r\n\r\nאך ורק אפשרות נוחות עבור משתמשים שמבלים זמן בתצוגות היומן."
    IDS_TWEAKS_TT_KEEP_UNAVAILABLE_FIXED_SHARED_DIRS           "שומר ספריות משותפות המוגדרות ידנית ברשימה גם כשהן אינן זמינות כרגע.\r\n\r\nשימושי לאחסון נשלף או חסר מדי פעם. השבת אותו אם אתה רוצה לגזום תיקיות חסרות בצורה אגרסיבית."
    IDS_TWEAKS_TT_PARTIALLY_PURGE_OLD_KNOWN_FILES              "מאפשר ניקוי אגרסיבי יותר של ערכים מיושנים בהיסטוריית הקבצים הידועים.\r\n\r\nיכול להפחית את העומס לאורך זמן, אך הוא גם שוכח את היסטוריית הקבצים הישנים מוקדם יותר. השאר את ברירת המחדל אלא אם כן אתה רוצה היסטוריה רזה יותר."
    IDS_TWEAKS_TT_DETECT_TCP_ERROR_FLOODER                     "מזהה פרצי שגיאה חוזרים ונשנים של TCP שעלולים להצביע על עמיתים פוגעניים או שבורים.\r\n\r\nמומלץ: מופעל. השבת אותו רק אם אתה מאבחן תוצאות חיוביות שגויות."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_INTERVAL_MINUTES           "חלון זמן המשמש לזיהוי שגיאות-הצפה TCP.\r\n\r\nחלונות קצרים יותר מגיבים מהר יותר; חלונות ארוכים יותר הם פחות רגישים. ערכי ברירת מחדל מומלצים."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_THRESHOLD                  "מספר שגיאות TCP בתוך המרווח שמפעיל טיפול בהצפה.\r\n\r\nהערכים הנמוכים יותר מחמירים. העלה אותו רק אם הסביבה שלך מייצרת שגיאות TCP תכופות לא מזיקות."
    IDS_TWEAKS_TT_SHAREE_MULE                                  "שולט כיצד eMuleBB מאחסן ומשתף מצב לכל משתמש במחשב Windows זה.\r\n\r\nעזוב את המצב הנוכחי אלא אם כן אתה משנה בכוונה את האופן שבו משתמשים מקומיים מרובים משתפים תצורה ונתונים."
    IDS_TWEAKS_TT_TCP_GROUP                                    "בקרות מתקדמת של חיבור TCP, זמן קצוב ושמירה על חיים.\r\n\r\nהגדרות אלו משפיעות על התנהגות החיבור ולא על מגבלות ההעברה. ערכי ברירת מחדל מומלצים אלא אם כן אתה מאבחן בעיות בהגדרת הרשת."
    IDS_TWEAKS_TT_SEARCH_GROUP                                 "מגבלות מתקדמות לכמה רחב וכמה זמן eMuleBB חיפושים ב-eD2K ו-Kad.\r\n\r\nערכים גבוהים יותר יכולים להחזיר יותר תוצאות, אבל הם גם מוסיפים יותר תעבורת רשת ורעש ממשק משתמש."
    IDS_TWEAKS_TT_SEARCH_ED2K_GROUP                            "מגבלות חיפוש מבוססות שרת eD2K.\r\n\r\nהשתמש בערכים שמרניים אלא אם כן אתה רוצה בכוונה חיפושים עמוקים יותר בשרת."
    IDS_TWEAKS_TT_SEARCH_KAD_GROUP                             "Kad רוחב החיפוש ובקרות לכל החיים.\r\n\r\nערכים גבוהים יותר שומרים על חיים של חיפושים מבוזרים זמן רב יותר ויכולים למצוא יותר תוצאות, אבל הם עולים יותר פעילות ברקע."
    IDS_TWEAKS_TT_BROADBAND                                    "מדיניות מיחזור מתקדמת של משבצות העלאה וציון בתור עבור התנהגות העלאה בסגנון פס רחב.\r\n\r\nהגדרות אלו מיועדות לכוונון מכוון. השאר אותם בברירות המחדל שלהם, אלא אם כן אתה משנה את הוגנות ההעלאה או מחזור המשבצות."
    IDS_TWEAKS_TT_UPLOAD_POLICY_MAX_UPLOAD_CLIENTS             "כובע רך עבור לקוחות העלאה פעילים בו-זמנית תחת מתזמן הפס הרחב.\r\n\r\nערכים גבוהים יותר מפזרים רוחב פס על פני יותר עמיתים, אך הופכים כל משבצת לדק יותר. ערכים נמוכים יותר שומרים על פחות חריצים חזקים יותר."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_THRESHOLD                 "חלק מקצב העלאת היעד לכל משבצת שמתחתיו משבצת נחשבת לאטית.\r\n\r\nערכים נמוכים יותר סובלים משבצות חלשות יותר. ערכים גבוהים יותר ממחזרים משבצות עם ביצועים נמוכים בצורה אגרסיבית יותר."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_GRACE                     "כמה זמן משבצת עשויה להישאר מתחת לסף האיטי לפני ש-eMuleBB שוקל למחזר אותו.\r\n\r\nחסד ארוך יותר הוא סבלני יותר עם עמיתים חלשים; חסד קצר יותר הופך חריצים חלשים מוקדם יותר."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_WARMUP                    "תקופת חימום עבור משבצת העלאה חדשה לפני תחילת זיהוי חריץ איטי.\r\n\r\nזה נמנע מענישה של העלאות חדשות עבור רעשי הפעלה וזמן התגברות."
    IDS_TWEAKS_TT_UPLOAD_POLICY_ZERO_RATE_GRACE                "תקופת חסד עבור משבצות שבעצם לא מספקות נתוני העלאה כלל.\r\n\r\nערכים נמוכים יותר מגיבים מהר יותר למשבצות מתות או נתקעות."
    IDS_TWEAKS_TT_UPLOAD_POLICY_COOLDOWN                       "כמה זמן משבצת אטית ממוחזרת נשארת נענשת בציונים ב\r\n\r\nתור לפני שהיא יכולה להתחרות שוב כרגיל."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BOOST                "מוסיף ציון תור נוסף עבור לקוחות המבקשים קבצים עם יחס העלאה היסטורי נמוך.\r\n\r\nהשתמש בו אם אתה רוצה להעדיף קבצים שקיבלו העלאה מועטה יחסית עד כה."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_THRESHOLD            "גזירה של יחס העלאה שמתחתיו חלה\r\n\r\nהגברת היחס הנמוכה של הציון בתור."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BONUS                "ציון תור אפקטיבי נוסף מוענק כאשר\r\n\r\nהפעלת הגברת היחס הנמוכה מופעלת."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_ID_DIVISOR                 "מחלק עונשים מוחל על לקוחות LowID במהלך ניקוד בתור העלאה.\r\n\r\nערכים גבוהים יותר מפחיתים את העדיפות LowID בצורה אגרסיבית יותר. הגדר 1 כדי להשבית את העונש הנוסף LowID."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER               "מגביל כמה סשן העלאה אחד יכול להעביר לפני ש-eMuleBB שוקל לסובב את המשבצת הזו.\r\n\r\nסיבוב מתרחש רק כאשר לקוח אחר באמת צריך את המשבצת."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_DISABLED      "אין למחזר הפעלות העלאה על סמך כמות המטען שהועבר."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT       "הגבל כל הפעלת העלאה לאחוז מגודל הקובץ המבוקש."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT_VALUE "האחוז בשימוש כאשר מגבלת העברת ההפעלה מוגדרת כחלק מגודל הקובץ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B          "הגבל כל הפעלת העלאה לכמות MiB קבועה ללא קשר לגודל הקובץ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B_VALUE    "כמות MiB מוחלטת בשימוש כאשר מגבלת העברת ההפעלה מוגדרת כגודל קבוע."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TIME_LIMIT             "משך מקסימלי של הפעלת העלאה אחת לפני eMuleBB שוקל לסובב את המשבצת.\r\n\r\nהגדר 0 כדי להשבית את מגבלת הזמן."
    IDS_TWEAKS_TT_A4_AF_SAVE_CPU                               "מפחית בדיקות מקור חוזרות של A4AF (Asked For Another File) כדי לחסוך זמן CPU.\r\n\r\nשימושי בלקוחות עסוקים, אבל זה יכול להפוך את החלפת המקור של אותו לקוח לפחות להוטה."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_NEVER                      "אין לחלץ מטא נתונים מקבצים.\r\n\r\nהאפשרות הקלה ביותר. השתמש בו אם אתה לא רוצה בדיקה של מטא נתונים ברקע."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_ID3_LIB                    "חלץ מטא נתונים רק דרך נתיב ספריית ID3 עבור קובצי אודיו MPEG.\r\n\r\nברירת מחדל מאוזנת עבור תגי מוזיקה בסיסיים ללא בדיקת מדיה רחבה יותר."
    IDS_TWEAKS_TT_PREVIEW_ON_ICON_DBL_CLK                      "לחיצה כפולה על סמל קובץ פותחת תצוגה מקדימה במקום\r\n\r\nפעולת ברירת המחדל הרגילה."
    IDS_TWEAKS_TT_EXTRA_PREVIEW_WITH_MENU                      "מציג פקודות תצוגה מקדימה דרך תפריט ייעודי לפעולת תצוגה מקדימה במקום רק לחשוף את פעולת התצוגה המקדימה הישירה הפשוטה יותר.\r\n\r\nשימושי אם אתה רוצה אפשרויות תצוגה מקדימה מפורשות יותר בתפריט ההקשר של רשימת ההורדות."
    IDS_TWEAKS_TT_SHOW_ACTIVE_DOWNLOADS_BOLD                   "מצייר העברת הורדות באופן פעיל ברשימת ההורדות.\r\n\r\nויזואלי לחלוטין. הפעל אותו אם אתה רוצה פריטים פעילים יבלוט בצורה ברורה יותר."
    IDS_TWEAKS_TT_USE_SYSTEM_FONT_FOR_MAIN_CONTROLS            "משתמש בגופן ממשק המשתמש הרגיל Windows עבור פקדים ראשיים ותצוגות רשימה במקום הגדרת הגופן המותאמת אישית של eMuleBB.\r\n\r\nשימושי אם אתה מעדיף טקסט בעל מראה מקורי או זקוק לתאימות טובה יותר עם הגדרות גופן המערכת שלך."
    IDS_TWEAKS_TT_FILTER_LANI_PS                               "מתעלם מכתובות שרת ולקוח מטווחים פרטיים/LAN.\r\n\r\nמומלץ: מופעל. כך נמנע מניסיון להשתמש בכתובות עמית שאינן ניתנות לניתוב מהרשת הציבורית."
    IDS_TWEAKS_TT_GEO_LOCATION_CHECK_DAYS                      "באיזו תדירות eMuleBB בודק תוכן מסד נתונים מעודכן של מיקום גיאוגרפי.\r\n\r\nהגדר 0 כדי להשבית בדיקות עדכונים אוטומטיות. ערכים גדולים יותר מפחיתים את פעילות רענון הרקע."
    IDS_TWEAKS_TT_VERBOSE                                      "מתג ראשי עבור פקדי הרישום המילוליים למטה.\r\n\r\nהשבת אותו לשימוש רגיל. אפשר את זה רק בזמן חקירת בעיה ספציפית."
    IDS_TWEAKS_TT_FULL_VERBOSE                                 "מתעד את המעקב המלא הזמין ביותר כאשר רישום מילולי מופעל.\r\n\r\nזה יכול להיות רועש מאוד ויש להשתמש בו רק עבור פתרון בעיות ממוקד."
    IDS_TWEAKS_TT_LOG_LEVEL                                    "סף מילולית עבור פלט יומן אבחון.\r\n\r\nרמות גבוהות יותר מתעדות יותר פרטים אך יוצרות יותר רעש."
    IDS_TWEAKS_TT_DEBUG2_DISK                                  "כותב פלט אבחון מילולי לדיסק במקום לשמור אותו חולף.\r\n\r\nשימושי כאשר אתה זקוק למעקב אחר באגים מתמשך, אך הוא מגביר את פעילות הדיסק."
    IDS_TWEAKS_TT_DEBUG_SOURCE_EXCHANGE                        "יומן מנות והחלטות הקשורות לחילופי מקור.\r\n\r\nאפשרות אבחון מיוחדת. אפשר את זה רק בזמן ניפוי באגים בהתנהגות גילוי מקור."
    IDS_TWEAKS_TT_LOG_BANNED_CLIENTS                           "מתעד מתי עמיתים נאסרים ומדוע.\r\n\r\nשימושי להתעללות או אבחנה חיובית שגויה, אבל רועש מדי לפעולה רגילה."
    IDS_TWEAKS_TT_LOG_RATING_DESC_RECEIVED                     "רשומות קיבלו הערות, תיאורים ודירוגים של קבצים.\r\n\r\nשימושי לאיתור באגים בזרימת מטא נתונים, אך בדרך כלל אין צורך."
    IDS_TWEAKS_TT_LOG_SECURE_IDENT                             "מתעד אימות מזהה מאובטח ובדיקות זהות קשורות.\r\n\r\nשימושי לפתרון בעיות אמון/אימות."
    IDS_TWEAKS_TT_LOG_FILTERED_I_PS                            "מתעד כאשר IP מסנן או התעלמות לוגיקה מפיל כתובות עמיתים או שרתים.\r\n\r\nשימושי לאבחון מדוע חלק מהעמיתים נדחים."
    IDS_TWEAKS_TT_LOG_FILE_SAVING                              "רשומות שמירות של נתונים מתמשכים כגון קבצים ידועים, זיכויים ומצב קשור.\r\n\r\nשימושי לאיתור באגים מתמשך, אך מיותר לשימוש רגיל."
    IDS_TWEAKS_TT_LOG_A4_AF                                    "מתעד A4AF (בקשה לקובץ אחר) פעילות של הקצאת מקור מחדש.\r\n\r\nאפשרות אבחון מיוחדת של מנהל הורדות."
    IDS_TWEAKS_TT_LOG_UL_DL_EVENTS                             "מתעד שינויים במחזור החיים של העלאה-חריץ והורדה.\r\n\r\nשימושי בעת אבחון נטישת תור, סיבוב חריץ או מעברי מצב העברה."
    IDS_TWEAKS_TT_U_PN_P                                       "הגדרות מיפוי אוטומטי של יציאות נתב עבור קישוריות נכנסת.\r\n\r\nרוב המשתמשים צריכים להשאיר את הקבוצה הזו בברירות מחדל אוטומטיות, אלא אם כן סביבת הנתב שלהם דורשת משהו ספציפי."
    IDS_TWEAKS_TT_SHAREE_MULE_MULTI_USER                       "כל משתמש Windows מקבל תצורה נפרדת של eMuleBB ומצב הורדה נפרד.\r\n\r\nConfig חי תחת Local AppData, והורדות משתמשות בתיקיית ההורדות של המשתמש עצמו. ההתאמה הטובה ביותר למחשבים משותפים שבהם משתמשים לא צריכים לשתף נתוני eMuleBB."
    IDS_TWEAKS_TT_SHAREE_MULE_PUBLIC_USER                      "כל משתמשי Windows חולקים את אותה תצורה והורדות eMuleBB.\r\n\r\nConfig חי תחת ProgramData, והורדות משתמשות בהורדות ציבוריות. השתמש בזה רק אם המכשיר חולק בכוונה מצב eMuleBB נפוץ אחד."
    IDS_TWEAKS_TT_SHAREE_MULE_OLD_STYLE                        "שמור את התצורה וההורדות בספריית התוכנית, תוך שימוש בפריסה הישנה יותר. מצב תאימות\r\n\r\nLegacy בלבד. בדרך כלל זו הבחירה הכי פחות רצויה ב-Windows המודרנית."
    IDS_CONNECTION_TT_AUTOCONNECT                              "הפעלה אוטומטית של הרשתות המופעלות כאשר eMuleBB מופעלת.\r\n\r\nמומלץ: מופעל לשימוש רגיל ללא השגחה. השבת אותו רק אם אתה רוצה להתחבר ידנית בכל הפעלה."
    IDS_CONNECTION_TT_RECONN                                   "מנסה שוב חיבורי שרת לאחר ניתוקים או ניסיונות כושלים.\r\n\r\nמומלץ: מופעל אם אתה משתמש ברשת השרת eD2K. אין לזה השפעה כאשר רשת שרת מושבתת."
    IDS_CONNECTION_TT_SHOWOVERHEAD                             "מציג תקורה של פרוטוקול בנפרד בקצבי ההעברה והסטטיסטיקה.\r\n\r\nהפעל את זה אם אתה רוצה תצוגה כנה יותר של תעבורה קווית. השאר את זה אם אתה מעדיף מספרים פשוטים יותר של מטען בלבד."
    IDS_CONNECTION_TT_PORT                                     "יציאת TCP הראשית המשמשת לחיבורי לקוח נכנסים.\r\n\r\nשנה אותה רק כאשר אתה מגדיר מחדש בכוונה את כללי חומת האש או הנתב. לאחר שינוי זה, בדוק מחדש את הקישוריות."
    IDS_CONNECTION_TT_UDPPORT                                  "יציאת UDP המשמשת עבור Kad ותכונות אחרות הנעזרות ב-UDP.\r\n\r\nמומלץ: השאר אותה מופעלת ונגישה, אלא אם כן אתה רוצה להשבית בכוונה רשת מבוססת UDP."
    IDS_CONNECTION_TT_MAXSOURCEPERFILE                         "הגבלה קשה לכמה מקורות מרוחקים eMuleBB שומר לכל הורדה.\r\n\r\nערכים גבוהים יותר יכולים לשפר את הזמינות של קבצים נדירים אך לעלות יותר זיכרון ותעבורת ניהול מקור. השתמש בערכים מתונים אלא אם יש לך סיבה ספציפית להעלות אותם."
    IDS_CONNECTION_TT_MAXCON                                   "גבול עליון לחיבורים בו-זמניים eMuleBB עשוי להישאר פתוח.\r\n\r\nערכים גבוהים יותר אינם טובים יותר באופן אוטומטי. השאר את זה ליד ברירת המחדל המכווננת אלא אם כן אתה מאבחן מגבלה ספציפית ברשת."
    IDS_CONNECTION_TT_DOWNLOAD_CAP                             "הקיבולת המוגדרת במורד הזרם ב-KiB/s. eMuleBB משתמש בזה בתור התייחסות עליונה להחלטות מחוונים ורוחב פס.\r\n\r\nהגדר אותו קרוב לקצב השורה השמיש האמיתי שלך, לא למקסימום השיווק."
    IDS_CONNECTION_TT_UPLOAD_CAP                               "הקיבולת המוגדרת שלך במעלה הזרם ב-KiB/s. eMuleBB משתמש בזה בתור התייחסות עליונה לבקרת העלאה.\r\n\r\nהגדר אותו קרוב לקצב ההעלאה הממושך והשמיש האמיתי של הקו שלך."
    IDS_CONNECTION_TT_NETWORK_ED2_K                            "מאפשר את רשת השרתים הקלאסית eD2K.\r\n\r\nהשאר אותה מופעלת אם אתה עדיין משתמש בגילוי מקור מבוסס שרת. השבת אותו רק אם אתה רוצה בכוונה פעולה Kad בלבד."
    IDS_CONNECTION_TT_NETWORK_KADEMLIA                         "מאפשר את הרשת המבוזרת Kad.\r\n\r\nמומלץ: מופעלת לשימוש מודרני. זה מחייב את יציאת UDP כדי להישאר פעילה."
    IDS_CONNECTION_TT_PREF_UPNPONSTART                         "ניסיונות מיפוי אוטומטי של יציאות NAT בעת האתחול עבור יציאות TCP ו-UDP המוגדרות.\r\n\r\nמומלץ: מופעל כאשר הנתב שלך תומך ב-UPnP או PCP/NAT-PMP. השבת אותו אם אתה מעביר יציאות באופן ידני."
    IDS_CONNECTION_TT_RANDOMIZE_PORTS_ON_STARTUP               "בוחר ביציאות האזנה חדשות TCP ו-UDP באתחול לפני הפעלת מיפוי יציאות אוטומטי.\r\n\r\nהאופציה משתמשת בטווח היציאות האקראיות הקיים של eMuleBB ומשאירה את UDP מושבתת כאשר יציאת UDP מושבתת."
    IDS_CONNECTION_TT_UDPDISABLE                               "משבית את יציאת UDP של eMuleBB ולכן משבית תכונות תלויות UDP כגון רשת Kad.\r\n\r\nמומלץ: השאר זאת כבוי אלא אם כן עליך להפעיל TCP בלבד עבור סביבת רשת ספציפית מאוד."
    IDS_CONNECTION_TT_STARTTEST                                "מפעיל את מבחן הקישוריות החיצונית עבו\r\n\r\nר יציאות TCP ו-UDP המוגדרות כעת."
    IDS_CONNECTION_TT_BIND_INTERFACE                           "שם ממשק רשת Windows אופציונלי המשמש לקשירת שקע P2P.\r\n\r\nMatch הוא לפי שם ממשק ידידותי, לא מספר מתאם. השינויים נכנסים לתוקף לאחר הפעלה מחדש."
    IDS_CONNECTION_TT_BIND_ADDRESS                             "כתובת IPv4 אופציונלית המשמשת לקשירת שקע P2P.\r\n\r\nהשאר אותה ריקה כדי להשתמש ב-IPv4 הראשון בממשק שנבחר, או בחירת ניתוב ברירת המחדל כאשר לא נבחר ממשק."
    IDS_WEBSERVER_TT_WEBBINDADDR                               "כתובת איגד מקומית עבור WebServer ו-REST API המובנים.\r\n\r\nהשאר אותה ריקה או כ-0.0.0.0 כדי להאזין בכל הממשקים. הגדר IPv4 ספציפי רק אם אתה רוצה בכוונה להגביל את המקום שבו השירות מאזין."
    IDS_WEBSERVER_TT_WSAPIKEY                                  "מפתח REST API פשוט בשימוש על ידי לקוחות בכותרת X-API-Key.\r\n\r\nמומלץ: שמור את הערך האקראי שנוצר אלא אם כן אתה צריך אסימון ספציפי. לכל מי שיש לו מפתח זה יש גישה מלאה ל-API."
    IDS_WEBSERVER_TT_WSUPNP                                    "כולל את יציאת WebServer במיפוי NAT ​​אוטומטי כאשר UPnP או PCP/NAT-PMP מופעלים.\r\n\r\nהפעל זאת רק אם אתה רוצה בכוונה להגיע ל-Web UI או REST API דרך מיפוי הנתב שלך."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD                          "גודל מקסימלי להעלאת קובץ בודד המתקבל על ידי ה-WebServer ב-MiB.\r\n\r\nהשתמש בערך קטן עבור שלט רחוק רגיל. הרם אותו רק אם לקוחות אינטרנט מהימנים צריכים להעלות קבצים גדולים יותר."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD_LBL                      "גודל מקסימלי להעלאת קובץ בודד המתקבל על ידי ה-WebServer ב-MiB.\r\n\r\nהשתמש בערך קטן עבור שלט רחוק רגיל. הרם אותו רק אם לקוחות אינטרנט מהימנים צריכים להעלות קבצים גדולים יותר."
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS                             "רשימת ההיתרים IPv4 מופרדת בנקודה-פסיק עבור לקוחות WebServer.\r\n\r\nהשאר ריק כדי לאפשר כל כתובת מרוחקת שיכולה להגיע ל-WebServer. דוגמה: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS_LBL                         "רשימת ההיתרים IPv4 מופרדת בנקודה-פסיק עבור לקוחות WebServer.\r\n\r\nהשאר ריק כדי לאפשר כל כתובת מרוחקת שיכולה להגיע ל-WebServer. דוגמה: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWHILEVFUNC                         "מאפשר פעולות אינטרנט אדמיניסטרטיביות ברמה גבוהה שיכולות לשנות את מצב זמן הריצה בצורה אגרסיבית יותר.\r\n\r\nמומלץ: השאר את זה כבוי, אלא אם כן אתה צריך במפורש פעולות אלה מלקוחות אדמין מהימנים."
    IDS_WEBSERVER_TT_WEB_HTTPS                                 "משרת את Web UI ו-REST API על HTTPS באמצעות האישור והמפתח המוגדרים.\r\n\r\nמומלץ: מופעל בכל פעם שאתה חושף את ה-WebServer מעבר למחשב המקומי."
    IDS_NOTIFY_TT_CB_TBN_USESOUND                              "מנגן קובץ WAV מותאם אישית עבור התראות בשורת המשימות.\r\n\r\nהשתמש בזה אם אתה רוצה התראה קולית. עזוב אותו אם די בחלונות קופצים שקטים או דיבור."
    IDS_NOTIFY_TT_CB_TBN_USESPEECH                             "משתמש בטקסט לדיבור עבור התראות בשורת המשימות כאשר מנוע דיבור זמין.\r\n\r\nשימושי במערכות ללא השגחה שבהן קל יותר להבחין בהתראות מדוברות מאשר בצלילים."
    IDS_NOTIFY_TT_CB_TBN_POP_ALWAYS                            "מציג חלון קופץ עבור כל הודעת צ'אט נכנסת במקום רק הראשונה.\r\n\r\nהפעל זאת אם אינך רוצה שהודעות צ'אט עוקבות ישארו בשקט."
    IDS_NOTIFY_TT_CB_TBN_USEWINDOWSTOAST                       "משתמש בהתראות Windows טוסט במקום בחלון הקופץ המותאם אישית של eMuleBB.\r\n\r\nאם Windows דוחה הודעת טוסט, eMuleBB חוזר לחלון הקופץ המותאם אישית."
    IDS_NOTIFY_TT_TBN_DISPLAYMODE                              "בוחר כיצד eMuleBB מציג התראות קופצות מופעלות.\r\n\r\nWindows טוסט הוא ברירת המחדל. אם Windows דוחה הודעת טוסט, כולל כאשר eMuleBB פועל כמנהל, eMuleBB נופל בחזרה לבלון המגש הקלאסי."
    IDS_NOTIFY_TT_CB_ENABLENOTIFICATIONS                       "מאפשר הודעות דוא""ל יוצאות עבור האירועים המוגדרים.\r\n\r\nאפשר זאת רק אם כבר הגדרת שרת SMTP וכתובות עובדים."
    IDS_NOTIFY_TT_SMTPSERVER                                   "פותח את תצורת שרת ה-SMTP המשמשת את הודעות האימייל.\r\n\r\nאתה צריך את זה רק אם הודעות דוא""ל מופעלות."
    IDS_BIND_STARTUP_INTERFACE_NOT_FOUND_FMT                   "הרשת מושבתת עבור הפעלה זו מכיוון שממשק החיבור שנבחר אינו זמין עוד: %s"
    IDS_BIND_STARTUP_INTERFACE_AMBIGUOUS_FMT                   "הרשת מושבתת עבור הפעלה זו מכיוון ששם ממשק החיבור שנבחר תואם למספר מתאמים חיים: %s"
    IDS_BIND_STARTUP_INTERFACE_NO_ADDRESS_FMT                  "הרשת מושבתת עבור הפעלה זו מכיוון שלממשק החיבור שנבחר אין כתובת IPv4 שמישה: %s"
    IDS_BIND_STARTUP_INTERFACE_ADDRESS_MISSING_FMT             "הרשת מושבתת עבור הפעלה זו מכיוון שהאיגד שנבחר IP אינו קיים עוד בממשק שנבחר: %s"
    IDS_BIND_STARTUP_ADDRESS_MISSING_FMT                       "הרשת מושבתת עבור הפעלה זו מכיוון שהאיגד שנבחר IP אינו קיים עוד באף ממשק חי: %s"
    IDS_BIND_EXIT_INTERFACE_CHANGED_FMT                        "יוצא מ-eMuleBB מכיוון שממשק החיבור שנבחר שינה את הכתובת מ-%s ל-%s: %s"
    IDS_BIND_EXIT_INTERFACE_UNAVAILABLE                        "יוצא מ-eMuleBB מכיוון שממשק החיבור שנבחר אינו זמין עוד."
    IDS_BIND_STARTUP_DISABLED_PREFIX                           "הרשת מושבתת עבור הפעלה זו"
