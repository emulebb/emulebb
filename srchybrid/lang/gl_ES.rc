    IDS_BIND_ANY_INTERFACE                                     "Calquera interface"
    IDS_BIND_STATUS_ACTIVE_ANY                                 "Enlace P2P activo: Calquera interface."
    IDS_BIND_STATUS_ACTIVE_FMT                                 "Enlace P2P activo: %s"
    IDS_BIND_STATUS_INTERFACE_NOT_FOUND_FMT                    "Enlace P2P activo: Calquera interface. A interface gardada non está dispoñible: %s"
    IDS_BIND_STATUS_INTERFACE_AMBIGUOUS_FMT                    "Enlace P2P activo: Calquera interface. O nome da interface gardada é ambiguo: %s"
    IDS_BIND_STATUS_INTERFACE_NO_ADDRESS_FMT                   "Enlace P2P activo: Calquera interface. A interface gardada non ten enderezo IPv4 utilizable: %s"
