    IDS_ELEVATED_PS_TIMEOUT                                    "Esgotouse o tempo de espera da acción de PowerShell elevada."
    IDS_SEARCHPARAMS_NAME_LABEL                                "&Nome:"
    IDS_SEARCHPARAMS_TYPE_LABEL                                "&Tipo"
