    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "Kopiera eD2K-länkar till Urklipp (Kad)"
    IDS_SHUTTING_DOWN_EMULE                                    "Stänger av eMuleBB"
