    IDS_FRIEND_AUTHENTICATING                                  "احراز هویت دوست"
    IDS_BUNDLED_SCRIPT_MISSING                                 "اسکریپت eMuleBB همراه وجود ندارد: %s"
    IDS_ELEVATED_PS_TIMEOUT                                    "مهلت عملکرد PowerShell بالا به پایان رسید."
    IDS_SEARCHPARAMS_NAME_LABEL                                "&نام:"
    IDS_SEARCHPARAMS_TYPE_LABEL                                "&تایپ کنید"
    IDS_SEARCHPARAMS_METHOD_LABEL                              "&روش:"
    IDS_SEARCHPARAMS_START_BUTTON                              "&جستجو برو"
    IDS_SEARCHPARAMS_MORE_BUTTON                               "&بیشتر"
    IDS_SEARCHPARAMS_RESET_BUTTON                              "&بازنشانی کنید"
    IDS_SEARCHPARAMS_CANCEL_BUTTON                             "&لغو کنید"
    IDS_STATUS_BIND_IP_LABEL                                   "IP را ببندید"
    IDS_STATUS_PUBLIC_IP_LABEL                                 "عمومی IP"
    IDS_STATUS_NETWORK_ADDRESS_TOOLTIP_FMT                     "%s: %s | %s: %s"
    IDS_PREVIEW_REQUESTED_WAIT                                 "پیش نمایش درخواست شده - لطفا صبر کنید"
    IDS_SEARCH_INFOTIP_SOURCES                                 "منابع"
    IDS_SEARCH_INFOTIP_SERVERS                                 "سرورها"
    IDS_NO_MATCHING_ENTRY_FOUND                                "هیچ ورودی منطبقی یافت نشد."
    IDS_FATAL_NO_RICHEDIT                                      "خطای مرگبار: هیچ کتابخانه کنترلی Rich Edit پیدا نشد!"
    IDS_FATAL_KAD_UNICODE_TABLES                               "خطای مرگبار: بارگیری جداول کاراکتر یونیکد برای Kademlia انجام نشد!"
    IDS_KAD_UNICODE_MAP_NOT_INITIALIZED                        "نقشه حروف کوچک Kad یونیکد مقدار دهی اولیه نشده است!"
    IDS_TWEAKS_TT_CONDITIONAL_TCP_ACCEPT                       "ترجیح می دهد اتصالات TCP ورودی را فقط زمانی بپذیرد که مفید به نظر برسند.\r\n\r\nآن را در حالت پیش فرض قرار دهید مگر اینکه فشار اتصال را تشخیص دهید."
    IDS_TWEAKS_TT_MAX_CON5_SEC                                 "حداکثر تعداد اتصالات TCP جدید eMuleBB ممکن است در عرض پنج ثانیه باز شوند.\r\n\r\nمقادیر پایین تر در Windows و روترها ملایم تر است. آن را نزدیک به پیش‌فرض بگذارید مگر اینکه در حال تنظیم رفتار انفجاری اتصال باشید."
    IDS_TWEAKS_TT_MAX_HALF_OPEN                                "حد بالایی برای تلاش برای اتصال TCP خروجی نیمه باز.\r\n\r\nعمدتاً یک محافظ سازگاری است. پیش‌فرض معمولاً انتخاب درستی است، مگر اینکه در حال بررسی مشکلات راه‌اندازی TCP باشید."
    IDS_TWEAKS_TT_CONNECTION_TIMEOUT                           "چه مدت eMuleBB منتظر یک اتصال جدید است تا پیشرفت کند قبل از اینکه آن را شکست بخورد.\r\n\r\nمقادیر طولانی تر نسبت به شبکه های کند تحمل بیشتری دارند. مقادیر پیش فرض توصیه می شود."
    IDS_TWEAKS_TT_DOWNLOAD_TIMEOUT                             "چه مدت ممکن است منبع دانلود قبل از اینکه eMuleBB آن را متوقف کند بیکار بماند.\r\n\r\nQ منابع مرده را سریعتر پاک می کند، اما مقادیر بسیار پایین می تواند به همتایان کند آسیب برساند. پیش‌فرض را رها کنید مگر اینکه در حال عیب‌یابی استال هستید."
    IDS_TWEAKS_TT_SERVER_KEEP_ALIVE_TIMEOUT                    "هر چند وقت یکبار eMuleBB یک اتصال سرور غیرفعال را تازه می کند.\r\n\r\nاز دقیقه استفاده کنید. 0 را برای غیرفعال کردن keepalives تنظیم کنید. پیش فرض را رها کنید مگر اینکه مشکل قطع اتصال بیکار سرور خاصی را حل کنید."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_RESULTS                      "حداکثر تعداد نتایج درخواست شده از سرور eD2K برای یک جستجو.\r\n\r\nنزدیک به پیش فرض بمانید مگر اینکه دلیل خاصی داشته باشید."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_MORE_REQUESTS                "حداکثر تعداد صفحات نتیجه پیگیری eMuleBB درخواست های eD2K از جستجوی eD2K.\r\n\r\nمقادیر بالاتر می تواند نتایج بیشتری به همراه داشته باشد اما هزینه و ترافیک سرور و زمان بیشتری را به همراه دارد. مقادیر محافظه کارانه توصیه می شود."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_TOTAL                        "تعداد نتایج مورد نظر برای جستجوهای فایل Kad.\r\n\r\nمقادیر بالاتر به طور گسترده تری جستجو می کنند اما جستجوهای Kad را برای مدت طولانی تری زنده نگه می دارند. نزدیک به پیش فرض بمانید مگر اینکه بخواهید جستجوهای عمیق تری داشته باشید."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_TOTAL                     "تعداد نتایج مورد نظر برای جستجوهای کلیدواژه Kad.\r\n\r\nمقادیر بالاتر می تواند موارد منطبق را پیدا کند اما بار پرس و جو Kad و نویز UI را افزایش می دهد. پیش فرض معمولاً تعادل مناسب است."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_LIFETIME                     "حداکثر طول عمر یک جستجوی فایل Kad در چند ثانیه.\r\n\r\nفقط اگر عمداً می خواهید جستجوهای Kad طولانی تر باشد، آن را افزایش دهید."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_LIFETIME                  "حداکثر طول عمر یک جس\r\n\r\nتجوی کلمه کلیدی Kad در چند ثانیه."
    IDS_TWEAKS_TT_GENERAL_ADVANCED                             "رفتار پیشرفته عمومی که به طور کامل تحت شبکه، فایل،\r\n\r\nنمایشگر یا امنیت قرار نمی گیرد."
    IDS_TWEAKS_TT_HIDDEN_FILE                                  "رفتار مدیریت پیشرفته فایل، بازرسی پیش‌ن\r\n\r\nمایش، و گزینه‌های مرتبط با تاریخچه فایل."
    IDS_TWEAKS_TT_STORAGE_PERSISTENCE                          "حفاظت پیشرفته از فضای دیسک، بافر فا\r\n\r\nیل، و تنظیمات ماندگاری فراداده."
    IDS_TWEAKS_TT_HIDDEN_STARTUP                               "رفتار بازیابی راه‌اندازی پیشرفته.\r\n\r\nاین گزینه‌ها فقط بر روی این که چه پنجره‌های رابط کاربری با شروع eMuleBB برمی‌گردند، تأثیر می‌گذارند."
    IDS_TWEAKS_TT_HIDDEN_DISPLAY                               "تنظیمات صفحه نمایش، نوار وظیفه، سینی و اطلاعات بصری پیشرفته.\r\n\r\nاین گزینه ها فقط ارائه را تغییر می دهند، نه رفتار انتقال را."
    IDS_TWEAKS_TT_HIDDEN_SECURITY                              "گزینه‌های فیلتر و حفاظت پیشرفته برای مدیریت\r\n\r\nسخت‌گیرانه‌تر همتایان و پیام‌ها."
    IDS_TWEAKS_TT_LOGGING_GROUP                                "ثبت مداوم و کنترل‌های خروجی تشخیصی.\r\n\r\nاکثر این تنظیمات فقط در هنگام تشخیص مشکل مفید هستند."
    IDS_TWEAKS_TT_AUTO_TAKE_ED2K_LINKS                         "eMuleBB را به عنوان کنترل‌کننده پیش‌فرض برای پیوندهای ed2k:// ثبت می‌کند. اگر این دستگاه باید پیوندهای ed2k را به‌طور خودکار در eMuleBB باز کند،\r\n\r\nرا فعال کنید. اگر ابزار دیگری مالک آن انجمن باشد، آن را غیرفعال کنید."
    IDS_TWEAKS_TT_CREDIT_SYSTEM                                "از سیستم اعتباری معمولی eMule هنگام رتبه بندی مشتریان آپلود استفاده می کند.\r\n\r\nتوصیه می شود: فعال است. آن را فقط برای اشکال زدایی یا آزمایش های سازگاری عمدی غیرفعال کنید."
    IDS_TWEAKS_TT_YOUR_HOSTNAME                                "برچسب نام میزبان اختیاری eMuleBB گزارش می دهد ک\r\n\r\nه در آن متن هویت محلی شما نشان داده شده است."
    IDS_TWEAKS_TT_TXT_EDITOR                                   "زمانی که eMuleBB فایل‌های متنی مانند گزارش‌ها یا خروجی متن ایجاد شده را باز می‌کند، استفاده می‌شود.\r\n\r\nاگر ویرایشگر در PATH نیست، از یک مسیر کامل استفاده کنید. پیش فرض notepad.exe است."
    IDS_TWEAKS_TT_HIGHRES_TIMER                                "زمانی که eMuleBB در حال اجرا است، یک تایمر Windows با وضوح بالا درخواست می کند.\r\n\r\nپس از تغییر eMuleBB آن را مجددا راه اندازی کنید."
    IDS_TWEAKS_TT_ICH                                          "مدیریت هوشمند فساد را برای قطعات دانلود شده آسیب دیده فعال می کند.\r\n\r\nتوصیه می شود: فعال است. به جای بارگیری مجدد بیش از حد لازم، به بازیابی اطلاعات خوب در قسمت های خراب کمک می کند."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS                         "کنترل می‌کند که آیا پیش‌نمایش رسانه قبل از انجام کا\r\n\r\nمل بررسی‌های ایمنی پیش‌نمایش معمولی ارائه شود یا خیر."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_DISABLED                "از قوانین پیش نمایش محافظه کارانه معمولی استفاده کنید."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_ALLOW                   "پیش‌نمایش با بلوک‌های کوچک‌تر در دسترس پس از پاس شدن متادیتاهای معمولی و چک‌های پخش‌کننده مجاز است."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_FORCE                   "حتی زمانی که اولین بلوک وجود ندارد، پیش‌نمایش را ارائه دهید.\r\n\r\nفقط با پخش‌کننده‌هایی که می‌توانند رسانه ناقص را تحمل کنند، مانند VLC استفاده کنید."
    IDS_TWEAKS_TT_BEEP_ON_ERROR                                "هنگامی که eMuleBB خطاهای مهم را گزارش می دهد، صدای خطای سیستم را پخش می کند.\r\n\r\nبرای عیب یابی بدون مراقبت مفید است. اگر هشدارهای صوتی حواس‌تان را پرت می‌کنند، آن را غیرفعال کنید."
    IDS_TWEAKS_TT_SHOW_COPY_ED2K_LINK_CMD                      "منوهای زمینه فایل را تغییر می‌دهد تا یک فرمان مستقیم Copy ed2k Link را به جای اجرای استاندارد Show ed2k Link نشان دهد.\r\n\r\nاگر کپی کردن پیوندها گردش کار عادی شماست، آن را فعال کنید."
    IDS_TWEAKS_TT_SPARSE_PART_FILES                            "هنگامی که سیستم فایل از آنها پشتیبانی می کند، از فایل های پراکنده برای فایل های جزئی استفاده می کند.\r\n\r\nفقط در صورتی غیرفعال شود که رفتار پراکنده فایل باعث مشکل خاص سیستم فایل شود."
    IDS_TWEAKS_TT_FULL_ALLOC                                   "با شروع دانلود، اندازه کامل فایل هدف را روی دیسک از قبل اختصاص می دهد.\r\n\r\nآن را کنار بگذارید مگر اینکه تخصیص کامل را ترجیح دهید."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_CONFIG                   "حداقل فضای خالی رزرو شده در حجم میزبان فایل های پیکربندی eMuleBB.\r\n\r\nحداقل سخت:\r\n1 گیگابایت. اگر این حجم از حد مجاز کمتر شود، eMuleBB همه دانلودها را متوقف می‌کند و بلافاصله فایل‌های .part.met را ذخیره می‌کند."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_TEMP                     "حداقل فضای خالی رزرو شده برای هر حجم فایل های موقت میزبانی.\r\n\r\nحداقل سخت:\r\n5 گیگابایت. اگر هر یک از حجم محافظت شده کمتر از حد مؤثر خود باشد، eMuleBB همه دانلودها را متوقف می‌کند و بلافاصله فایل‌های .part.met را ذخیره می‌کند."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_INCOMING                 "حداقل فضای خالی رزرو شده برای هر حجمی که میزبان فایل‌های ورودی است، از جمله دایرکتوری‌های ورودی مخصوص دسته.\r\n\r\nحداقل سخت: 5 گیگابایت. اگر ورودی حجمی را با پیکربندی یا دما به اشتراک بگذارد، بزرگترین محدودیت در آن حجم برنده می‌شود و با نقض آن، همه دانلودها متوقف می‌شوند."
    IDS_TWEAKS_TT_PERF_LOG                                     "نمونه‌های بار و سربار دوره‌ای را برای ابزارهای نموداری خارجی می‌نویسد. فقط ویژگی \r\nQ\r\nOperator/debug. آن را خاموش کنید مگر اینکه به طور فعال فایل های تولید شده را مصرف کنید."
    IDS_TWEAKS_TT_COMMIT                                       "کنترل می کند که eMuleBB چگونه Windows را به شدت مجبور می کند تا داده های فایل ذخیره شده را روی دیسک تخلیه کند.\r\n\r\n«فقط در حالت خاموش شدن» پیش‌فرض متعادل است."
    IDS_TWEAKS_TT_COMMIT_NEVER                                 "فایل‌ها را به‌طور معمول بدون ا\r\n\r\nجبار فلاش کردن دیسک در سطح سیستم‌عامل ببندید."
    IDS_TWEAKS_TT_COMMIT_ON_SHUTDOWN                           "فقط زمانی که eMuleBB در حال بسته شدن است، یک دیسک در سطح سیستم عامل را اجباری کنید.\r\n\r\nپیش فرض توصیه می شود. ایمنی ماندگاری را در خروجی تمیز بدون نیاز به شستشوی اضافی در طول هر ذخیره بهبود می بخشد."
    IDS_TWEAKS_TT_COMMIT_ALWAYS                                "یک دیسک در سطح سیستم عامل را در هر مسیر ذخیره ای که از\r\n\r\nکمک کننده commit-close eMuleBB استفاده می کند، وادار کنید."
    IDS_TWEAKS_TT_EXTRACT_META_DATA                            "کنترل می کند که آیا eMuleBB ابرداده هایی مانند برچسب ها و مدت زمان رسانه را از فایل ها استخراج می کند یا خیر.\r\n\r\nبرای اطلاعات غنی تر فایل مفید است، اما بازرسی فایل پس زمینه را اضافه می کند. اگر می خواهید سبک ترین اسکن را داشته باشید، آن را غیرفعال کنید."
    IDS_TWEAKS_TT_GEO_LOCATION_ENABLED                         "IPهای همتا را به داده های مکان در سطح کشور برای نمایش حل می کند.\r\n\r\nکاملاً اطلاعاتی است. اگر به پرچم‌های کشور اهمیتی نمی‌دهید یا نمی‌خواهید پس‌زمینه تازه‌سازی شود، آن را غیرفعال کنید."
    IDS_TWEAKS_TT_CLOSE_U_PN_P_PORTS                           "نقشه‌برداری‌های روتر را در هنگام خروج تمیز می‌بندد وقتی از نقشه‌برداری خودکار NAT استفاده می‌شود.\r\n\r\nتوصیه می‌شود: فعال است. فقط در صورتی آن را غیرفعال کنید که عمداً می خواهید نگاشت ها باقی بماند."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE                          "نحوه انجام نگاشت خودکار NAT توسط eMuleBB را انتخاب می کند.\r\n\r\nتوصیه می شود: خودکار. که ابتدا UPnP IGD را امتحان می کند و در صورت نیاز به PCP/NAT-PMP برمی گردد."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_AUTOMATIC                "حالت پیشنهادی ابتدا UPnP IGD را امتحان کنید، سپس اگر نقشه برداری ناموفق بود به PCP/NAT-PMP برگردید."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_IGD_ONLY                 "فقط از نقشه برداری UPnP IGD استفاده کنید. اگر رفتار کاملاً کلاسیک UPnP را می خواهید، این را انتخاب کنید."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_PCP_NAT_PMP_ONLY         "فقط از نقشه برداری PCP/NAT-PMP استفاده کنید. این را فقط در صورتی انتخاب کنید که محیط روتر شما به وضوح آن را ترجیح می دهد."
    IDS_TWEAKS_TT_FILE_BUFFER_TIME_LIMIT                       "حداکثر سن داده‌های فایل بافر شده قبل از اینکه eMuleBB آن را روی دیسک تخلیه کند.\r\n\r\nمقادیر بالاتر می تواند ریزش دیسک را کاهش دهد. پیش فرض معمولاً یک سازش خوب است."
    IDS_TWEAKS_TT_FILE_BUFFER_SIZE                             "اندازه بافر نوشتن در هر فایل که قبل از شستشوی داده های دانلود روی دیسک استفاده می شود.\r\n\r\nمقادیر متوسط ​​را حفظ کنید، مگر اینکه برای تنظیم ذخیره سازی خاصی تنظیم کنید."
    IDS_TWEAKS_TT_QUEUE_SIZE                                   "اندازه هدف صف انتظار آپلود.\r\n\r\nمقادیر بالاتر به مشتریان بیشتری اجازه می‌دهد منتظر بمانند، اما استفاده از حافظه و سربار مدیریت را اضافه می‌کنند. مقادیر پیش فرض برای اکثر کاربران توصیه می شود."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LISTS                      "قالب سفارشی تاریخ/زمان مورد استفاده در نماهای لیست.\r\n\r\nبرای استفاده از قالب بندی پیش فرض عادی، آن را خالی بگذارید. آن را تنها در صورتی تغییر دهید که می‌خواهید یک سبک مُهر زمانی سفارشی خاص داشته باشید."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT                             "فرمت سفارشی تاریخ/زمان مورد استفاده توسط نمایشگرهای فایل عمومی و جزئیات مشابه.\r\n\r\nاز نشانه های قالب بندی CTtime استفاده می کند. آن را خالی نگه دارید؛ توکن های نامعتبر می توانند مهر زمانی گیج کننده ای ایجاد کنند."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LOG                        "فرمت سفارشی تاریخ/زمان مورد استفاده در خطوط گزارش و خروجی وضعیت گزارش مانند.\r\n\r\nآن را مختصر نگه دارید تا خطوط گزارش خوانا بمانند."
    IDS_TWEAKS_TT_ICON_FLASH_ON_NEW_MESSAGE                    "هنگامی که یک پیام چت جدید می رسد، نماد سینی را چشمک می زند.\r\n\r\nصرفاً یک اولویت اعلان است. اگر می خواهید پیام ها در حالی که eMuleBB به حداقل رسیده است برجسته شوند، آن را فعال کنید."
    IDS_TWEAKS_TT_INSPECT_ALL_FILE_TYPES                       "همچنین مسیر بازرسی گران قیمت به سبک MediaInfo را برای انواع فایل‌هایی که قبلاً به عنوان صوتی یا تصویری طبقه‌بندی نشده‌اند، اجرا کنید.\r\n\r\nاگر می‌خواهید اطلاعات فایل غنی‌تری برای فایل‌های غیرمعمول یا دارای برچسب اشتباه بررسی شود، آن را فعال کنید. برای بازرسی فقط فایل‌های صوتی/تصویری احتمالی و کاهش کار بازرسی پس‌زمینه، آن را کنار بگذارید."
    IDS_TWEAKS_TT_RE_BAR_TOOLBAR                               "از محفظه نوار ابزار اصلی قدیمی‌تر به سبک میلگرد به جای طرح‌بندی ساده‌تر نوار ابزار ساده‌تر استفاده می‌کند.\r\n\r\nفقط در صورتی که نمایش نوار ابزار قدیمی را ترجیح می دهید آن را فعال کنید."
    IDS_TWEAKS_TT_SHOW_UP_DOWN_ICON_IN_TASKBAR                 "نماد سرعت بارگذاری/دانلود ترکیبی را در ناحیه اعلان نوار وظیفه نشان می‌دهد.\r\n\r\nکاملاً بصری. اگر می‌خواهید قسمت سینی تمیزتری داشته باشید، آن را غیرفعال کنید."
    IDS_ALWAYS_SHOW_TRAY_ICON                                  "همیشه نماد سینی نشان داده شود"
    IDS_TWEAKS_TT_ALWAYS_SHOW_TRAY_ICON                        "هنگامی که eMuleBB در حال اجرا است، نماد eMuleBB را در ناحیه اعلان Windows قابل مشاهده نگه می دارد.\r\n\r\nاعلان‌های بالون سینی کلاسیک و کوچک کردن به سینی همچنان می‌توانند نماد سینی را در صورت غیرفعال شدن مجبور به مشاهده کنند."
    IDS_TWEAKS_TT_SHOW_VERTICAL_HOUR_MARKERS                   "نشانگرهای راهنمای ساعتی را در نمودارهای آمار بلند مدت ترسیم می کند.\r\n\r\nبرای خواندن الگوهای ترافیک مبتنی بر زمان مفید است. اگر به هم ریختگی نمودار کمتری ترجیح می دهید، آن را غیرفعال کنید."
    IDS_TWEAKS_TT_FORCE_SPEEDS_TO_KB                           "نمایشگرهای نرخ را مجبور به استفاده از واحدهای سبک KB/s به جای مقیاس‌بندی خودکار به واحدهای بزرگتر می‌کند. اگر واحدهای آشنا ثابت را ترجیح می‌دهید،\r\n\r\nآن را فعال کنید. برای نمایشگرهای با سرعت زیاد خواناتر، آن را خاموش بگذارید."
    IDS_TWEAKS_TT_REARRANGE_KAD_SEARCH_KEYWORDS                "عبارت‌های جستجوی کلیدواژه Kad را مجدداً ترتیب می‌دهد تا ابتدا یک شکل جستجوی مفیدتر را امتحان کند.\r\n\r\nترفند رفتار جستجوی پیشرفته. آن را در حالت پیش فرض قرار دهید مگر اینکه رفتار جستجوی Kad را عمدا تنظیم کنید."
    IDS_TWEAKS_TT_MESSAGE_FROM_VALID_SOURCES_ONLY              "پیام‌ها را فقط از طرف همتایان خود می‌پذیرد که از قبل مانند منابع معتبر برای انتقال‌های شما به نظر می‌رسند.\r\n\r\nاگر می خواهید خط مشی پیام سخت تری داشته باشید، آن را فعال کنید."
    IDS_TWEAKS_TT_MAX_CHAT_HISTORY_LINES                       "حداکثر تعداد خطوط تاریخچه در هر چت یا نمایش کانال IRC حفظ می شود.\r\n\r\nمقادیر بالاتر زمینه بیشتری را حفظ می کند اما از حافظه بیشتری استفاده می کند و می تواند چت های شلوغ را کندتر کند."
    IDS_TWEAKS_TT_MAX_MESSAGE_SESSIONS                         "حداکثر تعداد جلسات پیام همتا در یک بار حفظ می شود.\r\n\r\nمقادیر بالاتر مکالمات بیشتری را در دسترس نگه می دارد، اما استفاده از حافظه را افزایش می دهد. پیش فرض محافظه کارانه است."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP                            "وقتی eMuleBB با یک خرابی کنترل نشده مواجه می شود، ایجاد خرابی را کنترل می کند.\r\n\r\nآنها را فقط با توسعه دهندگان قابل اعتماد به اشتراک بگذارید."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_DISABLED                   "فایل های خرابی را ایجاد نکنید."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_PROMPT                     "قبل از نوشتن یک خرابی در زمان وقوع خرابی بپرسید."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_ALWAYS                     "هنگامی که یک خرابی رخ می دهد،\r\n\r\nبه طور خودکار یک خرابی ایجاد کنید."
    IDS_TWEAKS_TT_MAX_LOG_FILE_SIZE                            "حداکثر اندازه هر فایل گزارش روی دیسک در KiB.\r\n\r\nUse 0 بدون محدودیت چرخش. مقادیر بسیار بزرگ تاریخچه بیشتری را حفظ می کنند اما فضای دیسک بیشتری را مصرف می کنند."
    IDS_TWEAKS_TT_MAX_LOG_BUFFER                               "حداکثر بافر نمایش گزارش در حافظه در KiB.\r\n\r\nمقادیر بالاتر سابقه گزارش قابل مشاهده بیشتری را حفظ می کند اما از حافظه بیشتری استفاده می کند و می تواند نمایش های گزارش بسیار شلوغ را کاهش دهد."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT                              "کدگذاری برای فایل‌های گزارش روی دیسک تازه باز شده استفاده می‌شود.\r\n\r\nتغییر این مورد زمانی که گزارش‌ها از قبل باز هستند ادامه دارد، اما قالب جدید پس از باز شدن مجدد فایل گزارش یا راه‌اندازی مجدد eMuleBB استفاده می‌شود."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UNICODE                      "گزارش ها را به صورت UTF-16 Unicode بنویسید. این پیش‌فرض قدیمی است و متن Windows را به طور گسترده حفظ می‌کند."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UTF8                         "گزارش ها را به صورت UTF-8 بنویسید. برای ابزارهایی که انتظار فایل های متنی مدرن UTF-8 را دارند مفید است."
    IDS_TWEAKS_TT_LOG2_DISK                                    "گزارش نرم‌افزار نرم‌افزار را به جای اینکه فقط در حافظه نگه دارد، روی دیسک می‌نویسد.\r\n\r\nآن را رها کنید مگر اینکه لاگ های مداوم بخواهید."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT                         "فرمت خروجی برای نمونه‌های ثبت عملکرد.\r\n\r\nCSV آسان‌ترین بازرسی دستی است. MRTG فایل های sidecar را برای ابزارهای نموداری می نویسد که انتظار ورودی به سبک MRTG را دارند."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_CSV                     "یک فایل گزارش عملکرد CSV با بار بار و نمونه های سربار دارای مهر زمانی بنویسید."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_MRTG                    "داده‌های MRTG را بنویسید و فایل‌های سربار کناری را که از مسیر پایه پیکربندی شده مشتق شده‌اند، بنویسید."
    IDS_TWEAKS_TT_PERF_LOG_FILE                                "مسیر فایل پایه برای ثبت عملکرد.\r\n\r\nبرای استفاده از فایل پیش‌فرض در فهرست پیکربندی eMuleBB، آن را خالی بگذارید. حالت MRTG فایل های _data و _overhead را از این مسیر استخراج می کند."
    IDS_TWEAKS_TT_PERF_LOG_INTERVAL                            "فاصله نمونه برداری برای ثبت عملکرد در دقیقه.\r\n\r\nاز 1..1440 استفاده کنید."
    IDS_TWEAKS_TT_VERBOSE_GROUP                                "کنترل‌های ثبت تشخیصی اضافی برای عیب‌یابی عمیق.\r\n\r\nاین گزینه‌ها برای اشکال‌زدایی هستند، نه عملکرد عادی. آنها را کنار بگذارید مگر اینکه در حال بررسی موضوع خاصی باشید."
    IDS_TWEAKS_TT_RESTORE_LAST_MAIN_WND_DLG                    "آخرین صفحه پنجره اصلی انتخاب شده را در هنگام راه اندازی بازیابی می کند.\r\n\r\nاگر می خواهید eMuleBB دوباره از جایی که کار را متوقف کرده اید باز شود، آن را فعال کنید."
    IDS_TWEAKS_TT_RESTORE_LAST_LOG_PANE                        "آخرین صفحه گزارش انتخاب ش\r\n\r\nده را در هنگام راه اندازی بازیابی می کند."
    IDS_TWEAKS_TT_KEEP_UNAVAILABLE_FIXED_SHARED_DIRS           "دایرکتوری های مشترک پیکربندی شده دستی را حتی زمانی که در حال حاضر در دسترس نیستند در لیست نگه می دارد.\r\n\r\nاگر می‌خواهید پوشه‌های گمشده به‌طور تهاجمی هرس شوند، آن را غیرفعال کنید."
    IDS_TWEAKS_TT_PARTIALLY_PURGE_OLD_KNOWN_FILES              "به پاکسازی تهاجمی‌تر ورودی‌های قدیمی در تاریخچه فایل‌های شناخته شده اجازه می‌دهد.\r\n\r\nپیش‌فرض را رها کنید مگر اینکه تاریخچه کمتری بخواهید."
    IDS_TWEAKS_TT_DETECT_TCP_ERROR_FLOODER                     "خطاهای تکراری TCP را شناسایی می کند که ممکن است نشان دهنده همتایان سوء استفاده یا شکسته باشد.\r\n\r\nتوصیه می شود: فعال است. فقط در صورت تشخیص مثبت کاذب آن را غیرفعال کنید."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_INTERVAL_MINUTES           "پنجره زمانی مورد استفاده برای تشخیص خطا-سیل TCP.\r\n\r\nپنجره های کوتاهتر سریعتر واکنش نشان می دهند. پنجره های بلندتر حساسیت کمتری دارند. مقادیر پیش فرض توصیه می شود."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_THRESHOLD                  "تعداد خطاهای TCP در فاصله زمانی که مدیریت flooder را فعال می کند.\r\n\r\nمقادیر پایین تر سختگیرانه تر هستند. فقط در صورتی آن را افزایش دهید که محیط شما خطاهای مکرر TCP بی ضرر ایجاد کند."
    IDS_TWEAKS_TT_SHAREE_MULE                                  "نحوه ذخیره و اشتراک‌گذاری وضعیت هر\r\n\r\nکاربر توسط eMuleBB در این دستگاه Windows را کنترل می‌کند."
    IDS_TWEAKS_TT_TCP_GROUP                                    "کنترل های پیشرفته اتصال TCP پشت سر هم، مهلت زمانی، و نگهدارنده.\r\n\r\nمقادیر پیش‌فرض توصیه می‌شوند مگر اینکه مشکلات راه‌اندازی شبکه را تشخیص دهید."
    IDS_TWEAKS_TT_SEARCH_GROUP                                 "محدودیت‌های پیشرفته برای گستردگی و مدت زمان جستجوهای eMuleBB در eD2K و Kad.\r\n\r\n."
    IDS_TWEAKS_TT_SEARCH_ED2K_GROUP                            "محدودیت های جستجوی مبتنی بر سرور eD2K.\r\n\r\nاز مقادیر محافظه کارانه استفاده کنید مگر اینکه عمداً جستجوهای عمیق تری در سرور بخواهید."
    IDS_TWEAKS_TT_SEARCH_KAD_GROUP                             "Kad وسعت و طول عمر جستجو را کنترل می کند.\r\n\r\nمقادیر بالاتر جستجوهای توزیع شده را برای مدت طولانی تری زنده نگه می دارند و می توانند نتایج بیشتری را پیدا کنند، اما هزینه فعالیت پس زمینه بیشتری دارند."
    IDS_TWEAKS_TT_BROADBAND                                    "بازیافت اسلات آپلود پیشرفته و خط مشی امتیازدهی صف برای رفتار آپلود به سبک باند پهن.\r\n\r\nاین تنظیمات برای تنظیم عمدی هستند. آنها را به حالت پیش فرض خود رها کنید، مگر اینکه عادلانه بودن آپلود یا گردش اسلات را تنظیم کنید."
    IDS_TWEAKS_TT_UPLOAD_POLICY_MAX_UPLOAD_CLIENTS             "درپوش نرم برای کلاینت‌های آپلود فعال همزمان تحت برنامه زمان‌بندی باند پهن.\r\n\r\nمقادیر پایین تر، اسلات های کمتر و قوی تری را حفظ می کنند."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_THRESHOLD                 "کسری از نرخ بارگذاری هدف در هر اسلات که کمتر از آن یک اسلات کند در نظر گرفته می شود.\r\n\r\nمقادیر بالاتر اسلات های با عملکرد ضعیف را با شدت بیشتری بازیافت می کند."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_GRACE                     "چه مدت ممکن است یک شکاف زیر آستانه آهسته باقی بماند تا اینکه eMuleBB به بازیافت آن فکر کند.\r\n\r\nلطف کوتاه‌تر زودتر شکاف‌های ضعیف را برمی‌گرداند."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_WARMUP                    "دوره گرم کردن برای اسلات آپلود ج\r\n\r\nدید قبل از شروع تشخیص اسلات آهسته."
    IDS_TWEAKS_TT_UPLOAD_POLICY_ZERO_RATE_GRACE                "دوره مهلت برای اسلات هایی که اساساً هی\r\n\r\nچ داده آپلودی را ارائه نمی دهند."
    IDS_TWEAKS_TT_UPLOAD_POLICY_COOLDOWN                       "مدت زمانی که یک اسلات آهسته بازیافتی در امتیازدهی صف جریمه می‌ما\r\n\r\nند قبل از اینکه بتواند دوباره به رقابت عادی بپردازد."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BOOST                "امتیاز صف اضافی را برای مشتریانی که درخواست فایل‌هایی با نسبت آپلود تاریخی پایین دارند، اضافه می‌کند.\r\n\r\nاگر می‌خواهید فایل‌هایی را که تاکنون آپلود نسبتا کمی دریافت کرده‌اند، از آن استفاده کنید."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_THRESHOLD            "بریدگی نسبت آپلود که زیر آن افزایش امتیاز صف با نسبت پایین اعمال می‌شود. مقادیر\r\n\r\nپایین‌تر، افزایش را به فایل‌هایی که به شدت کمتر ارائه می‌شوند محدود می‌کند."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BONUS                "امتیاز صف موثر اضافی که باعث افزا\r\n\r\nیش نسبت پایین می‌شود، اعطا می‌شود."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_ID_DIVISOR                 "تقسیم‌کننده جریمه در طول امتیازدهی صف آپلود برای مشتریان LowID اعمال می‌شود.\r\n\r\n1 را برای غیرفعال کردن جریمه اضافی LowID تنظیم کنید."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER               "مقدار یک جلسه آپلود را قبل از اینکه eMuleBB چرخش\r\n\r\nآن شکاف را در نظر بگیرد، محدود می کند."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_DISABLED      "جلسات آپلود را بر اساس مقدار بار انتقالی بازیافت نکنید."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT       "هر جلسه آپلود را به درصدی از اندازه فایل درخواستی محدود کنید."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT_VALUE "درصدی استفاده می‌شود که محدودیت انتقال جلسه به عنوان سهمی از اندازه فایل پیکربندی شود."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B          "هر جلسه آپلود را صرف نظر از اندازه فایل به مقدار MiB ثابت محدود کنید."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B_VALUE    "مقدار MiB مطلق زمانی که محدودیت انتقال جلسه به عنوان یک اندازه ثابت پیکربندی می شود استفاده می شود."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TIME_LIMIT             "حداکثر مدت یک جلسه آپلود قبل از eMuleBB چرخش شکاف را در نظر می گیرد.\r\n\r\n0 را برای غیرفعال کردن محدودیت مبتنی بر زمان تنظیم کنید."
    IDS_TWEAKS_TT_A4_AF_SAVE_CPU                               "بررسی های مکرر منبع A4AF (از درخواست یک فایل دیگر) برای صرفه جویی در زمان CPU.\r\n\r\nبرای مشتریان پرمشغله مفید است، اما می تواند سوئیچینگ منبع مشابه مشتری را کمتر مشتاق کند."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_NEVER                      "متادیتا را از فایل ها استخراج نکنید. گزینه\r\n\r\nLightest. اگر نمی‌خواهید کاوش ابرداده پس‌زمینه را نداشته باشید، از آن استفاده کنید."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_ID3_LIB                    "فراداده را فقط از طریق مسیر کتابخانه\r\n\r\nID3 برای فایل‌های صوتی MPEG استخراج کنید."
    IDS_TWEAKS_TT_PREVIEW_ON_ICON_DBL_CLK                      "با دوبار کلیک کردن روی نماد فایل، پیش‌نمایش به‌جای عملک\r\n\r\nرد پیش‌فرض معمول باز می‌شود."
    IDS_TWEAKS_TT_EXTRA_PREVIEW_WITH_MENU                      "دستورات پیش‌نمایش را از طریق یک منوی اقدام پیش‌نمایش اختصاصی نشان می‌دهد به‌جای اینکه فقط عمل پیش‌نمایش مستقیم ساده‌تر را نشان دهد.\r\n\r\nاگر می‌خواهید انتخاب‌های پیش‌نمایش واضح‌تری را در فهرست زمینه فهرست دانلود داشته باشید، مفید است."
    IDS_TWEAKS_TT_SHOW_ACTIVE_DOWNLOADS_BOLD                   "انتقال فعال بارگیری‌ها را به صورت پررنگ در فهرست دانلود ترسیم می‌کند.\r\n\r\nکاملاً بصری. اگر می‌خواهید موارد فعال با وضوح بیشتری برجسته شوند، آن را فعال کنید."
    IDS_TWEAKS_TT_USE_SYSTEM_FONT_FOR_MAIN_CONTROLS            "از فونت معمولی Windows UI برای کنترل‌های اصلی و نمایش‌های فهرست به‌جای تنظیم فونت سفارشی eMuleBB استفاده می‌کند.\r\n\r\nاگر متنی با ظاهر بومی را ترجیح می‌دهید یا نیاز به سازگاری بهتر با تنظیمات فونت سیستم خود دارید، مفید است."
    IDS_TWEAKS_TT_FILTER_LANI_PS                               "آدرس‌های سرور و سرویس گیرنده را از محدوده خصوصی/LAN نادیده می‌گیرد.\r\n\r\nتوصیه می‌شود: فعال است. این از تلاش برای استفاده از آدرس‌های همتای غیرقابل مسیریابی از شبکه عمومی جلوگیری می‌کند."
    IDS_TWEAKS_TT_GEO_LOCATION_CHECK_DAYS                      "هر چند وقت یک بار eMuleBB محتوای پایگاه داده موقعیت جغرافیایی به روز را بررسی می کند.\r\n\r\n0 را برای غیرفعال کردن بررسی های به روز رسانی خودکار تنظیم کنید. مقادیر بزرگتر فعالیت بازخوانی پس زمینه را کاهش می دهد."
    IDS_TWEAKS_TT_VERBOSE                                      "سوئیچ اصلی برای کنترل‌های گزارش‌گیری دقیق در زیر.\r\n\r\nآن را برای استفاده عادی غیرفعال کنید. آن را فقط در حین بررسی یک مشکل خاص فعال کنید."
    IDS_TWEAKS_TT_FULL_VERBOSE                                 "زمانی که گزارش‌گیری کامل فعال باشد، ک\r\n\r\nامل‌ترین ردیابی کلامی موجود را ثبت می‌کند."
    IDS_TWEAKS_TT_LOG_LEVEL                                    "آستانه پرحرفی برای خروجی لاگ تشخیصی.\r\n\r\nسطوح بالاتر جزئیات بیشتری را ثبت می کنند اما نویز بیشتری ایجاد می کنند."
    IDS_TWEAKS_TT_DEBUG2_DISK                                  "خروجی تشخیصی مفصل را به جای گذرا نگه داشتن آن روی دیسک می نویسد.\r\n\r\nبرای زمانی که به ردیابی اشکال زدایی مداوم نیاز دارید مفید است، اما فعالیت دیسک را افزایش می دهد."
    IDS_TWEAKS_TT_DEBUG_SOURCE_EXCHANGE                        "بسته ها و تصمیمات مربوط به مبادله منبع را ثبت می کند.\r\n\r\nگزینه تشخیصی تخصصی. آن را فقط هنگام اشکال زدایی رفتار کشف منبع فعال کنید."
    IDS_TWEAKS_TT_LOG_BANNED_CLIENTS                           "زمان ممنوعیت همتایان و چرا را ضبط می کند.\r\n\r\nبرای سوء استفاده یا تشخیص مثبت کاذب مفید است، اما برای عملکرد عادی بسیار پر سر و صدا است."
    IDS_TWEAKS_TT_LOG_RATING_DESC_RECEIVED                     "سوابق نظرات، توضیحات و رتبه‌بندی‌های فایل را دریافت کردند.\r\n\r\nبرای اشکال‌زدایی جریان ابرداده مفید است، اما معمولاً مورد نیاز نیست."
    IDS_TWEAKS_TT_LOG_SECURE_IDENT                             "تأیید هویت امن و بررسی‌های هویت مرتبط را ثبت می‌کند.\r\n\r\nبرای عیب‌یابی اعتماد/احراز هویت مفید است."
    IDS_TWEAKS_TT_LOG_FILTERED_I_PS                            "زمانی که IP آدرس‌های همتا یا سرور را فیل\r\n\r\nتر یا نادیده می‌گیرد، ضبط می‌کند."
    IDS_TWEAKS_TT_LOG_FILE_SAVING                              "داده‌های پایدار مانند فایل‌های شناخته شده، اعتبارات و وضعیت مرتبط را ذخیره می‌کند.\r\n\r\nبرای اشکال‌زدایی مداوم مفید است، اما برای استفاده عادی غیر ضروری است."
    IDS_TWEAKS_TT_LOG_A4_AF                                    "A4AF (از درخواست یک فایل دیگر) فعالیت تخصیص مجدد منبع.\r\n\r\nگزینه تشخیصی دانلود-مدیریت تخصصی."
    IDS_TWEAKS_TT_LOG_UL_DL_EVENTS                             "تغییرات چرخه عمر اسلات آپلود و دانلود-رویداد را ثبت می کند.\r\n\r\nبرای تشخیص انحراف صف، چرخش اسلات، یا انتقال حالت انتقال مفید است."
    IDS_TWEAKS_TT_U_PN_P                                       "تنظیمات نگاشت خودکار پورت روتر برای اتصال ورودی.\r\n\r\nاکثر کاربران باید این گروه را روی پیش‌فرض‌های خودکار رها کنند، مگر اینکه محیط روتر آنها به چیزی خاص نیاز داشته باشد."
    IDS_TWEAKS_TT_SHAREE_MULE_MULTI_USER                       "هر کاربر Windows یک پیکربندی eMuleBB جداگانه و وضعیت دانلود جداگانه دریافت می‌کند.\r\n\r\nبهترین مناسب برای رایانه های شخصی مشترک که در آن کاربران نباید داده های eMuleBB را به اشتراک بگذارند."
    IDS_TWEAKS_TT_SHAREE_MULE_PUBLIC_USER                      "همه کاربران Windows از پیکربندی و دانلودهای eMuleBB یکسان استفاده می کنند.\r\n\r\nConfig تحت ProgramData زندگی می کند و دانلودها از دانلودهای عمومی استفاده می کنند. فقط در صورتی از این مورد استفاده کنید که دستگاه عمداً یک وضعیت مشترک eMuleBB را به اشتراک بگذارد."
    IDS_TWEAKS_TT_SHAREE_MULE_OLD_STYLE                        "پیکربندی و دانلودها را با استفاده از طرح‌بندی قدیمی‌تر در فهرست برنامه‌ها نگه دارید. فقط حالت سازگاری\r\n\r\nLegacy. این معمولا کمترین انتخاب در Windows مدرن است."
    IDS_CONNECTION_TT_AUTOCONNECT                              "هنگامی که eMuleBB راه اندازی می شود، به طور خودکار شبکه های فعال را راه اندازی می کند.\r\n\r\nآن را فقط در صورتی غیرفعال کنید که بخواهید در هر جلسه به صورت دستی متصل شوید."
    IDS_CONNECTION_TT_RECONN                                   "اتصالات سرور را پس از قطع یا تلاش ناموفق دوباره امتحان می کند.\r\n\r\nتوصیه می شود: در صورت استفاده از شبکه سرور eD2K فعال می شود. هنگامی که شبکه سرور غیرفعال است تأثیری ندارد."
    IDS_CONNECTION_TT_SHOWOVERHEAD                             "سربار پروتکل را به طور جداگانه در نرخ انتقال و آمار نشان می دهد. اگر می خواهید دید صادقانه تری از ترافیک سیم داشته باشید،\r\n\r\nآن را فعال کنید. اگر اعداد ساده تری را که فقط برای بار بارگیری هستند ترجیح می دهید، آن را کنار بگذارید."
    IDS_CONNECTION_TT_PORT                                     "پورت اصلی TCP که برای اتصالات مشتری ورودی استفاده می شود.\r\n\r\nپس از تغییر آن، اتصال را دوباره تست کنید."
    IDS_CONNECTION_TT_UDPPORT                                  "پورت UDP برای Kad و سایر ویژگی‌های به کمک UDP استفاده می‌شود.\r\n\r\nتوصیه می‌شود: آن را فعال و قابل دسترس نگه دارید مگر اینکه عمداً بخواهید شبکه مبتنی بر UDP را غیرفعال کنید."
    IDS_CONNECTION_TT_MAXSOURCEPERFILE                         "محدودیت سخت برای تعداد منابع راه دور که eMuleBB در هر بار دانلود نگه می دارد.\r\n\r\nاز مقادیر متوسط ​​استفاده کنید مگر اینکه دلیل خاصی برای افزایش آن داشته باشید."
    IDS_CONNECTION_TT_MAXCON                                   "حد بالایی برای اتصالات همزمان eMuleBB ممکن است باز بماند.\r\n\r\nمقادیر بالاتر به طور خودکار بهتر نیستند. این را نزدیک به پیش‌فرض تنظیم‌شده بگذارید، مگر اینکه محدودیت شبکه خاصی را تشخیص دهید."
    IDS_CONNECTION_TT_DOWNLOAD_CAP                             "ظرفیت پایین دستی پیکربندی شده شما بر حسب KiB/s.\r\n\r\neMule از این به عنوان مرجع بالایی برای تصمیم گیری های لغزنده و پهنای باند استفاده می کند."
    IDS_CONNECTION_TT_UPLOAD_CAP                               "ظرفیت بالادستی پیکربندی شده شما بر حسب KiB/s. eMuleBB از این به عنوان مرجع بالایی برای کنترل آپلود استفاده می کند.\r\n\r\nآن را نزدیک به نرخ بارگذاری پایدار قابل استفاده واقعی خط خود تنظیم کنید."
    IDS_CONNECTION_TT_NETWORK_ED2_K                            "شبکه کلاسیک سرور eD2K را فعال می کند.\r\n\r\nاگر هنوز از کشف منبع مبتنی بر سرور استفاده می کنید، آن را فعال کنید. فقط در صورتی آن را غیرفعال کنید که عمداً می خواهید عملکرد فقط Kad را داشته باشید."
    IDS_CONNECTION_TT_NETWORK_KADEMLIA                         "شبکه توزیع شده Kad را فعال می کند.\r\n\r\nتوصیه شده: برای استفاده مدرن فعال است. برای فعال ماندن به پورت UDP نیاز دارد."
    IDS_CONNECTION_TT_PREF_UPNPONSTART                         "در هنگام راه‌اندازی، برای پورت‌های پیکربندی‌شده TCP و UDP، نقشه‌برداری خودکار پورت NAT را انجام می‌دهد.\r\n\r\nاگر پورت ها را به صورت دستی فوروارد می کنید، آن را غیرفعال کنید."
    IDS_CONNECTION_TT_RANDOMIZE_PORTS_ON_STARTUP               "پورت‌های گوش جدید TCP و UDP را هنگام راه‌اندازی قبل از اجرای نقشه‌برداری خودکار پورت انتخاب می‌کند.\r\n\r\nاین گزینه از محدوده پورت تصادفی موجود eMuleBB استفاده می‌کند و زمانی که پورت UDP غیرفعال است UDP را غیرفعال می‌کند."
    IDS_CONNECTION_TT_UDPDISABLE                               "پورت UDP eMuleBB را غیرفعال می کند و بنابراین ویژگ\r\n\r\nی های وابسته به UDP مانند شبکه Kad را غیرفعال می کند."
    IDS_CONNECTION_TT_STARTTEST                                "تست اتصال خارجی را برای پورت‌های TCP و UDP\r\n\r\nپیکربندی‌شده فعلی راه‌اندازی می‌کند."
    IDS_CONNECTION_TT_BIND_INTERFACE                           "نام واسط شبکه اختیاری Windows که برای اتصال سوکت P2P استفاده می‌شود.\r\n\r\nتغییرات پس از راه اندازی مجدد اعمال می شود."
    IDS_CONNECTION_TT_BIND_ADDRESS                             "آدرس IPv4 اختیاری که برای اتصال سوکت P2P استفاده می‌شود.\r\n\r\nبرای استفاده از اولین IPv4 در رابط انتخاب‌شده یا انتخاب مسیریابی پیش‌فرض زمانی که هیچ رابطی انتخاب نشده است، آن را خالی بگذارید."
    IDS_WEBSERVER_TT_WEBBINDADDR                               "آدرس پیوند محلی برای WebServer داخلی و REST API.\r\n\r\nآن را خالی یا به عنوان 0.0.0.0 برای گوش دادن به همه رابط ها بگذارید. فقط در صورتی یک IPv4 خاص را تنظیم کنید که عمداً بخواهید مکان گوش دادن سرویس را محدود کنید."
    IDS_WEBSERVER_TT_WSAPIKEY                                  "کلید متن ساده REST API که توسط کلاینت ها در هدر X-API-Key استفاده می شود.\r\n\r\nهر کسی که این کلید را داشته باشد دسترسی کامل به API دارد."
    IDS_WEBSERVER_TT_WSUPNP                                    "در صورت فعال بودن UPnP یا PCP/NAT-PMP، پورت WebServer را در نگاشت خودکار NAT در بر می‌گیرد.\r\n\r\nفقط اگر عمداً می‌خواهید که Web UI یا REST API از طریق روتر شما قابل دسترسی باشد، آن را فعال کنید."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD                          "حداکثر اندازه تک فایل آپلود شده توسط WebServer در MiB.\r\n\r\nاز یک مقدار کوچک برای کنترل از راه دور معمولی استفاده کنید. فقط در صورتی آن را افزایش دهید که کلاینت های وب مورد اعتماد نیاز به آپلود فایل های بزرگتر داشته باشند."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD_LBL                      "حداکثر اندازه تک فایل آپلود شده توسط WebServer در MiB.\r\n\r\nاز یک مقدار کوچک برای کنترل از راه دور معمولی استفاده کنید. فقط در صورتی آن را افزایش دهید که کلاینت های وب مورد اعتماد نیاز به آپلود فایل های بزرگتر داشته باشند."
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS                             "لیست مجاز IPv4 جدا شده با نقطه ویرگول اختیاری برای مشتریان WebServer.\r\n\r\nمثال: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS_LBL                         "لیست مجاز IPv4 جدا شده با نقطه ویرگول اختیاری برای مشتریان WebServer.\r\n\r\nمثال: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWHILEVFUNC                         "به اقدامات وب مدیریتی سطح بالا اجازه می\r\n\r\nدهد تا وضعیت زمان اجرا را به شدت تغییر دهند."
    IDS_WEBSERVER_TT_WEB_HTTPS                                 "Web UI و REST API را از طریق HTTPS با استفا\r\n\r\nده از گواهی و کلید پیکربندی شده ارائه می دهد."
    IDS_NOTIFY_TT_CB_TBN_USESOUND                              "یک فایل WAV سفارشی را برای اعلان‌های نوار وظیفه پخش می‌کند.\r\n\r\nاگر پنجره‌های بازشوی بی‌صدا یا گفتار کافی است، آن را کنار بگذارید."
    IDS_NOTIFY_TT_CB_TBN_USESPEECH                             "وقتی موتور گفتاری در دسترس است از تبدیل متن\r\n\r\nبه گفتار برای اعلان‌های نوار وظیفه استفاده می‌کند."
    IDS_NOTIFY_TT_CB_TBN_POP_ALWAYS                            "یک پنجره بازشو برای هر پیام چت دریافتی به جای اولین پیام نشان می دهد.\r\n\r\nاگر نمی خواهید پیام های گپ بعدی ساکت بمانند، آن را فعال کنید."
    IDS_NOTIFY_TT_CB_TBN_USEWINDOWSTOAST                       "به جای پنجره بازشو سفارشی eMuleBB ا\r\n\r\nز اعلان‌های نان تست Windows استفاده می‌کند."
    IDS_NOTIFY_TT_TBN_DISPLAYMODE                              "نحوه نشان دادن اعلان‌های بازشوی فعال eMuleBB را انتخاب می‌کند.\r\n\r\nاگر Windows اعلان نان تست را رد کند، از جمله زمانی که eMuleBB به عنوان سرپرست اجرا می شود، eMuleBB به بالون سینی کلاسیک برمی گردد."
    IDS_NOTIFY_TT_CB_ENABLENOTIFICATIONS                       "اعلان‌های ایمیل خروجی را بر\r\n\r\nای رویدادهای پیکربندی شده فعال می‌کند."
    IDS_NOTIFY_TT_SMTPSERVER                                   "پیکربندی سرور SMTP مورد استفاده تو\r\n\r\nسط اعلان‌های ایمیل را باز می‌کند."
    IDS_BIND_STARTUP_INTERFACE_NOT_FOUND_FMT                   "شبکه برای این جلسه غیرفعال شد زیرا رابط پیوند انتخاب شده دیگر در دسترس نیست: %s"
    IDS_BIND_STARTUP_INTERFACE_AMBIGUOUS_FMT                   "شبکه برای این جلسه غیرفعال شد زیرا نام رابط پیوند انتخابی با چندین آداپتور زنده مطابقت دارد: %s"
    IDS_BIND_STARTUP_INTERFACE_NO_ADDRESS_FMT                  "شبکه برای این جلسه غیرفعال شد زیرا رابط پیوند انتخابی آدرس IPv4 قابل استفاده ندارد: %s"
    IDS_BIND_STARTUP_INTERFACE_ADDRESS_MISSING_FMT             "شبکه برای این جلسه غیرفعال شد زیرا پیوند انتخابی IP دیگر در رابط انتخابی وجود ندارد: %s"
    IDS_BIND_STARTUP_ADDRESS_MISSING_FMT                       "شبکه برای این جلسه غیرفعال شد زیرا پیوند انتخابی IP دیگر در هیچ رابط زنده وجود ندارد: %s"
    IDS_BIND_EXIT_INTERFACE_CHANGED_FMT                        "خروج از eMuleBB زیرا رابط bind انتخاب شده آدرس را از %s به %s تغییر داد: %s"
    IDS_BIND_EXIT_INTERFACE_UNAVAILABLE                        "خروج از eMuleBB زیرا رابط bind انتخاب شده دیگر در دسترس نیست."
    IDS_BIND_STARTUP_DISABLED_PREFIX                           "شبکه برای این جلسه غیرفعال شد"
    IDS_BIND_EXIT_PREFIX                                       "خروج از eMuleBB"
    IDS_STATUS_BIND_IP_COMPACT_LABEL                           "ب"
    IDS_STATUS_PUBLIC_IP_COMPACT_LABEL                         "پ"
    IDS_STATUS_ANY_COMPACT                                     "هر"
    IDS_STATUS_UNKNOWN_COMPACT                                 "?"
    IDS_STATUS_NETWORK_ADDRESS_TEXT_FMT                        "%s:%s|%s:%s"
    IDS_PPG_DIRECTORIES_TT_INCFILES                            "دایرکتوری ورودی اصلی برای دانلودهای کامل شده.\r\n\r\nاز یک مسیر محلی پایدار با فضای خالی کافی استفاده کنید. از مکان‌های موقت یا قابل جابجایی خودداری کنید، مگر اینکه واقعاً فایل‌های کامل را در آنجا بخواهید."
    IDS_PPG_DIRECTORIES_TT_TEMPFILES                           "فهرست دایرکتوری کار برای فایل‌های قطعه، هش‌ها و وضعیت انتقال.\r\n\r\nدیسک های محلی سریع روی مسیرهای شبکه قابل جابجایی یا غیرقابل اطمینان توصیه می شود."
    IDS_PPG_DIRECTORIES_TT_SHARESELECTOR                       "پوشه های محلی را انتخاب می کند که eMuleBB با مشتریان دیگر به اشتراک گذاشته شود.\r\n\r\nاز ریشه های گسترده مانند یک درایو کامل اجتناب کنید."
    IDS_PPG_DISPLAY_TT_MINTRAY                                 "eMuleBB را در سینی به جای گذاشتن آن در نوار وظیفه به حداقل می رساند.\r\n\r\nبرای تنظیمات همیشه روشن مفید است. اگر رفتار عادی نوار وظیفه را ترجیح می دهید، آن را کنار بگذارید."
    IDS_PPG_DISPLAY_TT_TOOLTIPDELAY                            "تاخیر قبل از ظاهر شدن نکات ابزار رابط کاربری.\r\n\r\nمحدوده پیش فرض معمولاً مصالحه خوبی است."
    IDS_PPG_DISPLAY_TT_SHOWRATEONTITLE                         "نرخ بارگذاری و دانلود فعلی را در عنوان پنجره اصلی نشان می‌دهد.\r\n\r\nزمانی که eMuleBB در پس‌زمینه می‌ماند و شما همچنان می‌خواهید یک نگاه سریع به سرعت داشته باشید مفید است."
    IDS_PPG_DISPLAY_TT_STORESEARCHES                           "عبارت‌های جستجوی اخیر را نگه می\r\n\r\n‌دارد تا بتوان بعداً دوباره از آنها استفاده کرد."
    IDS_PPG_DISPLAY_TT_WIN7_TASKBARGOODIES                     "پیشرفت نوار وظیفه Windows و ادغام پو\r\n\r\nسته مربوطه را در صورت پشتیبانی فعال می کند."
    IDS_PPG_FILES_TT_PF_TIMECALC                               "از محاسبه دقیق‌تر زمان باقی مانده برای دانلودها استفاده می‌کند.\r\n\r\nفقط در صورتی آن را غیرفعال کنید که محاسبات ساده تر قدیمی را ترجیح می دهید."
    IDS_PPG_FILES_TT_PREVIEWPRIO                               "بخش‌های پیش‌نمایش فیلم را اولویت‌بندی می‌کند تا رسانه‌های نیمه دانلود شده زودتر قابل پیش‌نمایش شوند.\r\n\r\nبرای دانلود ویدیو مفید است. اگر سفارش دادن تکه های خنثی را ترجیح می دهید آن را کنار بگذارید."
    IDS_PPG_FILES_TT_WATCHCB                                   "کلیپ بورد را برای پیوندهای ed2k تماشا می کند و ارائه می دهد که آنها را مدیریت کند.\r\n\r\nراحت است اگر بارگیری از مرورگرها زیاد اضافه کنید. اگر نمی خواهید eMuleBB تماشای کلیپ بورد را داشته باشد، آن را غیرفعال کنید."
    IDS_PPG_FILES_TT_FNCLEANUP                                 "نام فایل های دانلود شده را به طور خودکار طبق قوانین پیکربندی شده پاک می کند.\r\n\r\nتوصیه می شود: اگر می خواهید نام فایل های نهایی منسجم تری بدون پاکسازی دستی داشته باشید، فعال شود."
    IDS_PPG_FILES_TT_STARTNEXTFILE                             "هنگامی که دانلود دیگری به پایان می رسد یا متوقف\r\n\r\nمی شود، فایل صف بعدی را به طور خودکار شروع می کند."
    IDS_PPG_FILES_TT_RUNONFILECOMPLETE                         "یک فایل اجرایی را پس از تکمیل موفقیت آمیز و نگهداری فایل اجرا می کند.\r\n\r\nاین به طور پیش فرض غیرفعال است. این برنامه مستقیماً بدون پوسته Windows راه اندازی می شود."
    IDS_PPG_FILES_TT_FILECOMPLETEARGS                          "نشانه‌های پشتیبانی شده: مسیر کامل %F، فهرست %D، نام فایل %N، هش فایل %H، بایت‌های اندازه %S، دسته %C.\r\n\r\nمتغیرهای محیطی گسترش نمی یابند. %F %D"
    IDS_PPG_GENERAL_TT_ONLINESIG                               "فایل وضعیت قدیمی onlinesig.dat را برای صفحات خارجی، اسکریپت ها یا ابزارک هایی که وضعیت eMule را می خوانند می نویسد.\r\n\r\nسرعت انتقال یا شبکه را بهبود نمی بخشد. آن را رها کنید مگر اینکه به طور فعال آن فایل را در جایی مصرف کنید."
    IDS_PPG_GENERAL_TT_BRINGTOFOREGROUND                       "زمانی که پیوند ed2k مدیریت شده یا اقدام خارجی مشابه برنامه را هدف قرار می دهد، eMuleBB را به پیش زمینه می آورد. اگر می خواهید کلیک روی پیوند فوراً eMuleBB را نشان دهد،\r\n\r\nآن را فعال کنید. اگر مدیریت پس‌زمینه را ترجیح می‌دهید، آن را کنار بگذارید."
    IDS_PPG_GENERAL_TT_CHECK4_UPDATE                           "GitHub را در هنگام راه‌اندازی با سپری شدن بازه زمانی پیکربندی شده بررسی می‌کند و فقط\r\n\r\nزمانی هشدار می‌دهد که بسته جدیدتر eMuleBB در دسترس باشد."
    IDS_PPG_GENERAL_TT_PREVENTSTANDBY                          "هنگامی که eMuleBB متصل است، خواب سیستم را مسدود می کند یا بارگیری ها، آپلودهای طولانی، Kad و جلسات سرور را قطع نمی کند.\r\n\r\nنمایشگر همچنان می تواند به طور معمول خاموش شود. غیرفعال کردن این گزینه بلافاصله سیاست خواب عادی Windows را بازیابی می کند."
    IDS_PPG_GENERAL_TT_WEBSVEDIT                               "فهرست سرویس‌های وب پیکربندی شده مورد استفاده توسط\r\n\r\nاقدامات کمکی مانند جستجوی وب از UI را ویرایش می‌کند."
    IDS_PPG_GENERAL_TT_ED2_KFIX                                "ثبت پیوند Windows ed2k را تعمیر می کند تا پیوندهای مرورگر و پوسته ed2k دوباره در eMuleBB باز شوند.\r\n\r\nزمانی که پیوندهای ed2k راه اندازی eMuleBB متوقف شد یا توسط کلاینت دیگری به سرقت رفت از آن استفاده کنید."
    IDS_PPG_GENERAL_TT_STARTMIN                                "به جای باز کردن فوری پنجره اصلی، eMuleBB را به حداقل می رساند.\r\n\r\nبرای راه اندازی بدون مراقبت مفید است. اگر معمولاً می خواهید فوراً رابط کاربری را بررسی کنید، آن را کنار بگذارید."
    IDS_PPG_GENERAL_TT_STARTWIN                                "eMuleBB را برای شروع با Windows برای کاربر فعلی ثبت می کند.\r\n\r\nآن را فقط در ماشین هایی که eMuleBB قرار است به طور مداوم در پس زمینه اجرا شود فعال کنید."
    IDS_PPG_IRC_TT_IRC_USECHANFILTER                           "هنگام درخواست لیست کانال IRC، نام کانال و فیلتر حداقل کاربر را اعمال می کند. اگر می خواهید لیست به طور خودکار محدود شود،\r\n\r\nآن را فعال کنید. آن را غیرفعال کنید تا همیشه لیست کامل کانال ها واکشی شود."
    IDS_PPG_IRC_TT_IRC_USEPERFORM                              "اسکریپت اجرا را پس از اتصال به IRC اجرا می کند.\r\n\r\nاز آن برای اتصالات خودکار یا دستورات IRC استفاده کنید. اگر اسکریپت اجرا را حفظ نمی کنید، آن را کنار بگذارید."
    IDS_PPG_IRC_TT_IRC_NAME_BOX                                "فیلتر کردن متن برای لیست کانال IRC.\r\n\r\nفقط کانال هایی که با این متن مطابقت دارند با فعال شدن فیلتر کانال حفظ می شوند."
    IDS_PPG_IRC_TT_IRC_MINUSER_BOX                             "حداقل تعداد کاربر برای کانال هایی که توسط فیلتر لیست کانال IRC نشان داده شده است.\r\n\r\nآن را افزایش دهید تا کانال های کوچک پنهان شوند. از 0 برای حفظ کانال ها بدون در نظر گرفتن اندازه استفاده کنید."
    IDS_PPG_MESSAGES_TT_MSGONLYFRIENDS                         "پیام‌های مستقیم را فقط از کاربران موجود در لیست دوستان شما می‌پذیرد.\r\n\r\nاگر همچنان از مشتریان عادی پیام می خواهید، آن را رها کنید."
    IDS_PPG_MESSAGES_TT_ADVSPAMFILTER                          "مسیر فیلتر هرزنامه پیام قوی تر را فعال می کند.\r\n\r\nتوصیه می شود: برای استفاده عادی در شبکه عمومی فعال است. برای فیلتر کردن سخت‌تر، همراه با کپچاهای چت کار می‌کند."
    IDS_PPG_MESSAGES_TT_USECAPTCHAS                            "قبل از اینکه مشتریان ناشناس بتوانند مکالمه چت را کامل کنند، به چالش کپچا نیاز دارد.\r\n\r\nدر برابر هرزنامه چت مفید است. بهترین استفاده همراه با فیلتر هرزنامه پیشرفته."
    IDS_PPG_MESSAGES_TT_COMMENTFILTER                          "نظرات فایل حاوی اصطلاحات فیلتر پیکربندی شده را مسدود می کند.\r\n\r\nاز ""|"" استفاده کنید جداکننده بین اصطلاحات برای کلمات هرزنامه شناخته شده یا الگوهای مزاحم خوب است."
    IDS_PPG_PROXY_TT_ENABLEPROXY                               "مسیرها از اتصالات خروجی از طریق پراکسی پیکربندی شده پشتیبانی می‌کنند.\r\n\r\nاتصالات مستقیم ساده تر و معمولا سریعتر هستند."
    IDS_PPG_PROXY_TT_PROXYTYPE                                 "پروتکل پراکسی مورد انتظار سرور پراکسی شما را انتخاب می کند.\r\n\r\nاز نوع دقیق ارائه شده توسط اپراتور پراکسی استفاده کنید. نوع اشتباه معمولاً به معنای خرابی اتصال فوری است."
    IDS_PPG_PROXY_TT_PROXYNAME                                 "نام میزبان یا آدرس IP سرور پراکسی.\r\n\r\nدقیقاً نقطه پایانی ارائه شده توسط سرویس پروکسی خود را وارد کنید. یک میزبان اشتباه به این معنی است که تمام ترافیک پروکسی شکست خواهد خورد."
    IDS_PPG_PROXY_TT_PROXYPORT                                 "درگاه گوش دادن سرور پراکسی.\r\n\r\nاز پورت دقیق مورد نیاز پروکسی استفاده کنید. پیش فرض های معمول SOCKS تضمین نمی شود که درست باشند."
    IDS_PPG_PROXY_TT_ENABLEAUTH                                "زمانی که پروکسی به احراز هویت نیاز دارد، نام\r\n\r\nکاربری و رمز عبور پروکسی را ارسال می‌کند."
    IDS_PPG_PROXY_TT_USERNAME_A                                "نام کاربری حساب پراکسی.\r\n\r\nآن را خالی بگذارید مگر اینکه پروکسی شما صراحتاً به دسترسی تأیید شده نیاز داشته باشد."
    IDS_PPG_SCHEDULER_TT_ENABLE                                "زمان‌بند را فعال می‌کند تا قوانین مبتنی بر زمان بتوانند تنظیمات را به‌طور خودکار تغییر دهند.\r\n\r\nآن را غیرفعال کنید مگر اینکه به طور فعال از پهنای باند، اتصال یا تغییرات دسته‌بندی برنامه‌ریزی شده استفاده کنید."
    IDS_PPG_SCHEDULER_TT_CHECKNOENDTIME                        "ورودی زمانبندی انتخابی را بدون زمان توقف اجرا می کند.\r\n\r\nاز آن برای تغییرات حالت یک طرفه استفاده کنید که باید فعال بماند تا زمانی که برنامه زمانی دیگری آنها را لغو کند."
    IDS_PPG_SCHEDULER_TT_APPLY                                 "جزئیات ویرایش شده را در ورودی برنا\r\n\r\nمه زمانی انتخاب شده فعلی اعمال می کند."
    IDS_PPG_SECURITY_TT_USESECIDENT                            "هنگامی که پشتیبانی می شود از شناسایی ایمن استفاده می کند تا جعل هویت اعتباری مشتری را سخت تر کند.\r\n\r\nتوصیه می شود: فعال است. غیرفعال کردن آن فقط اعتماد هویت را کاهش می دهد و به ندرت مفید است."
    IDS_PPG_SECURITY_TT_FILTERSERVERBYIPFILTER                 "فیلتر IP را در لیست سرورهای قابل مشاهده اعم\r\n\r\nال می کند تا سرورهای فیلتر شده پنهان یا حذف شوند."
    IDS_PPG_SECURITY_TT_UPDATEURL                              "نشانی وب منبع مورد استفاده هنگام بارگیری لیست‌های فیلتر IP تازه‌سازی شده.\r\n\r\nفقط از یک ارائه‌دهنده مورد اعتماد استفاده کنید. به‌روزرسانی‌های خودکار از این URL دوباره استفاده می‌کنند و در صورت نامعتبر بودن دانلود، فیلتر موجود را حفظ می‌کنند."
    IDS_PPG_SECURITY_TT_AUTOUPDATE_IPFILTER                    "URL فیلتر IP پیکربندی شده را به طور خودکار پس از راه‌ا\r\n\r\nندازی زمانی که فاصله زمانی به‌روزرسانی فرا می‌رسد، بررسی می‌کند."
    IDS_PPG_SECURITY_TT_IPFILTERPERIOD                         "تعداد روز بین تلاش‌های به‌روزرسانی خودکار فیلتر IP.\r\n\r\nمحدوده مجاز: 1 تا 365 روز. تلاش‌های ناموفق همچنان برای اجتناب از حلقه‌های تلاش مجدد در زمانی که ارائه‌دهنده در دسترس نیست، شمارش می‌شوند."
    IDS_PPG_SECURITY_TT_SEESHARE1                              "وقتی کلاینت راه دور از آن پشتیبانی می کند، به همه اجازه می دهد تا فایل های به اشتراک گذاشته شده شما را مرور کنند.\r\n\r\nبیشترین گزینه مجاز است. فقط در صورتی از آن استفاده کنید که به راحتی فهرست مشترک خود را به طور گسترده در معرض دید قرار دهید."
    IDS_PPG_SECURITY_TT_SEESHARE2                              "فقط به دوستان اجازه می‌دهد فایل‌های به اشتراک‌گذاشته‌شده شما را مرور کنند.\r\n\r\nاگر همچنان می‌خواهید برای مخاطبین صریحاً قابل اعتماد، پشتیبانی مرور کنید، انتخاب حریم خصوصی متعادل است."
    IDS_PPG_SECURITY_TT_SEESHARE3                              "از مرور کردن لیست فایل های مشت\r\n\r\nرک شما توسط مشتریان راه دور جلوگیری می کند."
    IDS_PPG_SECURITY_TT_ENABLEOBFUSCATION                      "هنگامی که سمت راه دور نیز از آن پشتیبانی می کند، مبهم سازی پروتکل را ترجیح می دهد.\r\n\r\nتوصیه می شود: فعال است. این می تواند در شبکه های محدود کننده بدون اجبار یک سیاست فقط مبهم سازی کمک کند."
    IDS_PPG_SECURITY_TT_ONLYOBFUSCATED                         "به جای پذیرش اتصالات معمولی، به اتصالات مبهم نیاز دارد.\r\n\r\nمی تواند اتصال و دسترسی به همتایان را کاهش دهد."
    IDS_PPG_SECURITY_TT_SEARCHSPAMFILTER                       "هرزنامه‌های آشکار نتایج جستجو را قبل از ای\r\n\r\nنکه UI را به هم بریزند فیلتر می‌کند."
    IDS_PPG_SECURITY_TT_CHECK_FILE_OPEN                        "قبل از عملیاتی که نیاز به دسترسی انحصاری دارند، فایل\r\n\r\nهای دانلود شده را برای حالت باز/قفل بررسی می کند."
    IDS_PPG_SERVER_TT_AUTOSERVER                               "به طور خودکار لیست سرور را از مشتریان متصل و سایر منابع قابل اعتماد به روز می کند.\r\n\r\nاگر ترجیح می‌دهید یک لیست سرور استاتیک کاملاً مدیریت‌شده، آن را غیرفعال کنید."
    IDS_PPG_SERVER_TT_UPDATESERVERCONNECT                      "به سرورهای متصل اجازه می دهد تا سرورهای اضافی را در لیست شما تبلیغ کنند.\r\n\r\nراحت است، اما می تواند لیست را با ورودی های کم ارزش افزایش دهد. اگر تنظیم دستی سخت گیرانه تر را ترجیح می دهید، آن را غیرفعال کنید."
    IDS_PPG_SERVER_TT_UPDATESERVERCLIENT                       "به مشتریان اجازه می دهد تا آدرس های سرور را به لیست سرور شما اضافه کنند.\r\n\r\nاگر می خواهید کنترل دقیق تری بر کیفیت لیست سرور دارید، آن را غیرفعال کنید."
    IDS_PPG_SERVER_TT_SAFESERVERCONNECT                        "از استراتژی اتصال به سرور محتاطانه تری استفاده می کند به جای عجله در بسیاری از نامزدها.\r\n\r\nتوصیه می شود: برای پایداری فعال است. آن را فقط در صورتی غیرفعال کنید که عمداً رویکرد اتصال تهاجمی‌تری می‌خواهید."
    IDS_PPG_SERVER_TT_SMARTIDCHECK                             "قبل از اینکه تصمیم بگیرید که دسترسی سمت سرور شما ضعیف است، بررسی هوشمند LowID را انجام می دهد.\r\n\r\nتوصیه می شود: فعال است. از برخی نتیجه گیری های نادرست LowID در شرایط شبکه گذرا جلوگیری می کند."
    IDS_PPG_SERVER_TT_SCORE                                    "هنگام انتخاب و سفارش سرورها از اولویت های سرور استفاده می کند.\r\n\r\nتوصیه می شود: اگر زیرمجموعه ترجیحی از سرورها را حفظ می کنید و می خواهید eMuleBB به آنها علاقه مند باشد فعال می شود."
    IDS_PPG_SERVER_TT_SERVERRETRIES                            "چند تلاش برای اتصال ناموفق ممکن است یک سرور قبل از اینکه eMuleBB آن را مرده تلقی کند جمع آوری کند.\r\n\r\nمقادیر بالاتر باعث بخشش بیشتر قطعی های گذرا می شود."
    IDS_PPG_SERVER_TT_AUTOCONNECTSTATICONLY                    "تلاش‌های اتصال خودکار سرور را به سرورهایی که به‌عنوان ثابت علامت‌گذاری شده‌اند محدود می‌کند.\r\n\r\nاگر یک لیست استاتیک کوچک قابل اعتماد دارید و نمی‌خواهید چرخش خودکار در لیست کامل سرور انجام شود، آن را فعال کنید."
    IDS_PPG_SERVER_TT_MANUALSERVERHIGHPRIO                     "به سرورهایی که به صورت دستی اضافه شده‌اند، اولویت بیشتری نسبت به ورودی‌های کشف‌شده معمولی می‌دهد.\r\n\r\nآن را فعال کنید اگر مجموعه‌ای از سرورها را انتخاب کرده‌اید و می‌خواهید آن افزوده‌ها مورد پسند قرار گیرند."
    IDS_PPG_STATS_TT_FILL_GRAPHS                               "مناطق نمودار را به جای ترسیم فقط خطوط پر می کند.\r\n\r\nکاملا بصری. اگر نمای آماری سبک‌تر و کم‌تر را ترجیح می‌دهید، آن را غیرفعال کنید."
    IDS_PPG_STATS_TT_SLIDER                                    "فاصله بازخوانی برای نمودار ترافیک زنده.\r\n\r\nمقادیر متوسط ​​معمولاً بهترین هستند."
    IDS_PPG_STATS_TT_SLIDER2                                   "فاصله بازخوانی درخت آمار و مقادیر خلاصه.\r\n\r\nاگر به‌روزرسانی‌های آرام‌تری می‌خواهید، آن را افزایش دهید."
    IDS_PPG_STATS_TT_SLIDER3                                   "میانگین پنجره استفاده شده توسط نمودارها.\r\n\r\nپنجره های طولانی تر نمایشگر را صاف می کنند و بر روندها تأکید می کنند."
    IDS_PPG_STATS_TT_COLORSELECTOR                             "رنگ عنصر آماری را که در حا\r\n\r\nل ویرایش هستید انتخاب می کند."
    IDS_PPG_STATS_TT_CGRAPHSCALE                               "مقیاس دستی محور Y برای نمودار اتصال.\r\n\r\nمقادیر کمتر جزئیات بیشتری را در تعداد اتصالات متوسط ​​ارائه می دهد."
    IDS_PPG_STATS_TT_CRATIO                                    "نسبت تصویر آپلود/دانلود که\r\n\r\nتوسط نمودار اتصال ترکیبی استفاده می‌شود."
    IDS_NOTIFY_TT_BTN_BROWSE_WAV                               "فایل WAV مورد استفاده توسط اعلان\r\n\r\n‌های صوتی نوار وظیفه را مرور می‌کند."
    IDS_NOTIFY_TT_CB_TBN_IMPORTATNT                            "اعلان‌ها را برای شرایط اضطراری مانند هشدارهای فضای دیسک ی\r\n\r\nا اتصالات از دست رفته سرور نشان می‌دهد."
    IDS_NOTIFY_TT_CB_TBN_NOSOUND                               "خروجی صدای اعلان را غیرفعال می کند.\r\n\r\nوقتی اعلان های بصری کافی است یا دستگاه باید بی صدا بماند، از این استفاده کنید."
    IDS_NOTIFY_TT_CB_TBN_ONCHAT                                "هنگامی که یک جلسه گپ شروع می شود، اعلانی را نشان می دهد.\r\n\r\nبرای اینکه eMuleBB را به حداقل برسانید و همچنان می خواهید به مکالمات جدید توجه کنید مفید است."
    IDS_NOTIFY_TT_CB_TBN_ONDOWNLOAD                            "هنگامی که دانلود به پایان می رسد، یک اعلان نشان می دهد.\r\n\r\nتوصیه می شود اگر فایل های تکمیل شده بدون تماشای صفحه انتقال نیاز به توجه دارند."
    IDS_NOTIFY_TT_CB_TBN_ONLOG                                 "هنگامی که یک ورودی گزار\r\n\r\nش اضافه می شود، یک اعلان نشان می دهد."
    IDS_NOTIFY_TT_CB_TBN_ONNEWDOWNLOAD                         "هنگامی که دانلود جدیدی اضافه می شود، اعلانی را نشان می دهد.\r\n\r\nاگر دانلودها می توانند به صورت خارجی اضافه شوند و تأیید می خواهید، آن را فعال کنید."
    IDS_NOTIFY_TT_CB_TBN_ONNEWVERSION                          "زمانی که جستجوگر به‌روزرسانی نسخه جدیدتری\r\n\r\neMuleBB را پیدا کند، اعلانی را نشان می‌دهد."
    IDS_NOTIFY_TT_EDIT_RECEIVER                                "آدرس ایمیلی که پیام های اعلان eMuleBB را دریافت می کند.\r\n\r\nاز آدرسی استفاده کنید که توسط سرور SMTP پیکربندی شده پذیرفته شده است."
    IDS_NOTIFY_TT_EDIT_SENDER                                  "آدرس فرستنده برای اعلان‌های ایمیل استفاده می‌شود.\r\n\r\nبسیاری از سرورهای SMTP برای مطابقت یا متعلق به حساب احراز هویت شده به این نیاز دارند."
    IDS_NOTIFY_TT_EDIT_TBN_WAVFILE                             "مسیر فایل WAV پخش شده برای اعلان های صوتی.\r\n\r\nیک فایل محلی کوتاه را انتخاب کنید. فایل های از دست رفته یا غیرقابل دسترس از پخش صدا جلوگیری می کند."
    IDS_NOTIFY_TT_TEST_NOTIFICATION                            "یک اعلان آزمایشی را با استفاده از\r\n\r\nتنظیمات اعلان فعلی ارسال می کند."
    IDS_PPG_DIRECTORIES_TT_SELINCDIR                           "فهرست راهنمای ورودی مورد استفاده برای دانلودهای تکمیل شده را مرور می کند.\r\n\r\nیک مسیر محلی پایدار با فضای خالی کافی انتخاب کنید."
    IDS_PPG_DIRECTORIES_TT_SELTEMPDIR                          "فهرست فایل‌های موقت انتخاب‌شده را مرور می‌کند. فایل‌های بخش\r\n\r\nبستگی به این دارند که این مسیر در حین اجرای دانلودها در دسترس بماند."
    IDS_PPG_DIRECTORIES_TT_SELTEMPDIRADD                       "فهرست فایل‌های موقت دیگری\r\n\r\nرا به فهرست فهرست کار اضافه می‌کند."
    IDS_PPG_DIRECTORIES_TT_UNCADD                              "یک مسیر UNC شبکه را به\r\n\r\nفهرست دایرکتوری مشترک اضافه می کند."
    IDS_PPG_DISPLAY_TT_3DDEPTH                                 "عمق سایه‌زنی سه‌بعدی مورد استفاده در فهرست‌های کلاسیک و تصاویر نمودار را کنترل می‌کند.\r\n\r\nمقادیر پایین‌تر صاف‌تر به نظر می‌رسند و مقادیر بالاتر سایه‌های قوی‌تری اضافه می‌کنند."
    IDS_PPG_DISPLAY_TT_CLEARCOMPL                              "دانلودهای تکمیل شده را به صورت خودکار از لیست انتقالات قابل مشاهده حذف می کند.\r\n\r\nاین فقط لیست دانلود را تمیزتر نگه می دارد."
    IDS_PPG_DISPLAY_TT_DBLCLICK                                "هنگامی که دانلودی در فهرست انتقال دوبار کلیک می شود، آن را بزرگ یا کوچک می کند.\r\n\r\nآن را غیرفعال کنید اگر با دوبار کلیک از تغییر طرح بندی ردیف جلوگیری می کنید."
    IDS_PPG_DISPLAY_TT_DISABLEHIST                             "تاریخچه های تکمیل خودکار را برای فیلدهایی مانند متن جستجو و URL های server.met فعال می کند.\r\n\r\nاگر نمی خواهید آن ورودی ها به خاطر سپرده شوند، آن را غیرفعال کنید."
    IDS_PPG_DISPLAY_TT_DISABLEKNOWNLIST                        "فهرست مشتریان شناخته شده را در\r\n\r\nپنجره انتقالات پنهان و غیرفعال می کند."
    IDS_PPG_DISPLAY_TT_DISABLEQUEUELIST                        "لیست Queue را در پنجره Tran\r\n\r\nsfers پنهان و غیرفعال می کند."
    IDS_PPG_DISPLAY_TT_RESETHIST                               "ورودی های تاریخچه تکمیل خودکار ذخیره شده را پاک می کند.\r\n\r\nاین فقط بر تاریخچه ذخیره شده تأثیر می گذارد و بارگیری های فعال یا لیست های سرور را تغییر نمی دهد."
    IDS_PPG_DISPLAY_TT_SELECT_HYPERTEXT_FONT                   "انتخابگر فونت را برای نمایش‌های متنی سرور، پیام و IRC باز می‌کند.\r\n\r\nCtrl را نگه دارید و در عوض آن را باز کنید تا فونت گزارش را ویرایش کنید."
    IDS_PPG_DISPLAY_TT_SHOWCATINFO                             "اطلاعات دسته را در برگه های دسته انتقال نشان می دهد.\r\n\r\nوقتی دانلودها را از طریق چندین دسته مدیریت می کنید مفید است."
    IDS_PPG_DISPLAY_TT_SHOWDWLPERCENT                          "درصد پیشرفت دانلود را در لیست انتقال ها نشان می دهد.\r\n\r\nآن را برای اسکن پیشرفت سریع بدون باز کردن جزئیات فایل فعال کنید."
    IDS_PPG_DISPLAY_TT_SHOWTRANSTOOLBAR                        "نوار ابزار اضافی را در پنجره انتقال ها نشان می دهد.\r\n\r\nاگر فضای بیشتری را برای ردیف های انتقال ترجیح می دهید، آن را غیرفعال کنید."
    IDS_PPG_FILES_TT_ADDNEWFILESPAUSED                         "بارگیری‌های تازه در صف را در حالت توقف اضافه می‌کند.\r\n\r\nبرای زمانی که می‌خواهید فایل‌ها را قبل از شروع انتقال مرور یا زمان‌بندی کنید، مفید است."
    IDS_PPG_FILES_TT_BROWSEV                                   "برای پخش کننده ویدیوی خارجی قابل اجرا جستجو می کند.\r\n\r\nبرنامه ای را انتخاب کنید که باید فایل های رسانه ای پیش نمایش شده را باز کند."
    IDS_PPG_FILES_TT_BROWSE_FILECOMPLETEPROGRAM                "برنامه‌ای را که پس از تکمی\r\n\r\nل فایل راه‌اندازی می‌شود، مرور می‌کند."
    IDS_PPG_FILES_TT_DAP                                       "اولویت خودکار را به دانلودهای تازه اضافه شده اختصاص می دهد.\r\n\r\nتوصیه می شود مگر اینکه ترجیح دهید اولویت های دانلود را به صورت دستی مدیریت کنید."
    IDS_PPG_FILES_TT_FILECOMPLETEPROGRAM                       "قابل اجرا برای اجرا پس از تکمیل فایل.\r\n\r\nاز یک مسیر کامل به یک برنامه قابل اعتماد استفاده کنید. مستقیماً بدون پوسته Windows راه اندازی می شود."
    IDS_PPG_FILES_TT_FNC                                       "فیلتر پاکسازی مورد استفاده برا\r\n\r\nی پاکسازی خودکار نام فایل را ویرایش می کند."
    IDS_PPG_FILES_TT_FULLCHUNKTRANS                            "سعی می‌کند در صورت امکان، تکه‌های کامل را در مشتریان آپلود کند.\r\n\r\nاین می‌تواند توزیع تکه‌ها را بهبود بخشد، اما ممکن است برخی از آپلودها را طولانی‌تر نگه دارد."
    IDS_PPG_FILES_TT_REMEMBERCANCELLED                         "فایل‌های لغو شده را به خاطر\r\n\r\nمی‌آورد تا بعداً شناسایی شوند."
    IDS_PPG_FILES_TT_REMEMBERDOWNLOADED                        "دانلودهای تکمیل شده را به خاطر می آورد تا فایل های از\r\n\r\nقبل تمام شده را بتوان بعداً شناسایی کرد."
    IDS_PPG_FILES_TT_STARTNEXTFILECAT                          "هنگام شروع فایل متوقف شده بعدی، فایل هایی را از همان\r\n\r\nدسته فایل تکمیل شده ترجیح دهید."
    IDS_PPG_FILES_TT_STARTNEXTFILECAT2                         "هنگام شروع فایل متوقف شده بعدی، فقط از همان دسته فایل تکمیل شده را انتخاب کنید.\r\n\r\nاز آن برای کنترل دقیق صف هر دسته استفاده کنید."
    IDS_PPG_FILES_TT_UAP                                       "اولویت خودکار را به فایل های به اشتراک گذاشته شده جدید اختصاص می دهد.\r\n\r\nتوصیه می شود مگر اینکه خودتان عمدا اولویت های فایل مشترک را تنظیم کنید."
    IDS_PPG_FILES_TT_VIDEOPLAYER                               "پخش‌کننده خارجی برای پیش‌نمایش رسانه‌ها استفاده می‌شود.\r\n\r\nبرای استفاده از ارتباط پیش‌فرض، آن را خالی بگذارید، یا پخش‌کننده مطمئن خاصی را تنظیم کنید."
    IDS_PPG_FILES_TT_VIDEOPLAYER_ARGS                          "آرگومان‌ها به پخش‌کننده پیش‌نمایش خارجی ارسال می‌شوند.\r\n\r\nاز این فقط در صورتی استفاده کنید که پخش‌کننده به گزینه‌های خط فرمان سفارشی نیاز داشته باشد."
    IDS_PPG_GENERAL_TT_CHECKDAYS                               "تعداد روزهای بین بررسی‌های به‌روزرسانی راه‌اندازی.\r\n\r\nمقادیر بالاتر بررسی‌های شبکه را کاهش می‌دهد. مقادیر پایین تر، نسخه های جدید منتشر شده را زودتر پیدا می کنند."
    IDS_PPG_GENERAL_TT_EXIT                                    "قبل از خروج eM\r\n\r\nule درخواست تأیید می کند."
    IDS_PPG_GENERAL_TT_LANGS                                   "منبع زبان UI بارگیری شده توسط eMuleBB را انتخاب می کند.\r\n\r\nتغییر زبان ممکن است نیاز به باز کردن مجدد گفتگوها قبل از بازخوانی هر برچسب داشته باشد."
    IDS_PPG_GENERAL_TT_NICK                                    "نام کاربری اعلام شده به سایر مشتریان eMule.\r\n\r\nاز یک نام مستعار غیر حساس استفاده کنید. می تواند برای همسالان قابل مشاهده باشد."
    IDS_PPG_IRC_TT_IRC_NICK_BOX                                "نام مستعار مورد استفاده هنگام اتصال به IRC.\r\n\r\nنامی را انتخاب کنید که توسط شبکه IRC مورد قبول باشد."
    IDS_PPG_IRC_TT_IRC_PERFORM_BOX                             "دستورات پس از اتصال IRC در صورت فعال\r\n\r\nبودن اجرا به طور خودکار اجرا می شوند."
    IDS_PPG_IRC_TT_IRC_SERVER_BOX                              "آدرس سرور IRC که توسط سرو\r\n\r\nیس گیرنده داخلی IRC استفاده می شود."
    IDS_PPG_MESSAGES_TT_FILTER                                 "فیلتر متن برای پیام‌های چت ورودی.\r\n\r\nاز آن برای سرکوب کلمات یا الگوهای مزاحم شناخته شده استفاده کنید."
    IDS_PPG_MESSAGES_TT_INDICATERATINGS                        "نمادی را برای دانلودهایی که دارای نظرات یا رتبه‌بندی هستند نشان می‌دهد.\r\n\r\nزمانی که می‌خواهید بازخورد انجمن را قبل از باز کردن فایل‌ها مرور کنید مفید است."
    IDS_PPG_MESSAGES_TT_MSHOWSMILEYS                           "صورتک ها را در پیام های چت نمایش می دهد.\r\n\r\nاگر رندر متن ساده را ترجیح می دهید، آن را غیرفعال کنید."
    IDS_PPG_PROXY_TT_PASSWORD                                  "رمز عبور حساب پراکسی.\r\n\r\nآن را خالی بگذارید مگر اینکه احراز هویت پراکسی فعال باشد و توسط سرور پراکسی مورد نیاز باشد."
    IDS_PPG_SCHEDULER_TT_DATETIMEPICKER1                       "زمان شروع برای ورودی برنامه انتخابی.\r\n\r\nقانون در این زمان در الگوی روز انتخابی فعال می شود."
    IDS_PPG_SCHEDULER_TT_DATETIMEPICKER2                       "زمان پایان برای ورودی برنامه انتخابی.\r\n\r\nزمان پایان زمانی که قانون باید فعال بماند تا زمانی که برنامه زمانی دیگری آن را تغییر دهد، غیرفعال کنید."
    IDS_PPG_SCHEDULER_TT_NEW                                   "یک ورودی برنامه زمانی جدید ایجاد می کند.\r\n\r\nجزئیات آن را ویرایش کنید و روی Apply کلیک کنید تا قانون پیکربندی شده ذخیره شود."
    IDS_PPG_SCHEDULER_TT_REMOVE                                "ورودی زمانبندی انتخابی را حذف می کند.\r\n\r\nفقط پس از انتخاب قانونی که دیگر نمی خواهید از آن استفاده کنید."
    IDS_PPG_SCHEDULER_TT_SCHEDACTION                           "اقداماتی که ورودی ب\r\n\r\nرنامه انتخابی اعمال می‌شود."
    IDS_PPG_SCHEDULER_TT_SCHEDLIST                             "فهرست ورودی‌های زمان‌بندی پیکربندی‌شده.\r\n\r\nیک ورودی را برای ویرایش عنوان، زمان، الگوی روز، وضعیت فعال و اقدامات آن انتخاب کنید."
    IDS_PPG_SCHEDULER_TT_S_ENABLE                              "ورودی زمانبندی انتخابی را فعال یا غیرفعال می کند.\r\n\r\nاز این برای توقف یک قانون بدون حذف آن استفاده کنید."
    IDS_PPG_SCHEDULER_TT_S_TITLE                               "نام نمایشی برای ورودی برنامه انتخابی.\r\n\r\nاز نام کوتاهی استفاده کنید که مشخص کند قانون چه چیزی را تغییر می دهد."
    IDS_PPG_SCHEDULER_TT_TIMESEL                               "الگوی روز برای ورودی برنامه انتخابی.\r\n\r\nانتخاب کنید زمان شروع و پایان چه زمانی اعمال شود."
    IDS_PPG_SECURITY_TT_DD                                     "تاریخچه URL ذخیره شده فیلتر IP را برای انتخاب سریع باز می کند.\r\n\r\nفقط از ارائه دهندگان فیلتر قابل اعتماد استفاده کنید."
    IDS_PPG_SECURITY_TT_DISABLEOBFUSCATION                     "پشتیبانی از اتصالات مبهم را به طور کامل غیرفعال می کند.\r\n\r\nتوصیه نمی شود مگر اینکه به رفتار قدیمی سختگیرانه نیاز داشته باشید."
    IDS_PPG_SECURITY_TT_EDITFILTER                             "فایل فیلتر محلی IP را برای ویرایش دستی باز می کند.\r\n\r\nبا دقت ذخیره کنید. ورودی های نامعتبر ممکن است نادیده گرفته شوند."
    IDS_PPG_SECURITY_TT_LOADURL                                "لیست فیلتر IP را از URL پیکربندی شده دانلود و اعمال می کند.\r\n\r\nفقط از ارائه دهندگان مورد اعتماد استفاده کنید فیلتر موجود در صورت عدم موفقیت در دانلود حفظ می شود."
    IDS_PPG_SECURITY_TT_RELOADFILTER                           "فایل فیلتر محلی IP را از دیسک بارگیری مجدد می کند.\r\n\r\nپس از ویرایش دستی فایل فیلتر خارج از eMuleBB از آن استفاده کنید."
    IDS_PPG_SERVER_TT_EDITADR                                  "URL های به روز رسانی لیست سرور راه اندازی را ویرایش می کند.\r\n\r\nفقط از منابع server.met مطمئن استفاده کنید لیست های غیر قابل اعتماد می توانند کشف سرور را آلوده کنند."
    IDS_PPG_STATS_TT_COLOR_BUTTON                              "انتخابگر رنگ را برای عنصر آمار انتخاب شده باز می کند.\r\n\r\nپس از انتخاب یک عنصر در انتخابگر رنگ، از آن استفاده کنید."
    IDS_WEBSERVER_TT_CERTBROWSE                                "فایل گواهی HTTPS را جستجو می کند.\r\n\r\nاز یک فایل گواهی که با کلید خصوصی پیکربندی شده مطابقت دارد استفاده کنید."
    IDS_WEBSERVER_TT_CERTPATH                                  "فایل گواهی زمانی که HTTPS فعال است استفاده می شود.\r\n\r\nاگر این فایل موجود نباشد یا نامعتبر باشد، WebServer نمی تواند در حالت HTTPS شروع به کار کند."
    IDS_WEBSERVER_TT_KEYBROWSE                                 "فایل کلید خص\r\n\r\nوصی HTTPS را مرور می کند."
    IDS_WEBSERVER_TT_KEYPATH                                   "فایل کلید خصوصی زمانی که HTTPS فعال است استفاده می شود.\r\n\r\nاز این فایل محافظت کنید. هر کسی که این کلید را داشته باشد می تواند گواهینامه WebServer را جعل کند."
    IDS_WEBSERVER_TT_WEB_GENERATE                              "یک گواهی محلی و کلید خصوصی جدید برای HTTPS ایجاد می کند.\r\n\r\nاز این برای تنظیمات شبکه محلی یا قابل اعتماد زمانی که گواهی خود را ارائه نمی کنید استفاده کنید."
    IDS_WEBSERVER_TT_WSENABLEDLOW                              "حساب WebServer با حقوق پایین را فعال می کند.\r\n\r\nاز آن برای کلاینت هایی استفاده کنید که نباید دسترسی مدیریتی کامل به وب داشته باشند."
    IDS_WEBSERVER_TT_WSPASS                                    "رمز عبور برای حساب اصلی WebServer.\r\n\r\nاز یک رمز عبور منحصر به فرد قوی استفاده کنید، به خصوص اگر WebServer فراتر از لوکال هاست قابل دسترسی باشد."
    IDS_WEBSERVER_TT_WSPASSLOW                                 "رمز عبور برای حساب WebServer با حقوق پایین.\r\n\r\nاز یک رمز عبور متفاوت از حساب اصلی استفاده کنید."
    IDS_WEBSERVER_TT_WSPORT                                    "درگاه TCP که توسط WebServer و REST API استفاده می شود.\r\n\r\nآن را فقط زمانی تغییر دهید که قوانین فایروال، پروکسی معکوس یا روتر برای مطابقت به روز شوند."
    IDS_WEBSERVER_TT_WSTIMEOUT                                 "زمان پایان جلسه برای ورود به سیستم WebServer در چند دقیقه.\r\n\r\nتایم اوت های طولانی تر راحت تر هستند."
    IDS_PPG_DEBUG_TT_SERVER                                    "دسته‌های گزارش اشکا\r\n\r\nل‌زدایی سمت سرور را فعال می‌کند."
    IDS_PPG_DEBUG_TT_CLIENT                                    "دسته‌های ثبت اشکال‌زدایی\r\n\r\nسمت سرویس گیرنده را فعال می‌کند."
