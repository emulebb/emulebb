    IDS_NOTIFICATION_MODE_CUSTOM_POPUP                         "پنجره بازشو سفارشی"
    IDS_EMAILNOT_GROUP_FMT                                     "(*) %s"
    IDS_FOLLOW_MAJORITY_FILENAME                               "نام فایل اکثریت را دنبال کنید"
    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "کپی پیوندهای eD2K در کلیپ بورد (Kad)"
