    IDS_TWEAKS_VALIDATION_UINT_KIB_RANGE_FMT                   "Verwacht bereik: %u..%u KiB."
    IDS_TWEAKS_VALIDATION_INT_RANGE_FMT                        "Verwacht bereik: %d..%d."
    IDS_TWEAKS_VALIDATION_LOG_FILE_SIZE_RANGE_FMT              "Verwacht bereik: 0..%u KiB. Gebruik 0 voor geen rotatielimiet."
    IDS_TWEAKS_VALIDATION_MINUTES_RANGE_FMT                    "Verwacht bereik: 1..%u minuten."
    IDS_BIND_ANY_INTERFACE                                     "Elke interface"
    IDS_BIND_STATUS_ACTIVE_ANY                                 "Actieve P2P-binding: elke interface."
    IDS_BIND_STATUS_ACTIVE_FMT                                 "Actieve P2P-binding: %s"
    IDS_BIND_STATUS_INTERFACE_NOT_FOUND_FMT                    "Actieve P2P-binding: elke interface. De opgeslagen interface is niet beschikbaar: %s"
    IDS_BIND_STATUS_INTERFACE_AMBIGUOUS_FMT                    "Actieve P2P-binding: elke interface. De opgeslagen interfacenaam is dubbelzinnig: %s"
    IDS_BIND_STATUS_INTERFACE_NO_ADDRESS_FMT                   "Actieve P2P-binding: elke interface. De opgeslagen interface heeft geen bruikbaar IPv4-adres: %s"
    IDS_BIND_STATUS_INTERFACE_ADDRESS_MISSING_FMT              "Actieve P2P-binding: elke interface. De opgeslagen binding IP ontbreekt op de geselecteerde interface: %s"
    IDS_BIND_STATUS_ADDRESS_MISSING_FMT                        "Actieve P2P-binding: elke interface. De opgeslagen binding IP ontbreekt op alle live-interfaces: %s"
    IDS_BIND_RESTART_REQUIRED                                  "Opnieuw opstarten vereist: de nieuwe bindingsinstellingen worden pas van kracht na het opnieuw opstarten van eMule."
    IDS_BIND_RESTART_FALLBACK_DEFAULT                          "Bij opnieuw opstarten wordt teruggevallen op de standaardinterface omdat het opgeslagen bindingsdoel niet is opgelost."
    IDS_BIND_ADDRESS_INVALID_IPV4                              "BindAddr moet leeg zijn of een geldig IPv4-adres zijn."
    IDS_EQUIVALENT                                             "Equivalent"
    IDS_UNIT_KIB_PER_SEC                                       "KiB/s"
    IDS_RANDOMIZE_PORTS_ON_STARTUP                             "Willekeurige luisterpoorten bij het opstarten"
    IDS_STARTUP_BIND_BLOCK                                     "Houd netwerken offline als het bindingsdoel niet beschikbaar is bij het opstarten"
    IDS_SPEED_MIB_PER_SEC_FMT                                  "%.2f MiB/s"
    IDS_WEB_MAX_UPLOAD_MIB_LABEL                               "Maximale upload MiB:"
    IDS_WEB_ALLOWED_IPS_LABEL                                  "Toegestane IP's:"
    IDS_WEB_INVALID_UPLOAD_SIZE_MIB                            "Voer een geldige WebServer-uploadgrootte in MiB in."
    IDS_WEB_INVALID_ALLOWED_IP_FMT                             "Ongeldig toegestaan ​​WebServer IP-adres ""%s"".\r\n\r\nGebruik door puntkomma's gescheiden IPv4-adressen of laat het veld leeg om elk extern adres toe te staan."
    IDS_USE_WINDOWS_TOAST_NOTIFICATIONS                        "Gebruik Windows-toastmeldingen"
    IDS_NOTIFICATION_DISPLAY_MODE                              "Weergavemodus:"
    IDS_NOTIFICATION_MODE_WINDOWS_TOAST                        "Windows-toast"
    IDS_NOTIFICATION_MODE_CLASSIC_TRAY_BALLOON                 "Klassieke dienbladballon"
    IDS_NOTIFICATION_MODE_CUSTOM_POPUP                         "Aangepaste pop-up"
    IDS_EMAILNOT_GROUP_FMT                                     "(*) %s"
    IDS_FOLLOW_MAJORITY_FILENAME                               "Volg de meerderheidsbestandsnaam"
    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "Kopieer eD2K-koppelingen naar het klembord (Kad)"
    IDS_SHUTTING_DOWN_EMULE                                    "eMule afsluiten"
    IDS_SEARCHPARAMS_NAME_LABEL                                "&Naam:"
    IDS_SEARCHPARAMS_TYPE_LABEL                                "&Type"
    IDS_SEARCHPARAMS_METHOD_LABEL                              "&Methode:"
    IDS_SEARCHPARAMS_START_BUTTON                              "&Zoeken Ga"
    IDS_SEARCHPARAMS_MORE_BUTTON                               "&Meer"
    IDS_SEARCHPARAMS_RESET_BUTTON                              "&Opnieuw instellen"
    IDS_SEARCHPARAMS_CANCEL_BUTTON                             "&Annuleren"
    IDS_STATUS_BIND_IP_LABEL                                   "IP binden"
    IDS_STATUS_PUBLIC_IP_LABEL                                 "Openbaar IP"
    IDS_STATUS_NETWORK_ADDRESS_TOOLTIP_FMT                     "%s: %s | %s: %s"
    IDS_PREVIEW_REQUESTED_WAIT                                 "Voorbeeld aangevraagd - Even geduld a.u.b"
    IDS_SEARCH_INFOTIP_SOURCES                                 "Bronnen"
    IDS_SEARCH_INFOTIP_SERVERS                                 "Servers"
    IDS_NO_MATCHING_ENTRY_FOUND                                "Geen overeenkomend item gevonden."
    IDS_FATAL_NO_RICHEDIT                                      "Fatale fout: geen Rich Edit-controlebibliotheek gevonden!"
    IDS_FATAL_KAD_UNICODE_TABLES                               "Fatale fout: Kan Unicode-tekentabellen voor Kademlia niet laden!"
    IDS_KAD_UNICODE_MAP_NOT_INITIALIZED                        "Kad Unicode-tekenkaart in kleine letters niet geïnitialiseerd!"
    IDS_TWEAKS_TT_CONDITIONAL_TCP_ACCEPT                       "Geeft er de voorkeur aan om inkomende TCP-verbindingen alleen te accepteren als ze er nuttig uitzien.\r\n\r\nGeavanceerde aanpassing van het verkeer. Laat deze op de standaardwaarde staan, tenzij u de verbindingsdruk diagnosticeert."
    IDS_TWEAKS_TT_MAX_CON5_SEC                                 "Maximaal aantal nieuwe TCP-verbindingen eMule kan binnen vijf seconden worden geopend.\r\n\r\nLagere waarden zijn vriendelijker voor Windows en routers. Laat dit op de standaardwaarde staan, tenzij u het gedrag van verbindingsburst aanpast."
    IDS_TWEAKS_TT_MAX_HALF_OPEN                                "Bovengrens voor half-open uitgaande TCP-verbindingspogingen.\r\n\r\nMeestal een compatibiliteitsgarantie. De standaardinstelling is doorgaans de juiste keuze, tenzij u installatieproblemen met TCP onderzoekt."
    IDS_TWEAKS_TT_CONNECTION_TIMEOUT                           "Hoe lang eMule wacht tot een nieuwe verbinding vooruitgang boekt voordat hij deze als mislukt beschouwt.\r\n\r\nKorte waarden herstellen zich sneller van dode peers; langere waarden zijn toleranter ten opzichte van trage netwerken. Standaardwaarden worden aanbevolen."
    IDS_TWEAKS_TT_DOWNLOAD_TIMEOUT                             "Hoe lang een downloadbron inactief mag blijven voordat eMule deze als vastgelopen laat vallen.\r\n\r\nLagere waarden ruimen dode bronnen sneller op, maar zeer lage waarden kunnen trage peers schaden. Laat de standaardinstelling staan, tenzij u een diagnose stelt van stallingen."
    IDS_TWEAKS_TT_SERVER_KEEP_ALIVE_TIMEOUT                    "Hoe vaak eMule een anderszins inactieve serververbinding vernieuwt.\r\n\r\nGebruik minuten. Stel 0 in om keepalives uit te schakelen. Laat de standaardinstelling staan, tenzij u een specifiek probleem met het verbreken van de verbinding met de server oplost."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_RESULTS                      "Maximaal aantal resultaten dat wordt opgevraagd bij een eD2K-server voor één zoekopdracht.\r\n\r\nHogere waarden kunnen meer bestanden vinden, maar verhogen het serverwerk en de UI-ruis. Blijf in de buurt van de standaardwaarde, tenzij u een specifieke reden heeft."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_MORE_REQUESTS                "Maximaal aantal vervolgresultatenpagina's eMule-verzoeken van een eD2K-zoekopdracht.\r\n\r\nHogere waarden kunnen meer resultaten opleveren, maar kosten meer serververkeer en tijd. Conservatieve waarden worden aanbevolen."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_TOTAL                        "Doelaantal resultaten voor zoekopdrachten naar Kad-bestanden.\r\n\r\nHogere waarden zoeken breder, maar houden Kad-zoekopdrachten langer actief. Blijf in de buurt van de standaard, tenzij u diepere zoekopdrachten wilt."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_TOTAL                     "Doelaantal resultaten voor zoekopdrachten met trefwoorden Kad.\r\n\r\nHogere waarden kunnen meer overeenkomsten opleveren, maar verhogen de Kad-querybelasting en UI-ruis. De standaard is meestal het juiste evenwicht."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_LIFETIME                     "Maximale levensduur van één Kad-bestandszoekopdracht in seconden.\r\n\r\nVerhoog deze optie alleen als u opzettelijk langer lopende Kad-zoekopdrachten wilt."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_LIFETIME                  "Maximale levensduur van één zoekopdracht met Kad trefwoorden in seconden.\r\n\r\nEen langere levensduur kan latere resultaten opleveren, maar verhoogt de zoekactiviteit op de achtergrond."
    IDS_TWEAKS_TT_GENERAL_ADVANCED                             "Algemeen geavanceerd gedrag dat niet goed past onder netwerk, bestand, beeldscherm of beveiliging.\r\n\r\nDe meeste gebruikers zouden deze op de standaardwaarden moeten laten staan."
    IDS_TWEAKS_TT_HIDDEN_FILE                                  "Geavanceerd gedrag bij bestandsverwerking, preview-inspectie en opties gerelateerd aan de bestandsgeschiedenis.\r\n\r\nDeze instellingen bepalen hoe eMule bestanden behandelt, niet hoeveel schijfruimte het reserveert."
    IDS_TWEAKS_TT_STORAGE_PERSISTENCE                          "Geavanceerde schijfruimtebescherming, bestandsbuffering en instellingen voor persistentie van metagegevens.\r\n\r\nDit is de hoofdgroep voor opslagveiligheid en schijf-I/O-afwegingen."
    IDS_TWEAKS_TT_HIDDEN_STARTUP                               "Geavanceerd gedrag bij opstartherstel.\r\n\r\nDeze opties hebben alleen invloed op welke UI-vensters terugkomen wanneer eMule start."
    IDS_TWEAKS_TT_HIDDEN_DISPLAY                               "Geavanceerde instellingen voor weergave, taakbalk, lade en visuele informatie.\r\n\r\nDeze opties veranderen alleen de presentatie, niet het overdrachtsgedrag."
    IDS_TWEAKS_TT_HIDDEN_SECURITY                              "Geavanceerde filter- en beveiligingsopties voor striktere verwerking van peers en berichten.\r\n\r\nAanbevolen standaardwaarden zijn geschikt voor de meeste gebruikers."
    IDS_TWEAKS_TT_LOGGING_GROUP                                "Continue controle op logboekregistratie en diagnostische uitvoer.\r\n\r\nDe meeste van deze instellingen zijn alleen nuttig bij het diagnosticeren van een probleem."
    IDS_TWEAKS_TT_AUTO_TAKE_ED2K_LINKS                         "Registreert eMule als de standaardhandler voor ed2k:// links.\r\n\r\nSchakel dit in als deze machine ed2k-links in eMule automatisch moet openen. Schakel het uit als een ander hulpmiddel eigenaar zou moeten zijn van die koppeling."
    IDS_TWEAKS_TT_CREDIT_SYSTEM                                "Gebruikt het normale eMule-creditsysteem bij het rangschikken van uploadclients.\r\n\r\nAanbevolen: ingeschakeld. Schakel het alleen uit voor foutopsporing of opzettelijke compatibiliteitsexperimenten."
    IDS_TWEAKS_TT_YOUR_HOSTNAME                                "Optioneel hostnaamlabel eMule rapporteert waar uw lokale identiteitstekst wordt weergegeven.\r\n\r\nLaat dit leeg tenzij u deze instantie opzettelijk een naam wilt geven."
    IDS_TWEAKS_TT_TXT_EDITOR                                   "Commando dat wordt gebruikt wanneer eMule tekstbestanden opent, zoals logbestanden of gegenereerde tekstuitvoer.\r\n\r\nGebruik een volledig pad als de editor zich niet op PATH bevindt. De standaardwaarde is notepad.exe."
    IDS_TWEAKS_TT_HIGHRES_TIMER                                "Verzoekt een Windows-timer met hoge resolutie terwijl eMule actief is.\r\n\r\nDit kan de timing op sommige systemen vloeiender maken, maar het kan het stroomverbruik verhogen. Start eMule opnieuw nadat u deze hebt gewijzigd."
    IDS_TWEAKS_TT_ICH                                          "Maakt intelligente corruptieafhandeling mogelijk voor beschadigde gedownloade chunks.\r\n\r\nAanbevolen: ingeschakeld. Het helpt bij het herstellen van goede gegevens in beschadigde delen in plaats van meer dan nodig opnieuw te downloaden."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS                         "Bepaalt of mediavoorbeelden worden aangeboden voordat volledig aan de normale veiligheidscontroles voor previews is voldaan.\r\n\r\nHogere niveaus zorgen ervoor dat previews eerder beschikbaar zijn, maar mislukte of misleidende previews worden waarschijnlijker."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_DISABLED                "Gebruik de normale conservatieve voorbeeldregels."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_ALLOW                   "Sta een voorbeeld toe met kleinere beschikbare blokken nadat de normale metadata en spelercontroles zijn verstreken."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_FORCE                   "Bied een voorbeeld aan, zelfs als het eerste blok ontbreekt.\r\n\r\nGebruik alleen met spelers die onvolledige media kunnen verdragen, zoals VLC."
    IDS_TWEAKS_TT_BEEP_ON_ERROR                                "Speelt het systeemfoutgeluid af wanneer eMule belangrijke fouten rapporteert.\r\n\r\nHandig voor probleemoplossing zonder toezicht. Schakel het uit als hoorbare waarschuwingen afleidend zouden zijn."
    IDS_TWEAKS_TT_SHOW_COPY_ED2K_LINK_CMD                      "Wijzigt de bestandscontextmenu's zodat een directe opdracht 'Kopieer ed2k Link' wordt weergegeven in plaats van de standaardactie 'Toon ed2k Link'.\r\n\r\nSchakel dit in als het kopiëren van koppelingen uw normale workflow is."
    IDS_TWEAKS_TT_SPARSE_PART_FILES                            "Gebruikt beperkte bestanden voor deelbestanden wanneer het bestandssysteem deze ondersteunt.\r\n\r\nAanbevolen: ingeschakeld op NTFS om de schijftoewijzing vooraf te verminderen. Alleen uitschakelen als het gedrag van sparse-bestanden een bestandssysteemspecifiek probleem veroorzaakt."
    IDS_TWEAKS_TT_FULL_ALLOC                                   "Wijst vooraf de volledige doelbestandsgrootte op schijf toe wanneer het downloaden start.\r\n\r\nKan fragmentatie verminderen, maar reserveert onmiddellijk ruimte en kost meer schijfwerk. Laat het uitgeschakeld, tenzij u de voorkeur geeft aan volledige toewijzing vooraf."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_CONFIG                   "Minimale vrije ruimte gereserveerd op het volume dat de configuratiebestanden van eMule host.\r\n\r\nHard minimum: 1 GiB. Als dit volume onder de effectieve limiet komt, stopt eMule alle downloads en slaat onmiddellijk .part.met-bestanden op.\r\nAls config een volume deelt met tijdelijk of inkomend, wint de grootste limiet op dat volume."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_TEMP                     "Minimale vrije ruimte gereserveerd op elk volume waarop tijdelijke bestanden worden gehost.\r\n\r\nHard minimum: 5 GiB. Als een beschermd volume onder de effectieve limiet komt, stopt eMule alle downloads en slaat onmiddellijk .part.met-bestanden op.\r\nAls temp een volume deelt met configuratie of inkomend, wint de grootste limiet op dat volume."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_INCOMING                 "Minimale vrije ruimte gereserveerd op elk volume waarop inkomende bestanden worden gehost, inclusief categoriespecifieke inkomende mappen.\r\n\r\nHard minimum: 5 GiB. Als inkomend een volume deelt met config of temp, wint de grootste limiet op dat volume en worden alle downloads gestopt wanneer deze wordt overschreden."
    IDS_TWEAKS_TT_PERF_LOG                                     "Schrijft periodieke payload- en overheadvoorbeelden voor externe grafische tools.\r\n\r\nAlleen operator/debug-functie. Laat het uitgeschakeld, tenzij u de gegenereerde bestanden actief gebruikt."
    IDS_TWEAKS_TT_COMMIT                                       "Bepaalt hoe agressief eMule Windows dwingt om opgeslagen bestandsgegevens naar schijf te spoelen.\r\n\r\nVeiliger instellingen verminderen het risico op crashverlies, maar kosten meer schijf-I/O. 'Alleen bij afsluiten' is de gebalanceerde standaard."
    IDS_TWEAKS_TT_COMMIT_NEVER                                 "Sluit bestanden normaal zonder een schijfspoeling op besturingssysteemniveau te forceren.\r\n\r\nSnelste en lichtste schijf-I/O, maar het meest afhankelijk van Windows later leegmaken."
    IDS_TWEAKS_TT_COMMIT_ON_SHUTDOWN                           "Forceer het leegmaken van de schijf op besturingssysteemniveau alleen terwijl eMule wordt gesloten.\r\n\r\nAanbevolen standaard. Het verbetert de persistentieveiligheid bij een schone uitgang zonder extra spoelingen te forceren tijdens elke opslag."
    IDS_TWEAKS_TT_COMMIT_ALWAYS                                "Forceer een schijfspoeling op besturingssysteemniveau op elk opslagpad dat de commit-close-helper van eMule gebruikt.\r\n\r\nVeiligst tegen crashes of verlies van metagegevens door stroomverlies, maar veroorzaakt de meeste schijf-I/O."
    IDS_TWEAKS_TT_EXTRACT_META_DATA                            "Bepaalt of eMule metagegevens zoals tags en mediaduur uit bestanden extraheert.\r\n\r\nHandig voor rijkere bestandsinformatie, maar voegt achtergrondinspectie van bestanden toe. Schakel het uit als u zo licht mogelijk wilt scannen."
    IDS_TWEAKS_TT_GEO_LOCATION_ENABLED                         "Lost peer-IP's op naar locatiegegevens op landniveau voor weergave.\r\n\r\nPuur informatief. Schakel het uit als u niet geïnteresseerd bent in landvlaggen of als u de achtergrond niet wilt vernieuwen."
    IDS_TWEAKS_TT_CLOSE_U_PN_P_PORTS                           "Sluit routertoewijzingen bij schoon afsluiten wanneer automatische NAT-toewijzing werd gebruikt.\r\n\r\nAanbevolen: ingeschakeld. Schakel het alleen uit als u opzettelijk wilt dat de toewijzingen achterblijven."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE                          "Selecteert hoe eMule automatische NAT-toewijzing uitvoert.\r\n\r\nAanbevolen: Automatisch. Dat probeert eerst UPnP IGD en valt indien nodig terug op PCP/NAT-PMP."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_AUTOMATIC                "Aanbevolen modus. Probeer eerst UPnP IGD en val dan terug naar PCP/NAT-PMP als de mapping mislukt."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_IGD_ONLY                 "Gebruik alleen UPnP IGD-toewijzing. Kies dit als u strikt klassiek UPnP-gedrag wilt."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_PCP_NAT_PMP_ONLY         "Gebruik alleen PCP/NAT-PMP-toewijzingen. Kies dit alleen als uw routeromgeving hier duidelijk de voorkeur aan geeft."
    IDS_TWEAKS_TT_FILE_BUFFER_TIME_LIMIT                       "Maximale leeftijd van gebufferde bestandsgegevens voordat eMule deze naar schijf leegmaakt.\r\n\r\nLagere waarden verminderen het risico op gegevens tijdens crashes. Hogere waarden kunnen het schijfverloop verminderen. De standaardinstelling is meestal een goed compromis."
    IDS_TWEAKS_TT_FILE_BUFFER_SIZE                             "Grootte van de schrijfbuffer per bestand die wordt gebruikt voordat de downloadgegevens naar de schijf worden gespoeld.\r\n\r\nGrotere buffers kunnen de schijfactiviteit verminderen, maar ze verhogen het geheugengebruik en vertragen het schrijven. Houd gematigde waarden aan, tenzij u afstemt op een specifieke opslagconfiguratie."
    IDS_TWEAKS_TT_QUEUE_SIZE                                   "Doelgrootte van de uploadwachtrij.\r\n\r\nHogere waarden zorgen ervoor dat meer clients kunnen wachten, maar voegen geheugengebruik en beheeroverhead toe. Standaardwaarden worden aanbevolen voor de meeste gebruikers."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LISTS                      "Aangepaste datum-/tijdnotatie gebruikt in lijstweergaven.\r\n\r\nLaat dit veld leeg om de normale standaardopmaak te gebruiken. Wijzig dit alleen als u een specifieke aangepaste tijdstempelstijl wilt."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT                             "Aangepaste datum-/tijdnotatie gebruikt door algemene bestands- en peer-detailweergaven.\r\n\r\nGebruikt CTime-opmaaktokens. Houd het niet leeg; ongeldige tokens kunnen verwarrende tijdstempels opleveren."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LOG                        "Aangepaste datum-/tijdnotatie gebruikt in logregels en logachtige statusuitvoer.\r\n\r\nGebruikt CTime-opmaaktokens. Houd het beknopt, zodat logregels leesbaar blijven."
    IDS_TWEAKS_TT_ICON_FLASH_ON_NEW_MESSAGE                    "Het systeemvakpictogram knippert wanneer er een nieuw chatbericht binnenkomt.\r\n\r\nPuur een meldingsvoorkeur. Schakel dit in als u wilt dat berichten opvallen terwijl eMule wordt geminimaliseerd."
    IDS_TWEAKS_TT_INSPECT_ALL_FILE_TYPES                       "Voer ook het dure inspectiepad in MediaInfo-stijl uit voor bestandstypen die nog niet zijn geclassificeerd als audio of video.\r\n\r\nSchakel dit in als u uitgebreidere bestandsinformatie wilt zoeken naar ongebruikelijke of verkeerd gelabelde bestanden. Laat het uitgeschakeld om alleen waarschijnlijke audio-/videobestanden te inspecteren en de achtergrondinspectiewerkzaamheden te verminderen."
    IDS_TWEAKS_TT_RE_BAR_TOOLBAR                               "Gebruikt de oudere hoofdwerkbalkcontainer in wapeningstijl in plaats van de eenvoudigere, gewone werkbalkindeling.\r\n\r\nMeestal een voorkeur voor de indeling van de gebruikersinterface. Laat dit alleen ingeschakeld als u de voorkeur geeft aan de oudere werkbalkpresentatie."
    IDS_TWEAKS_TT_SHOW_UP_DOWN_ICON_IN_TASKBAR                 "Toont het gecombineerde pictogram voor upload-/downloadsnelheid in het systeemvak van de taakbalk.\r\n\r\nPuur visueel. Schakel dit uit als u een schoner ladegebied wilt."
    IDS_TWEAKS_TT_ALWAYS_SHOW_TRAY_ICON                        "Houdt het pictogram eMule zichtbaar in het systeemvak Windows terwijl eMule actief is.\r\n\r\nKlassieke ladeballonmeldingen en minimaliseren naar lade kunnen er nog steeds voor zorgen dat het ladepictogram zichtbaar wordt wanneer dit is uitgeschakeld."
    IDS_TWEAKS_TT_SHOW_VERTICAL_HOUR_MARKERS                   "Tekent uurmarkeringen in de langetermijnstatistiekengrafieken.\r\n\r\nHandig voor het lezen van op tijd gebaseerde verkeerspatronen. Schakel het uit als u de voorkeur geeft aan minder rommel in de grafieken."
    IDS_TWEAKS_TT_FORCE_SPEEDS_TO_KB                           "Dwingt tariefweergaven af ​​om eenheden in KB/s-stijl te gebruiken in plaats van automatisch te schalen naar grotere eenheden.\r\n\r\nSchakel dit in als u de voorkeur geeft aan vaste, bekende eenheden. Laat het uitgeschakeld voor beter leesbare displays met grote snelheid."
    IDS_TWEAKS_TT_REARRANGE_KAD_SEARCH_KEYWORDS                "Herschikt zoektermen voor trefwoorden Kad om eerst een nuttiger zoekopdrachtvorm te proberen.\r\n\r\nGeavanceerde aanpassing van het zoekgedrag. Laat dit op de standaardwaarde staan, tenzij u het zoekgedrag van Kad opzettelijk aanpast."
    IDS_TWEAKS_TT_MESSAGE_FROM_VALID_SOURCES_ONLY              "Accepteert alleen berichten van collega's die er al uitzien als geldige bronnen voor uw overdrachten.\r\n\r\nSterkere privacy-/spambescherming, maar kan ongevraagd contact blokkeren. Schakel dit in als u een strenger berichtenbeleid wilt."
    IDS_TWEAKS_TT_MAX_CHAT_HISTORY_LINES                       "Maximaal aantal geschiedenisregels dat per chat of IRC-kanaalweergave wordt bewaard.\r\n\r\nHogere waarden behouden meer context, maar gebruiken meer geheugen en kunnen ervoor zorgen dat drukke chats langzamer worden weergegeven."
    IDS_TWEAKS_TT_MAX_MESSAGE_SESSIONS                         "Maximaal aantal peer-berichtsessies dat tegelijk wordt bewaard.\r\n\r\nHogere waarden houden meer gesprekken beschikbaar, maar verhogen het geheugengebruik. De standaard is conservatief."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP                            "Beheert het maken van crashdumps wanneer eMule een onverwerkte crash tegenkomt.\r\n\r\nCrashdumps helpen bij het diagnosticeren van harde fouten, maar kunnen procesgeheugen bevatten. Deel ze alleen met vertrouwde ontwikkelaars."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_DISABLED                   "Maak geen crashdumpbestanden."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_PROMPT                     "Vraag voordat u een crashdump schrijft wanneer er een crash optreedt."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_ALWAYS                     "Maak automatisch een crashdump wanneer er een crash optreedt.\r\n\r\nBest voor het opsporen van fouten in herhaalbare crashes op een vertrouwde machine."
    IDS_TWEAKS_TT_MAX_LOG_FILE_SIZE                            "Maximale grootte van elk logbestand op schijf in KiB.\r\n\r\nGebruik 0 voor geen rotatielimiet. Zeer grote waarden houden meer geschiedenis bij, maar verbruiken meer schijfruimte."
    IDS_TWEAKS_TT_MAX_LOG_BUFFER                               "Maximale logweergavebuffer in het geheugen in KiB.\r\n\r\nHogere waarden zorgen voor een beter zichtbare loggeschiedenis, maar gebruiken meer geheugen en kunnen zeer drukke logweergaven vertragen."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT                              "Codering die wordt gebruikt voor nieuw geopende logbestanden op schijf.\r\n\r\nHet wijzigen hiervan terwijl de logbestanden al open zijn, blijft bestaan, maar de nieuwe indeling wordt gebruikt nadat het logbestand opnieuw is geopend of eMule opnieuw is opgestart."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UNICODE                      "Schrijf logs als UTF-16 Unicode. Dit is de oude standaard en behoudt de Windows-tekst in grote lijnen."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UTF8                         "Schrijf logs als UTF-8. Handig voor tools die moderne UTF-8-tekstbestanden verwachten."
    IDS_TWEAKS_TT_LOG2_DISK                                    "Schrijft het normale applicatielogboek naar schijf in plaats van het alleen in het geheugen te bewaren.\r\n\r\nHandig voor foutopsporing en langdurig onbeheerd gebruik, maar het voegt schijfschrijfbewerkingen toe. Laat het uitgeschakeld, tenzij u permanente logboeken wilt."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT                         "Uitvoerformaat voor voorbeelden van prestatieregistratie.\r\n\r\nCSV is het gemakkelijkst handmatig te inspecteren. MRTG schrijft zijspanbestanden voor grafische tools die invoer in MRTG-stijl verwachten."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_CSV                     "Schrijf één CSV-prestatielogbestand met tijdstempel van de payload en overheadvoorbeelden."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_MRTG                    "Schrijf gegevens in MRTG-stijl en zijspanbestanden die zijn afgeleid van het geconfigureerde basispad."
    IDS_TWEAKS_TT_PERF_LOG_FILE                                "Basisbestandspad voor prestatieregistratie.\r\n\r\nLaat dit leeg om het standaardbestand in de configuratiemap van eMule te gebruiken. De MRTG-modus leidt _data- en _overhead-bestanden af ​​van dit pad."
    IDS_TWEAKS_TT_PERF_LOG_INTERVAL                            "Bemonsteringsinterval voor prestatieregistratie in minuten.\r\n\r\nKorte intervallen zorgen voor fijnere grafieken, maar meer schijfschrijfbewerkingen. Gebruik 1..1440."
    IDS_TWEAKS_TT_VERBOSE_GROUP                                "Extra diagnostische logboekcontroles voor diepgaande probleemoplossing.\r\n\r\nDeze opties zijn bedoeld voor foutopsporing, niet voor normaal gebruik. Laat ze uitgeschakeld, tenzij u een specifiek probleem onderzoekt."
    IDS_TWEAKS_TT_RESTORE_LAST_MAIN_WND_DLG                    "Herstelt de laatst geselecteerde hoofdvensterpagina bij het opstarten.\r\n\r\nSchakel dit in als u wilt dat eMule opnieuw opent waar u was gebleven."
    IDS_TWEAKS_TT_RESTORE_LAST_LOG_PANE                        "Herstelt het laatst geselecteerde logvenster bij het opstarten.\r\n\r\nPuur een gemaksoptie voor gebruikers die tijd doorbrengen in de logweergaven."
    IDS_TWEAKS_TT_KEEP_UNAVAILABLE_FIXED_SHARED_DIRS           "Houdt handmatig geconfigureerde gedeelde mappen in de lijst, zelfs als ze momenteel niet beschikbaar zijn.\r\n\r\nHandig voor verwijderbare of soms ontbrekende opslag. Schakel het uit als u wilt dat ontbrekende mappen agressief worden gesnoeid."
    IDS_TWEAKS_TT_PARTIALLY_PURGE_OLD_KNOWN_FILES              "Maakt een agressievere opruiming van verouderde vermeldingen in de geschiedenis van bekende bestanden mogelijk.\r\n\r\nKan na verloop van tijd de rommel verminderen, maar vergeet ook de oude bestandsgeschiedenis eerder. Laat de standaardwaarde staan, tenzij u een slankere geschiedenis wilt."
    IDS_TWEAKS_TT_DETECT_TCP_ERROR_FLOODER                     "Detecteert herhaalde TCP-foutuitbarstingen die kunnen duiden op misbruik of kapotte peers.\r\n\r\nAanbevolen: ingeschakeld. Schakel het alleen uit als u valse positieven diagnosticeert."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_INTERVAL_MINUTES           "Tijdvenster gebruikt voor TCP-fout-overstromingsdetectie.\r\n\r\nKorte vensters reageren sneller; langere vensters zijn minder gevoelig. Standaardwaarden worden aanbevolen."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_THRESHOLD                  "Aantal TCP-fouten binnen het interval dat de afhandeling van flooders activeert.\r\n\r\nLagere waarden zijn strenger. Verhoog het alleen als uw omgeving onschadelijke, frequente TCP-fouten produceert."
    IDS_TWEAKS_TT_SHAREE_MULE                                  "Bepaalt hoe eMule de status per gebruiker op deze Windows-machine opslaat en deelt.\r\n\r\nVerlaat de huidige modus tenzij u opzettelijk wijzigt hoe meerdere lokale gebruikers configuratie en gegevens delen."
    IDS_TWEAKS_TT_TCP_GROUP                                    "Geavanceerde TCP verbindingsburst-, time-out- en keepalive-besturingselementen.\r\n\r\nDeze instellingen beïnvloeden het verbindingsgedrag in plaats van de overdrachtslimieten. Standaardwaarden worden aanbevolen, tenzij u problemen met de netwerkinstallatie diagnosticeert."
    IDS_TWEAKS_TT_SEARCH_GROUP                                 "Geavanceerde limieten voor hoe breed en hoe lang eMule zoekt op eD2K en Kad.\r\n\r\nHogere waarden kunnen meer resultaten opleveren, maar ze voegen ook meer netwerkverkeer en UI-ruis toe."
    IDS_TWEAKS_TT_SEARCH_ED2K_GROUP                            "Servergebaseerde eD2K-zoeklimieten.\r\n\r\nGebruik conservatieve waarden, tenzij u opzettelijk diepere serverzoekopdrachten wilt."
    IDS_TWEAKS_TT_SEARCH_KAD_GROUP                             "Kad zoekbreedte en levensduurcontroles.\r\n\r\nHogere waarden houden gedistribueerde zoekopdrachten langer levend en kunnen meer resultaten opleveren, maar ze kosten meer achtergrondactiviteit."
    IDS_TWEAKS_TT_BROADBAND                                    "Geavanceerd beleid voor recycling van uploadslots en wachtrijscores voor uploadgedrag in breedbandstijl.\r\n\r\nDeze instellingen zijn bedoeld voor doelbewuste afstemming. Laat ze op hun standaardwaarden staan, tenzij u de eerlijkheid van de uploads of de slotomzet aanpast."
    IDS_TWEAKS_TT_UPLOAD_POLICY_MAX_UPLOAD_CLIENTS             "Zachte cap voor gelijktijdig actieve uploadclients onder de breedbandplanner.\r\n\r\nHogere waarden verspreiden de bandbreedte over meer peers, maar maken elk slot dunner. Lagere waarden houden minder, sterkere slots over."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_THRESHOLD                 "Fractie van de beoogde uploadsnelheid per slot waaronder een slot als langzaam wordt beschouwd.\r\n\r\nLagere waarden tolereren zwakkere slots langer. Hogere waarden recyclen slecht presterende slots agressiever."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_GRACE                     "Hoe lang een slot onder de langzame drempel mag blijven voordat eMule overweegt het te recyclen.\r\n\r\nLangere genade is geduldiger met zwakke collega's; Bij een kortere uitstelperiode worden zwakke slots eerder omgezet."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_WARMUP                    "Opwarmperiode voor een nieuw uploadslot voordat de detectie van langzame slots begint.\r\n\r\nHiermee wordt voorkomen dat nieuwe uploads worden bestraft vanwege opstartgeluid en aanlooptijd."
    IDS_TWEAKS_TT_UPLOAD_POLICY_ZERO_RATE_GRACE                "Respijtperiode voor slots die in wezen helemaal geen uploadgegevens leveren.\r\n\r\nLagere waarden reageren sneller op dode of vastgelopen slots."
    IDS_TWEAKS_TT_UPLOAD_POLICY_COOLDOWN                       "Hoe lang een gerecycleerd langzaam slot bestraft blijft in de wachtrijscore voordat het weer normaal kan concurreren.\r\n\r\nEen langere afkoelperiode vermindert de onmiddellijke herselectie van onlangs zwakke klanten."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BOOST                "Voegt een extra wachtrijscore toe voor klanten die om bestanden vragen met een lage historische uploadratio.\r\n\r\nGebruik dit als u de voorkeur wilt geven aan bestanden die tot nu toe relatief weinig uploads hebben ontvangen."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_THRESHOLD            "Cutoff van de uploadratio waaronder de wachtrijscoreboost met een lage ratio van toepassing is.\r\n\r\nLagere waarden beperken de boost tot bestanden die sterker onderbediend zijn."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BONUS                "Er wordt een extra effectieve wachtrijscore toegekend wanneer de boost met een lage ratio wordt geactiveerd.\r\n\r\nHogere waarden zorgen ervoor dat de boost belangrijker is bij het bestellen van uploads."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_ID_DIVISOR                 "Strafdeler toegepast op LowID-clients tijdens het scoren van de uploadwachtrij.\r\n\r\nHogere waarden verminderen de LowID-prioriteit agressiever. Stel 1 in om de extra LowID-boete uit te schakelen."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER               "Beperkt hoeveel één uploadsessie kan worden overgedragen voordat eMule overweegt dat slot te roteren.\r\n\r\nRotatie vindt alleen plaats wanneer een andere client het slot daadwerkelijk nodig heeft."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_DISABLED      "Recycle uploadsessies niet op basis van het overgedragen payloadbedrag."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT       "Beperk elke uploadsessie tot een percentage van de gevraagde bestandsgrootte."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT_VALUE "Percentage dat wordt gebruikt wanneer de limiet voor sessieoverdracht is geconfigureerd als een deel van de bestandsgrootte."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B          "Beperk elke uploadsessie tot een vast MiB-bedrag, ongeacht de bestandsgrootte."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B_VALUE    "Absoluut MiB-bedrag dat wordt gebruikt wanneer de sessieoverdrachtslimiet is geconfigureerd als een vaste grootte."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TIME_LIMIT             "Maximale duur van één uploadsessie voordat eMule overweegt het slot te roteren.\r\n\r\nStel 0 in om de op tijd gebaseerde limiet uit te schakelen."
    IDS_TWEAKS_TT_A4_AF_SAVE_CPU                               "Vermindert herhaalde A4AF-broncontroles (Asked For Another File) om CPU-tijd te besparen.\r\n\r\nHandig op drukke clients, maar het kan ervoor zorgen dat er minder snel van bron wordt gewisseld naar dezelfde client."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_NEVER                      "Extraheer geen metagegevens uit bestanden.\r\n\r\nLichtste optie. Gebruik het als u geen onderzoek naar metagegevens op de achtergrond wilt."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_ID3_LIB                    "Extraheer metagegevens alleen via het ID3-bibliotheekpad voor MPEG-audiobestanden.\r\n\r\nEvenwichtige standaard voor basismuziektags zonder bredere media-inspectie."
    IDS_TWEAKS_TT_PREVIEW_ON_ICON_DBL_CLK                      "Als u dubbelklikt op een bestandspictogram, wordt een voorbeeld geopend in plaats van de gebruikelijke standaardactie.\r\n\r\nPuur een voorkeur voor de UI-workflow."
    IDS_TWEAKS_TT_EXTRA_PREVIEW_WITH_MENU                      "Toont voorbeeldopdrachten via een speciaal voorbeeldactiemenu in plaats van alleen de eenvoudigere directe voorbeeldactie weer te geven.\r\n\r\nHandig als u meer expliciete voorbeeldkeuzes wilt in het contextmenu van de downloadlijst."
    IDS_TWEAKS_TT_SHOW_ACTIVE_DOWNLOADS_BOLD                   "Tekent actief overgedragen downloads vetgedrukt in de downloadlijst.\r\n\r\nPuur visueel. Schakel dit in als u wilt dat actieve items duidelijker opvallen."
    IDS_TWEAKS_TT_USE_SYSTEM_FONT_FOR_MAIN_CONTROLS            "Gebruikt het normale Windows UI-lettertype voor hoofdbesturingselementen en lijstweergaven in plaats van de aangepaste lettertype-instellingen van eMule.\r\n\r\nHandig als u de voorkeur geeft aan native ogende tekst of een betere compatibiliteit nodig heeft met de lettertype-instellingen van uw systeem."
    IDS_TWEAKS_TT_FILTER_LANI_PS                               "Negeert server- en clientadressen uit privé-/LAN-bereiken.\r\n\r\nAanbevolen: ingeschakeld. Hierdoor wordt voorkomen dat u probeert niet-routeerbare peer-adressen van het openbare netwerk te gebruiken."
    IDS_TWEAKS_TT_GEO_LOCATION_CHECK_DAYS                      "Hoe vaak eMule controleert op bijgewerkte inhoud van de geolocatiedatabase.\r\n\r\nStel 0 in om automatische updatecontroles uit te schakelen. Grotere waarden verminderen de vernieuwingsactiviteit op de achtergrond."
    IDS_TWEAKS_TT_VERBOSE                                      "Hoofdschakelaar voor de uitgebreide logboekbediening hieronder.\r\n\r\nSchakel deze uit voor normaal gebruik. Schakel dit alleen in als u een specifiek probleem onderzoekt."
    IDS_TWEAKS_TT_FULL_VERBOSE                                 "Registreert de meest volledige beschikbare uitgebreide tracering wanneer uitgebreide logboekregistratie is ingeschakeld.\r\n\r\nDit kan zeer luidruchtig zijn en mag alleen worden gebruikt voor doelgerichte probleemoplossing."
    IDS_TWEAKS_TT_LOG_LEVEL                                    "Drempel voor breedsprakigheid voor diagnostische loguitvoer.\r\n\r\nHogere niveaus registreren meer details maar creëren meer ruis."
    IDS_TWEAKS_TT_DEBUG2_DISK                                  "Schrijft uitgebreide diagnostische uitvoer naar schijf in plaats van deze tijdelijk te houden.\r\n\r\nHandig als u een aanhoudende foutopsporingstrace nodig hebt, maar het verhoogt de schijfactiviteit."
    IDS_TWEAKS_TT_DEBUG_SOURCE_EXCHANGE                        "Registreert bronuitwisselingsgerelateerde pakketten en beslissingen.\r\n\r\nGespecialiseerde diagnostische optie. Schakel dit alleen in tijdens het opsporen van fouten in het brondetectiegedrag."
    IDS_TWEAKS_TT_LOG_BANNED_CLIENTS                           "Registreert wanneer peers worden verbannen en waarom.\r\n\r\nHandig voor misbruik of vals-positieve diagnoses, maar te luidruchtig voor normaal gebruik."
    IDS_TWEAKS_TT_LOG_RATING_DESC_RECEIVED                     "Records hebben bestandsopmerkingen, beschrijvingen en beoordelingen ontvangen.\r\n\r\nHandig voor het opsporen van fouten in de metagegevensstroom, maar doorgaans niet nodig."
    IDS_TWEAKS_TT_LOG_SECURE_IDENT                             "Registreert beveiligde identiteitsverificatie en gerelateerde identiteitscontroles.\r\n\r\nHandig voor het oplossen van problemen met vertrouwen/authenticatie."
    IDS_TWEAKS_TT_LOG_FILTERED_I_PS                            "Registreert wanneer IP filter- of negeerlogica peer- of serveradressen verwijdert.\r\n\r\nHandig voor het diagnosticeren waarom sommige peers worden afgewezen."
    IDS_TWEAKS_TT_LOG_FILE_SAVING                              "Registreert opslag van persistente gegevens, zoals bekende bestanden, credits en gerelateerde status.\r\n\r\nHandig voor het debuggen van persistentie, maar niet nodig voor normaal gebruik."
    IDS_TWEAKS_TT_LOG_A4_AF                                    "Registreert activiteit voor het opnieuw toewijzen van A4AF-bronnen (gevraagd om een ​​ander bestand).\r\n\r\nGespecialiseerde diagnostische optie voor downloadmanager."
    IDS_TWEAKS_TT_LOG_UL_DL_EVENTS                             "Registreert wijzigingen in de levenscyclus van upload-slots en download-gebeurtenissen.\r\n\r\nHandig bij het diagnosticeren van wachtrijverloop, slotrotatie of overdrachtsstatusovergangen."
    IDS_TWEAKS_TT_U_PN_P                                       "Instellingen voor het automatisch toewijzen van routerpoorten voor inkomende connectiviteit.\r\n\r\nDe meeste gebruikers moeten deze groep op automatische standaardwaarden laten staan, tenzij hun routeromgeving iets specifieks vereist."
    IDS_TWEAKS_TT_SHAREE_MULE_MULTI_USER                       "Elke Windows-gebruiker krijgt een afzonderlijke eMule-configuratie en een afzonderlijke downloadstatus.\r\n\r\nConfig bevindt zich onder Local AppData en downloads gebruiken de eigen map Downloads van die gebruiker. Meest geschikt voor gedeelde pc's waar gebruikers geen eMule-gegevens mogen delen."
    IDS_TWEAKS_TT_SHAREE_MULE_PUBLIC_USER                      "Alle Windows-gebruikers delen dezelfde eMule-configuratie en downloads.\r\n\r\nConfig staat onder ProgramData en downloads gebruiken openbare downloads. Gebruik dit alleen als de machine opzettelijk één gemeenschappelijke eMule-status deelt."
    IDS_TWEAKS_TT_SHAREE_MULE_OLD_STYLE                        "Bewaar configuratie en downloads in de programmamap en gebruik de oudere, oudere lay-out.\r\n\r\nAlleen oudere compatibiliteitsmodus. Het is meestal de minst wenselijke keuze op de moderne Windows."
    IDS_CONNECTION_TT_AUTOCONNECT                              "Start automatisch de ingeschakelde netwerken wanneer eMule wordt gestart.\r\n\r\nAanbevolen: ingeschakeld voor normaal onbeheerd gebruik. Schakel het alleen uit als u elke sessie handmatig verbinding wilt maken."
    IDS_CONNECTION_TT_RECONN                                   "Probeert serververbindingen opnieuw na verbroken verbindingen of mislukte pogingen.\r\n\r\nAanbevolen: ingeschakeld als u het eD2K-servernetwerk gebruikt. Het heeft geen effect als het servernetwerk is uitgeschakeld."
    IDS_CONNECTION_TT_SHOWOVERHEAD                             "Toont protocoloverhead afzonderlijk in de overdrachtssnelheden en statistieken.\r\n\r\nSchakel dit in als u een eerlijker beeld van het draadverkeer wilt. Laat het uit als u de voorkeur geeft aan eenvoudiger nummers met alleen een payload."
    IDS_CONNECTION_TT_PORT                                     "Hoofdpoort TCP die wordt gebruikt voor inkomende clientverbindingen.\r\n\r\nWijzig dit alleen als u opzettelijk de firewall- of routerregels opnieuw configureert. Test de connectiviteit opnieuw nadat u deze hebt gewijzigd."
    IDS_CONNECTION_TT_UDPPORT                                  "UDP-poort gebruikt voor Kad en andere door UDP ondersteunde functies.\r\n\r\nAanbevolen: houd deze ingeschakeld en bereikbaar tenzij u opzettelijk op UDP gebaseerde netwerken wilt uitschakelen."
    IDS_CONNECTION_TT_MAXSOURCEPERFILE                         "Harde limiet voor het aantal externe bronnen dat eMule per download bewaart.\r\n\r\nHogere waarden kunnen de beschikbaarheid van zeldzame bestanden verbeteren, maar kosten meer geheugen en bronbeheerverkeer. Gebruik gematigde waarden tenzij u een specifieke reden hebt om deze te verhogen."
    IDS_CONNECTION_TT_MAXCON                                   "Bovengrens voor gelijktijdige verbindingen eMule blijft mogelijk open.\r\n\r\nHogere waarden zijn niet automatisch beter. Laat dit in de buurt van de afgestemde standaard, tenzij u een specifieke netwerkbeperking constateert."
    IDS_CONNECTION_TT_DOWNLOAD_CAP                             "Uw geconfigureerde downstream-capaciteit in KiB/s. eMule gebruikt dit als referentie voor sliders en bandbreedtebeslissingen.\r\n\r\nStel het dicht in de buurt van uw werkelijk bruikbare lijnsnelheid, niet het marketingmaximum."
    IDS_CONNECTION_TT_UPLOAD_CAP                               "Uw geconfigureerde upstream-capaciteit in KiB/s. eMule gebruikt dit als bovenste referentie voor uploadcontrole.\r\n\r\nStel dit in de buurt van de werkelijk bruikbare aanhoudende uploadsnelheid van uw lijn."
    IDS_CONNECTION_TT_NETWORK_ED2_K                            "Schakelt het klassieke eD2K-servernetwerk in.\r\n\r\nLaat dit ingeschakeld als u nog steeds servergebaseerde brondetectie gebruikt. Schakel dit alleen uit als u opzettelijk alleen Kad wilt gebruiken."
    IDS_CONNECTION_TT_NETWORK_KADEMLIA                         "Schakelt het Kad gedistribueerde netwerk in.\r\n\r\nAanbevolen: ingeschakeld voor modern gebruik. Het vereist dat de UDP-poort ingeschakeld blijft."
    IDS_CONNECTION_TT_PREF_UPNPONSTART                         "Probeert automatische NAT-poorttoewijzing bij het opstarten voor de geconfigureerde TCP- en UDP-poorten.\r\n\r\nAanbevolen: ingeschakeld wanneer uw router UPnP of PCP/NAT-PMP ondersteunt. Schakel dit uit als u poorten handmatig doorstuurt."
    IDS_CONNECTION_TT_RANDOMIZE_PORTS_ON_STARTUP               "Kiest nieuwe TCP- en UDP-luisterpoorten bij het opstarten voordat de automatische poorttoewijzing wordt uitgevoerd.\r\n\r\nDe optie gebruikt het bestaande willekeurige poortbereik van eMule en laat UDP uitgeschakeld wanneer de UDP-poort is uitgeschakeld."
    IDS_CONNECTION_TT_UDPDISABLE                               "Schakelt de UDP-poort van eMule uit en schakelt daarom UDP-afhankelijke functies uit, zoals Kad-netwerken.\r\n\r\nAanbevolen: laat dit uitgeschakeld tenzij u TCP alleen moet gebruiken voor een zeer specifieke netwerkomgeving."
    IDS_CONNECTION_TT_STARTTEST                                "Start de externe connectiviteitstest voor de momenteel geconfigureerde TCP- en UDP-poorten.\r\n\r\nGebruik deze na het wijzigen van poorten, bindingsinstellingen of routertoewijzingsregels."
    IDS_CONNECTION_TT_BIND_INTERFACE                           "Optionele Windows-netwerkinterfacenaam die wordt gebruikt voor P2P-socketbinding.\r\n\r\nMatch is op basis van de gebruiksvriendelijke interfacenaam, niet op het adapternummer. Wijzigingen worden van kracht na opnieuw opstarten."
    IDS_CONNECTION_TT_BIND_ADDRESS                             "Optioneel IPv4-adres gebruikt voor P2P-socketbinding.\r\n\r\nLaat dit leeg om de eerste IPv4 op de geselecteerde interface te gebruiken, of de standaard routeringskeuze wanneer er geen interface is geselecteerd."
    IDS_CONNECTION_TT_STARTUP_BIND_BLOCK                       "Houdt P2P-netwerken offline gedurende de sessie als het geconfigureerde bindingsdoel niet kan worden opgelost bij het opstarten.\r\n\r\nAlleen beschikbaar wanneer een bindingsinterface is geselecteerd. Aanbevolen wanneer u expliciet bindt aan een benoemde interface en geen stille terugval wilt."
    IDS_WEBSERVER_TT_WEBBINDADDR                               "Lokaal bindadres voor de ingebouwde WebServer en REST API.\r\n\r\nLaat het leeg of als 0.0.0.0 om op alle interfaces te luisteren. Stel alleen een specifieke IPv4 in als u opzettelijk wilt beperken waar de dienst luistert."
    IDS_WEBSERVER_TT_WSAPIKEY                                  "REST API-sleutel in platte tekst die door clients wordt gebruikt in de X-API-Key-header.\r\n\r\nAanbevolen: bewaar de gegenereerde willekeurige waarde, tenzij u een specifiek token nodig hebt. Iedereen met deze sleutel heeft volledige API-toegang."
    IDS_WEBSERVER_TT_WSUPNP                                    "Omvat de WebServer-poort in automatische NAT-toewijzing wanneer UPnP of PCP/NAT-PMP is ingeschakeld.\r\n\r\nSchakel dit alleen in als u opzettelijk wilt dat de Web UI of REST API bereikbaar is via uw routertoewijzing."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD                          "Maximale uploadgrootte van één bestand geaccepteerd door de WebServer in MiB.\r\n\r\nGebruik een kleine waarde voor normale bediening op afstand. Verhoog dit alleen als vertrouwde webclients grotere bestanden moeten uploaden."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD_LBL                      "Maximale uploadgrootte van één bestand geaccepteerd door de WebServer in MiB.\r\n\r\nGebruik een kleine waarde voor normale bediening op afstand. Verhoog dit alleen als vertrouwde webclients grotere bestanden moeten uploaden."
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS                             "Optionele door puntkomma's gescheiden IPv4-toelatingslijst voor WebServer-clients.\r\n\r\nLaat dit veld leeg om elk extern adres toe te staan ​​dat de WebServer kan bereiken. Voorbeeld: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS_LBL                         "Optionele door puntkomma's gescheiden IPv4-toelatingslijst voor WebServer-clients.\r\n\r\nLaat dit veld leeg om elk extern adres toe te staan ​​dat de WebServer kan bereiken. Voorbeeld: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWHILEVFUNC                         "Maakt webbeheeracties op hoog niveau mogelijk die de runtimestatus agressiever kunnen veranderen.\r\n\r\nAanbevolen: houd dit uitgeschakeld tenzij u deze acties expliciet nodig heeft van vertrouwde beheerdersclients."
    IDS_WEBSERVER_TT_WEB_HTTPS                                 "Bedient de Web UI en REST API via HTTPS met behulp van het geconfigureerde certificaat en de geconfigureerde sleutel.\r\n\r\nAanbevolen: ingeschakeld wanneer u de WebServer buiten de lokale machine beschikbaar stelt."
    IDS_NOTIFY_TT_CB_TBN_USESOUND                              "Speelt een aangepast WAV-bestand af voor taakbalkmeldingen.\r\n\r\nGebruik dit als u een hoorbare waarschuwing wilt. Laat het uit als stille pop-ups of spraak voldoende zijn."
    IDS_NOTIFY_TT_CB_TBN_USESPEECH                             "Maakt gebruik van tekst-naar-spraak voor taakbalkmeldingen wanneer er een spraakengine beschikbaar is.\r\n\r\nHandig op onbeheerde systemen waar gesproken waarschuwingen gemakkelijker op te merken zijn dan geluiden."
    IDS_NOTIFY_TT_CB_TBN_POP_ALWAYS                            "Toont een pop-up voor elk binnenkomend chatbericht in plaats van alleen het eerste.\r\n\r\nSchakel dit in als u niet wilt dat vervolgchatberichten stil blijven."
    IDS_NOTIFY_TT_CB_TBN_USEWINDOWSTOAST                       "Maakt gebruik van Windows-toastmeldingen in plaats van de aangepaste eMule-pop-up.\r\n\r\nAls Windows een toast-melding afwijst, valt eMule terug naar de aangepaste pop-up."
    IDS_NOTIFY_TT_TBN_DISPLAYMODE                              "Selecteert hoe eMule ingeschakelde pop-upmeldingen toont.\r\n\r\nWindows toast is de standaard. Als Windows een toastmelding afwijst, ook wanneer eMule als beheerder wordt uitgevoerd, valt eMule terug naar de klassieke ladeballon."
    IDS_NOTIFY_TT_CB_ENABLENOTIFICATIONS                       "Schakelt uitgaande e-mailmeldingen in voor de geconfigureerde gebeurtenissen.\r\n\r\nSchakel dit alleen in als u al een werkende SMTP-server en adressen hebt geconfigureerd."
    IDS_NOTIFY_TT_SMTPSERVER                                   "Opent de SMTP-serverconfiguratie die wordt gebruikt door e-mailmeldingen.\r\n\r\nJe hebt dit alleen nodig als e-mailmeldingen zijn ingeschakeld."
    IDS_BIND_STARTUP_INTERFACE_NOT_FOUND_FMT                   "Netwerken uitgeschakeld voor deze sessie omdat de geselecteerde bindinterface niet langer beschikbaar is: %s"
    IDS_BIND_STARTUP_INTERFACE_AMBIGUOUS_FMT                   "Netwerken uitgeschakeld voor deze sessie omdat de geselecteerde naam van de bindinterface overeenkomt met meerdere live-adapters: %s"
    IDS_BIND_STARTUP_INTERFACE_NO_ADDRESS_FMT                  "Netwerken uitgeschakeld voor deze sessie omdat de geselecteerde bindinterface geen bruikbaar IPv4-adres heeft: %s"
    IDS_BIND_STARTUP_INTERFACE_ADDRESS_MISSING_FMT             "Netwerken uitgeschakeld voor deze sessie omdat de geselecteerde binding IP niet langer aanwezig is op de geselecteerde interface: %s"
    IDS_BIND_STARTUP_ADDRESS_MISSING_FMT                       "Netwerken uitgeschakeld voor deze sessie omdat de geselecteerde binding IP niet langer aanwezig is op een live interface: %s"
    IDS_BIND_EXIT_INTERFACE_CHANGED_FMT                        "eMule wordt afgesloten omdat de geselecteerde bindinterface het adres heeft gewijzigd van %s in %s: %s"
    IDS_BIND_EXIT_INTERFACE_UNAVAILABLE                        "eMule wordt afgesloten omdat de geselecteerde bindinterface niet langer beschikbaar is."
    IDS_BIND_STARTUP_DISABLED_PREFIX                           "Netwerken uitgeschakeld voor deze sessie"
    IDS_BIND_EXIT_PREFIX                                       "eMule afsluiten"
    IDS_STATUS_BIND_IP_COMPACT_LABEL                           "B"
    IDS_STATUS_PUBLIC_IP_COMPACT_LABEL                         "P"
    IDS_STATUS_ANY_COMPACT                                     "Elk"
    IDS_STATUS_UNKNOWN_COMPACT                                 "?"
    IDS_STATUS_NETWORK_ADDRESS_TEXT_FMT                        "%s:%s|%s:%s"
    IDS_PPG_DIRECTORIES_TT_INCFILES                            "Belangrijkste inkomende map voor voltooide downloads.\r\n\r\nGebruik een stabiel lokaal pad met voldoende vrije ruimte. Vermijd tijdelijke of verwijderbare locaties, tenzij u daar echt voltooide bestanden wilt hebben."
    IDS_PPG_DIRECTORIES_TT_TEMPFILES                           "Werkmaplijst voor onderdeelbestanden, hashes en overdrachtsstatus.\r\n\r\nDeze paden moeten beschikbaar blijven terwijl downloads worden uitgevoerd. Snelle lokale schijven worden aanbevolen via verwijderbare of onbetrouwbare netwerkpaden."
    IDS_PPG_DIRECTORIES_TT_SHARESELECTOR                       "Selecteert welke lokale mappen eMule deelt met andere clients.\r\n\r\nDeel alleen de mappen die u wilt publiceren. Vermijd brede wortels, zoals een hele rit."
    IDS_PPG_DISPLAY_TT_MINTRAY                                 "Minimaliseert eMule naar de lade in plaats van deze op de taakbalk te laten staan.\r\n\r\nHandig voor instellingen die altijd aan staan. Laat het uitgeschakeld als u de voorkeur geeft aan normaal taakbalkgedrag."
    IDS_PPG_DISPLAY_TT_TOOLTIPDELAY                            "Vertraging voordat UI-tooltips verschijnen.\r\n\r\nLagere waarden voelen sneller aan, hogere waarden verminderen onbedoelde pop-ups. Het standaardbereik is meestal een goed compromis."
    IDS_PPG_DISPLAY_TT_SHOWRATEONTITLE                         "Toont de huidige upload- en downloadsnelheden in de titel van het hoofdvenster.\r\n\r\nHandig wanneer eMule op de achtergrond blijft en u toch een snelle blik wilt hebben."
    IDS_PPG_DISPLAY_TT_STORESEARCHES                           "Behoudt recente zoektermen zodat ze later opnieuw kunnen worden gebruikt.\r\n\r\nAanbevolen: ingeschakeld tenzij u specifiek geen bewaarde zoekgeschiedenis wilt."
    IDS_PPG_DISPLAY_TT_WIN7_TASKBARGOODIES                     "Maakt Windows taakbalkvoortgang en gerelateerde shell-integratie mogelijk, waar ondersteund.\r\n\r\nAanbevolen: ingeschakeld op moderne Windows, tenzij u een meer minimale shell-aanwezigheid wilt."
    IDS_PPG_FILES_TT_PF_TIMECALC                               "Gebruikt de meer gedetailleerde berekening van de resterende tijd voor downloads.\r\n\r\nAanbevolen: ingeschakeld als u stabielere geschatte aankomsttijden wilt. Schakel het alleen uit als u de voorkeur geeft aan de oudere, eenvoudigere berekening."
    IDS_PPG_FILES_TT_PREVIEWPRIO                               "Geeft prioriteit aan fragmenten van filmvoorbeelden, zodat gedeeltelijk gedownloade media eerder kunnen worden bekeken.\r\n\r\nHandig voor videodownloads. Laat het uit als u de voorkeur geeft aan een neutrale brokbestelling."
    IDS_PPG_FILES_TT_WATCHCB                                   "Houdt het klembord in de gaten voor ed2k-links en biedt aan om deze af te handelen.\r\n\r\nHandig als u veel downloads uit browsers toevoegt. Schakel dit uit als u niet wilt dat eMule naar het klembord kijkt."
    IDS_PPG_FILES_TT_FNCLEANUP                                 "Ruimt gedownloade bestandsnamen automatisch op volgens de geconfigureerde regels.\r\n\r\nAanbevolen: ingeschakeld als u consistentere definitieve bestandsnamen wilt zonder handmatig opschonen."
    IDS_PPG_FILES_TT_STARTNEXTFILE                             "Start automatisch het volgende bestand in de wachtrij wanneer een andere download is voltooid of wordt onderbroken.\r\n\r\nAanbevolen: ingeschakeld als u gepauzeerde wachtrijen gebruikt om te bepalen hoeveel bestanden tegelijk worden uitgevoerd."
    IDS_PPG_FILES_TT_RUNONFILECOMPLETE                         "Voert een uitvoerbaar bestand uit nadat een bestand met succes is voltooid en bewaard.\r\n\r\nDit is standaard uitgeschakeld. Het programma wordt rechtstreeks gestart zonder de Windows-shell."
    IDS_PPG_FILES_TT_FILECOMPLETEARGS                          "Ondersteunde tokens: %F volledig pad, %D map, %N bestandsnaam, %H bestandshash, %S groottebytes, %C categorie.\r\n\r\n%F en %D worden automatisch geciteerd. Omgevingsvariabelen worden niet uitgebreid."
    IDS_PPG_GENERAL_TT_ONLINESIG                               "Schrijft het verouderde statusbestand onlinesig.dat voor externe pagina's, scripts of widgets die de status eMule lezen.\r\n\r\nHet verbetert de overdrachtssnelheid of het netwerk niet. Laat het uitgeschakeld, tenzij u dat bestand ergens actief gebruikt."
    IDS_PPG_GENERAL_TT_BRINGTOFOREGROUND                       "Brengt eMule naar de voorgrond wanneer een afgehandelde ed2k-link of soortgelijke externe actie de app target.\r\n\r\nSchakel dit in als u wilt dat klikken op links eMule onmiddellijk onthullen. Laat het uitgeschakeld als u de voorkeur geeft aan achtergrondverwerking."
    IDS_PPG_GENERAL_TT_CHECK4_UPDATE                           "Controleert GitHub-releases bij het opstarten wanneer het geconfigureerde interval is verstreken en waarschuwt alleen wanneer een nieuwer eMule BB-pakket beschikbaar is.\r\n\r\nLaat het uitgeschakeld voor een rustige start, of schakel het in als u een periodieke updatecontrole wilt."
    IDS_PPG_GENERAL_TT_PREVENTSTANDBY                          "Blokkeert de slaapstand van het systeem terwijl eMule BB verbonden is of overdraagt, zodat downloads, uploads, Kad en serversessies niet worden onderbroken.\r\n\r\nHet scherm kan nog steeds normaal uitschakelen. Als u deze optie uitschakelt, wordt het normale Windows-slaapbeleid direct hersteld."
    IDS_PPG_GENERAL_TT_WEBSVEDIT                               "Bewerkt de geconfigureerde lijst met webservices die wordt gebruikt door helperacties zoals webzoekopdrachten vanuit de gebruikersinterface.\r\n\r\nDit heeft u normaal gesproken alleen nodig als u die externe opzoekitems wilt aanpassen of repareren."
    IDS_PPG_GENERAL_TT_ED2_KFIX                                "Herstelt de Windows ed2k-linkregistratie, zodat browser- en shell-ed2k-links weer openen in eMule.\r\n\r\nGebruik het wanneer ed2k-links stoppen met het starten van eMule of zijn gestolen door een andere client."
    IDS_PPG_GENERAL_TT_STARTMIN                                "Start eMule geminimaliseerd in plaats van het hoofdvenster onmiddellijk te openen.\r\n\r\nHandig voor opstarten zonder toezicht. Laat het uitgeschakeld als u de gebruikersinterface normaal gesproken meteen wilt inspecteren."
    IDS_PPG_GENERAL_TT_STARTWIN                                "Registreert eMule om te beginnen met Windows voor de huidige gebruiker.\r\n\r\nSchakel dit alleen in op machines waarop eMule permanent op de achtergrond moet draaien."
    IDS_PPG_IRC_TT_IRC_USECHANFILTER                           "Past de kanaalnaam en het minimale gebruikersfilter toe bij het opvragen van de IRC-kanaallijst.\r\n\r\nSchakel dit in als u wilt dat de lijst automatisch wordt beperkt. Schakel dit uit om altijd de volledige zenderlijst op te halen."
    IDS_PPG_IRC_TT_IRC_USEPERFORM                              "Voert het perform-script uit nadat verbinding is gemaakt met IRC.\r\n\r\nGebruik het voor automatische joins of IRC-opdrachten. Laat het uitgeschakeld als u geen perform-script onderhoudt."
    IDS_PPG_IRC_TT_IRC_NAME_BOX                                "Filtertekst voor de IRC-kanaallijst.\r\n\r\nAlleen kanalen die overeenkomen met deze tekst worden bewaard als het kanaalfilter is ingeschakeld."
    IDS_PPG_IRC_TT_IRC_MINUSER_BOX                             "Minimum aantal gebruikers voor kanalen weergegeven door het IRC kanaallijstfilter.\r\n\r\nVerhoog deze om kleine kanalen te verbergen. Gebruik 0 om kanalen ongeacht de grootte te behouden."
    IDS_PPG_MESSAGES_TT_MSGONLYFRIENDS                         "Accepteert alleen directe berichten van gebruikers in uw vriendenlijst.\r\n\r\nAanbevolen als u een zeer rustige chatopstelling wilt. Laat het uit als je nog steeds berichten van gewone klanten wilt."
    IDS_PPG_MESSAGES_TT_ADVSPAMFILTER                          "Schakelt het sterkere spamfilterpad voor berichten in.\r\n\r\nAanbevolen: ingeschakeld voor normaal gebruik van openbare netwerken. Het werkt samen met chat-captcha's voor strengere filtering."
    IDS_PPG_MESSAGES_TT_USECAPTCHAS                            "Vereist een captcha-uitdaging voordat onbekende clients een chatgesprek kunnen voltooien.\r\n\r\nHandig tegen chatspam. Het beste te gebruiken in combinatie met het geavanceerde spamfilter."
    IDS_PPG_MESSAGES_TT_COMMENTFILTER                          "Blokkeert bestandsopmerkingen die de geconfigureerde filtertermen bevatten.\r\n\r\nGebruik een '|' scheidingsteken tussen termen. Goed voor bekende spamwoorden of hinderlijke patronen."
    IDS_PPG_PROXY_TT_ENABLEPROXY                               "Routes ondersteunde uitgaande verbindingen via de geconfigureerde proxy.\r\n\r\nSchakel dit alleen in als u opzettelijk eMule achter een proxy uitvoert. Directe verbindingen zijn eenvoudiger en meestal sneller."
    IDS_PPG_PROXY_TT_PROXYTYPE                                 "Selecteert het proxyprotocol dat door uw proxyserver wordt verwacht.\r\n\r\nGebruik het exacte type dat door de proxy-operator is opgegeven; het verkeerde type betekent meestal onmiddellijke verbindingsfouten."
    IDS_PPG_PROXY_TT_PROXYNAME                                 "Hostnaam of IP-adres van de proxyserver.\r\n\r\nVoer precies het eindpunt in dat door uw proxyservice wordt geleverd. Een verkeerde host betekent dat al het proxyverkeer zal mislukken."
    IDS_PPG_PROXY_TT_PROXYPORT                                 "Luisterpoort van de proxyserver.\r\n\r\nGebruik de exacte poort die door de proxy wordt vereist. Het is niet gegarandeerd dat veelvoorkomende standaardinstellingen van SOCKS juist zijn."
    IDS_PPG_PROXY_TT_ENABLEAUTH                                "Verstuurt gebruikersnaam- en wachtwoordreferenties voor de proxy wanneer de proxy authenticatie vereist.\r\n\r\nSchakel dit alleen in als uw proxyservice daadwerkelijk inloggegevens gebruikt."
    IDS_PPG_PROXY_TT_USERNAME_A                                "Gebruikersnaam proxyaccount.\r\n\r\nLaat dit leeg, tenzij uw proxy expliciet geverifieerde toegang vereist."
    IDS_PPG_SCHEDULER_TT_ENABLE                                "Schakelt de planner in, zodat op tijd gebaseerde regels instellingen automatisch kunnen wijzigen.\r\n\r\nLaat dit uitgeschakeld tenzij u actief gebruik maakt van geplande bandbreedte-, verbindings- of categoriewijzigingen."
    IDS_PPG_SCHEDULER_TT_CHECKNOENDTIME                        "Voert het geselecteerde schema-item uit zonder stoptijd.\r\n\r\nGebruik het voor statuswijzigingen in één richting die actief moeten blijven totdat een ander schema deze overschrijft."
    IDS_PPG_SCHEDULER_TT_APPLY                                 "Past de bewerkte details toe op de momenteel geselecteerde planningsinvoer.\r\n\r\nGebruik dit nadat u de dag, tijd of actielijst voor die rij hebt gewijzigd."
    IDS_PPG_SECURITY_TT_USESECIDENT                            "Maakt gebruik van veilige identificatie wanneer dit wordt ondersteund, zodat de kredietidentiteit van klanten moeilijker te vervalsen is.\r\n\r\nAanbevolen: ingeschakeld. Het uitschakelen ervan vermindert alleen maar het identiteitsvertrouwen en is zelden nuttig."
    IDS_PPG_SECURITY_TT_FILTERSERVERBYIPFILTER                 "Past het IP-filter toe op de zichtbare serverlijst, zodat gefilterde servers worden verborgen of verwijderd.\r\n\r\nAanbevolen: ingeschakeld als u vertrouwt op het IP-filter voor zowel serverhygiëne als peer-filtering."
    IDS_PPG_SECURITY_TT_UPDATEURL                              "Bron-URL gebruikt bij het downloaden van vernieuwde IP-filterlijsten.\r\n\r\nGebruik alleen een vertrouwde provider. Automatische updates hergebruiken deze URL en behouden het bestaande filter als de download ongeldig is."
    IDS_PPG_SECURITY_TT_AUTOUPDATE_IPFILTER                    "Controleert de geconfigureerde IP-filter-URL automatisch na het opstarten wanneer het update-interval is verstreken.\r\n\r\nAanbevolen: uitgeschakeld tenzij u de provider vertrouwt en wilt dat het filter wordt vernieuwd zonder handmatige actie."
    IDS_PPG_SECURITY_TT_IPFILTERPERIOD                         "Aantal dagen tussen automatische updatepogingen van het IP-filter.\r\n\r\nToegestaan ​​bereik: 1 tot 365 dagen. Mislukte pogingen worden nog steeds geteld om herhalingen van pogingen te voorkomen wanneer een provider niet beschikbaar is."
    IDS_PPG_SECURITY_TT_SEESHARE1                              "Hiermee kan iedereen door uw gedeelde bestanden bladeren als de externe client dit ondersteunt.\r\n\r\nMeest toegeeflijke optie. Gebruik het alleen als u het prettig vindt om uw gedeelde lijst breed bekend te maken."
    IDS_PPG_SECURITY_TT_SEESHARE2                              "Hiermee kunnen alleen vrienden door uw gedeelde bestanden bladeren.\r\n\r\nEvenwichtige privacykeuze als u nog steeds ondersteuning wilt zoeken voor expliciet vertrouwde contacten."
    IDS_PPG_SECURITY_TT_SEESHARE3                              "Voorkomt dat externe clients door uw lijst met gedeelde bestanden kunnen bladeren.\r\n\r\nAanbevolen als u het strengste privacybeleid wilt voor het bladeren door gedeelde bestanden."
    IDS_PPG_SECURITY_TT_ENABLEOBFUSCATION                      "Geeft de voorkeur aan protocolverduistering wanneer de externe kant dit ook ondersteunt.\r\n\r\nAanbevolen: ingeschakeld. Het kan helpen bij restrictieve netwerken zonder een beleid van uitsluitend verduistering af te dwingen."
    IDS_PPG_SECURITY_TT_ONLYOBFUSCATED                         "Vereist onduidelijke verbindingen in plaats van normale verbindingen.\r\n\r\nGebruik dit alleen als uw netwerkomgeving dit echt nodig heeft. Het kan de connectiviteit en het bereik van collega's verminderen."
    IDS_PPG_SECURITY_TT_SEARCHSPAMFILTER                       "Filtert duidelijke spam uit zoekresultaten voordat deze de gebruikersinterface onoverzichtelijk maakt.\r\n\r\nAanbevolen: ingeschakeld voor normaal gebruik van openbare netwerken."
    IDS_PPG_SECURITY_TT_CHECK_FILE_OPEN                        "Controleert gedownloade bestanden op geopende/vergrendelde status vóór bewerkingen waarvoor exclusieve toegang vereist is.\r\n\r\nAanbevolen: ingeschakeld tenzij u een specifieke reden hebt om de veiligheidscontrole over te slaan."
    IDS_PPG_SERVER_TT_AUTOSERVER                               "Werkt automatisch de serverlijst bij van verbonden clients en andere vertrouwde bronnen.\r\n\r\nHandig, maar laat de lijst ook in de loop van de tijd afwijken. Schakel het uit als u de voorkeur geeft aan een strak samengestelde statische serverlijst."
    IDS_PPG_SERVER_TT_UPDATESERVERCONNECT                      "Hiermee kunnen verbonden servers extra servers in uw lijst adverteren.\r\n\r\nHandig, maar de lijst kan groter worden met vermeldingen met een lage waarde. Schakel het uit als u de voorkeur geeft aan strikter handmatig beheer."
    IDS_PPG_SERVER_TT_UPDATESERVERCLIENT                       "Hiermee kunnen clients serveradressen toevoegen aan uw serverlijst.\r\n\r\nDe meeste gebruikers moeten hier voorzichtig mee omgaan. Schakel het uit als u meer controle wilt over de kwaliteit van de serverlijsten."
    IDS_PPG_SERVER_TT_SAFESERVERCONNECT                        "Maakt gebruik van een voorzichtigere serververbindingsstrategie in plaats van zich door veel kandidaten heen te haasten.\r\n\r\nAanbevolen: ingeschakeld voor stabiliteit. Schakel het alleen uit als u opzettelijk een agressievere verbindingsaanpak wilt."
    IDS_PPG_SERVER_TT_SMARTIDCHECK                             "Voert de slimme LowID-controle uit voordat wordt besloten dat de bereikbaarheid van uw server slecht is.\r\n\r\nAanbevolen: ingeschakeld. Het vermijdt enkele valse LowID-conclusies tijdens tijdelijke netwerkomstandigheden."
    IDS_PPG_SERVER_TT_SCORE                                    "Maakt gebruik van serverprioriteiten bij het kiezen en bestellen van servers.\r\n\r\nAanbevolen: ingeschakeld als u een voorkeurssubset van servers onderhoudt en wilt dat eMule deze de voorkeur geeft."
    IDS_PPG_SERVER_TT_SERVERRETRIES                            "Hoeveel mislukte verbindingspogingen kan een server verzamelen voordat eMule deze als dood beschouwt.\r\n\r\nLagere waarden snoeien slechte servers sneller; hogere waarden zijn vergevingsgezinder bij tijdelijke storingen."
    IDS_PPG_SERVER_TT_AUTOCONNECTSTATICONLY                    "Beperkt automatische serververbindingspogingen tot servers die zijn gemarkeerd als statisch.\r\n\r\nSchakel dit in als u een kleine vertrouwde statische lijst bijhoudt en geen automatische rotatie over de volledige serverlijst wilt."
    IDS_PPG_SERVER_TT_MANUALSERVERHIGHPRIO                     "Geeft handmatig toegevoegde servers een hogere prioriteit dan gewone ontdekte vermeldingen.\r\n\r\nSchakel dit in als u een zorgvuldig geselecteerde serverset onderhoudt en wilt dat deze toevoegingen de voorkeur krijgen."
    IDS_PPG_STATS_TT_FILL_GRAPHS                               "Vult de grafiekgebieden in plaats van alleen lijnen te tekenen.\r\n\r\nPuur visueel. Schakel het uit als u de voorkeur geeft aan een lichtere, minder drukke statistiekenweergave."
    IDS_PPG_STATS_TT_SLIDER                                    "Vernieuwingsinterval voor de live verkeersgrafiek.\r\n\r\nLagere waarden voelen responsiever aan, maar kosten meer UI-werk. Gematigde waarden zijn meestal het beste."
    IDS_PPG_STATS_TT_SLIDER2                                   "Vernieuwingsinterval voor de statistische structuur en samenvattingswaarden.\r\n\r\nLagere waarden worden vaker bijgewerkt, maar kosten meer UI-verloop. Verhoog het als je rustigere updates wilt."
    IDS_PPG_STATS_TT_SLIDER3                                   "Middelingsvenster gebruikt door de grafieken.\r\n\r\nKorte vensters laten duidelijk pieken zien; langere vensters maken de weergave gladder en benadrukken trends."
