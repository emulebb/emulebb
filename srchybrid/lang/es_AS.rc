    IDS_TWEAKS_INCOMING_DRIVES                                 "Unidades entrantes"
    IDS_TWEAKS_FLUSH_FILE_DATA                                 "Vaciar los datos del archivo al disco"
    IDS_TWEAKS_COMMIT_NEVER                                    "Nunca fuerce el lavado"
    IDS_TWEAKS_COMMIT_ON_SHUTDOWN                              "Sólo al apagar"
    IDS_TWEAKS_COMMIT_ALWAYS                                   "En cada guardado"
    IDS_TWEAKS_VALIDATION_INVALID_VALUE_FMT                    "Valor no válido para ""%s"".\n\n%s"
    IDS_TWEAKS_VALIDATION_INTEGER                              "Por favor ingrese un número entero."
    IDS_TWEAKS_VALIDATION_EDITOR_COMMAND                       "Ingrese un comando del editor, por ejemplo notepad.exe."
    IDS_TWEAKS_VALIDATION_FOLLOW_MAJORITY_PERCENT_RANGE_FMT    "Rango esperado: %u..%u por ciento."
    IDS_TWEAKS_VALIDATION_FOLLOW_MAJORITY_VOTES_RANGE_FMT      "Rango esperado: 0..%u votos."
    IDS_TWEAKS_VALIDATION_CTIME_FORMAT                         "Introduzca una cadena de formato CTime que no esté vacía."
    IDS_TWEAKS_VALIDATION_ZERO_OR_RANGE_FMT                    "Valor esperado: 0, o %u..%u."
    IDS_TWEAKS_VALIDATION_POSITIVE_UINT_RANGE_FMT              "Rango esperado: 1..%u."
    IDS_TWEAKS_VALIDATION_UINT_KIB_RANGE_FMT                   "Rango esperado: %u..%u KiB."
    IDS_TWEAKS_VALIDATION_INT_RANGE_FMT                        "Rango esperado: %d..%d."
    IDS_TWEAKS_VALIDATION_LOG_FILE_SIZE_RANGE_FMT              "Rango esperado: 0..%u KiB. Utilice 0 para no tener límite de rotación."
    IDS_TWEAKS_VALIDATION_MINUTES_RANGE_FMT                    "Rango esperado: 1..%u minutos."
    IDS_BIND_ANY_INTERFACE                                     "Cualquier interfaz"
    IDS_BIND_STATUS_ACTIVE_ANY                                 "Enlace P2P activo: cualquier interfaz."
    IDS_BIND_STATUS_ACTIVE_FMT                                 "Enlace P2P activo: %s"
    IDS_BIND_STATUS_INTERFACE_NOT_FOUND_FMT                    "Enlace P2P activo: cualquier interfaz. La interfaz guardada no está disponible: %s"
    IDS_BIND_STATUS_INTERFACE_AMBIGUOUS_FMT                    "Enlace P2P activo: cualquier interfaz. El nombre de la interfaz guardada es ambiguo: %s"
    IDS_BIND_STATUS_INTERFACE_NO_ADDRESS_FMT                   "Enlace P2P activo: cualquier interfaz. La interfaz guardada no tiene una dirección IPv4 utilizable: %s"
    IDS_BIND_STATUS_INTERFACE_ADDRESS_MISSING_FMT              "Enlace P2P activo: cualquier interfaz. Falta el enlace guardado IP en la interfaz seleccionada: %s"
    IDS_BIND_STATUS_ADDRESS_MISSING_FMT                        "Enlace P2P activo: cualquier interfaz. Falta el enlace guardado IP en todas las interfaces en vivo: %s"
    IDS_BIND_RESTART_REQUIRED                                  "Se requiere reinicio: la nueva configuración de enlace entra en vigor solo después de reiniciar eMule."
    IDS_BIND_RESTART_FALLBACK_DEFAULT                          "El reinicio volverá a la interfaz predeterminada porque el destino de enlace guardado no está resuelto."
    IDS_BIND_ADDRESS_INVALID_IPV4                              "BindAddr debe estar vacío o ser una dirección IPv4 válida."
    IDS_EQUIVALENT                                             "Equivalente"
    IDS_UNIT_KIB_PER_SEC                                       "KiB/s"
    IDS_RANDOMIZE_PORTS_ON_STARTUP                             "Aleatorizar los puertos de escucha al inicio"
    IDS_STARTUP_BIND_BLOCK                                     "Mantenga la red fuera de línea si el destino de enlace no está disponible al inicio"
    IDS_SPEED_MIB_PER_SEC_FMT                                  "%.2f MiB/s"
    IDS_WEB_MAX_UPLOAD_MIB_LABEL                               "MiB de carga máxima:"
    IDS_WEB_ALLOWED_IPS_LABEL                                  "IP permitidos:"
    IDS_WEB_INVALID_UPLOAD_SIZE_MIB                            "Ingrese un tamaño de carga WebServer válido en MiB."
    IDS_WEB_INVALID_ALLOWED_IP_FMT                             "Dirección WebServer IP permitida no válida ""%s"".\r\n\r\nUuse direcciones IPv4 separadas por punto y coma o deje el campo en blanco para permitir cualquier dirección remota."
    IDS_USE_WINDOWS_TOAST_NOTIFICATIONS                        "Utilice notificaciones de brindis Windows"
    IDS_NOTIFICATION_DISPLAY_MODE                              "Modo de visualización:"
    IDS_NOTIFICATION_MODE_WINDOWS_TOAST                        "tostada Windows"
    IDS_NOTIFICATION_MODE_CLASSIC_TRAY_BALLOON                 "Globo de bandeja clásico"
    IDS_NOTIFICATION_MODE_CUSTOM_POPUP                         "ventana emergente personalizada"
    IDS_EMAILNOT_GROUP_FMT                                     "(*) %s"
    IDS_FOLLOW_MAJORITY_FILENAME                               "Seguir el nombre de archivo mayoritario"
    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "Copie enlaces eD2K al portapapeles (Kad)"
    IDS_SHUTTING_DOWN_EMULE                                    "Apagar eMuleBB"
    IDS_FRIEND_AUTHENTICATING                                  "Amigo autenticando"
    IDS_BUNDLED_SCRIPT_MISSING                                 "Falta el script eMuleBB incluido: %s"
    IDS_ELEVATED_PS_TIMEOUT                                    "Se agotó el tiempo de espera de la acción elevada de PowerShell."
    IDS_SEARCHPARAMS_NAME_LABEL                                "&Nombre:"
    IDS_SEARCHPARAMS_TYPE_LABEL                                "&Tipo"
    IDS_SEARCHPARAMS_METHOD_LABEL                              "&Método:"
    IDS_SEARCHPARAMS_START_BUTTON                              "&Buscar Ir"
    IDS_SEARCHPARAMS_MORE_BUTTON                               "&Más"
    IDS_SEARCHPARAMS_RESET_BUTTON                              "&Reiniciar"
    IDS_SEARCHPARAMS_CANCEL_BUTTON                             "&Cancelar"
    IDS_STATUS_BIND_IP_LABEL                                   "Enlazar IP"
    IDS_STATUS_PUBLIC_IP_LABEL                                 "Público IP"
    IDS_STATUS_NETWORK_ADDRESS_TOOLTIP_FMT                     "%s: %s | %s: %s"
    IDS_PREVIEW_REQUESTED_WAIT                                 "Vista previa solicitada: espere"
    IDS_SEARCH_INFOTIP_SOURCES                                 "Fuentes"
    IDS_SEARCH_INFOTIP_SERVERS                                 "Servidores"
    IDS_NO_MATCHING_ENTRY_FOUND                                "No se encontró ninguna entrada coincidente."
    IDS_FATAL_NO_RICHEDIT                                      "Error fatal: ¡No se encontró ninguna biblioteca de control Rich Edit!"
    IDS_FATAL_KAD_UNICODE_TABLES                               "Error grave: ¡No se pudieron cargar las tablas de caracteres Unicode para Kademlia!"
    IDS_KAD_UNICODE_MAP_NOT_INITIALIZED                        "Kad ¡El mapa de caracteres en minúsculas Unicode no se ha inicializado!"
    IDS_TWEAKS_TT_CONDITIONAL_TCP_ACCEPT                       "Prefiere aceptar conexiones TCP entrantes solo cuando parecen útiles.\r\n\r\nAjuste avanzado de configuración del tráfico. Déjelo en el valor predeterminado a menos que esté diagnosticando la presión de la conexión."
    IDS_TWEAKS_TT_MAX_CON5_SEC                                 "La cantidad máxima de nuevas conexiones TCP eMule se puede abrir en cinco segundos.\r\n\r\nLos valores más bajos son más suaves en Windows y enrutadores. Déjelo cerca del valor predeterminado a menos que esté ajustando el comportamiento de ráfaga de conexión."
    IDS_TWEAKS_TT_MAX_HALF_OPEN                                "Límite superior para intentos de conexión TCP salientes medio abiertos.\r\n\r\nPrincipalmente una protección de compatibilidad. El valor predeterminado suele ser la opción correcta a menos que esté investigando problemas de configuración de TCP."
    IDS_TWEAKS_TT_CONNECTION_TIMEOUT                           "Cuánto tiempo espera eMule para que una nueva conexión progrese antes de considerar que falló.\r\n\r\nLos valores más cortos se recuperan más rápido de los pares muertos; los valores más largos son más tolerantes con las redes lentas. Se recomiendan los valores predeterminados."
    IDS_TWEAKS_TT_DOWNLOAD_TIMEOUT                             "Cuánto tiempo puede permanecer inactiva una fuente de descarga antes de que eMule la descarte como estancada.\r\n\r\nLos valores más bajos limpian las fuentes inactivas más rápido, pero los valores muy bajos pueden dañar a los pares lentos. Deje el valor predeterminado a menos que esté diagnosticando bloqueos."
    IDS_TWEAKS_TT_SERVER_KEEP_ALIVE_TIMEOUT                    "Con qué frecuencia eMule actualiza una conexión de servidor que de otro modo estaría inactiva.\r\n\r\nUuse minutos. Establezca 0 para desactivar los keepalives. Deje el valor predeterminado a menos que esté resolviendo un problema específico de desconexión del servidor inactivo."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_RESULTS                      "Número máximo de resultados solicitados desde un servidor eD2K para una búsqueda.\r\n\r\nLos valores más altos pueden encontrar más archivos pero aumentan el trabajo del servidor y el ruido de la interfaz de usuario. Manténgase cerca del valor predeterminado a menos que tenga un motivo específico."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_MORE_REQUESTS                "Número máximo de páginas de resultados de seguimiento eMule solicitudes de una búsqueda eD2K.\r\n\r\nLos valores más altos pueden generar más resultados, pero cuestan más tráfico y tiempo del servidor. Se recomiendan valores conservadores."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_TOTAL                        "Número objetivo de resultados para búsquedas de archivos Kad.\r\n\r\nLos valores más altos buscan de manera más amplia pero mantienen activas las búsquedas de Kad por más tiempo. Manténgase cerca del valor predeterminado a menos que desee realizar búsquedas más profundas."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_TOTAL                     "Número objetivo de resultados para búsquedas de palabras clave Kad.\r\n\r\nLos valores más altos pueden encontrar más coincidencias, pero aumentan la carga de consultas Kad y el ruido de la interfaz de usuario. El valor predeterminado suele ser el equilibrio correcto."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_LIFETIME                     "Duración máxima de una búsqueda de archivos Kad en segundos.\r\n\r\nAumente solo si desea deliberadamente realizar búsquedas Kad de mayor duración."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_LIFETIME                  "Duración máxima de una búsqueda de palabras clave Kad en segundos.\r\n\r\nLas duraciones más largas pueden encontrar resultados posteriores, pero aumentan la actividad de búsqueda en segundo plano."
    IDS_TWEAKS_TT_GENERAL_ADVANCED                             "Comportamiento general avanzado que no encaja claramente en la red, el archivo, la pantalla o la seguridad.\r\n\r\nLa mayoría de los usuarios deberían dejarlos cerca de sus valores predeterminados."
    IDS_TWEAKS_TT_HIDDEN_FILE                                  "Comportamiento avanzado de manejo de archivos, inspección de vista previa y opciones relacionadas con el historial de archivos.\r\n\r\nEstas configuraciones determinan cómo eMule trata los archivos, no cuánto espacio en disco reserva."
    IDS_TWEAKS_TT_STORAGE_PERSISTENCE                          "Configuración avanzada de protección del espacio en disco, almacenamiento en búfer de archivos y persistencia de metadatos.\r\n\r\nEste es el grupo principal para la seguridad del almacenamiento y las compensaciones de E/S del disco."
    IDS_TWEAKS_TT_HIDDEN_STARTUP                               "Comportamiento avanzado de restauración de inicio.\r\n\r\nEstas opciones solo afectan qué paneles de la interfaz de usuario regresan cuando se inicia eMule."
    IDS_TWEAKS_TT_HIDDEN_DISPLAY                               "Configuración avanzada de pantalla, barra de tareas, bandeja e información visual.\r\n\r\nEstas opciones solo cambian la presentación, no el comportamiento de transferencia."
    IDS_TWEAKS_TT_HIDDEN_SECURITY                              "Opciones avanzadas de filtrado y protección para un manejo más estricto de mensajes y pares.\r\n\r\nLos valores predeterminados recomendados son apropiados para la mayoría de los usuarios."
    IDS_TWEAKS_TT_LOGGING_GROUP                                "Controles de salida de diagnóstico y registro persistente.\r\n\r\nLa mayoría de estas configuraciones solo son útiles al diagnosticar un problema."
    IDS_TWEAKS_TT_AUTO_TAKE_ED2K_LINKS                         "Registra eMule como el controlador predeterminado para enlaces ed2k://.\r\n\r\nHabilítelo si esta máquina debe abrir enlaces ed2k en eMule automáticamente. Deshabilítelo si otra herramienta debe poseer esa asociación."
    IDS_TWEAKS_TT_CREDIT_SYSTEM                                "Utiliza el sistema de crédito eMule normal al clasificar a los clientes de carga.\r\n\r\nRecomendado: habilitado. Deshabilítelo sólo para depurar o realizar experimentos de compatibilidad deliberados."
    IDS_TWEAKS_TT_YOUR_HOSTNAME                                "La etiqueta de nombre de host opcional eMule informa dónde se muestra el texto de su identidad local.\r\n\r\nDéjelo en blanco a menos que desee nombrar intencionalmente esta instancia."
    IDS_TWEAKS_TT_TXT_EDITOR                                   "Comando utilizado cuando eMule abre archivos de texto como registros o salida de texto generado.\r\n\r\nUuse una ruta completa si el editor no está en PATH. El valor predeterminado es notepad.exe."
    IDS_TWEAKS_TT_HIGHRES_TIMER                                "Solicita un temporizador Windows de alta resolución mientras se ejecuta eMule.\r\n\r\nEsto puede hacer que la sincronización sea más fluida en algunos sistemas, pero puede aumentar el uso de energía. Reinicie eMule después de cambiarlo."
    IDS_TWEAKS_TT_ICH                                          "Habilita el manejo inteligente de la corrupción para fragmentos descargados dañados.\r\n\r\nRecomendado: habilitado. Ayuda a recuperar buenos datos dentro de partes corruptas en lugar de volver a descargar más de lo necesario."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS                         "Controla si se ofrece una vista previa de medios antes de que se cumplan completamente las comprobaciones de seguridad de vista previa normales.\r\n\r\nLos niveles más altos hacen que la vista previa esté disponible antes, pero es más probable que se obtengan vistas previas fallidas o engañosas."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_DISABLED                "Utilice las reglas conservadoras normales de vista previa."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_ALLOW                   "Permitir una vista previa con bloques disponibles más pequeños después de que pasen los metadatos normales y las comprobaciones del jugador."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_FORCE                   "Ofrezca una vista previa incluso cuando falte el primer bloque.\r\n\r\nUÚselo solo con reproductores que puedan tolerar medios incompletos, como VLC."
    IDS_TWEAKS_TT_BEEP_ON_ERROR                                "Reproduce el sonido de error del sistema cuando eMule informa errores importantes.\r\n\r\nUútil para la resolución de problemas sin supervisión. Desactívelo si las alertas audibles distraerían."
    IDS_TWEAKS_TT_SHOW_COPY_ED2K_LINK_CMD                      "Cambia los menús contextuales de archivos para mostrar un comando directo Copiar enlace ed2k en lugar de la acción estándar Mostrar enlace ed2k.\r\n\r\nHabilítelo si copiar enlaces es su flujo de trabajo normal."
    IDS_TWEAKS_TT_SPARSE_PART_FILES                            "Utiliza archivos dispersos para archivos de piezas cuando el sistema de archivos los admite.\r\n\r\nRecomendado: habilitado en NTFS para reducir la asignación inicial de disco. Desactívelo solo si el comportamiento de los archivos dispersos causa un problema específico del sistema de archivos."
    IDS_TWEAKS_TT_FULL_ALLOC                                   "Preasigna el tamaño completo del archivo de destino en el disco cuando comienzan las descargas.\r\n\r\nPuede reducir la fragmentación, pero reserva espacio de inmediato y cuesta más trabajo en el disco. Déjelo desactivado a menos que prefiera la preasignación completa."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_CONFIG                   "Espacio libre mínimo reservado en el volumen que aloja los archivos de configuración de eMule.\r\n\r\nMínimo máximo: 1 GiB. Si este volumen cae por debajo del límite efectivo, eMule detiene todas las descargas y guarda inmediatamente los archivos .part.met.\r\nSi la configuración comparte un volumen con temporal o entrante, gana el límite más grande de ese volumen."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_TEMP                     "Espacio libre mínimo reservado en cada volumen que aloje archivos temporales.\r\n\r\nMínimo máximo: 5 GiB. Si algún volumen protegido cae por debajo de su límite efectivo, eMule detiene todas las descargas y guarda inmediatamente los archivos .part.met.\r\nSi temp comparte un volumen con config o entrante, gana el límite más grande de ese volumen."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_INCOMING                 "Espacio libre mínimo reservado en cada volumen que aloja archivos entrantes, incluidos directorios entrantes específicos de categorías.\r\n\r\nMínimo máximo: 5 GiB. Si el entrante comparte un volumen con config o temp, el límite más grande de ese volumen gana y todas las descargas se detienen cuando se supera."
    IDS_TWEAKS_TT_PERF_LOG                                     "Escribe carga útil periódica y muestras generales para herramientas gráficas externas.\r\n\r\nFunción de operador/depuración únicamente. Déjalo desactivado a menos que consumas activamente los archivos generados."
    IDS_TWEAKS_TT_COMMIT                                       "Controla la agresividad con la que eMule obliga a Windows a vaciar los datos de los archivos guardados en el disco.\r\n\r\nLas configuraciones más seguras reducen el riesgo de pérdida por fallas, pero cuestan más E/S del disco. ""Solo al apagar"" es el valor predeterminado equilibrado."
    IDS_TWEAKS_TT_COMMIT_NEVER                                 "Cierre los archivos normalmente sin forzar una descarga de disco a nivel del sistema operativo.\r\n\r\nEl más rápido y liviano en E/S de disco, pero el más dependiente de la descarga Windows posterior."
    IDS_TWEAKS_TT_COMMIT_ON_SHUTDOWN                           "Fuerce una descarga de disco a nivel de sistema operativo solo mientras se cierra eMule.\r\n\r\nPredeterminado recomendado. Mejora la seguridad de la persistencia en la salida limpia sin forzar descargas adicionales durante cada guardado."
    IDS_TWEAKS_TT_COMMIT_ALWAYS                                "Fuerce un vaciado de disco a nivel de sistema operativo en cada ruta de guardado que utilice el asistente de cierre de confirmación de eMule.\r\n\r\nEs más seguro contra fallas o pérdida de metadatos por pérdida de energía, pero causa la mayor cantidad de E/S de disco."
    IDS_TWEAKS_TT_EXTRACT_META_DATA                            "Controla si eMule extrae metadatos como etiquetas y duración de los medios de los archivos.\r\n\r\nUútil para obtener información más rica sobre los archivos, pero agrega inspección de archivos en segundo plano. Desactívelo si desea el escaneo más ligero."
    IDS_TWEAKS_TT_GEO_LOCATION_ENABLED                         "Resuelve IP de pares en datos de ubicación a nivel de país para su visualización.\r\n\r\nPuramente informativo. Deshabilítelo si no le importan las banderas de los países o no desea actualizaciones de fondo."
    IDS_TWEAKS_TT_CLOSE_U_PN_P_PORTS                           "Cierra las asignaciones de enrutador al salir limpiamente cuando se utilizó la asignación NAT automática.\r\n\r\nRecomendado: habilitado. Deshabilítelo sólo si desea deliberadamente que las asignaciones queden atrás."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE                          "Selecciona cómo eMule realiza la asignación NAT automática.\r\n\r\nRecomendado: Automático. Eso prueba UPnP IGD primero y recurre a PCP/NAT-PMP si es necesario."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_AUTOMATIC                "Modo recomendado. Pruebe primero UPnP IGD y luego recurra a PCP/NAT-PMP si falla la asignación."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_IGD_ONLY                 "Utilice únicamente la asignación de IGD UPnP. Elija esto si desea un comportamiento UPnP estrictamente clásico."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_PCP_NAT_PMP_ONLY         "Utilice únicamente la asignación PCP/NAT-PMP. Elija esto sólo si el entorno de su enrutador claramente lo prefiere."
    IDS_TWEAKS_TT_FILE_BUFFER_TIME_LIMIT                       "Antigüedad máxima de los datos del archivo almacenado en el búfer antes de que eMule los vacíe en el disco.\r\n\r\nLos valores más bajos reducen los datos en riesgo durante los bloqueos. Los valores más altos pueden reducir la rotación de discos. El valor predeterminado suele ser un buen compromiso."
    IDS_TWEAKS_TT_FILE_BUFFER_SIZE                             "Tamaño del búfer de escritura por archivo utilizado antes de vaciar los datos de descarga en el disco.\r\n\r\nLos búferes más grandes pueden reducir la actividad del disco, pero aumentan el uso de memoria y las escrituras retrasadas. Mantenga valores moderados a menos que esté ajustando una configuración de almacenamiento específica."
    IDS_TWEAKS_TT_QUEUE_SIZE                                   "Tamaño objetivo de la cola de espera de carga.\r\n\r\nLos valores más altos permiten que más clientes esperen, pero agregan uso de memoria y sobrecarga de administración. Se recomiendan valores predeterminados para la mayoría de los usuarios."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LISTS                      "Formato de fecha/hora personalizado utilizado en vistas de lista.\r\n\r\nDéjelo en blanco para usar el formato predeterminado normal. Cámbielo solo si desea un estilo de marca de tiempo personalizado específico."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT                             "Formato de fecha/hora personalizado utilizado por archivos generales y pantallas de detalles de pares.\r\n\r\nU utiliza tokens de formato CTime. Mantenlo no vacío; Los tokens no válidos pueden producir marcas de tiempo confusas."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LOG                        "Formato de fecha/hora personalizado utilizado en líneas de registro y salida de estado similar a un registro.\r\n\r\nU utiliza tokens de formato CTime. Sea conciso para que las líneas del registro sean legibles."
    IDS_TWEAKS_TT_ICON_FLASH_ON_NEW_MESSAGE                    "El ícono de la bandeja parpadea cuando llega un nuevo mensaje de chat.\r\n\r\nPuramente una preferencia de notificación. Habilítelo si desea que los mensajes se destaquen mientras eMule está minimizado."
    IDS_TWEAKS_TT_INSPECT_ALL_FILE_TYPES                       "También ejecute la costosa ruta de inspección estilo MediaInfo para tipos de archivos que aún no están clasificados como audio o video.\r\n\r\nHabilítelo si desea un análisis más completo de información de archivos para archivos inusuales o mal etiquetados. Déjelo desactivado para inspeccionar sólo archivos probables de audio/vídeo y reducir el trabajo de inspección en segundo plano."
    IDS_TWEAKS_TT_RE_BAR_TOOLBAR                               "Utiliza el contenedor de barra de herramientas principal de estilo de barra de refuerzo más antiguo en lugar del diseño de barra de herramientas simple y simple.\r\n\r\nPrincipalmente una preferencia de diseño de interfaz de usuario. Déjelo habilitado solo si prefiere la presentación de la barra de herramientas heredada."
    IDS_TWEAKS_TT_SHOW_UP_DOWN_ICON_IN_TASKBAR                 "Muestra el ícono de tasa combinada de carga/descarga en el área de notificación de la barra de tareas.\r\n\r\nPuramente visual. Desactívelo si desea un área de bandeja más limpia."
    IDS_ALWAYS_SHOW_TRAY_ICON                                  "Mostrar siempre el icono de la bandeja"
    IDS_TWEAKS_TT_ALWAYS_SHOW_TRAY_ICON                        "Mantiene el ícono eMule visible en el área de notificación Windows mientras se ejecuta eMule.\r\n\r\nLas notificaciones de globo de bandeja clásicas y minimizar a bandeja aún pueden forzar que el ícono de la bandeja esté visible cuando está deshabilitado."
    IDS_TWEAKS_TT_SHOW_VERTICAL_HOUR_MARKERS                   "Dibuja marcadores de guía por horas en los gráficos de estadísticas a largo plazo.\r\n\r\nUútil para leer patrones de tráfico basados ​​en el tiempo. Desactívelo si prefiere menos desorden de gráficos."
    IDS_TWEAKS_TT_FORCE_SPEEDS_TO_KB                           "Obliga a las visualizaciones de tasas a utilizar unidades estilo KB/s en lugar de escalar automáticamente a unidades más grandes.\r\n\r\nHabilítelo si prefiere unidades familiares fijas. Déjelo desactivado para obtener pantallas de gran velocidad más legibles."
    IDS_TWEAKS_TT_REARRANGE_KAD_SEARCH_KEYWORDS                "Reordena los términos de búsqueda de palabras clave Kad para probar primero una forma de consulta más útil.\r\n\r\nAjuste avanzado del comportamiento de búsqueda. Déjelo en el valor predeterminado a menos que esté ajustando deliberadamente el comportamiento de búsqueda de Kad."
    IDS_TWEAKS_TT_MESSAGE_FROM_VALID_SOURCES_ONLY              "Acepta mensajes solo de pares que ya parecen fuentes válidas para sus transferencias.\r\n\r\nProtección de privacidad/spam más sólida, pero puede bloquear contactos no solicitados. Habilítelo si desea una política de mensajes más estricta."
    IDS_TWEAKS_TT_MAX_CHAT_HISTORY_LINES                       "Número máximo de líneas del historial retenidas por chat o vista de canal IRC.\r\n\r\nLos valores más altos mantienen más contexto pero usan más memoria y pueden hacer que los chats ocupados se muestren más lentamente."
    IDS_TWEAKS_TT_MAX_MESSAGE_SESSIONS                         "Número máximo de sesiones de mensajes entre pares retenidas a la vez.\r\n\r\nLos valores más altos mantienen más conversaciones disponibles, pero aumentan el uso de memoria. El valor predeterminado es conservador."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP                            "Controla la creación de volcados de memoria cuando eMule encuentra un bloqueo no controlado.\r\n\r\nLos volcados de memoria ayudan a diagnosticar fallas graves, pero pueden contener memoria de proceso. Compártelos sólo con desarrolladores de confianza."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_DISABLED                   "No cree archivos de volcado de memoria."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_PROMPT                     "Pregunte antes de escribir un volcado de memoria cuando se produzca un fallo."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_ALWAYS                     "Cree un volcado de memoria automáticamente cuando se produzca un fallo.\r\n\r\nLo mejor para depurar fallos repetibles en una máquina confiable."
    IDS_TWEAKS_TT_MAX_LOG_FILE_SIZE                            "Tamaño máximo de cada archivo de registro en disco en KiB.\r\n\r\nUuse 0 sin límite de rotación. Los valores muy grandes mantienen más historial pero consumen más espacio en disco."
    IDS_TWEAKS_TT_MAX_LOG_BUFFER                               "Búfer de visualización de registros en memoria máximo en KiB.\r\n\r\nLos valores más altos mantienen un historial de registros más visible, pero usan más memoria y pueden ralentizar las vistas de registros muy ocupadas."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT                              "La codificación utilizada para los archivos de registro en disco recién abiertos.\r\n\r\nCambiar esto mientras los registros ya están abiertos persiste, pero el nuevo formato se usa después de volver a abrir el archivo de registro o reiniciar eMule."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UNICODE                      "Escriba registros como UTF-16 Unicode. Este es el valor predeterminado heredado y conserva el texto Windows en términos generales."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UTF8                         "Escriba registros como UTF-8. Útil para herramientas que esperan archivos de texto UTF-8 modernos."
    IDS_TWEAKS_TT_LOG2_DISK                                    "Escribe el registro normal de la aplicación en el disco en lugar de mantenerlo solo en la memoria.\r\n\r\nUútil para la depuración y el uso desatendido de larga duración, pero agrega escrituras en el disco. Déjalo desactivado a menos que quieras registros persistentes."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT                         "Formato de salida para muestras de registro de rendimiento.\r\n\r\nCSV es el más fácil de inspeccionar manualmente. MRTG escribe archivos complementarios para herramientas gráficas que esperan una entrada de estilo MRTG."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_CSV                     "Escriba un archivo de registro de rendimiento CSV con carga útil con marca de tiempo y ejemplos generales."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_MRTG                    "Escriba datos de estilo MRTG y archivos complementarios derivados de la ruta base configurada."
    IDS_TWEAKS_TT_PERF_LOG_FILE                                "Ruta de archivo base para el registro de rendimiento.\r\n\r\nDéjelo en blanco para usar el archivo predeterminado en el directorio de configuración de eMule. El modo MRTG deriva archivos _data y _overhead de esta ruta."
    IDS_TWEAKS_TT_PERF_LOG_INTERVAL                            "Intervalo de muestreo para el registro de rendimiento en minutos.\r\n\r\nLos intervalos cortos crean gráficos más finos pero más escrituras en el disco. Utilice 1..1440."
    IDS_TWEAKS_TT_VERBOSE_GROUP                                "Controles de registro de diagnóstico adicionales para una solución profunda de problemas.\r\n\r\nEstas opciones son para depuración, no para funcionamiento normal. Déjalos fuera a menos que estés investigando un tema específico."
    IDS_TWEAKS_TT_RESTORE_LAST_MAIN_WND_DLG                    "Restaura la última página de la ventana principal seleccionada al inicio.\r\n\r\nHabilítelo si desea que eMule vuelva a abrir donde lo dejó."
    IDS_TWEAKS_TT_RESTORE_LAST_LOG_PANE                        "Restaura el último panel de registro seleccionado al inicio.\r\n\r\nUna opción puramente conveniente para los usuarios que pasan tiempo en las vistas de registro."
    IDS_TWEAKS_TT_KEEP_UNAVAILABLE_FIXED_SHARED_DIRS           "Mantiene los directorios compartidos configurados manualmente en la lista incluso cuando no están disponibles actualmente.\r\n\r\nUútil para almacenamiento extraíble o que ocasionalmente falta. Deshabilítelo si desea que las carpetas faltantes se eliminen agresivamente."
    IDS_TWEAKS_TT_PARTIALLY_PURGE_OLD_KNOWN_FILES              "Permite una limpieza más agresiva de entradas obsoletas en el historial de archivos conocidos.\r\n\r\nPuede reducir el desorden con el tiempo, pero también olvida antes el historial de archivos antiguos. Deje el valor predeterminado a menos que desee un historial más sencillo."
    IDS_TWEAKS_TT_DETECT_TCP_ERROR_FLOODER                     "Detecta ráfagas repetidas de errores TCP que pueden indicar pares abusivos o rotos.\r\n\r\nRecomendado: habilitado. Desactívelo sólo si está diagnosticando falsos positivos."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_INTERVAL_MINUTES           "Ventana de tiempo utilizada para la detección de inundación de errores TCP.\r\n\r\nLas ventanas más cortas reaccionan más rápido; las ventanas más largas son menos sensibles. Se recomiendan los valores predeterminados."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_THRESHOLD                  "Número de errores TCP dentro del intervalo que desencadena el manejo de la inundación.\r\n\r\nLos valores más bajos son más estrictos. Auméntelo sólo si su entorno produce errores TCP frecuentes e inofensivos."
    IDS_TWEAKS_TT_SHAREE_MULE                                  "Controla cómo eMule almacena y comparte el estado por usuario en esta máquina Windows.\r\n\r\nDeje el modo actual a menos que esté cambiando intencionalmente cómo varios usuarios locales comparten la configuración y los datos."
    IDS_TWEAKS_TT_TCP_GROUP                                    "Controles avanzados de ráfaga, tiempo de espera y mantenimiento de conexión TCP.\r\n\r\nEstas configuraciones afectan el comportamiento de la conexión en lugar de los límites de transferencia. Se recomiendan los valores predeterminados a menos que esté diagnosticando problemas de configuración de la red."
    IDS_TWEAKS_TT_SEARCH_GROUP                                 "Límites avanzados sobre la amplitud y duración de las búsquedas eMule en eD2K y Kad.\r\n\r\nLos valores más altos pueden arrojar más resultados, pero también agregan más tráfico de red y ruido de la interfaz de usuario."
    IDS_TWEAKS_TT_SEARCH_ED2K_GROUP                            "Límites de búsqueda eD2K basados ​​en servidor.\r\n\r\nUuse valores conservadores a menos que desee deliberadamente realizar búsquedas de servidor más profundas."
    IDS_TWEAKS_TT_SEARCH_KAD_GROUP                             "Kad controles de duración y amplitud de búsqueda.\r\n\r\nLos valores más altos mantienen activas las búsquedas distribuidas por más tiempo y pueden encontrar más resultados, pero cuestan más actividad en segundo plano."
    IDS_TWEAKS_TT_BROADBAND                                    "Política avanzada de reciclaje de espacios de carga y puntuación de colas para un comportamiento de carga de estilo de banda ancha.\r\n\r\nEstas configuraciones son para un ajuste deliberado. Déjelos en sus valores predeterminados a menos que esté ajustando la equidad de carga o la rotación de espacios."
    IDS_TWEAKS_TT_UPLOAD_POLICY_MAX_UPLOAD_CLIENTS             "Límite flexible para clientes de carga activos simultáneamente bajo el programador de banda ancha.\r\n\r\nLos valores más altos distribuyen el ancho de banda entre más pares pero hacen que cada ranura sea más delgada. Los valores más bajos mantienen menos ranuras y más fuertes."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_THRESHOLD                 "Fracción de la tasa de carga por ranura objetivo por debajo de la cual una ranura se considera lenta.\r\n\r\nLos valores más bajos toleran ranuras más débiles por más tiempo. Los valores más altos reciclan de manera más agresiva las tragamonedas de bajo rendimiento."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_GRACE                     "Cuánto tiempo puede permanecer una ranura por debajo del umbral lento antes de que eMule considere reciclarla.\r\n\r\nUna gracia más larga es más paciente con sus pares débiles; La gracia más corta entrega las ranuras débiles antes."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_WARMUP                    "Período de calentamiento para una nueva ranura de carga antes de que comience la detección de ranura lenta.\r\n\r\nEsto evita penalizar las nuevas cargas por el ruido de inicio y el tiempo de aceleración."
    IDS_TWEAKS_TT_UPLOAD_POLICY_ZERO_RATE_GRACE                "Período de gracia para las ranuras que prácticamente no ofrecen datos de carga.\r\n\r\nLos valores más bajos reaccionan más rápido a las ranuras muertas o estancadas."
    IDS_TWEAKS_TT_UPLOAD_POLICY_COOLDOWN                       "Cuánto tiempo una ranura lenta reciclada permanece penalizada en la puntuación de la cola antes de que pueda volver a competir normalmente.\r\n\r\nUn tiempo de reutilización más largo reduce la reselección inmediata de clientes recientemente débiles."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BOOST                "Agrega una puntuación de cola adicional para los clientes que solicitan archivos con un índice de carga histórico bajo.\r\n\r\nUÚselo si desea favorecer los archivos que han recibido una carga relativamente pequeña hasta el momento."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_THRESHOLD            "Límite de índice de carga por debajo del cual se aplica el aumento de puntuación de cola de índice bajo.\r\n\r\nLos valores más bajos restringen el impulso a archivos más desatendidos."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BONUS                "Puntuación de cola efectiva adicional otorgada cuando se activa el impulso de proporción baja.\r\n\r\nLos valores más altos hacen que el impulso sea más importante en el orden de carga."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_ID_DIVISOR                 "Divisor de penalización aplicado a los clientes LowID durante la puntuación de la cola de carga.\r\n\r\nLos valores más altos reducen la prioridad LowID de manera más agresiva. Establezca 1 para desactivar la penalización adicional LowID."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER               "Limita cuánto se puede transferir una sesión de carga antes de que eMule considere rotar esa ranura.\r\n\r\nLa rotación ocurre solo cuando otro cliente realmente necesita la ranura."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_DISABLED      "No recicle las sesiones de carga según la cantidad de carga útil transferida."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT       "Limite cada sesión de carga a un porcentaje del tamaño del archivo solicitado."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT_VALUE "Porcentaje utilizado cuando el límite de transferencia de sesión se configura como una proporción del tamaño del archivo."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B          "Limite cada sesión de carga a una cantidad fija de MiB independientemente del tamaño del archivo."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B_VALUE    "Cantidad absoluta de MiB utilizada cuando el límite de transferencia de sesión está configurado como un tamaño fijo."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TIME_LIMIT             "Duración máxima de una sesión de carga antes de que eMule considere rotar la ranura.\r\n\r\nEstablezca 0 para deshabilitar el límite basado en tiempo."
    IDS_TWEAKS_TT_A4_AF_SAVE_CPU                               "Reduce las comprobaciones repetidas de fuente A4AF (Solicitud de otro archivo) para ahorrar tiempo de CPU.\r\n\r\nUútil en clientes ocupados, pero puede hacer que el cambio de fuente del mismo cliente sea menos ansioso."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_NEVER                      "No extraiga metadatos de archivos.\r\n\r\nOpción más ligera. Úselo si no desea sondear metadatos en segundo plano."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_ID3_LIB                    "Extraiga metadatos solo a través de la ruta de la biblioteca ID3 para archivos de audio MPEG.\r\n\r\nPredeterminado equilibrado para etiquetas de música básicas sin una inspección multimedia más amplia."
    IDS_TWEAKS_TT_PREVIEW_ON_ICON_DBL_CLK                      "Al hacer doble clic en el icono de un archivo, se abre una vista previa en lugar de la acción predeterminada habitual.\r\n\r\nPuramente una preferencia de flujo de trabajo de la interfaz de usuario."
    IDS_TWEAKS_TT_EXTRA_PREVIEW_WITH_MENU                      "Muestra comandos de vista previa a través de un menú de acción de vista previa dedicado en lugar de exponer solo la acción de vista previa directa más simple.\r\n\r\nUútil si desea opciones de vista previa más explícitas en el menú contextual de la lista de descargas."
    IDS_TWEAKS_TT_SHOW_ACTIVE_DOWNLOADS_BOLD                   "Dibuja la transferencia activa de descargas en negrita en la lista de descargas.\r\n\r\nPuramente visual. Habilítelo si desea que los elementos activos se destaquen más claramente."
    IDS_TWEAKS_TT_USE_SYSTEM_FONT_FOR_MAIN_CONTROLS            "Utiliza la fuente de interfaz de usuario Windows normal para los controles principales y vistas de lista en lugar de la configuración de fuente personalizada de eMule.\r\n\r\nUútil si prefiere texto de aspecto nativo o necesita una mejor compatibilidad con la configuración de fuentes de su sistema."
    IDS_TWEAKS_TT_FILTER_LANI_PS                               "Ignora las direcciones de servidor y cliente de rangos LAN/privados.\r\n\r\nRecomendado: habilitado. Esto evita intentar utilizar direcciones de pares no enrutables de la red pública."
    IDS_TWEAKS_TT_GEO_LOCATION_CHECK_DAYS                      "Con qué frecuencia eMule busca contenido actualizado de la base de datos de geolocalización.\r\n\r\nEstablezca 0 para deshabilitar las comprobaciones de actualización automática. Los valores más grandes reducen la actividad de actualización en segundo plano."
    IDS_TWEAKS_TT_VERBOSE                                      "Interruptor maestro para los controles de registro detallados a continuación.\r\n\r\nDesactívelo para uso normal. Habilítelo sólo mientras investiga un problema específico."
    IDS_TWEAKS_TT_FULL_VERBOSE                                 "Registra el seguimiento detallado más completo disponible cuando el registro detallado está habilitado.\r\n\r\nEsto puede volverse muy ruidoso y debe usarse solo para la resolución de problemas específicos."
    IDS_TWEAKS_TT_LOG_LEVEL                                    "Umbral de detalle para la salida del registro de diagnóstico.\r\n\r\nLos niveles más altos registran más detalles pero crean más ruido."
    IDS_TWEAKS_TT_DEBUG2_DISK                                  "Escribe resultados de diagnóstico detallados en el disco en lugar de mantenerlos transitorios.\r\n\r\nUútil cuando necesita un seguimiento de depuración persistente, pero aumenta la actividad del disco."
    IDS_TWEAKS_TT_DEBUG_SOURCE_EXCHANGE                        "Registra decisiones y paquetes relacionados con el intercambio de origen.\r\n\r\nOpción de diagnóstico especializada. Habilítelo solo mientras depura el comportamiento de descubrimiento de origen."
    IDS_TWEAKS_TT_LOG_BANNED_CLIENTS                           "Registra cuándo se prohíbe a los compañeros y por qué.\r\n\r\nUútil para abuso o diagnóstico falso positivo, pero demasiado ruidoso para el funcionamiento normal."
    IDS_TWEAKS_TT_LOG_RATING_DESC_RECEIVED                     "Registra los comentarios, descripciones y calificaciones de los archivos recibidos.\r\n\r\nUútil para depurar el flujo de metadatos, pero generalmente no es necesario."
    IDS_TWEAKS_TT_LOG_SECURE_IDENT                             "Registra la verificación de identidad segura y las comprobaciones de identidad relacionadas.\r\n\r\nUútil para la resolución de problemas de confianza/autenticación."
    IDS_TWEAKS_TT_LOG_FILTERED_I_PS                            "Registra cuando el filtro IP o ignora la lógica descarta direcciones de pares o servidores.\r\n\r\nUútil para diagnosticar por qué se rechazan algunos pares."
    IDS_TWEAKS_TT_LOG_FILE_SAVING                              "Guarda registros de datos persistentes, como archivos conocidos, créditos y estados relacionados.\r\n\r\nUútil para la depuración de persistencia, pero innecesario para el uso normal."
    IDS_TWEAKS_TT_LOG_A4_AF                                    "Registra la actividad de reasignación de fuente A4AF (Solicitud de otro archivo).\r\n\r\nOpción de diagnóstico de administrador de descargas especializada."
    IDS_TWEAKS_TT_LOG_UL_DL_EVENTS                             "Registra los cambios en el ciclo de vida de los eventos de carga y descarga.\r\n\r\nUútil para diagnosticar la rotación de colas, la rotación de ranuras o las transiciones de estado de transferencia."
    IDS_TWEAKS_TT_U_PN_P                                       "Configuración automática de asignación de puertos del enrutador para la conectividad entrante.\r\n\r\nLa mayoría de los usuarios deben dejar este grupo con los valores predeterminados automáticos a menos que el entorno de su enrutador requiera algo específico."
    IDS_TWEAKS_TT_SHAREE_MULE_MULTI_USER                       "Cada usuario de Windows obtiene una configuración eMule separada y un estado de descarga separado.\r\n\r\nConfig se encuentra en Local AppData y las descargas usan la propia carpeta de Descargas de ese usuario. La mejor opción para PC compartidas donde los usuarios no deben compartir datos eMule."
    IDS_TWEAKS_TT_SHAREE_MULE_PUBLIC_USER                      "Todos los usuarios de Windows comparten la misma configuración y descargas de eMule.\r\n\r\nConfig se encuentra en ProgramData y las descargas utilizan Descargas públicas. Úselo solo si la máquina comparte intencionalmente un estado eMule común."
    IDS_TWEAKS_TT_SHAREE_MULE_OLD_STYLE                        "Mantenga la configuración y las descargas en el directorio del programa, utilizando el diseño heredado anterior.\r\n\r\nSolo modo de compatibilidad heredado. Suele ser la opción menos deseable en los Windows modernos."
    IDS_CONNECTION_TT_AUTOCONNECT                              "Inicia automáticamente las redes habilitadas cuando se inicia eMule.\r\n\r\nRecomendado: habilitado para uso normal sin supervisión. Desactívelo solo si desea conectarse manualmente en cada sesión."
    IDS_CONNECTION_TT_RECONN                                   "Reintenta las conexiones del servidor después de desconexiones o intentos fallidos.\r\n\r\nRecomendado: habilitado si utiliza la red del servidor eD2K. No tiene ningún efecto cuando la red del servidor está deshabilitada."
    IDS_CONNECTION_TT_SHOWOVERHEAD                             "Muestra la sobrecarga del protocolo por separado en las tasas de transferencia y las estadísticas.\r\n\r\nHabilítelo si desea una visión más honesta del tráfico por cable. Déjelo desactivado si prefiere números más simples de carga útil."
    IDS_CONNECTION_TT_PORT                                     "Puerto principal TCP utilizado para conexiones entrantes de clientes.\r\n\r\nCámbielo solo cuando reconfigure intencionalmente las reglas del firewall o del enrutador. Después de cambiarlo, vuelva a probar la conectividad."
    IDS_CONNECTION_TT_UDPPORT                                  "Puerto UDP utilizado para Kad y otras funciones asistidas por UDP.\r\n\r\nRecomendado: manténgalo habilitado y accesible a menos que desee deshabilitar intencionalmente la red basada en UDP."
    IDS_CONNECTION_TT_MAXSOURCEPERFILE                         "Límite estricto de cuántas fuentes remotas conserva eMule por descarga.\r\n\r\nLos valores más altos pueden mejorar la disponibilidad de archivos raros, pero cuestan más memoria y tráfico de administración de fuentes. Utilice valores moderados a menos que tenga una razón específica para aumentarlos."
    IDS_CONNECTION_TT_MAXCON                                   "El límite superior para conexiones simultáneas eMule puede permanecer abierto.\r\n\r\nLos valores más altos no son mejores automáticamente. Déjelo cerca del valor predeterminado ajustado a menos que esté diagnosticando una limitación de red específica."
    IDS_CONNECTION_TT_DOWNLOAD_CAP                             "Su capacidad descendente configurada en KiB/s. eMule utiliza esto como referencia superior para controles deslizantes y decisiones de ancho de banda.\r\n\r\nAjústelo cerca de su velocidad de línea utilizable real, no del máximo de marketing."
    IDS_CONNECTION_TT_UPLOAD_CAP                               "Su capacidad ascendente configurada en KiB/s. eMule usa esto como referencia superior para el control de carga.\r\n\r\nAjústelo cerca de la tasa de carga sostenida real utilizable de su línea."
    IDS_CONNECTION_TT_NETWORK_ED2_K                            "Habilita la red de servidor eD2K clásica.\r\n\r\nDéjelo habilitado si todavía usa el descubrimiento de fuentes basado en servidor. Deshabilítelo sólo si desea intencionalmente el funcionamiento exclusivo de Kad."
    IDS_CONNECTION_TT_NETWORK_KADEMLIA                         "Habilita la red distribuida Kad.\r\n\r\nRecomendado: habilitado para uso moderno. Requiere que el puerto UDP permanezca habilitado."
    IDS_CONNECTION_TT_PREF_UPNPONSTART                         "Intenta asignar automáticamente el puerto NAT al inicio para los puertos TCP y UDP configurados.\r\n\r\nRecomendado: habilitado cuando su enrutador admite UPnP o PCP/NAT-PMP. Deshabilítelo si reenvía puertos manualmente."
    IDS_CONNECTION_TT_RANDOMIZE_PORTS_ON_STARTUP               "Elige los nuevos puertos de escucha TCP y UDP al inicio antes de que se ejecute la asignación automática de puertos.\r\n\r\nLa opción utiliza el rango de puertos aleatorios existente de eMule y deja UDP deshabilitado cuando el puerto UDP está deshabilitado."
    IDS_CONNECTION_TT_UDPDISABLE                               "Deshabilita el puerto UDP de eMule y, por lo tanto, deshabilita las funciones dependientes de UDP, como la red Kad.\r\n\r\nRecomendado: deje esta opción desactivada a menos que deba ejecutar TCP solo para un entorno de red muy específico."
    IDS_CONNECTION_TT_STARTTEST                                "Inicia la prueba de conectividad externa para los puertos TCP y UDP configurados actualmente.\r\n\r\nUÚselo después de cambiar los puertos, la configuración de enlace o las reglas de asignación del enrutador."
    IDS_CONNECTION_TT_BIND_INTERFACE                           "Nombre de interfaz de red Windows opcional utilizado para el enlace de socket P2P.\r\n\r\nLa coincidencia se realiza por nombre de interfaz descriptivo, no por número de adaptador. Los cambios entran en vigor después del reinicio."
    IDS_CONNECTION_TT_BIND_ADDRESS                             "Dirección IPv4 opcional utilizada para el enlace de socket P2P.\r\n\r\nDéjelo vacío para usar el primer IPv4 en la interfaz seleccionada, o la opción de enrutamiento predeterminada cuando no se selecciona ninguna interfaz."
    IDS_CONNECTION_TT_STARTUP_BIND_BLOCK                       "Mantiene la red P2P fuera de línea durante la sesión si el destino de enlace configurado no se puede resolver al inicio.\r\n\r\nDisponible solo cuando se selecciona una interfaz de enlace. Recomendado cuando se vincula explícitamente a una interfaz con nombre y no desea un respaldo silencioso."
    IDS_WEBSERVER_TT_WEBBINDADDR                               "Dirección de enlace local para WebServer y REST API integrados.\r\n\r\nDéjelo vacío o como 0.0.0.0 para escuchar en todas las interfaces. Configure un IPv4 específico solo si desea restringir deliberadamente dónde escucha el servicio."
    IDS_WEBSERVER_TT_WSAPIKEY                                  "Clave REST API de texto sin formato utilizada por los clientes en el encabezado X-API-Key.\r\n\r\nRecomendado: mantenga el valor aleatorio generado a menos que necesite un token específico. Cualquiera que tenga esta clave tiene acceso completo a la API."
    IDS_WEBSERVER_TT_WSUPNP                                    "Incluye el puerto WebServer en la asignación NAT automática cuando UPnP o PCP/NAT-PMP está habilitado.\r\n\r\nHabilítelo solo si intencionalmente desea que se pueda acceder al Web UI o REST API a través de la asignación de su enrutador."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD                          "Tamaño máximo de carga de un solo archivo aceptado por el WebServer en MiB.\r\n\r\nUuse un valor pequeño para el control remoto normal. Auméntelo sólo si los clientes web confiables necesitan cargar archivos más grandes."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD_LBL                      "Tamaño máximo de carga de un solo archivo aceptado por el WebServer en MiB.\r\n\r\nUuse un valor pequeño para el control remoto normal. Auméntelo sólo si los clientes web confiables necesitan cargar archivos más grandes."
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS                             "Lista de permitidos IPv4 opcional separada por punto y coma para clientes WebServer.\r\n\r\nDeje en blanco para permitir cualquier dirección remota que pueda llegar al WebServer. Ejemplo: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS_LBL                         "Lista de permitidos IPv4 opcional separada por punto y coma para clientes WebServer.\r\n\r\nDeje en blanco para permitir cualquier dirección remota que pueda llegar al WebServer. Ejemplo: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWHILEVFUNC                         "Permite acciones web administrativas de alto nivel que pueden cambiar el estado del tiempo de ejecución de manera más agresiva.\r\n\r\nRecomendado: mantenga esta opción desactivada a menos que necesite explícitamente esas acciones de clientes administradores confiables."
    IDS_WEBSERVER_TT_WEB_HTTPS                                 "Sirve Web UI y REST API sobre HTTPS utilizando el certificado y la clave configurados.\r\n\r\nRecomendado: habilitado siempre que exponga el WebServer más allá de la máquina local."
    IDS_NOTIFY_TT_CB_TBN_USESOUND                              "Reproduce un archivo WAV personalizado para notificaciones de la barra de tareas.\r\n\r\nUuse esto si desea una alerta audible. Déjalo desactivado si las ventanas emergentes silenciosas o el habla son suficientes."
    IDS_NOTIFY_TT_CB_TBN_USESPEECH                             "Utiliza texto a voz para las notificaciones de la barra de tareas cuando hay un motor de voz disponible.\r\n\r\nUútil en sistemas desatendidos donde las alertas habladas son más fáciles de notar que los sonidos."
    IDS_NOTIFY_TT_CB_TBN_POP_ALWAYS                            "Muestra una ventana emergente para cada mensaje de chat entrante en lugar de solo el primero.\r\n\r\nHabilítelo si no desea que los mensajes de chat siguientes permanezcan en silencio."
    IDS_NOTIFY_TT_CB_TBN_USEWINDOWSTOAST                       "Utiliza notificaciones del sistema Windows en lugar de la ventana emergente personalizada eMule.\r\n\r\nSi Windows rechaza una notificación del sistema, eMule recurre a la ventana emergente personalizada."
    IDS_NOTIFY_TT_TBN_DISPLAYMODE                              "Selecciona cómo eMule muestra las notificaciones emergentes habilitadas. La notificación\r\n\r\nWindows es la opción predeterminada. Si Windows rechaza una notificación del sistema, incluso cuando eMule se ejecuta como administrador, eMule recurre al globo de bandeja clásico."
    IDS_NOTIFY_TT_CB_ENABLENOTIFICATIONS                       "Habilita las notificaciones de correo electrónico salientes para los eventos configurados.\r\n\r\nHabilítelo solo si ya ha configurado un servidor SMTP y direcciones que funcionen."
    IDS_NOTIFY_TT_SMTPSERVER                                   "Abre la configuración del servidor SMTP utilizada por las notificaciones por correo electrónico.\r\n\r\nSolo necesita esto si las notificaciones por correo electrónico están habilitadas."
    IDS_BIND_STARTUP_INTERFACE_NOT_FOUND_FMT                   "Redes deshabilitadas para esta sesión porque la interfaz de enlace seleccionada ya no está disponible: %s"
    IDS_BIND_STARTUP_INTERFACE_AMBIGUOUS_FMT                   "Redes deshabilitadas para esta sesión porque el nombre de la interfaz de enlace seleccionada coincide con varios adaptadores en vivo: %s"
    IDS_BIND_STARTUP_INTERFACE_NO_ADDRESS_FMT                  "Redes deshabilitadas para esta sesión porque la interfaz de enlace seleccionada no tiene una dirección IPv4 utilizable: %s"
    IDS_BIND_STARTUP_INTERFACE_ADDRESS_MISSING_FMT             "Redes deshabilitadas para esta sesión porque el enlace seleccionado IP ya no está presente en la interfaz seleccionada: %s"
    IDS_BIND_STARTUP_ADDRESS_MISSING_FMT                       "Redes deshabilitadas para esta sesión porque el enlace seleccionado IP ya no está presente en ninguna interfaz en vivo: %s"
    IDS_BIND_EXIT_INTERFACE_CHANGED_FMT                        "Saliendo de eMule porque la interfaz de enlace seleccionada cambió la dirección de %s a %s: %s"
    IDS_BIND_EXIT_INTERFACE_UNAVAILABLE                        "Saliendo de eMule porque la interfaz de enlace seleccionada ya no está disponible."
    IDS_BIND_STARTUP_DISABLED_PREFIX                           "Redes deshabilitadas para esta sesión"
    IDS_BIND_EXIT_PREFIX                                       "Saliendo de eMule"
    IDS_STATUS_BIND_IP_COMPACT_LABEL                           "B"
    IDS_STATUS_PUBLIC_IP_COMPACT_LABEL                         "PAG"
    IDS_STATUS_ANY_COMPACT                                     "Cualquier"
    IDS_STATUS_UNKNOWN_COMPACT                                 "?"
    IDS_STATUS_NETWORK_ADDRESS_TEXT_FMT                        "%s:%s|%s:%s"
    IDS_PPG_DIRECTORIES_TT_INCFILES                            "Directorio entrante principal para descargas completadas.\r\n\r\nUuse una ruta local estable con suficiente espacio libre. Evite ubicaciones temporales o extraíbles a menos que realmente quiera archivos terminados allí."
    IDS_PPG_DIRECTORIES_TT_TEMPFILES                           "Lista de directorios de trabajo para archivos de piezas, hash y estado de transferencia.\r\n\r\nEstas rutas deben permanecer disponibles mientras se ejecutan las descargas. Se recomiendan discos locales rápidos en lugar de rutas de red extraíbles o no confiables."
    IDS_PPG_DIRECTORIES_TT_SHARESELECTOR                       "Selecciona qué carpetas locales comparte eMule con otros clientes.\r\n\r\nComparta solo los directorios que desea publicar. Evite raíces amplias, como una unidad completa."
    IDS_PPG_DISPLAY_TT_MINTRAY                                 "Minimiza eMule en la bandeja en lugar de dejarlo en la barra de tareas.\r\n\r\nUútil para configuraciones siempre activas. Déjalo desactivado si prefieres el comportamiento normal de la barra de tareas."
    IDS_PPG_DISPLAY_TT_TOOLTIPDELAY                            "Retraso antes de que aparezca la información sobre herramientas de la interfaz de usuario.\r\n\r\nLos valores más bajos se sienten más rápidos, los valores más altos reducen las ventanas emergentes accidentales. El rango predeterminado suele ser un buen compromiso."
    IDS_PPG_DISPLAY_TT_SHOWRATEONTITLE                         "Muestra las tasas de carga y descarga actuales en el título de la ventana principal.\r\n\r\nUútil cuando eMule permanece en segundo plano y aún desea un vistazo rápido a la velocidad."
    IDS_PPG_DISPLAY_TT_STORESEARCHES                           "Mantiene los términos de búsqueda recientes para que puedan reutilizarse más adelante.\r\n\r\nRecomendado: habilitado a menos que específicamente no desee conservar el historial de búsqueda."
    IDS_PPG_DISPLAY_TT_WIN7_TASKBARGOODIES                     "Habilita el progreso de la barra de tareas de Windows y la integración del shell relacionado cuando sea compatible.\r\n\r\nRecomendado: habilitado en Windows moderno a menos que desee una presencia de shell más mínima."
    IDS_PPG_FILES_TT_PF_TIMECALC                               "Utiliza el cálculo más detallado del tiempo restante para las descargas.\r\n\r\nRecomendado: habilitado si desea estimaciones de ETA más estables. Deshabilítelo sólo si prefiere el cálculo más simple y antiguo."
    IDS_PPG_FILES_TT_PREVIEWPRIO                               "Da prioridad a los fragmentos de vista previa de películas para que los medios descargados parcialmente se puedan obtener antes.\r\n\r\nUútil para descargas de videos. Déjalo desactivado si prefieres realizar pedidos en trozos neutros."
    IDS_PPG_FILES_TT_WATCHCB                                   "Observa el portapapeles en busca de enlaces de ed2k y se ofrece a manejarlos.\r\n\r\nConveniente si agregas descargas desde navegadores con frecuencia. Desactívelo si no desea que eMule mire el portapapeles."
    IDS_PPG_FILES_TT_FNCLEANUP                                 "Limpia los nombres de los archivos descargados automáticamente de acuerdo con las reglas configuradas.\r\n\r\nRecomendado: habilitado si desea nombres de archivos finales más consistentes sin limpieza manual."
    IDS_PPG_FILES_TT_STARTNEXTFILE                             "Inicia automáticamente el siguiente archivo en cola cuando finaliza o se detiene otra descarga.\r\n\r\nRecomendado: habilitado si usa colas en pausa para controlar cuántos archivos se ejecutan a la vez."
    IDS_PPG_FILES_TT_RUNONFILECOMPLETE                         "Ejecuta un ejecutable después de que un archivo se completa y conserva correctamente.\r\n\r\nEsto está deshabilitado de forma predeterminada. El programa se inicia directamente sin el shell Windows."
    IDS_PPG_FILES_TT_FILECOMPLETEARGS                          "Tokens admitidos: ruta completa %F, directorio %D, nombre de archivo %N, hash de archivo %H, bytes de tamaño %S, categoría %C.\r\n\r\n%F y %D se citan automáticamente. Las variables de entorno no se expanden."
    IDS_PPG_GENERAL_TT_ONLINESIG                               "Escribe el archivo de estado heredado onlinesig.dat para páginas externas, scripts o widgets que leen el estado eMule.\r\n\r\nIn. No mejora la velocidad de transferencia ni la conexión en red. Déjalo desactivado a menos que consumas activamente ese archivo en algún lugar."
    IDS_PPG_GENERAL_TT_BRINGTOFOREGROUND                       "Pone eMule en primer plano cuando un enlace ed2k manejado o una acción externa similar apunta a la aplicación.\r\n\r\nHabilítelo si desea que los clics en el enlace revelen eMule inmediatamente. Déjalo desactivado si prefieres el manejo en segundo plano."
    IDS_PPG_GENERAL_TT_CHECK4_UPDATE                           "Comprueba las versiones de GitHub al inicio cuando el intervalo configurado ha transcurrido y solo alerta cuando hay disponible un paquete eMuleBB más nuevo.\r\n\r\nDéjalo desactivado para un inicio silencioso o habilítalo si deseas una verificación de actualización periódica."
    IDS_PPG_GENERAL_TT_PREVENTSTANDBY                          "Bloquea la suspensión del sistema mientras eMuleBB está conectado o transfiriendo, de modo que las descargas, cargas, Kad y las sesiones del servidor no se interrumpan.\r\n\r\nLa pantalla aún puede apagarse normalmente. Al desactivar esta opción se restaura inmediatamente la política de suspensión normal del Windows."
    IDS_PPG_GENERAL_TT_WEBSVEDIT                               "Edita la lista de servicios web configurados utilizados por acciones auxiliares como búsquedas web desde la interfaz de usuario.\r\n\r\nNormalmente, solo necesita esto si desea personalizar o reparar esas entradas de búsqueda externas."
    IDS_PPG_GENERAL_TT_ED2_KFIX                                "Repara el registro del enlace ed2k Windows para que los enlaces ed2k del navegador y el shell se abran nuevamente en eMule.\r\n\r\nUÚselo cuando los enlaces ed2k dejen de iniciarse en eMule o hayan sido robados por otro cliente."
    IDS_PPG_GENERAL_TT_STARTMIN                                "Inicia eMule minimizado en lugar de abrir la ventana principal inmediatamente.\r\n\r\nUútil para el inicio desatendido. Déjelo desactivado si normalmente desea inspeccionar la interfaz de usuario de inmediato."
    IDS_PPG_GENERAL_TT_STARTWIN                                "Registra eMule para comenzar con Windows para el usuario actual.\r\n\r\nHabilítelo solo en máquinas donde eMule debe ejecutarse persistentemente en segundo plano."
    IDS_PPG_IRC_TT_IRC_USECHANFILTER                           "Aplica el filtro de nombre de canal y usuario mínimo al solicitar la lista de canales IRC.\r\n\r\nHabilítelo si desea que la lista se reduzca automáticamente. Desactívelo para obtener siempre la lista completa de canales."
    IDS_PPG_IRC_TT_IRC_USEPERFORM                              "Ejecuta el script de ejecución después de conectarse a IRC.\r\n\r\nUÚselo para uniones automáticas o comandos IRC. Déjelo desactivado si no mantiene un guión de ejecución."
    IDS_PPG_IRC_TT_IRC_NAME_BOX                                "Texto de filtro para la lista de canales IRC.\r\n\r\nSolo los canales que coinciden con este texto se conservan cuando el filtro de canales está habilitado."
    IDS_PPG_IRC_TT_IRC_MINUSER_BOX                             "Recuento mínimo de usuarios para los canales que muestra el filtro de lista de canales IRC.\r\n\r\nAuéntelo para ocultar canales pequeños. Utilice 0 para mantener los canales independientemente del tamaño."
    IDS_PPG_MESSAGES_TT_MSGONLYFRIENDS                         "Acepta mensajes directos solo de usuarios de tu lista de amigos.\r\n\r\nRecomendado si deseas una configuración de chat muy silenciosa. Déjalo desactivado si aún quieres recibir mensajes de clientes normales."
    IDS_PPG_MESSAGES_TT_ADVSPAMFILTER                          "Habilita la ruta de filtro de spam de mensajes más potente.\r\n\r\nRecomendado: habilitado para uso normal de redes públicas. Funciona junto con captchas de chat para un filtrado más estricto."
    IDS_PPG_MESSAGES_TT_USECAPTCHAS                            "Requiere un desafío de captcha antes de que clientes desconocidos puedan completar una conversación de chat.\r\n\r\nUútil contra el spam de chat. Se utiliza mejor junto con el filtro de spam avanzado."
    IDS_PPG_MESSAGES_TT_COMMENTFILTER                          "Bloquea los comentarios de archivos que contienen los términos de filtro configurados.\r\n\r\nUuse un '|' separador entre términos. Bueno para palabras spam conocidas o patrones molestos."
    IDS_PPG_PROXY_TT_ENABLEPROXY                               "Enruta conexiones salientes admitidas a través del proxy configurado.\r\n\r\nHabilítelo solo si ejecuta intencionalmente eMule detrás de un proxy. Las conexiones directas son más sencillas y normalmente más rápidas."
    IDS_PPG_PROXY_TT_PROXYTYPE                                 "Selecciona el protocolo de proxy esperado por su servidor proxy.\r\n\r\nUuse el tipo exacto proporcionado por el operador de proxy; el tipo incorrecto generalmente significa fallas de conexión inmediatas."
    IDS_PPG_PROXY_TT_PROXYNAME                                 "Nombre de host o dirección IP del servidor proxy.\r\n\r\nIngrese exactamente el punto final proporcionado por su servicio proxy. Un host incorrecto significa que todo el tráfico proxy fallará."
    IDS_PPG_PROXY_TT_PROXYPORT                                 "Puerto de escucha del servidor proxy.\r\n\r\nUuse el puerto exacto requerido por el proxy. No se garantiza que los valores predeterminados comunes de SOCKS sean correctos."
    IDS_PPG_PROXY_TT_ENABLEAUTH                                "Envía credenciales de nombre de usuario y contraseña del proxy cuando el proxy requiere autenticación.\r\n\r\nHabilítelo solo si su servicio de proxy realmente usa credenciales de inicio de sesión."
    IDS_PPG_PROXY_TT_USERNAME_A                                "Nombre de usuario de la cuenta de proxy.\r\n\r\nDéjelo vacío a menos que su proxy requiera explícitamente acceso autenticado."
    IDS_PPG_SCHEDULER_TT_ENABLE                                "Habilita el programador para que las reglas basadas en tiempo puedan cambiar la configuración automáticamente.\r\n\r\nDéjelo desactivado a menos que utilice activamente cambios programados de ancho de banda, conexión o categoría."
    IDS_PPG_SCHEDULER_TT_CHECKNOENDTIME                        "Ejecuta la entrada de programación seleccionada sin una hora de parada.\r\n\r\nUÚsela para cambios de estado unidireccionales que deberían permanecer activos hasta que otra programación los anule."
    IDS_PPG_SCHEDULER_TT_APPLY                                 "Aplica los detalles editados a la entrada de programación seleccionada actualmente.\r\n\r\nUuse esto después de cambiar el día, la hora o la lista de acciones para esa fila."
    IDS_PPG_SECURITY_TT_USESECIDENT                            "Utiliza identificación segura cuando es compatible para hacer que las identidades crediticias de los clientes sean más difíciles de falsificar.\r\n\r\nRecomendado: habilitado. Deshabilitarlo solo reduce la confianza en la identidad y rara vez es útil."
    IDS_PPG_SECURITY_TT_FILTERSERVERBYIPFILTER                 "Aplica el filtro IP a la lista de servidores visibles para que los servidores filtrados se oculten o eliminen.\r\n\r\nRecomendado: habilitado si confía en el filtro IP para la higiene del servidor y el filtrado de pares."
    IDS_PPG_SECURITY_TT_UPDATEURL                              "URL de origen utilizada al descargar listas de filtros IP actualizadas.\r\n\r\nUuse únicamente un proveedor confiable. Las actualizaciones automáticas reutilizan esta URL y mantienen el filtro existente si la descarga no es válida."
    IDS_PPG_SECURITY_TT_AUTOUPDATE_IPFILTER                    "Comprueba la URL del filtro IP configurada automáticamente después del inicio cuando vence el intervalo de actualización.\r\n\r\nRecomendado: deshabilitado a menos que confíe en el proveedor y desee que el filtro se actualice sin acción manual."
    IDS_PPG_SECURITY_TT_IPFILTERPERIOD                         "Número de días entre intentos de actualización automática del filtro IP.\r\n\r\nRango permitido: de 1 a 365 días. Los intentos fallidos todavía se cuentan para evitar bucles de reintento cuando un proveedor no está disponible."
    IDS_PPG_SECURITY_TT_SEESHARE1                              "Permite que todos exploren sus archivos compartidos cuando el cliente remoto lo admite.\r\n\r\nOpción más permisiva. Úselo sólo si se siente cómodo exponiendo ampliamente su lista compartida."
    IDS_PPG_SECURITY_TT_SEESHARE2                              "Permite que solo los amigos exploren sus archivos compartidos.\r\n\r\nElección de privacidad equilibrada si aún desea soporte de navegación para contactos de confianza explícita."
    IDS_PPG_SECURITY_TT_SEESHARE3                              "Evita que los clientes remotos exploren su lista de archivos compartidos.\r\n\r\nRecomendado si desea la postura de privacidad más estricta para la exploración de archivos compartidos."
    IDS_PPG_SECURITY_TT_ENABLEOBFUSCATION                      "Prefiere la ofuscación de protocolo cuando el lado remoto también lo admite.\r\n\r\nRecomendado: habilitado. Puede ayudar en redes restrictivas sin forzar una política de solo ofuscación."
    IDS_PPG_SECURITY_TT_ONLYOBFUSCATED                         "Requiere conexiones ofuscadas en lugar de aceptar conexiones normales.\r\n\r\nÚselo solo si su entorno de red realmente lo necesita. Puede reducir la conectividad y el alcance entre pares."
    IDS_PPG_SECURITY_TT_SEARCHSPAMFILTER                       "Filtra el spam obvio de los resultados de búsqueda antes de que saturan la interfaz de usuario.\r\n\r\nRecomendado: habilitado para uso normal en redes públicas."
    IDS_PPG_SECURITY_TT_CHECK_FILE_OPEN                        "Comprueba los archivos descargados en busca de estado abierto/bloqueado antes de operaciones que requieren acceso exclusivo.\r\n\r\nRecomendado: habilitado a menos que tenga una razón específica para omitir la verificación de seguridad."
    IDS_PPG_SERVER_TT_AUTOSERVER                               "Actualiza automáticamente la lista de servidores de los clientes conectados y otras fuentes confiables.\r\n\r\nConveniente, pero también permite que la lista cambie con el tiempo. Desactívelo si prefiere una lista de servidores estáticos cuidadosamente seleccionados."
    IDS_PPG_SERVER_TT_UPDATESERVERCONNECT                      "Permite que los servidores conectados anuncien servidores adicionales en su lista.\r\n\r\nConveniente, pero puede hacer crecer la lista con entradas de bajo valor. Desactívelo si prefiere una curación manual más estricta."
    IDS_PPG_SERVER_TT_UPDATESERVERCLIENT                       "Permite a los clientes contribuir con direcciones de servidores a su lista de servidores.\r\n\r\nLa mayoría de los usuarios deben tratar esto con cautela. Desactívelo si desea un control más estricto sobre la calidad de la lista de servidores."
    IDS_PPG_SERVER_TT_SAFESERVERCONNECT                        "Utiliza una estrategia de conexión al servidor más cautelosa en lugar de apresurarse entre muchos candidatos.\r\n\r\nRecomendado: habilitado para estabilidad. Desactívelo sólo si desea deliberadamente un enfoque de conexión más agresivo."
    IDS_PPG_SERVER_TT_SMARTIDCHECK                             "Realiza la comprobación inteligente LowID antes de decidir que la accesibilidad del lado del servidor es deficiente.\r\n\r\nRecomendado: habilitado. Evita algunas conclusiones LowID falsas durante condiciones transitorias de la red."
    IDS_PPG_SERVER_TT_SCORE                                    "Utiliza las prioridades del servidor al elegir y ordenar servidores.\r\n\r\nRecomendado: habilitado si mantiene un subconjunto preferido de servidores y desea que eMule los favorezca."
    IDS_PPG_SERVER_TT_SERVERRETRIES                            "Cuántos intentos fallidos de conexión puede acumular un servidor antes de que eMule lo trate como muerto.\r\n\r\nLos valores más bajos eliminan los servidores defectuosos más rápido; los valores más altos son más indulgentes con las interrupciones transitorias."
    IDS_PPG_SERVER_TT_AUTOCONNECTSTATICONLY                    "Restringe los intentos de conexión automática del servidor a servidores marcados como estáticos.\r\n\r\nHabilítelo si mantiene una pequeña lista estática confiable y no desea la rotación automática en toda la lista de servidores."
    IDS_PPG_SERVER_TT_MANUALSERVERHIGHPRIO                     "Otorga a los servidores agregados manualmente un sesgo de prioridad más alto que las entradas descubiertas normales.\r\n\r\nHabilítelo si mantiene un conjunto de servidores cuidadosamente seleccionados y desea que se favorezcan esas adiciones."
    IDS_PPG_STATS_TT_FILL_GRAPHS                               "Rellena las áreas del gráfico en lugar de dibujar solo líneas.\r\n\r\nPuramente visual. Deshabilítelo si prefiere una vista de estadísticas más liviana y menos ocupada."
    IDS_PPG_STATS_TT_SLIDER                                    "Intervalo de actualización para el gráfico de tráfico en vivo.\r\n\r\nLos valores más bajos se sienten más receptivos pero cuestan más trabajo de interfaz de usuario. Los valores moderados suelen ser los mejores."
    IDS_PPG_STATS_TT_SLIDER2                                   "Intervalo de actualización para el árbol de estadísticas y los valores de resumen.\r\n\r\nLos valores más bajos se actualizan con más frecuencia pero cuestan más abandono de la interfaz de usuario. Auméntelo si desea actualizaciones más tranquilas."
    IDS_PPG_STATS_TT_SLIDER3                                   "Ventana de promedio utilizada por los gráficos.\r\n\r\nLas ventanas cortas muestran picos claramente; las ventanas más largas suavizan la visualización y enfatizan las tendencias."
    IDS_PPG_STATS_TT_COLORSELECTOR                             "Selecciona qué color del elemento estadístico está editando.\r\n\r\nUÚselo solo si está personalizando la paleta de gráficos."
    IDS_PPG_STATS_TT_CGRAPHSCALE                               "Escala manual del eje Y para el gráfico de conexión.\r\n\r\nLevántelo si el gráfico recorta valores altos; los valores más bajos brindan más detalles en recuentos de conexiones modestos."
    IDS_PPG_STATS_TT_CRATIO                                    "Cargar/descargar la relación de aspecto utilizada por el gráfico de conexión combinado.\r\n\r\nDéjelo cerca del valor predeterminado a menos que desee que el gráfico enfatice una dirección con más fuerza."
    IDS_NOTIFY_TT_BTN_BROWSE_WAV                               "Busca el archivo WAV utilizado por las notificaciones de sonido de la barra de tareas.\r\n\r\nSolo disponible cuando se seleccionan notificaciones de sonido personalizadas."
    IDS_NOTIFY_TT_CB_TBN_IMPORTATNT                            "Muestra notificaciones de condiciones urgentes, como advertencias de espacio en disco o conexiones perdidas al servidor.\r\n\r\nRecomendado: habilitado si la máquina funciona desatendida con frecuencia."
    IDS_NOTIFY_TT_CB_TBN_NOSOUND                               "Desactiva la salida de sonido de notificación.\r\n\r\nUuse esto cuando las notificaciones visuales sean suficientes o la máquina deba permanecer en silencio."
    IDS_NOTIFY_TT_CB_TBN_ONCHAT                                "Muestra una notificación cuando se inicia una sesión de chat.\r\n\r\nUútil si mantiene eMule minimizado y aún desea notar nuevas conversaciones."
    IDS_NOTIFY_TT_CB_TBN_ONDOWNLOAD                            "Muestra una notificación cuando finaliza una descarga.\r\n\r\nRecomendado si los archivos completados necesitan atención sin mirar la página de Transferencias."
    IDS_NOTIFY_TT_CB_TBN_ONLOG                                 "Muestra una notificación cuando se agrega una entrada de registro.\r\n\r\nUútil para el diagnóstico, pero ruidoso durante sesiones normales de larga duración."
    IDS_NOTIFY_TT_CB_TBN_ONNEWDOWNLOAD                         "Muestra una notificación cuando se agrega una nueva descarga.\r\n\r\nHabilítelo si las descargas se pueden agregar externamente y desea confirmación."
    IDS_NOTIFY_TT_CB_TBN_ONNEWVERSION                          "Muestra una notificación cuando el verificador de actualizaciones encuentra una versión más reciente de eMuleBB.\r\n\r\nEsto solo importa cuando las comprobaciones de actualizaciones están habilitadas en la página General."
    IDS_NOTIFY_TT_EDIT_RECEIVER                                "Dirección de correo electrónico que recibe mensajes de notificación eMule.\r\n\r\nUuse una dirección aceptada por el servidor SMTP configurado."
    IDS_NOTIFY_TT_EDIT_SENDER                                  "Dirección del remitente utilizada para notificaciones por correo electrónico.\r\n\r\nMuchos servidores SMTP requieren que esto coincida o pertenezca a la cuenta autenticada."
    IDS_NOTIFY_TT_EDIT_TBN_WAVFILE                             "Ruta al archivo WAV reproducido para notificaciones de sonido.\r\n\r\nElija un archivo local corto; Los archivos faltantes o inaccesibles impiden que se reproduzca el sonido."
    IDS_NOTIFY_TT_TEST_NOTIFICATION                            "Envía una notificación de prueba utilizando la configuración de notificación actual.\r\n\r\nUúsela después de cambiar la configuración de ventana emergente, sonido o correo electrónico."
    IDS_PPG_DIRECTORIES_TT_SELINCDIR                           "Busca el directorio entrante utilizado para las descargas completadas.\r\n\r\nElija una ruta local estable con suficiente espacio libre."
    IDS_PPG_DIRECTORIES_TT_SELTEMPDIR                          "Busca el directorio de archivos temporales seleccionados. Los archivos\r\n\r\nPart dependen de que esta ruta permanezca disponible mientras se ejecutan las descargas."
    IDS_PPG_DIRECTORIES_TT_SELTEMPDIRADD                       "Agrega otro directorio de archivos temporales a la lista de directorios de trabajo.\r\n\r\nUuse múltiples discos locales rápidos y confiables solo cuando desee distribuir deliberadamente archivos parciales."
    IDS_PPG_DIRECTORIES_TT_UNCADD                              "Agrega una ruta UNC de red a la lista de directorios compartidos.\r\n\r\nSolo comparta carpetas de red que permanezcan accesibles y que estén destinadas a su publicación."
    IDS_PPG_DISPLAY_TT_3DDEPTH                                 "Controla la profundidad del sombreado 3D utilizado por las imágenes clásicas de listas y gráficos.\r\n\r\nPuramente visual; los valores más bajos parecen más planos y los valores más altos añaden sombras más fuertes."
    IDS_PPG_DISPLAY_TT_CLEARCOMPL                              "Elimina automáticamente las descargas completadas de la lista de Transferencias visibles.\r\n\r\nLos archivos terminados permanecen en el disco; esto sólo mantiene la lista de descargas más limpia."
    IDS_PPG_DISPLAY_TT_DBLCLICK                                "Expande o contrae una descarga cuando se hace doble clic en ella en la lista de Transferencias.\r\n\r\nDesactívela si los dobles clics deben evitar cambiar el diseño de la fila."
    IDS_PPG_DISPLAY_TT_DISABLEHIST                             "Habilita historiales de autocompletar para campos como texto de búsqueda y URL server.met.\r\n\r\nDesactívelo si no desea que se recuerden esas entradas."
    IDS_PPG_DISPLAY_TT_DISABLEKNOWNLIST                        "Oculta y deshabilita la lista de Clientes conocidos en la ventana Transferencias.\r\n\r\nUÚselo solo si desea una interfaz de usuario más liviana y no necesita esa vista de diagnóstico."
    IDS_PPG_DISPLAY_TT_DISABLEQUEUELIST                        "Oculta y deshabilita la lista de colas en la ventana Transferencias.\r\n\r\nUÚselo solo si no inspecciona los clientes de carga en cola."
    IDS_PPG_DISPLAY_TT_RESETHIST                               "Borra las entradas almacenadas del historial de autocompletar.\r\n\r\nEsto afecta únicamente al historial guardado y no cambia las descargas activas ni las listas de servidores."
    IDS_PPG_DISPLAY_TT_SELECT_HYPERTEXT_FONT                   "Abre el selector de fuentes para las vistas de servidor, mensajes y texto IRC.\r\n\r\nMantenga presionada la tecla Ctrl mientras lo abre para editar la fuente del registro."
    IDS_PPG_DISPLAY_TT_SHOWCATINFO                             "Muestra información de categorías en las pestañas de categorías de transferencia.\r\n\r\nUútil cuando administra descargas a través de múltiples categorías."
    IDS_PPG_DISPLAY_TT_SHOWDWLPERCENT                          "Muestra porcentajes de progreso de descarga en la lista de Transferencias.\r\n\r\nHabilítelo para escanear rápidamente el progreso sin abrir los detalles del archivo."
    IDS_PPG_DISPLAY_TT_SHOWTRANSTOOLBAR                        "Muestra la barra de herramientas adicional en la ventana Transferencias.\r\n\r\nDesactívela si prefiere más espacio para transferir filas."
    IDS_PPG_FILES_TT_ADDNEWFILESPAUSED                         "Agrega descargas recién puestas en cola en modo pausado.\r\n\r\nUútil cuando desea revisar o programar archivos antes de que comiencen a transferirse."
    IDS_PPG_FILES_TT_BROWSEV                                   "Busca el ejecutable del reproductor de vídeo externo.\r\n\r\nElija el programa que debería abrir los archivos multimedia previsualizados."
    IDS_PPG_FILES_TT_BROWSE_FILECOMPLETEPROGRAM                "Busca el programa iniciado después de que se completa un archivo.\r\n\r\nUuse un ejecutable local confiable porque se ejecuta automáticamente cuando está habilitado."
    IDS_PPG_FILES_TT_DAP                                       "Asigna prioridad automática a las descargas recién agregadas.\r\n\r\nRecomendado a menos que prefiera administrar las prioridades de descarga manualmente."
    IDS_PPG_FILES_TT_FILECOMPLETEPROGRAM                       "Ejecutable para ejecutar después de que se complete un archivo.\r\n\r\nUuse una ruta completa a un programa confiable; se inicia directamente sin el shell Windows."
    IDS_PPG_FILES_TT_FNC                                       "Edita el filtro de limpieza utilizado para la limpieza automática de nombres de archivos.\r\n\r\nUÚselo solo si las reglas de limpieza predeterminadas no coinciden con sus preferencias de nombres."
    IDS_PPG_FILES_TT_FULLCHUNKTRANS                            "Intenta cargar fragmentos completos a los clientes cuando sea posible.\r\n\r\nEsto puede mejorar la distribución de fragmentos, pero puede hacer que algunas cargas se ejecuten por más tiempo."
    IDS_PPG_FILES_TT_REMEMBERCANCELLED                         "Recuerda los archivos cancelados para que puedan ser reconocidos más tarde.\r\n\r\nUútil para evitar volver a agregar archivos que canceló intencionalmente."
    IDS_PPG_FILES_TT_REMEMBERDOWNLOADED                        "Recuerda las descargas completadas para que los archivos ya finalizados puedan reconocerse más tarde.\r\n\r\nRecomendado si desea advertencias de descargas duplicadas."
    IDS_PPG_FILES_TT_STARTNEXTFILECAT                          "Al iniciar el siguiente archivo en pausa, prefiera archivos de la misma categoría que el archivo completado.\r\n\r\nUÚselo para mantener las colas de categorías moviéndose juntas."
    IDS_PPG_FILES_TT_STARTNEXTFILECAT2                         "Al iniciar el siguiente archivo en pausa, elija solo de la misma categoría que el archivo completado.\r\n\r\nUÚselo para un control estricto de la cola por categoría."
    IDS_PPG_FILES_TT_UAP                                       "Asigna prioridad automática a los archivos recién compartidos.\r\n\r\nRecomendado a menos que usted mismo ajuste deliberadamente las prioridades de los archivos compartidos."
    IDS_PPG_FILES_TT_VIDEOPLAYER                               "Reproductor externo utilizado para vistas previas multimedia.\r\n\r\nDéjelo vacío para usar la asociación predeterminada o configure un reproductor de confianza específico."
    IDS_PPG_FILES_TT_VIDEOPLAYER_ARGS                          "Argumentos pasados ​​al reproductor de vista previa externo.\r\n\r\nUuse esto solo si el reproductor necesita opciones de línea de comandos personalizadas."
    IDS_PPG_GENERAL_TT_CHECKDAYS                               "Número de días entre comprobaciones de actualización de inicio.\r\n\r\nLos valores más altos reducen las comprobaciones de red; los valores más bajos encuentran antes los nuevos lanzamientos publicados."
    IDS_PPG_GENERAL_TT_EXIT                                    "Solicita confirmación antes de que salga eMule.\r\n\r\nRecomendado en sistemas desatendidos para evitar apagados accidentales."
    IDS_PPG_GENERAL_TT_LANGS                                   "Selecciona el recurso de idioma de la interfaz de usuario cargado por eMule.\r\n\r\nCambiar el idioma puede requerir volver a abrir los cuadros de diálogo antes de actualizar cada etiqueta."
    IDS_PPG_GENERAL_TT_NICK                                    "Nombre de usuario anunciado a otros clientes eMule.\r\n\r\nUuse un apodo no confidencial; puede ser visible para sus compañeros."
    IDS_PPG_IRC_TT_IRC_NICK_BOX                                "Apodo utilizado al conectarse a IRC.\r\n\r\nElija un nombre aceptado por la red IRC de destino."
    IDS_PPG_IRC_TT_IRC_PERFORM_BOX                             "Los comandos se ejecutan automáticamente después de que IRC se conecta cuando la ejecución está habilitada.\r\n\r\nUuse los comandos IRC de una línea solo si confía en ellos y los comprende."
    IDS_PPG_IRC_TT_IRC_SERVER_BOX                              "Dirección del servidor IRC utilizada por el cliente IRC integrado.\r\n\r\nCámbielo solo cuando utilice intencionalmente otra red IRC."
    IDS_PPG_MESSAGES_TT_FILTER                                 "Filtro de texto para mensajes de chat entrantes.\r\n\r\nUÚselo para suprimir palabras o patrones molestos conocidos."
    IDS_PPG_MESSAGES_TT_INDICATERATINGS                        "Muestra un ícono para descargas que tienen comentarios o calificaciones.\r\n\r\nUútil cuando desea revisar los comentarios de la comunidad antes de abrir archivos."
    IDS_PPG_MESSAGES_TT_MSHOWSMILEYS                           "Muestra emoticonos en los mensajes de chat.\r\n\r\nDesactívelo si prefiere la representación de texto sin formato."
    IDS_PPG_PROXY_TT_PASSWORD                                  "Contraseña de la cuenta de proxy.\r\n\r\nDéjela vacía a menos que la autenticación de proxy esté habilitada y sea requerida por el servidor proxy."
    IDS_PPG_SCHEDULER_TT_DATETIMEPICKER1                       "Hora de inicio para la entrada de programación seleccionada.\r\n\r\nLa regla se activa a esta hora en el patrón de día seleccionado."
    IDS_PPG_SCHEDULER_TT_DATETIMEPICKER2                       "Hora de finalización de la entrada de programación seleccionada.\r\n\r\nDesactive la hora de finalización en la que la regla debe permanecer activa hasta que otra programación la cambie."
    IDS_PPG_SCHEDULER_TT_NEW                                   "Crea una nueva entrada de programación.\r\n\r\nEdite sus detalles y haga clic en Aplicar para almacenar la regla configurada."
    IDS_PPG_SCHEDULER_TT_REMOVE                                "Elimina la entrada de programación seleccionada.\r\n\r\nUÚsela solo después de seleccionar la regla que ya no desea."
    IDS_PPG_SCHEDULER_TT_SCHEDACTION                           "Acciones que aplica la entrada de programación seleccionada.\r\n\r\nHaga doble clic o haga clic con el botón derecho en la lista para editar los cambios programados."
    IDS_PPG_SCHEDULER_TT_SCHEDLIST                             "Lista de entradas de programación configuradas.\r\n\r\nSeleccione una entrada para editar su título, hora, patrón diario, estado habilitado y acciones."
    IDS_PPG_SCHEDULER_TT_S_ENABLE                              "Habilita o deshabilita la entrada de programación seleccionada.\r\n\r\nUuse esto para pausar una sola regla sin eliminarla."
    IDS_PPG_SCHEDULER_TT_S_TITLE                               "Nombre para mostrar de la entrada de programación seleccionada.\r\n\r\nUuse un nombre corto que identifique lo que cambia la regla."
    IDS_PPG_SCHEDULER_TT_TIMESEL                               "Patrón de día para la entrada de programación seleccionada.\r\n\r\nElija cuándo deben aplicarse las horas de inicio y finalización."
    IDS_PPG_SECURITY_TT_DD                                     "Abre el historial de URL del filtro IP almacenado para una selección rápida.\r\n\r\nUuse solo proveedores de filtros confiables."
    IDS_PPG_SECURITY_TT_DISABLEOBFUSCATION                     "Deshabilita por completo la compatibilidad con conexiones ofuscadas.\r\n\r\nNo se recomienda a menos que necesite un comportamiento heredado estricto."
    IDS_PPG_SECURITY_TT_EDITFILTER                             "Abre el archivo de filtro IP local para editarlo manualmente.\r\n\r\nGuarde con cuidado; Las entradas no válidas pueden ignorarse."
    IDS_PPG_SECURITY_TT_LOADURL                                "Descarga y aplica la lista de filtros IP desde la URL configurada.\r\n\r\nUuse proveedores confiables únicamente; el filtro existente se mantiene si falla la descarga."
    IDS_PPG_SECURITY_TT_RELOADFILTER                           "Vuelve a cargar el archivo de filtro IP local desde el disco.\r\n\r\nUÚselo después de editar manualmente el archivo de filtro fuera de eMule."
    IDS_PPG_SERVER_TT_EDITADR                                  "Edita las URL de actualización de la lista de servidores de inicio.\r\n\r\nUuse únicamente fuentes server.met confiables; Las listas que no son de confianza pueden contaminar el descubrimiento del servidor."
    IDS_PPG_STATS_TT_COLOR_BUTTON                              "Abre el selector de color para el elemento estadístico seleccionado.\r\n\r\nUÚselo después de elegir un elemento en el selector de color."
    IDS_WEBSERVER_TT_CERTBROWSE                                "Busca el archivo de certificado HTTPS.\r\n\r\nUuse un archivo de certificado que coincida con la clave privada configurada."
    IDS_WEBSERVER_TT_CERTPATH                                  "Archivo de certificado utilizado cuando HTTPS está habilitado.\r\n\r\nEl WebServer no puede iniciarse en el modo HTTPS si este archivo falta o no es válido."
    IDS_WEBSERVER_TT_KEYBROWSE                                 "Busca el archivo de clave privada HTTPS.\r\n\r\nMantenga la clave seleccionada privada y legible solo por usuarios locales de confianza."
    IDS_WEBSERVER_TT_KEYPATH                                   "Archivo de clave privada utilizado cuando HTTPS está habilitado.\r\n\r\nProteja este archivo; cualquiera que tenga la clave puede hacerse pasar por el certificado WebServer."
    IDS_WEBSERVER_TT_WEB_GENERATE                              "Crea un nuevo certificado local y una clave privada para HTTPS.\r\n\r\nU. Utilícelo para configuraciones de red locales o de confianza cuando no proporcione su propio certificado."
    IDS_WEBSERVER_TT_WSENABLEDLOW                              "Habilita la cuenta WebServer de derechos bajos.\r\n\r\nUÚsela para clientes que no deberían tener acceso administrativo completo a la Web."
    IDS_WEBSERVER_TT_WSPASS                                    "Contraseña para la cuenta principal WebServer.\r\n\r\nUuse una contraseña única y segura, especialmente si se puede acceder al WebServer más allá del host local."
    IDS_WEBSERVER_TT_WSPASSLOW                                 "Contraseña para la cuenta WebServer de derechos bajos.\r\n\r\nUuse una contraseña diferente a la de la cuenta principal."
    IDS_WEBSERVER_TT_WSPORT                                    "Puerto TCP utilizado por WebServer y REST API.\r\n\r\nCámbielo solo cuando las reglas de firewall, proxy inverso o enrutador se actualicen para que coincidan."
    IDS_WEBSERVER_TT_WSTIMEOUT                                 "Tiempo de espera de sesión para inicios de sesión WebServer en minutos.\r\n\r\nLos tiempos de espera más cortos son más seguros en máquinas compartidas; los tiempos de espera más largos son más convenientes."
    IDS_PPG_DEBUG_TT_SERVER                                    "Habilita las categorías de registro de depuración del lado del servidor.\r\n\r\nUÚselo únicamente mientras se diagnostican problemas de descubrimiento o comunicación del servidor."
    IDS_PPG_DEBUG_TT_CLIENT                                    "Habilita las categorías de registro de depuración del lado del cliente.\r\n\r\nUÚselo solo al diagnosticar problemas de comunicación entre pares."
    IDS_PPG_DEBUG_TT_DETAIL                                    "Habilita esta categoría de depuración.\r\n\r\nEl registro de depuración puede ser ruidoso y normalmente debería permanecer fuera del diagnóstico."
    IDS_PPG_DEBUG_TT_DETAIL_LEVEL                              "Nivel de detalle para esta categoría de depuración.\r\n\r\nLos valores más altos registran más información y pueden aumentar significativamente el volumen de registro."
    IDS_PPG_DEBUG_TT_HEAP_LEVEL                                "Nivel de verificación de corrupción de memoria utilizado por los diagnósticos de depuración.\r\n\r\nLos valores más altos pueden detectar más problemas pero pueden ralentizar la aplicación."
    IDS_TREEOPTIONS_BROWSE_FOLDER_CAPTION                      "Por favor especifica una carpeta"
    IDS_TREEOPTIONS_BROWSE_FILE_CAPTION                        "Por favor especifica un archivo"
    IDS_TREEOPTIONS_ALL_FILES_FILTER                           "Todos los archivos (*.*)|*.*||"
