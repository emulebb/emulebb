    IDS_BIND_STATUS_ACTIVE_ANY                                 "Irbit P2P attiv: Kwalunkwe interface."
    IDS_BIND_STATUS_ACTIVE_FMT                                 "Irbit P2P attiv: %s"
    IDS_BIND_STATUS_INTERFACE_NOT_FOUND_FMT                    "Irbit P2P attiv: Kwalunkwe interface. L-interface ssejvjata mhix disponibbli: %s"
