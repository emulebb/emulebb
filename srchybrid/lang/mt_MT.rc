    IDS_PREVIEW_REQUESTED_WAIT                                 "Preview Requested - Jekk jogħġbok stenna"
    IDS_SEARCH_INFOTIP_SOURCES                                 "Sorsi"
    IDS_SEARCH_INFOTIP_SERVERS                                 "Servers"
    IDS_NO_MATCHING_ENTRY_FOUND                                "Ma nstabet l-ebda dħul li taqbel."
    IDS_FATAL_NO_RICHEDIT                                      "Żball Fatali: Ma nstabet l-ebda librerija ta' kontroll Rich Edit!"
    IDS_FATAL_KAD_UNICODE_TABLES                               "Żball Fatali: Naqas milli tgħabbi t-tabelli tal-karattri Unicode għal Kademlia!"
    IDS_KAD_UNICODE_MAP_NOT_INITIALIZED                        "Kad Mappa tal-karattri Unicode minusura mhux inizjalizzata!"
    IDS_TWEAKS_TT_CONDITIONAL_TCP_ACCEPT                       "Jippreferi li jaċċetta konnessjonijiet TCP deħlin biss meta jidhru utli.\r\n\r\nTweak avvanzat għat-tfassil tat-traffiku. Ħallih fil-default sakemm ma tkunx qed tiddijanjostika l-pressjoni tal-konnessjoni."
    IDS_TWEAKS_TT_MAX_CON5_SEC                                 "Numru massimu ta' konnessjonijiet TCP ġodda eMuleBB jistgħu jinfetħu fi żmien ħames sekondi.\r\n\r\nValuri aktar baxxi huma aktar ġentili fuq Windows u routers. Ħallih qrib il-default sakemm ma tkunx qed tirfina l-imġieba tal-fqigħ tal-konnessjoni."
    IDS_TWEAKS_TT_MAX_HALF_OPEN                                "Limitu ta' fuq għal tentattivi ta' konnessjoni 'l barra nofshom miftuħa TCP.\r\n\r\nL-aktar salvagwardja ta' kompatibilità. Id-default normalment huwa l-għażla t-tajba sakemm ma tkunx qed tinvestiga kwistjonijiet ta 'setup TCP."
    IDS_TWEAKS_TT_CONNECTION_TIMEOUT                           "Kemm eMuleBB jistenna għal konnessjoni ġdida biex tagħmel progress qabel ma tikkunsidra li falliet.\r\n\r\nValuri iqsar jirkupraw aktar malajr minn sħabhom mejta; valuri itwal huma aktar tolleranti għal netwerks bil-mod. Il-valuri awtomatiċi huma rakkomandati."
    IDS_TWEAKS_TT_DOWNLOAD_TIMEOUT                             "Kemm idum sors ta' tniżżil jista' jibqa' inattiv qabel eMuleBB iwaqqa' bħala waqfien.\r\n\r\nValuri aktar baxxi inaddfu sorsi mejta aktar malajr, iżda valuri baxxi ħafna jistgħu jweġġgħu lil sħabhom bil-mod. Ħalli l-inadempjenza sakemm ma tkunx qed tiddijanjostika l-istalel."
    IDS_TWEAKS_TT_SERVER_KEEP_ALIVE_TIMEOUT                    "Kemm-il darba eMuleBB jġedded konnessjoni ta' server li kieku kien idle.\r\n\r\nUse minuti. Issettja 0 biex tiddiżattiva keepalives. Ħalli l-inadempjenza sakemm ma tkunx qed issolvi problema speċifika ta' skonnettjar ta' server-idle."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_RESULTS                      "Numru massimu ta' riżultati mitluba minn server eD2K għal tfittxija waħda.\r\n\r\nValuri ogħla jistgħu jsibu aktar fajls iżda jżidu x-xogħol tas-server u l-istorbju tal-UI. Żomm qrib il-inadempjenza sakemm ma jkollokx raġuni speċifika."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_MORE_REQUESTS                "Numru massimu ta' paġni ta' riżultati ta' segwitu eMuleBB talbiet minn eD2K tfittxija.\r\n\r\nValuri ogħla jistgħu jiġbdu aktar riżultati iżda jiswew aktar traffiku u ħin tas-server. Valuri konservattivi huma rakkomandati."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_TOTAL                        "Għadd ta' riżultati fil-mira għat-tfittxijiet tal-fajls Kad.\r\n\r\nValuri ogħla jfittxu b'mod aktar wiesa' iżda jżommu t-tiftix Kad ħajjin itwal. Żomm ħdejn il-default sakemm ma tridx tfittxijiet aktar profondi."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_TOTAL                     "Għadd ta' riżultati fil-mira għat-tfittxijiet tal-kliem kjavi Kad.\r\n\r\nValuri ogħla jistgħu jsibu aktar logħbiet iżda jżidu t-tagħbija tal-mistoqsijiet Kad u l-istorbju tal-UI. In-nuqqas normalment ikun il-bilanċ it-tajjeb."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_LIFETIME                     "Il-ħajja massima ta' tfittxija waħda ta' fajls Kad f'sekondi.\r\n\r\nGħolliha biss jekk deliberatament trid tfittxijiet Kad li jdumu itwal."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_LIFETIME                  "Ħajja massima ta' tfittxija waħda ta' keyword Kad f'sekondi.\r\n\r\nĦajja itwal jistgħu jsibu riżultati aktar tard iżda jżidu l-attività ta' tfittxija fl-isfond."
    IDS_TWEAKS_TT_GENERAL_ADVANCED                             "Imġieba ġenerali avvanzata li ma taqbilx b'mod nadif taħt in-netwerk, il-fajl, il-wiri, jew is-sigurtà.\r\n\r\nIl-biċċa l-kbira tal-utenti għandhom iħallu dawn qrib l-inadempjenzi tagħhom."
    IDS_TWEAKS_TT_HIDDEN_FILE                                  "Imġieba avvanzata fl-immaniġġjar tal-fajls, spezzjoni t\r\n\r\na' previżjoni, u għażliet relatati mal-istorja tal-fajls."
    IDS_TWEAKS_TT_STORAGE_PERSISTENCE                          "Protezzjoni avvanzata tal-ispazju tad-disk, file-buffering, u settings tal-persistenza tal-metadata.\r\n\r\nDan huwa l-grupp ewlieni għas-sikurezza tal-ħażna u l-kompromessi tal-I/O tad-disk."
    IDS_TWEAKS_TT_HIDDEN_STARTUP                               "L-istartjar avvanzat jirrestawra l-imġiba.\r\n\r\nDawn l-għażliet jaffettwaw biss liema panewijiet tal-UI jerġgħu lura meta jibda eMuleBB."
    IDS_TWEAKS_TT_HIDDEN_DISPLAY                               "Wirja avvanzata, taskbar, trej, u settings ta' informazzjoni viżwali.\r\n\r\nDawn l-għażliet jibdlu l-preżentazzjoni biss, mhux jittrasferixxu l-imġiba."
    IDS_TWEAKS_TT_HIDDEN_SECURITY                              "Għażliet avvanzati ta' filtrazzjoni u protezzjoni għal immaniġġjar aktar strett tal-pari u l-messaġġi.\r\n\r\nDefaults rakkomandati huma xierqa għall-biċċa l-kbira tal-utenti."
    IDS_TWEAKS_TT_LOGGING_GROUP                                "Kontrolli persistenti ta' illoggjar u output dijanjostiku.\r\n\r\nIl-biċċa l-kbira ta' dawn is-settings huma utli biss waqt id-dijanjosi ta' problema."
    IDS_TWEAKS_TT_AUTO_TAKE_ED2K_LINKS                         "Jirreġistra eMuleBB bħala l-immaniġġjar default għal ed2k:// links.\r\n\r\nIppermettiha jekk din il-magna għandha tiftaħ links ed2k f'eMuleBB awtomatikament. Itfih jekk għodda oħra għandha dik l-assoċjazzjoni."
    IDS_TWEAKS_TT_CREDIT_SYSTEM                                "Juża s-sistema ta' kreditu eMule normali meta tikklassifika l-klijenti tat-tlugħ.\r\n\r\nRakkomandat: attivat. Itfih biss għal debugging jew esperimenti intenzjonati ta 'kompatibilità."
    IDS_TWEAKS_TT_YOUR_HOSTNAME                                "It-tikketta tal-isem tal-host fakultattiv eMuleBB tirrapporta fejn jintwera t-test tal-identità lokali tiegħek.\r\n\r\nĦalliha vojta sakemm ma tridx intenzjonalment issemmi din l-istanza."
    IDS_TWEAKS_TT_TXT_EDITOR                                   "Kmand użat meta eMuleBB jiftaħ fajls tat-test bħal zkuk jew output tat-test iġġenerat.\r\n\r\nUUża mogħdija sħiħa jekk l-editur ma jkunx fuq PATH. In-nuqqas huwa notepad.exe."
    IDS_TWEAKS_TT_HIGHRES_TIMER                                "Jitlob timer Windows b'riżoluzzjoni għolja waqt li eMuleBB ikun qed jaħdem.\r\n\r\nDan jista' jagħmel iż-żmien aktar faċli fuq xi sistemi, iżda jista' jżid l-użu tal-enerġija. Ibda mill-ġdid eMuleBB wara li tibdelha."
    IDS_TWEAKS_TT_ICH                                          "Jippermetti l-Immaniġġjar Intelliġenti tal-Korruzzjoni għal biċċiet imniżżla bil-ħsara.\r\n\r\nRakkomandat: attivat. Jgħin biex tirkupra dejta tajba ġewwa partijiet korrotta minflok ma terġa 'tniżżel aktar milli meħtieġ."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS                         "Jikkontrolla jekk il-preview tal-midja hijiex offruta qabel ma l-kontrolli normali tas-sigurtà tal-preview ikunu kompletament sodisfatti.\r\n\r\nLivelli ogħla jagħmlu preview disponibbli aktar kmieni, iżda previews falluti jew qarrieqa jsiru aktar probabbli."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_DISABLED                "Uża r-regoli normali tal-preview konservattiv."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_ALLOW                   "Ħalli preview bi blokki disponibbli iżgħar wara li jgħaddu l-metadata normali u l-kontrolli tal-plejers."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_FORCE                   "Offerta preview anke meta l-ewwel blokk tkun nieqsa.\r\n\r\nUUża biss ma' plejers li jistgħu jittolleraw midja mhux kompluta, bħal VLC."
    IDS_TWEAKS_TT_BEEP_ON_ERROR                                "Jilgħab il-ħoss tal-iżball tas-sistema meta eMuleBB jirrapporta żbalji importanti.\r\n\r\nUseful għal issolvi l-problemi mingħajr attenzjoni. Itfih jekk it-twissijiet li jinstemgħu jkunu jfixkluh."
    IDS_TWEAKS_TT_SHOW_COPY_ED2K_LINK_CMD                      "Tibdel il-menus tal-kuntest tal-fajls biex turi kmand dirett Kopja ed2k Link minflok l-azzjoni standard Uri ed2k Link.\r\n\r\nIppermettiha jekk l-ikkupjar tal-links huwa l-fluss tax-xogħol normali tiegħek."
    IDS_TWEAKS_TT_SPARSE_PART_FILES                            "Juża fajls skars għal fajls parti meta s-sistema tal-fajls tappoġġjahom.\r\n\r\nRakkomandat: attivat fuq NTFS biex titnaqqas l-allokazzjoni bil-quddiem tad-disk. Itfi biss jekk l-imġieba ta' fajl skars tikkawża problema speċifika għas-sistema tal-fajls."
    IDS_TWEAKS_TT_FULL_ALLOC                                   "Jalloka minn qabel id-daqs sħiħ tal-fajl fil-mira fuq id-diska meta jibdew it-tniżżil.\r\n\r\nJista 'jnaqqas il-frammentazzjoni, iżda jirriżerva spazju immedjatament u jiswa aktar xogħol fuq id-diska. Ħallih barra sakemm ma tippreferix preallokazzjoni sħiħa."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_CONFIG                   "Spazju liberu minimu riżervat fuq il-volum li jospita l-fajls tal-konfigurazzjoni ta' eMuleBB.\r\n\r\nMinimu iebes: 1 GiB. Jekk dan il-volum jaqa' taħt il-limitu effettiv, eMuleBB iwaqqaf it-tniżżil kollu u immedjatament jiffranka .part.met files.\r\nJekk il-konfigurazzjoni taqsam volum mat-temp jew id-dħul, l-akbar limitu fuq dak il-volum jirbaħ."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_TEMP                     "Spazju liberu minimu riżervat fuq kull volum li jospita fajls temp.\r\n\r\nMinimu iebes: 5 GiB. Jekk xi volum protett jaqa 'taħt il-limitu effettiv tiegħu, eMuleBB iwaqqaf it-tniżżil kollu u immedjatament jiffranka .part.met files.\r\nJekk temp taqsam volum mal-konfigurazzjoni jew deħlin, l-akbar limitu fuq dak il-volum jirbaħ."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_INCOMING                 "Spazju liberu minimu riżervat fuq kull volum li jospita fajls deħlin, inklużi direttorji deħlin speċifiċi għal kategorija.\r\n\r\nMinimu iebes: 5 GiB. Jekk id-dħul jaqsam volum mal-konfigurazzjoni jew temp, l-akbar limitu fuq dak il-volum jirbaħ u t-tniżżil kollu jitwaqqaf meta jinkiser."
    IDS_TWEAKS_TT_PERF_LOG                                     "Jikteb payload perjodiku u kampjuni overhead għal għodod esterni tal-grafika.\r\n\r\nOperator/debug feature biss. Ħallih barra sakemm ma tikkonsmax b'mod attiv il-fajls iġġenerati."
    IDS_TWEAKS_TT_COMMIT                                       "Jikkontrolla b'mod aggressiv eMuleBB iġġiegħel lil Windows li jlaħlaħ id-dejta tal-fajl issejvjata fuq disk.\r\n\r\nSettings aktar sikuri jnaqqsu r-riskju ta' telf ta' ħabta iżda jiswew aktar I/O tad-diska. 'Only on shutdown' hija l-inadempjenza bilanċjata."
    IDS_TWEAKS_TT_COMMIT_NEVER                                 "Agħlaq il-fajls normalment mingħajr ma jiġi sfurzat disk flush fil-livell tal-OS.\r\n\r\nL-aktar mgħaġġel u l-eħfef fuq id-disk I/O, iżda l-aktar dipendenti fuq Windows flush aktar tard."
    IDS_TWEAKS_TT_COMMIT_ON_SHUTDOWN                           "Ġegħel flush tad-diska fil-livell tal-OS biss waqt li eMuleBB ikun qed jagħlaq.\r\n\r\nDefault rakkomandat. Ittejjeb is-sigurtà tal-persistenza fuq il-ħruġ nadif mingħajr ma jiġu sfurzati fwawar żejda waqt kull salvataġġ."
    IDS_TWEAKS_TT_COMMIT_ALWAYS                                "Ġegħel flush tad-diska fil-livell tal-OS fuq kull mogħdija ta' salvataġġ li tuża l-helper tal-commit-close ta' eMuleBB.\r\n\r\nSafest kontra t-telf tal-metadata ta' crash jew power-loss, iżda tikkawża l-aktar I/O tad-diska."
    IDS_TWEAKS_TT_EXTRACT_META_DATA                            "Jikkontrolla jekk eMuleBB estrattix metadata bħal tags u tul tal-midja minn files.\r\n\r\nUseful għal informazzjoni aktar sinjuri tal-fajl, iżda żżid l-ispezzjoni tal-fajl fl-isfond. Itfih jekk trid l-eħfef skanjar."
    IDS_TWEAKS_TT_GEO_LOCATION_ENABLED                         "Issolvi l-IPs tal-pari għal dejta tal-lokalità fil-livell tal-pajjiż għall-wiri.\r\n\r\nPurement informattiv. Itfih jekk ma jimpurtakx mill-bnadar tal-pajjiż jew ma tridx aġġornar fl-isfond."
    IDS_TWEAKS_TT_CLOSE_U_PN_P_PORTS                           "Jagħlaq il-mappings tar-router mal-ħruġ nadif meta ntuża l-immappjar awtomatiku NAT.\r\n\r\nRakkomandat: attivat. Itfih biss jekk deliberatament trid li l-mappings jitħallew warajhom."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE                          "Jagħżel kif eMuleBB twettaq l-immappjar NAT awtomatiku.\r\n\r\nRakkomandat: Awtomatiku. Li jipprova UPnP IGD l-ewwel u jaqa 'lura għal PCP/NAT-PMP jekk meħtieġ."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_AUTOMATIC                "Mod rakkomandat. Ipprova UPnP IGD l-ewwel, imbagħad taqa' lura għal PCP/NAT-PMP jekk l-immappjar ifalli."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_IGD_ONLY                 "Uża biss mapping UPnP IGD. Agħżel dan jekk trid imġieba UPnP strettament klassika."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_PCP_NAT_PMP_ONLY         "Uża biss l-immappjar PCP/NAT-PMP. Agħżel dan biss jekk l-ambjent tar-router tiegħek jippreferi b'mod ċar."
    IDS_TWEAKS_TT_FILE_BUFFER_TIME_LIMIT                       "Età massima tad-dejta tal-fajl buffered qabel ma eMuleBB jiflaħ fuq disk.\r\n\r\nValuri aktar baxxi jnaqqsu d-dejta f'riskju waqt il-ħabtiet. Valuri ogħla jistgħu jnaqqsu d-disk churn. In-nuqqas normalment ikun kompromess tajjeb."
    IDS_TWEAKS_TT_FILE_BUFFER_SIZE                             "Daqs tal-buffer tal-kitba għal kull fajl użat qabel il-flawra ​​tad-dejta tat-tniżżil fuq id-diska.\r\n\r\nBuffers akbar jistgħu jnaqqsu l-attività tad-disk, iżda jżidu l-użu tal-memorja u l-kitba ttardjata. Żomm valuri moderati sakemm ma tkunx qed tirfina għal setup speċifiku tal-ħażna."
    IDS_TWEAKS_TT_QUEUE_SIZE                                   "Daqs fil-mira tal-kju ta' stennija tat-tlugħ.\r\n\r\nValuri ogħla iħallu aktar klijenti jistennew, iżda jżidu l-użu tal-memorja u l-overhead ta' ġestjoni. Il-valuri awtomatiċi huma rakkomandati għal ħafna utenti."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LISTS                      "Format tad-data/ħin apposta użat fil-veduti tal-lista.\r\n\r\nĦallih vojt biex tuża l-ifformattjar normali default. Ibdelha biss jekk trid stil ta 'timestamp tad-dwana speċifiku."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT                             "Format tad-data/ħin tad-dwana użat mill-wiri ġenerali tal-fajl u d-dettall tal-pari.\r\n\r\nUses tokens tal-ifformattjar CTime. Żommha mhux vojta; tokens invalidi jistgħu jipproduċu timestamps konfużi."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LOG                        "Format tad-data/ħin tad-dwana użat fil-linji tal-ġurnal u l-output tal-istatus bħal log.\r\n\r\nUses CTime tokens tal-ifformattjar. Żommha konċiża sabiex il-linji tal-log jibqgħu jinqraw."
    IDS_TWEAKS_TT_ICON_FLASH_ON_NEW_MESSAGE                    "Teptip l-ikona tat-trej meta jasal messaġġ ġdid taċ-chat.\r\n\r\nPurament preferenza ta' notifika. Ippermettiha jekk trid li l-messaġġi jispikkaw waqt li eMuleBB jiġi minimizzat."
    IDS_TWEAKS_TT_INSPECT_ALL_FILE_TYPES                       "Mexxi wkoll il-mogħdija ta 'spezzjoni ta' stil MediaInfo għalja għal tipi ta 'fajls li mhumiex diġà kklassifikati bħala awdjo jew vidjo.\r\n\r\nIppermettiha jekk trid tinvestiga fajls aktar sinjuri għal fajls mhux tas-soltu jew tikkettati ħażin. Ħalliha off biex tispezzjona biss fajls awdjo/vidjo probabbli u tnaqqas ix-xogħol ta 'spezzjoni fl-isfond."
    IDS_TWEAKS_TT_RE_BAR_TOOLBAR                               "Juża l-kontenitur tal-bar tal-għodda prinċipali stil rebar antik minflok it-tqassim sempliċi tal-bar tal-għodda.\r\n\r\nL-aktar preferenza tat-tqassim tal-UI. Ħalliha attivata biss jekk tippreferi l-preżentazzjoni tal-għodda tal-wirt."
    IDS_TWEAKS_TT_SHOW_UP_DOWN_ICON_IN_TASKBAR                 "Juri l-ikona magħquda tar-rata ta' upload/download fiż-żona ta' notifika tal-taskbar.\r\n\r\nPurament viżwali. Itfih jekk trid żona tat-trej aktar nadifa."
    IDS_ALWAYS_SHOW_TRAY_ICON                                  "Dejjem uri l-ikona tat-trej"
    IDS_TWEAKS_TT_ALWAYS_SHOW_TRAY_ICON                        "Iżomm l-ikona eMuleBB viżibbli fiż-żona tan-notifika Windows waqt li eMuleBB tkun qed taħdem.\r\n\r\nNotifiki tal-bużżieqa tat-trej klassiċi u l-minimize-to-trey xorta jistgħu jġiegħlu l-ikona tat-trej viżibbli meta din tkun diżattivata."
    IDS_TWEAKS_TT_SHOW_VERTICAL_HOUR_MARKERS                   "Jiġbed marki ta' gwida għal kull siegħa fil-grafiċi tal-istatistika fit-tul.\r\n\r\nUseful għall-qari ta' mudelli tat-traffiku bbażati fuq il-ħin. Itfih jekk tippreferi inqas imbarazz tal-grafiċi."
    IDS_TWEAKS_TT_FORCE_SPEEDS_TO_KB                           "Jġiegħel lill-wiri tar-rata juża unitajiet KB/s-style minflok awtomatikament jiskalaw għal unitajiet akbar.\r\n\r\nIppermettiha jekk tippreferi unitajiet familjari fissi. Ħallih barra għal wirjiet ta' veloċità kbira li jinqraw aktar."
    IDS_TWEAKS_TT_REARRANGE_KAD_SEARCH_KEYWORDS                "Jordna mill-ġdid it-termini tat-tfittxija tal-keyword Kad biex l-ewwel jipprova forma ta' mistoqsija aktar utli.\r\n\r\nTweak avvanzat tal-imġieba tat-tfittxija. Ħallih b'mod awtomatiku sakemm ma tkunx qed tirfina l-imġieba tat-tfittxija Kad deliberatament."
    IDS_TWEAKS_TT_MESSAGE_FROM_VALID_SOURCES_ONLY              "Jaċċetta messaġġi biss minn sħabhom li diġà jidhru qishom sorsi validi għat-trasferimenti tiegħek.\r\n\r\nProtezzjoni tal-privatezza/ispam aktar b'saħħitha, iżda tista' timblokka kuntatt mhux mitlub. Ippermettiha jekk trid politika tal-messaġġi aktar stretta."
    IDS_TWEAKS_TT_MAX_CHAT_HISTORY_LINES                       "Numru massimu ta' linji tal-istorja miżmuma għal kull chat jew IRC view channel.\r\n\r\nValuri ogħla jżommu aktar kuntest iżda jużaw aktar memorja u jistgħu jagħmlu chats okkupati aktar bil-mod biex jintwerew."
    IDS_TWEAKS_TT_MAX_MESSAGE_SESSIONS                         "Numru massimu ta' sessjonijiet ta' messaġġi bejn il-pari miżmuma f'daqqa.\r\n\r\nValuri ogħla jżommu aktar konversazzjonijiet disponibbli, iżda jżidu l-użu tal-memorja. In-nuqqas huwa konservattiv."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP                            "Jikkontrolla l-ħolqien ta' crash dump meta eMuleBB tiltaqa' ma' crash mhux immaniġġjat.\r\n\r\nCrash dumps jgħinu biex jiddijanjostikaw fallimenti iebsa iżda jista' jkun fihom memorja tal-proċess. Aqsamhom biss ma' żviluppaturi ta' fiduċja."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_DISABLED                   "Toħloqx fajls tal-crash dump."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_PROMPT                     "Staqsi qabel ma tikteb crash dump meta tiġri ħabta."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_ALWAYS                     "Oħloq crash dump awtomatikament meta tiġri ħabta.\r\n\r\nL-aħjar għad-debugging ta' ħabtiet ripetuti fuq magna ta' fiduċja."
    IDS_TWEAKS_TT_MAX_LOG_FILE_SIZE                            "Daqs massimu ta' kull fajl log fuq id-diska f'KiB.\r\n\r\nUse 0 għall-ebda limitu ta' rotazzjoni. Valuri kbar ħafna jżommu aktar storja iżda jikkunsmaw aktar spazju fuq disk."
    IDS_TWEAKS_TT_MAX_LOG_BUFFER                               "Buffer massimu tal-vista tal-log fil-memorja f'KiB.\r\n\r\nValuri ogħla jżommu l-istorja tal-log aktar viżibbli iżda jużaw aktar memorja u jistgħu jnaqqsu l-veduti tal-log okkupati ħafna."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT                              "Il-kodifikazzjoni użata għal fajls log fuq id-diska li għadhom kif infetħu.\r\n\r\nIl-bidla ta' dan waqt li z-zkuk huma diġà miftuħa hija persistenti, iżda l-format il-ġdid jintuża wara li jerġa' jinfetaħ il-fajl log jew eMuleBB jerġa' jibda."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UNICODE                      "Ikteb zkuk bħala UTF-16 Unicode. Dan huwa l-wirt default u jippreserva t-test Windows b'mod wiesa '."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UTF8                         "Ikteb zkuk bħala UTF-8. Utli għal għodod li jistennew fajls ta' test moderni UTF-8."
    IDS_TWEAKS_TT_LOG2_DISK                                    "Jikteb il-log tal-applikazzjoni normali fuq id-diska minflok iżżommha fil-memorja biss.\r\n\r\nUseful għall-debugging u l-użu bla attenzjoni fit-tul, iżda żżid disk writes. Ħallih barra sakemm ma tridx zkuk persistenti."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT                         "Format tal-output għall-kampjuni tal-qtugħ tal-prestazzjoni.\r\n\r\nCSV huwa l-aktar faċli biex tispezzjona manwalment. MRTG jikteb fajls sidecar għal għodod tal-grafika li jistennew input stil MRTG."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_CSV                     "Ikteb fajl tal-ġurnal tal-prestazzjoni CSV wieħed b'kampjuni ta' tagħbija u overhead b'timbra taż-żmien."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_MRTG                    "Ikteb data stil MRTG u fajls sidecar overhead derivati ​​mill-mogħdija bażi konfigurata."
    IDS_TWEAKS_TT_PERF_LOG_FILE                                "Mogħdija tal-fajl bażi għall-logging tal-prestazzjoni.\r\n\r\nĦalliha vojta biex tuża l-fajl default fid-direttorju tal-konfigurazzjoni ta' eMuleBB. Il-mod MRTG joħroġ fajls _data u _overhead minn din it-triq."
    IDS_TWEAKS_TT_PERF_LOG_INTERVAL                            "Intervall ta' kampjunar għall-illoggjar tal-prestazzjoni f'minuti.\r\n\r\nIntervalli qosra joħolqu graphs ifjen iżda aktar kitba fuq disk. Uża 1..1440."
    IDS_TWEAKS_TT_VERBOSE_GROUP                                "Kontrolli dijanjostiċi żejda tal-illoggjar għall-issolvi l-problemi fil-fond.\r\n\r\nDawn l-għażliet huma għal debugging, mhux tħaddim normali. Ħallihom barra sakemm ma tkunx qed tinvestiga kwistjoni speċifika."
    IDS_TWEAKS_TT_RESTORE_LAST_MAIN_WND_DLG                    "Jirrestawra l-aħħar paġna tat-tieqa prinċipali magħżula fuq l-istartjar.\r\n\r\nIppermettiha jekk trid li eMuleBB jerġa’ jiftaħ fejn ħallejt."
    IDS_TWEAKS_TT_RESTORE_LAST_LOG_PANE                        "Jirrestawra l-aħħar panew tal-log magħżul fuq l-istartjar.\r\n\r\nPurament għażla ta’ konvenjenza għall-utenti li jqattgħu ħin fil-veduti tar-reġistru."
    IDS_TWEAKS_TT_KEEP_UNAVAILABLE_FIXED_SHARED_DIRS           "Iżomm direttorji kondiviżi kkonfigurati manwalment fil-lista anki meta bħalissa mhumiex disponibbli.\r\n\r\nItfih jekk trid folders neqsin maqtugħin b'mod aggressiv."
    IDS_TWEAKS_TT_PARTIALLY_PURGE_OLD_KNOWN_FILES              "Jippermetti tindif aktar aggressiv ta 'daħliet skaduti fl-istorja tal-fajls magħrufa.\r\n\r\nJistgħu jnaqqas l-imbarazz maż-żmien, iżda jinsa wkoll l-istorja tal-fajls qodma aktar kmieni. Ħalli l-inadempjenza sakemm ma tridx storja aktar ħafifa."
    IDS_TWEAKS_TT_DETECT_TCP_ERROR_FLOODER                     "Jiskopri żbalji TCP ripetuti li jistgħu jindikaw sħabhom abbużivi jew miksura.\r\n\r\nRakkomandat: attivat. Itfih biss jekk tkun qed tiddijanjostika pożittivi foloz."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_INTERVAL_MINUTES           "Tieqa tal-ħin użata għal TCP error-flood detection.\r\n\r\nTwieqi iqsar jirreaġixxu aktar malajr; twieqi itwal huma inqas sensittivi. Il-valuri awtomatiċi huma rakkomandati."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_THRESHOLD                  "Numru ta' żbalji TCP fl-intervall li jqanqal l-immaniġġjar tal-għargħar.\r\n\r\nValuri aktar baxxi huma aktar stretti. Għolliha biss jekk l-ambjent tiegħek jipproduċi żbalji TCP frekwenti li ma jagħmlux ħsara."
    IDS_TWEAKS_TT_SHAREE_MULE                                  "Jikkontrolla kif eMuleBB jaħżen u jaqsam l-istat għal kull utent fuq din il-magna Windows.\r\n\r\nĦalli l-modalità attwali sakemm ma tkunx qed tbiddel intenzjonalment kif jaqsmu l-konfigurazzjoni u d-dejta multipli utenti lokali."
    IDS_TWEAKS_TT_TCP_GROUP                                    "Kontrolli avvanzati tal-fqigħ tal-konnessjoni TCP, timeout, u keepalive.\r\n\r\nDawn is-settings jaffettwaw l-imġiba tal-konnessjoni aktar milli l-limiti tat-trasferiment. Il-valuri awtomatiċi huma rrakkomandati sakemm ma tkunx qed tiddijanjostika kwistjonijiet ta' setup tan-netwerk."
    IDS_TWEAKS_TT_SEARCH_GROUP                                 "Limiti avvanzati għal kemm eMuleBB tfittex b'mod wiesa 'u kemm fit-tul fuq eD2K u Kad.\r\n\r\nValuri ogħla jistgħu jirritornaw aktar riżultati, iżda jżidu wkoll aktar traffiku tan-netwerk u storbju tal-UI."
    IDS_TWEAKS_TT_SEARCH_ED2K_GROUP                            "Limiti tat-tiftix eD2K ibbażat fuq server.\r\n\r\nUUża valuri konservattivi sakemm ma tridx deliberatament tfittxijiet aktar profondi fuq is-server."
    IDS_TWEAKS_TT_SEARCH_KAD_GROUP                             "Kad kontrolli tal-wisa' tat-tfittxija u tal-ħajja.\r\n\r\nValuri ogħla jżommu t-tfittxijiet imqassma ħajjin itwal u jistgħu jsibu aktar riżultati, iżda jiswew aktar attività fl-isfond."
    IDS_TWEAKS_TT_BROADBAND                                    "Politika avvanzata ta' riċiklaġġ ta' upload-slots u kju-punteġġ għal imġiba ta' upload ta' stil broadband.\r\n\r\nDawn is-settings huma għal irfinar intenzjonat. Ħallihom fil-inadempjenzi tagħhom sakemm ma tkunx qed taġġusta l-ġustizzja tat-tlugħ jew il-fatturat tal-islott."
    IDS_TWEAKS_TT_UPLOAD_POLICY_MAX_UPLOAD_CLIENTS             "Limitu artab għal klijenti ta' upload attivi fl-istess ħin taħt il-broadband scheduler.\r\n\r\nValuri ogħla jinfirxu bandwidth fuq aktar sħabhom iżda jagħmlu kull slot irqaq. Valuri aktar baxxi jżommu slots inqas u aktar b'saħħithom."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_THRESHOLD                 "Frazzjoni tar-rata ta' upload fil-mira għal kull slot li taħtha slot jitqies bil-mod.\r\n\r\nValuri aktar baxxi jittolleraw slots aktar dgħajfa itwal. Valuri ogħla jirriċiklaw slots b'rendiment baxx b'mod aktar aggressiv."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_GRACE                     "Kemm idum slot jista jibqa taħt il-limitu bil-mod qabel eMuleBB tikkunsidra li tirriċiklah.\r\n\r\nGrazzja itwal hija aktar paċenzjuża ma sħabhom dgħajfa; grazzja iqsar dawriet slots dgħajfa qabel."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_WARMUP                    "Perjodu ta' tisħin għal slot ta' upload ġdid qabel ma jibda l-iskoperta tal-islot bil-mod.\r\n\r\nDan jevita li tippenalizza uploads ġodda għall-istorbju tal-istartjar u l-ħin tar-rampa."
    IDS_TWEAKS_TT_UPLOAD_POLICY_ZERO_RATE_GRACE                "Perjodu ta' grazzja għal slots li essenzjalment ma jagħtu l-ebda dejta ta' upload.\r\n\r\nValuri aktar baxxi jirreaġixxu aktar malajr għal slots mejta jew waqfien."
    IDS_TWEAKS_TT_UPLOAD_POLICY_COOLDOWN                       "Kemm idum slott bil-mod riċiklat jibqa’ penalizzat fil-punteġġ\r\n\r\nfil-kju qabel ma jerġa’ jikkompeti b’mod normali."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BOOST                "Iżid punteġġ ta' kju żejjed għall-klijenti li jitolbu fajls bi proporzjon baxx ta' upload storiku.\r\n\r\nUUżaha jekk trid tiffavorixxi fajls li s'issa rċevew komparattivament ftit upload."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_THRESHOLD            "Qtugħ tal-proporzjon ta' upload li taħtu japplika l-ispinta tal-punteġġ tal-kju ta' proporzjon baxx.\r\n\r\nValuri aktar baxxi jirrestrinġu l-ispinta għal fajls li ma jaqbdux biżżejjed."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BONUS                "Punteġġ ta' kju effettiv addizzjonali mogħti meta tiskatta l-ispinta ta' proporzjon baxx.\r\n\r\nValuri ogħla jagħmlu l-ispinta tkun aktar qawwija fl-ordni tat-tlugħ."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_ID_DIVISOR                 "Diviżur tal-penali applikat lill-klijenti LowID waqt il-punteġġ tal-kju tat-upload.\r\n\r\nValuri ogħla jnaqqsu l-prijorità LowID b'mod aktar aggressiv. Issettja 1 biex tiddiżattiva l-penali LowID żejda."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER               "Limita kemm tista' tittrasferixxi sessjoni waħda ta' upload qabel eMuleBB tikkunsidra li ddawwar dak is-slot.\r\n\r\nRotazzjoni sseħħ biss meta klijent ieħor fil-fatt jeħtieġ is-slot."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_DISABLED      "Tirriċiklax sessjonijiet ta' upload ibbażati fuq l-ammont tat-tagħbija trasferita."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT       "Illimita kull sessjoni ta' upload għal persentaġġ tad-daqs tal-fajl mitlub."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT_VALUE "Perċentwal użat meta l-limitu tat-trasferiment tas-sessjoni huwa kkonfigurat bħala sehem tad-daqs tal-fajl."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B          "Illimita kull sessjoni ta' upload għal ammont fiss ta' MiB irrispettivament mid-daqs tal-fajl."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B_VALUE    "Ammont MiB assolut użat meta l-limitu tat-trasferiment tas-sessjoni huwa kkonfigurat bħala daqs fiss."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TIME_LIMIT             "Tul massimu ta' sessjoni waħda ta' upload qabel eMuleBB tikkunsidra li ddawwar is-slot.\r\n\r\nIssettja 0 biex tiddiżattiva l-limitu ibbażat fuq il-ħin."
    IDS_TWEAKS_TT_A4_AF_SAVE_CPU                               "Inaqqas il-kontrolli tas-sors ripetuti A4AF (Mistoqsi Għal Fajl Ieħor) biex jiffrankaw il-ħin tas-CPU.\r\n\r\nUseful fuq klijenti okkupati, iżda jista 'jagħmel il-bidla tas-sors tal-istess klijent inqas ħerqana."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_NEVER                      "Tiġbedx metadata minn files.\r\n\r\nL-aktar għażla ħafifa. Użaha jekk trid l-ebda probing tal-metadata fl-isfond."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_ID3_LIB                    "Oħroġ metadata biss permezz tal-mogħdija tal-librerija ID3 għal fajls awdjo MPEG.\r\n\r\nDefault bilanċjat għal tikketti tal-mużika bażiċi mingħajr spezzjoni tal-midja usa '."
    IDS_TWEAKS_TT_PREVIEW_ON_ICON_DBL_CLK                      "Meta tikklikkja darbtejn fuq ikona tal-fajl tiftaħ preview minflok l-azzjoni default tas-soltu.\r\n\r\nPurament preferenza tal-fluss tax-xogħol tal-UI."
    IDS_TWEAKS_TT_EXTRA_PREVIEW_WITH_MENU                      "Juri kmandi ta' previżjoni permezz ta' menu ta' azzjoni ta' previżjoni ddedikata minfl\r\n\r\nok tesponi biss l-azzjoni ta' previżjoni diretta aktar sempliċi."
    IDS_TWEAKS_TT_SHOW_ACTIVE_DOWNLOADS_BOLD                   "Jiġbed b'mod attiv it-trasferiment tat-tniżżil b'tipa grassa fil-lista tat-tniżżil.\r\n\r\nPurament viżwali. Ippermettiha jekk trid li oġġetti attivi jispikkaw b'mod aktar ċar."
    IDS_TWEAKS_TT_USE_SYSTEM_FONT_FOR_MAIN_CONTROLS            "Juża l-font Windows UI normali għall-kontrolli prinċipali u l-veduti tal-lista minflok is-setup tal-font personalizzat ta' eMuleBB.\r\n\r\nUseful jekk tippreferi test li jidher indiġenu jew teħtieġ kompatibilità aħjar mas-settings tat-tipa tas-sistema tiegħek."
    IDS_TWEAKS_TT_FILTER_LANI_PS                               "Tinjora l-indirizzi tas-server u tal-klijenti minn firxiet privati/LAN.\r\n\r\nRakkomandat: attivat. Dan jevita li tipprova tuża indirizzi tal-pari mhux routable min-netwerk pubbliku."
    IDS_TWEAKS_TT_GEO_LOCATION_CHECK_DAYS                      "Kemm-il darba eMuleBB jiċċekkja għal kontenut aġġornat tad-database tal-lokazzjoni ġeografika.\r\n\r\nIssettja 0 biex tiddiżattiva l-kontrolli tal-aġġornament awtomatiku. Valuri akbar inaqqsu l-attività ta 'aġġornament fl-isfond."
    IDS_TWEAKS_TT_VERBOSE                                      "Swiċċ ewlieni għall-kontrolli tal-illoggjar verbose hawn taħt.\r\n\r\nIżżommha għall-użu normali. Ippermettiha biss waqt li tkun qed tinvestiga problema speċifika."
    IDS_TWEAKS_TT_FULL_VERBOSE                                 "Jirreġistra l-aktar traċċa verbose disponibbli sħiħa meta l-illoggjar verbose huwa attivat.\r\n\r\nDan jista' jsir storbjuż ħafna u għandu jintuża biss għal soluzzjoni ta' problemi ffukata."
    IDS_TWEAKS_TT_LOG_LEVEL                                    "Limitu tal-verbosità għall-output ta’ log dijanjostiku.\r\n\r\nLivelli ogħla jirreġistraw aktar dettall iżda joħolqu aktar storbju."
    IDS_TWEAKS_TT_DEBUG2_DISK                                  "Jikteb output dijanjostiku verbose fuq id-diska minflok iżżommha temporanja.\r\n\r\nUseful meta jkollok bżonn traċċa persistenti ta' debug, iżda żżid l-attività tad-diska."
    IDS_TWEAKS_TT_DEBUG_SOURCE_EXCHANGE                        "Jirreġistra pakketti u deċiżjonijiet relatati mal-iskambju tas-sors.\r\n\r\nGħażla dijanjostika speċjalizzata. Ippermettiha biss waqt li tiddibaggja l-imġieba tal-iskoperta tas-sors."
    IDS_TWEAKS_TT_LOG_BANNED_CLIENTS                           "Jirreġistra meta sħabhom huma pprojbiti u għaliex.\r\n\r\nUseful għal abbuż jew dijanjosi pożittiva falza, iżda storbjużi wisq għal tħaddim normali."
    IDS_TWEAKS_TT_LOG_RATING_DESC_RECEIVED                     "Ir-rekords irċevew kummenti tal-fajls, deskrizzjonijiet, u klassifikazzjonijiet.\r\n\r\nu siewi għad-debugging tal-fluss tal-metadejta, iżda ġeneralment mhux meħtieġ."
    IDS_TWEAKS_TT_LOG_SECURE_IDENT                             "Tirreġistra verifika ta' identità sigura u kontrolli ta' identità relatati.\r\n\r\nu siewi għas-soluzzjoni tal-problemi ta' fiduċja/awtentikazzjoni."
    IDS_TWEAKS_TT_LOG_FILTERED_I_PS                            "Ir-rekords meta IP jiffiltraw jew jinjoraw il-loġika jaqtgħu l-indirizzi tal-pari jew tas-server.\r\n\r\nUseful għad-dijanjosi għaliex xi peers jiġu rrifjutati."
    IDS_TWEAKS_TT_LOG_FILE_SAVING                              "Rekords jiffrankaw ta 'dejta persistenti bħal fajls magħrufa, krediti, u state.\r\n\r\nUseful għall-persistenza debugging, iżda mhux meħtieġ għall-użu normali."
    IDS_TWEAKS_TT_LOG_A4_AF                                    "Rekords A4AF (Mistoqsi Għal Fajl Ieħor) attività ta' assenjazzjoni mill-ġdid tas-sors.\r\n\r\nGħażla dijanjostika speċjalizzata tal-maniġer tat-tniżżil."
    IDS_TWEAKS_TT_LOG_UL_DL_EVENTS                             "Jirreġistra l-bidliet fiċ-ċiklu tal-ħajja tal-upload-slot u t-tniżżil tal-avvenimenti.\r\n\r\nUseful meta jiġu djanjostikati l-qlib tal-kju, ir-rotazzjoni tal-islots, jew it-transizzjonijiet tal-istat tat-trasferiment."
    IDS_TWEAKS_TT_U_PN_P                                       "Settings awtomatiċi tal-immappjar tal-port tar-router għall-konnettività deħlin.\r\n\r\nIl-biċċa l-kbira tal-utenti għandhom iħallu dan il-grupp fuq nuqqasijiet awtomatiċi sakemm l-ambjent tar-router tagħhom ma jkunx jeħtieġ xi ħaġa speċifika."
    IDS_TWEAKS_TT_SHAREE_MULE_MULTI_USER                       "Kull utent Windows jikseb konfigurazzjoni eMuleBB separata u stat tat-tniżżil separat.\r\n\r\nConfig jgħix taħt AppData Lokali, u downloads jużaw il-folder ta' Downloads ta' dak l-utent stess. L-aħjar għażla għal kompjuters kondiviżi fejn l-utenti m'għandhomx jaqsmu data eMuleBB."
    IDS_TWEAKS_TT_SHAREE_MULE_PUBLIC_USER                      "L-utenti kollha tal-Windows jaqsmu l-istess konfigurazzjoni eMuleBB u downloads.\r\n\r\nConfig jgħix taħt ProgramData, u downloads jużaw Public Downloads. Uża dan biss jekk il-magna tkun intenzjonalment taqsam stat eMuleBB wieħed komuni."
    IDS_TWEAKS_TT_SHAREE_MULE_OLD_STYLE                        "Żomm il-konfigurazzjoni u t-tniżżil fid-direttorju tal-programm, billi tuża t-tqassim tal-wirt antik.\r\n\r\nModalità ta' kompatibilità tal-legat biss. Normalment hija l-inqas għażla mixtieqa fuq Windows moderna."
    IDS_CONNECTION_TT_AUTOCONNECT                              "Jibda awtomatikament in-netwerks attivati ​​meta jinbeda eMuleBB.\r\n\r\nRakkomandat: attivat għal użu normali mingħajr attenzjoni. Itfih biss jekk trid tikkonnettja manwalment kull sessjoni."
    IDS_CONNECTION_TT_RECONN                                   "Jipprova l-konnessjonijiet tas-server wara skonnettja jew tentattivi falluti.\r\n\r\nRakkomandat: attivat jekk tuża n-netwerk tas-server eD2K. M'għandu l-ebda effett meta n-netwerking tas-server ikun diżattivat."
    IDS_CONNECTION_TT_SHOWOVERHEAD                             "Juri l-overhead tal-protokoll separatament fir-rati tat-trasferiment u l-istatistika.\r\n\r\nIppermettiha jekk trid ħarsa aktar onesta tat-traffiku tal-wajer. Ħalliha off jekk tippreferi numri aktar sempliċi ta 'tagħbija biss."
    IDS_CONNECTION_TT_PORT                                     "Port TCP prinċipali użat għall-konnessjonijiet tal-klijenti deħlin.\r\n\r\nIbdelha biss meta inti intenzjonalment tikkonfigura r-regoli tal-firewall jew tar-router. Wara li tibdelha, ittestja mill-ġdid il-konnettività."
    IDS_CONNECTION_TT_UDPPORT                                  "Port UDP użat għal Kad u karatteristiċi oħra assistiti minn UDP.\r\n\r\nRakkomandat: żommu attivat u aċċessibbli sakemm ma tridx intenzjonalment tiddiżattiva netwerking ibbażat fuq UDP."
    IDS_CONNECTION_TT_MAXSOURCEPERFILE                         "Limitu iebes għal kemm eMuleBB iżomm sorsi remoti għal kull tniżżil.\r\n\r\nValuri ogħla jistgħu jtejbu d-disponibbiltà għal fajls rari iżda jiswew aktar memorja u traffiku tal-ġestjoni tas-sors. Uża valuri moderati sakemm ma jkollokx raġuni speċifika biex tgħollih."
    IDS_CONNECTION_TT_MAXCON                                   "Limitu ta' fuq għal konnessjonijiet simultanji eMuleBB jista' jżomm miftuħ.\r\n\r\nValuri ogħla mhumiex awtomatikament aħjar. Ħalli dan qrib il-default sintonizzat sakemm ma tkunx qed tiddijanjostika limitazzjoni speċifika tan-netwerk."
    IDS_CONNECTION_TT_DOWNLOAD_CAP                             "Il-kapaċità downstream konfigurata tiegħek f'KiB/s. eMuleBB juża dan bħala referenza ta 'fuq għal sliders u deċiżjonijiet ta' bandwidth.\r\n\r\nIssettjah qrib ir-rata tal-linja reali użabbli tiegħek, mhux il-massimu tal-kummerċjalizzazzjoni."
    IDS_CONNECTION_TT_UPLOAD_CAP                               "Il-kapaċità upstream konfigurata tiegħek f'KiB/s. eMuleBB juża dan bħala referenza ta' fuq għall-kontroll tat-tlugħ.\r\n\r\nIssettjah qrib ir-rata ta' upload sostnuta li tista' tintuża reali tal-linja tiegħek."
    IDS_CONNECTION_TT_NETWORK_ED2_K                            "Jippermetti n-netwerk tas-server eD2K klassiku.\r\n\r\nĦallih attivat jekk għadek tuża l-iskoperta tas-sors ibbażata fuq is-server. Itfih biss jekk intenzjonalment trid operazzjoni Kad biss."
    IDS_CONNECTION_TT_NETWORK_KADEMLIA                         "Jippermetti n-netwerk distribwit Kad.\r\n\r\nRakkomandat: attivat għal użu modern. Jeħtieġ li l-port UDP jibqa' attivat."
    IDS_CONNECTION_TT_PREF_UPNPONSTART                         "Tentattivi ta' mmappjar awtomatiku tal-port NAT mal-istartjar għall-portijiet konfigurati TCP u UDP.\r\n\r\nRakkomandat: attivat meta r-router tiegħek jappoġġja UPnP jew PCP/NAT-PMP. Itfih jekk tibgħat il-portijiet manwalment."
    IDS_CONNECTION_TT_RANDOMIZE_PORTS_ON_STARTUP               "Jagħżel TCP u UDP jisimgħu portijiet ġodda f\r\n\r\nl-istartjar qabel ma jibda l-immappjar tal-port awtomatiku."
    IDS_CONNECTION_TT_UDPDISABLE                               "Jitwaqqaf il-port UDP ta' eMuleBB u għalhekk tiddiżattiva karatteristiċi dipendenti fuq UDP bħal netwerking Kad.\r\n\r\nRakkomandat: ħalli dan off sakemm ma tridx tħaddem TCP-biss għal ambjent tan-netwerk speċifiku ħafna."
    IDS_CONNECTION_TT_STARTTEST                                "Tniedi t-test tal-konnettività esterna għall-portijiet TCP u UDP konfigurati bħalissa.\r\n\r\nUużah wara li tbiddel il-portijiet, torbot is-settings, jew ir-regoli tal-mapping tar-router."
    IDS_CONNECTION_TT_BIND_INTERFACE                           "L-isem tal-interface tan-netwerk Windows mhux obbligatorju użat għall-irbit tas-socket P2P.\r\n\r\nMatch huwa bl-isem tal-interface faċli, mhux in-numru tal-adapter. Il-bidliet jidħlu fis-seħħ wara l-bidu mill-ġdid."
    IDS_CONNECTION_TT_BIND_ADDRESS                             "Indirizz IPv4 mhux obbligatorju użat għall-irbit tas-socket P2P.\r\n\r\nĦallih vojt biex tuża l-ewwel IPv4 fuq l-interface magħżula, jew l-għażla default tar-rotta meta ma jintgħażel l-ebda interface."
    IDS_WEBSERVER_TT_WEBBINDADDR                               "Indirizz tal-bind lokali għall-WebServer integrati u REST API.\r\n\r\nĦallih vojt jew bħala 0.0.0.0 biex tisma' fuq l-interfaces kollha. Issettja IPv4 speċifiku biss jekk deliberatament trid tirrestrinġi fejn jisma' s-servizz."
    IDS_WEBSERVER_TT_WSAPIKEY                                  "Ċavetta REST API tat-test sempliċi użata mill-klijenti fl-header X-API-Key.\r\n\r\nRakkomandat: żomm il-valur każwali ġġenerat sakemm ma jkollokx bżonn token speċifiku. Kull min għandu din iċ-ċavetta għandu aċċess sħiħ għall-API."
    IDS_WEBSERVER_TT_WSUPNP                                    "Jinkludi l-port WebServer fl-immappjar awtomatiku NAT meta UPnP jew PCP/NAT-PMP tkun attivata.\r\n\r\nIppermettiha biss jekk trid intenzjonalment li l-Web UI jew REST API jintlaħaq permezz tal-mapping tar-router tiegħek."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD                          "Daqs massimu ta' upload ta' fajl wieħed aċċettat mill-WebServer f'MiB.\r\n\r\nUUża valur żgħir għal kontroll remot normali. Għolliha biss jekk il-klijenti tal-Web fdati jridu jtellgħu fajls akbar."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD_LBL                      "Daqs massimu ta' upload ta' fajl wieħed aċċettat mill-WebServer f'MiB.\r\n\r\nUUża valur żgħir għal kontroll remot normali. Għolliha biss jekk il-klijenti tal-Web fdati jridu jtellgħu fajls akbar."
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS                             "IPv4 allow-list mhux obbligatorju separati minn punt u virgola għal WebServer clients.\r\n\r\nĦalli vojt biex jippermetti kwalunkwe indirizz remot li jista 'jilħaq il-WebServer. Eżempju: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS_LBL                         "IPv4 allow-list mhux obbligatorju separati minn punt u virgola għal WebServer clients.\r\n\r\nĦalli vojt biex jippermetti kwalunkwe indirizz remot li jista 'jilħaq il-WebServer. Eżempju: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWHILEVFUNC                         "Jippermetti azzjonijiet amministrattivi tal-Web ta' livell għoli li jistgħu jbiddlu l-istat tar-runtime b'mod aktar aggressiv.\r\n\r\nRakkomandat: żomm dan off sakemm ma tkunx teħtieġ b'mod espliċitu dawk l-azzjonijiet minn klijenti amministraturi ta' fiduċja."
    IDS_WEBSERVER_TT_WEB_HTTPS                                 "Jservi l-Web UI u l-REST API fuq il-HTTPS billi tuża ċ-ċertifikat u ċ-ċavetta konfigurati.\r\n\r\nRakkomandat: attivat kull meta tesponi l-WebServer lil hinn mill-magna lokali."
    IDS_NOTIFY_TT_CB_TBN_USESOUND                              "Jilgħab fajl WAV personalizzat għan-notifiki tat-taskbar.\r\n\r\nUUża dan jekk trid twissija li tinstema'. Ħalliha off jekk popups siekta jew diskors huma biżżejjed."
    IDS_NOTIFY_TT_CB_TBN_USESPEECH                             "Juża text-to-speech għan-notifiki tat-taskbar meta magna tat-taħdit tkun disponibbli.\r\n\r\nUseful fuq sistemi waħedhom fejn it-twissijiet mitkellma huma aktar faċli biex jinnutaw milli ħsejjes."
    IDS_NOTIFY_TT_CB_TBN_POP_ALWAYS                            "Juri popup għal kull messaġġ taċ-chat li jidħol minflok l-ewwel wieħed biss.\r\n\r\nIppermettiha jekk ma tridx li l-messaġġi taċ-chat ta' segwitu jibqgħu kwiet."
    IDS_NOTIFY_TT_CB_TBN_USEWINDOWSTOAST                       "Juża notifiki toast Windows minflok il-popup personalizzat eMuleBB.\r\n\r\nJekk Windows jirrifjuta notifika toast, eMuleBB jaqa' lura għall-popup personalizzat."
    IDS_NOTIFY_TT_TBN_DISPLAYMODE                              "Jagħżel kif eMuleBB juri notifiki pop-up attivati.\r\n\r\nWindows toast huwa l-default. Jekk Windows tirrifjuta notifika toast, inkluż meta eMuleBB ikun qed jaħdem bħala amministratur, eMuleBB jaqa' lura għall-bużżieqa tat-trej klassika."
    IDS_NOTIFY_TT_CB_ENABLENOTIFICATIONS                       "Jippermetti notifiki bl-email barra għall-avvenimenti kkonfigurati.\r\n\r\nIppermettiha biss jekk diġà kkonfigurajt server SMTP u indirizzi li jaħdmu."
    IDS_NOTIFY_TT_SMTPSERVER                                   "Tiftaħ il-konfigurazzjoni tas-server SMTP użata min-notifiki bl-email.\r\n\r\nIkollok bżonn dan biss jekk in-notifiki bl-email huma attivati."
    IDS_BIND_STARTUP_INTERFACE_NOT_FOUND_FMT                   "Netwerking diżattivat għal din is-sessjoni minħabba li l-interface tal-irbit magħżula m'għadhiex disponibbli: %s"
    IDS_BIND_STARTUP_INTERFACE_AMBIGUOUS_FMT                   "Netwerking diżattivat għal din is-sessjoni minħabba li l-isem tal-interface tal-bind magħżul jaqbel ma' diversi adapters ħajjin: %s"
    IDS_BIND_STARTUP_INTERFACE_NO_ADDRESS_FMT                  "Netwerking diżattivat għal din is-sessjoni minħabba li l-interface ta' rabta magħżula m'għandha l-ebda indirizz IPv4 li jista' jintuża: %s"
    IDS_BIND_STARTUP_INTERFACE_ADDRESS_MISSING_FMT             "Netwerking diżattivat għal din is-sessjoni minħabba li l-irbit magħżul IP m'għadux preżenti fuq l-interface magħżula: %s"
    IDS_BIND_STARTUP_ADDRESS_MISSING_FMT                       "Netwerking diżattivat għal din is-sessjoni minħabba li l-irbit magħżul IP m'għadux preżenti fuq l-ebda interface live: %s"
    IDS_BIND_EXIT_INTERFACE_CHANGED_FMT                        "Ħruġ minn eMuleBB minħabba li l-interface tal-irbit magħżul biddel l-indirizz minn %s għal %s: %s"
