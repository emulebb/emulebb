    IDS_WEB_MAX_UPLOAD_MIB_LABEL                               "Max upload MiB:"
    IDS_WEB_ALLOWED_IPS_LABEL                                  "IPs permessi:"
    IDS_WEB_INVALID_UPLOAD_SIZE_MIB                            "Jekk jogħġbok daħħal daqs validu ta' upload WebServer f'MiB."
    IDS_WEB_INVALID_ALLOWED_IP_FMT                             "Indirizz WebServer IP permess mhux validu ""%s"".\r\n\r\nUse indirizzi IPv4 separati minn punt u virgola, jew ħalli l-qasam vojt biex jippermetti kwalunkwe indirizz remot."
    IDS_USE_WINDOWS_TOAST_NOTIFICATIONS                        "Uża notifiki toast Windows"
    IDS_NOTIFICATION_DISPLAY_MODE                              "Modalità tal-wiri:"
    IDS_NOTIFICATION_MODE_WINDOWS_TOAST                        "Windows toast"
    IDS_NOTIFICATION_MODE_CLASSIC_TRAY_BALLOON                 "Bużżieqa tat-trej klassika"
    IDS_NOTIFICATION_MODE_CUSTOM_POPUP                         "Popup personalizzat"
