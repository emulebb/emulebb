    IDS_FOLLOW_MAJORITY_FILENAME                               "Segwi l-isem tal-fajl tal-maġġoranza"
    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "Ikkopja eD2K Links Mal-Klipboard (Kad)"
    IDS_SHUTTING_DOWN_EMULE                                    "Jingħalqu eMuleBB"
    IDS_FRIEND_AUTHENTICATING                                  "Awtentika ħabib"
    IDS_BUNDLED_SCRIPT_MISSING                                 "L-iskrittura eMuleBB miġbura hija nieqsa: %s"
    IDS_ELEVATED_PS_TIMEOUT                                    "Azzjoni PowerShell elevata skaduta."
    IDS_SEARCHPARAMS_NAME_LABEL                                "&Isem:"
    IDS_SEARCHPARAMS_TYPE_LABEL                                "&Tip"
    IDS_SEARCHPARAMS_METHOD_LABEL                              "&Metodu:"
