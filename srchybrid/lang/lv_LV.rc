    IDS_SPEED_MIB_PER_SEC_FMT                                  "%.2f MiB/s"
    IDS_WEB_MAX_UPLOAD_MIB_LABEL                               "Maksimālā augšupielāde MiB:"
    IDS_WEB_ALLOWED_IPS_LABEL                                  "Atļautie IP:"
    IDS_WEB_INVALID_UPLOAD_SIZE_MIB                            "Lūdzu, ievadiet derīgu WebServer augšupielādes lielumu miB."
    IDS_WEB_INVALID_ALLOWED_IP_FMT                             "Nederīga atļautā WebServer IP adrese ""%s"".\r\n\r\nIzmantojiet ar semikolu atdalītas IPv4 adreses vai atstājiet lauku tukšu, lai atļautu jebkuru attālo adresi."
    IDS_USE_WINDOWS_TOAST_NOTIFICATIONS                        "Izmantojiet Windows grauzdiņu paziņojumus"
    IDS_NOTIFICATION_DISPLAY_MODE                              "Displeja režīms:"
    IDS_NOTIFICATION_MODE_WINDOWS_TOAST                        "Windows grauzdiņš"
    IDS_NOTIFICATION_MODE_CLASSIC_TRAY_BALLOON                 "Klasisks paplātes balons"
