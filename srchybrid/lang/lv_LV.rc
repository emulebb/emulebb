    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "Kopēt eD2K saites starpliktuvē (Kad)"
    IDS_SHUTTING_DOWN_EMULE                                    "eMuleBB izslēgšana"
    IDS_FRIEND_AUTHENTICATING                                  "Autentificē draugu"
    IDS_BUNDLED_SCRIPT_MISSING                                 "Trūkst komplektā iekļautā eMuleBB skripta: %s"
    IDS_ELEVATED_PS_TIMEOUT                                    "Paaugstinātās PowerShell darbības noildze."
    IDS_SEARCHPARAMS_NAME_LABEL                                "&Vārds:"
    IDS_SEARCHPARAMS_TYPE_LABEL                                "&Tips"
    IDS_SEARCHPARAMS_METHOD_LABEL                              "&Metode:"
