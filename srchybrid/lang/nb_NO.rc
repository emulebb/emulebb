    IDS_BIND_ANY_INTERFACE                                     "Ethvert grensesnitt"
    IDS_BIND_STATUS_ACTIVE_ANY                                 "Aktiv P2P-binding: Ethvert grensesnitt."
    IDS_BIND_STATUS_ACTIVE_FMT                                 "Aktiv P2P-binding: %s"
    IDS_BIND_STATUS_INTERFACE_NOT_FOUND_FMT                    "Aktiv P2P-binding: Ethvert grensesnitt. Det lagrede grensesnittet er utilgjengelig: %s"
