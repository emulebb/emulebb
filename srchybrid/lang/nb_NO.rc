    IDS_RANDOMIZE_PORTS_ON_STARTUP                             "Tilfeldig lytteporter ved oppstart"
    IDS_STARTUP_BIND_BLOCK                                     "Fortsett å være i frakoblet nettverk hvis bindingsmålet ikke er tilgjengelig ved oppstart"
    IDS_SPEED_MIB_PER_SEC_FMT                                  "%.2f MiB/s"
    IDS_WEB_MAX_UPLOAD_MIB_LABEL                               "Maks opplasting MiB:"
    IDS_WEB_ALLOWED_IPS_LABEL                                  "Tillatte IPs:"
    IDS_WEB_INVALID_UPLOAD_SIZE_MIB                            "Vennligst skriv inn en gyldig WebServer opplastingsstørrelse i MiB."
    IDS_WEB_INVALID_ALLOWED_IP_FMT                             "Ugyldig tillatt WebServer IP-adresse ""%s"".\r\n\r\nBruk semikolon-separerte IPv4-adresser, eller la feltet stå tomt for å tillate en hvilken som helst ekstern adresse."
    IDS_USE_WINDOWS_TOAST_NOTIFICATIONS                        "Bruk Windows toast-varsler"
    IDS_NOTIFICATION_DISPLAY_MODE                              "Visningsmodus:"
    IDS_NOTIFICATION_MODE_WINDOWS_TOAST                        "Windows toast"
    IDS_NOTIFICATION_MODE_CLASSIC_TRAY_BALLOON                 "Klassisk brettballong"
    IDS_NOTIFICATION_MODE_CUSTOM_POPUP                         "Egendefinert popup"
    IDS_EMAILNOT_GROUP_FMT                                     "(*) %s"
    IDS_FOLLOW_MAJORITY_FILENAME                               "Følg majoritetsfilnavnet"
    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "Kopier eD2K-lenker til utklippstavlen (Kad)"
    IDS_SHUTTING_DOWN_EMULE                                    "Slår av eMuleBB"
    IDS_FRIEND_AUTHENTICATING                                  "Autentiserer venn"
    IDS_BUNDLED_SCRIPT_MISSING                                 "Medfølgende eMuleBB-skript mangler: %s"
    IDS_ELEVATED_PS_TIMEOUT                                    "Forhøyet PowerShell-handling ble tidsavbrutt."
    IDS_SEARCHPARAMS_NAME_LABEL                                "&Navn:"
    IDS_SEARCHPARAMS_TYPE_LABEL                                "&Type"
    IDS_SEARCHPARAMS_METHOD_LABEL                              "&Metode:"
    IDS_SEARCHPARAMS_START_BUTTON                              "&Søk Go"
    IDS_SEARCHPARAMS_MORE_BUTTON                               "&Flere"
    IDS_SEARCHPARAMS_RESET_BUTTON                              "&Tilbakestill"
    IDS_SEARCHPARAMS_CANCEL_BUTTON                             "&Kansellere"
    IDS_STATUS_BIND_IP_LABEL                                   "Bind IP"
    IDS_STATUS_PUBLIC_IP_LABEL                                 "Offentlig IP"
    IDS_STATUS_NETWORK_ADDRESS_TOOLTIP_FMT                     "%s: %s | %s: %s"
    IDS_PREVIEW_REQUESTED_WAIT                                 "Forhåndsvisning forespurt - Vennligst vent"
    IDS_SEARCH_INFOTIP_SOURCES                                 "Kilder"
    IDS_SEARCH_INFOTIP_SERVERS                                 "Servere"
    IDS_NO_MATCHING_ENTRY_FOUND                                "Ingen samsvarende oppføring funnet."
    IDS_FATAL_NO_RICHEDIT                                      "Fatal feil: Ingen Rich Edit-kontrollbibliotek funnet!"
    IDS_FATAL_KAD_UNICODE_TABLES                               "Fatal feil: Kunne ikke laste Unicode-tegntabeller for Kademlia!"
    IDS_KAD_UNICODE_MAP_NOT_INITIALIZED                        "Kad Unicode små bokstavkart ikke initialisert!"
    IDS_TWEAKS_TT_CONDITIONAL_TCP_ACCEPT                       "Foretrekker å akseptere innkommende TCP-tilkoblinger bare når de ser nyttige ut.\r\n\r\nAvansert trafikkformende tweak. La den stå som standard med mindre du diagnostiserer tilkoblingstrykk."
    IDS_TWEAKS_TT_MAX_CON5_SEC                                 "Maksimalt antall nye TCP-tilkoblinger eMule kan åpne innen fem sekunder.\r\n\r\nLavere verdier er mildere for Windows og rutere. La den være nær standarden med mindre du justerer oppførselen til tilkoblingsburst."
    IDS_TWEAKS_TT_MAX_HALF_OPEN                                "Øvre grense for halvåpne utgående TCP-tilkoblingsforsøk.\r\n\r\nFor det meste en kompatibilitetssikring. Standard er vanligvis det riktige valget med mindre du undersøker TCP-oppsettproblemer."
    IDS_TWEAKS_TT_CONNECTION_TIMEOUT                           "Hvor lenge eMule venter på en ny tilkobling for å gjøre fremskritt før den vurderer at den mislyktes.\r\n\r\nKortere verdier gjenopprettes raskere fra døde jevnaldrende; lengre verdier er mer tolerante for trege nettverk. Standardverdier anbefales."
    IDS_TWEAKS_TT_DOWNLOAD_TIMEOUT                             "Hvor lenge en nedlastingskilde kan forbli inaktiv før eMule slipper den som stoppet.\r\n\r\nLavere verdier rydder opp i døde kilder raskere, men svært lave verdier kan skade trege peers. La standarden være med mindre du diagnostiserer stall."
    IDS_TWEAKS_TT_SERVER_KEEP_ALIVE_TIMEOUT                    "Hvor ofte eMule oppdaterer en ellers inaktiv servertilkobling.\r\n\r\nBruk minutter. Sett 0 for å deaktivere keepalives. La standarden være med mindre du løser et spesifikt problem med frakobling av server-tomgang."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_RESULTS                      "Maksimalt antall resultater forespurt fra en eD2K-server for ett søk.\r\n\r\nHøyere verdier kan finne flere filer, men øke serverarbeid og brukergrensesnittstøy. Hold deg nær standarden med mindre du har en spesifikk grunn."
    IDS_TWEAKS_TT_SEARCH_ED2K_MAX_MORE_REQUESTS                "Maksimalt antall oppfølgingsresultatsider eMule-forespørsler fra et eD2K-søk.\r\n\r\nHøyere verdier kan trekke inn flere resultater, men koster mer servertrafikk og tid. Konservative verdier anbefales."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_TOTAL                        "Mål antall resultater for Kad-filsøk.\r\n\r\nHøyere verdier søker bredere, men holder Kad-oppslag i live lenger. Hold deg nær standarden med mindre du vil ha dypere søk."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_TOTAL                     "Mål antall resultater for Kad søkeordsøk.\r\n\r\nHøyere verdier kan finne flere treff, men øke Kad-søkebelastningen og brukergrensesnittstøy. Standard er vanligvis den riktige balansen."
    IDS_TWEAKS_TT_SEARCH_KAD_FILE_LIFETIME                     "Maksimal levetid på ett Kad-filsøk på sekunder.\r\n\r\nØv den bare hvis du bevisst vil ha lengre løpende Kad-søk."
    IDS_TWEAKS_TT_SEARCH_KAD_KEYWORD_LIFETIME                  "Maksimal levetid på ett Kad nøkkelordsøk på sekunder.\r\n\r\nLengre levetid kan finne senere resultater, men øke søkeaktiviteten i bakgrunnen."
    IDS_TWEAKS_TT_GENERAL_ADVANCED                             "Generell avansert oppførsel som ikke passer rent under nettverk, fil, skjerm eller sikkerhet.\r\n\r\nDe fleste brukere bør la disse være i nærheten av standardinnstillingene."
    IDS_TWEAKS_TT_HIDDEN_FILE                                  "Avansert filhåndteringsatferd, forhåndsvisningsinspeksjon og filhistorikk relaterte alternativer.\r\n\r\nDisse innstillingene former hvordan eMule behandler filer, ikke hvor mye diskplass den reserverer."
    IDS_TWEAKS_TT_STORAGE_PERSISTENCE                          "Avanserte innstillinger for beskyttelse av diskplass, filbuffring og metadata-persistens.\r\n\r\nDette er hovedgruppen for lagringssikkerhet og disk-I/O-avveininger."
    IDS_TWEAKS_TT_HIDDEN_STARTUP                               "Avansert oppstartsgjenopprettingsatferd.\r\n\r\nDisse alternativene påvirker bare hvilke UI-ruter som kommer tilbake når eMule starter."
    IDS_TWEAKS_TT_HIDDEN_DISPLAY                               "Avanserte innstillinger for visning, oppgavelinje, skuff og visuell informasjon.\r\n\r\nDisse alternativene endrer kun presentasjonen, ikke overføringsatferd."
    IDS_TWEAKS_TT_HIDDEN_SECURITY                              "Avanserte filtrerings- og beskyttelsesalternativer for strengere peer- og meldingshåndtering.\r\n\r\nAnbefalte standardinnstillinger passer for de fleste brukere."
    IDS_TWEAKS_TT_LOGGING_GROUP                                "Vedvarende logging og diagnostiske utdatakontroller.\r\n\r\nDe fleste av disse innstillingene er bare nyttige når du diagnostiserer et problem."
    IDS_TWEAKS_TT_AUTO_TAKE_ED2K_LINKS                         "Registrerer eMule som standardbehandler for ed2k:// links.\r\n\r\nAktiver det hvis denne maskinen skal åpne ed2k-lenker i eMule automatisk. Deaktiver den hvis et annet verktøy skulle eie den tilknytningen."
    IDS_TWEAKS_TT_CREDIT_SYSTEM                                "Bruker det vanlige kredittsystemet eMule ved rangering av opplastingsklienter.\r\n\r\nAnbefalt: aktivert. Deaktiver den bare for feilsøking eller bevisste kompatibilitetseksperimenter."
    IDS_TWEAKS_TT_YOUR_HOSTNAME                                "Valgfri vertsnavnetikett eMule rapporterer hvor din lokale identitetstekst vises.\r\n\r\nLa det stå tomt med mindre du med vilje ønsker å navngi denne forekomsten."
    IDS_TWEAKS_TT_TXT_EDITOR                                   "Kommando som brukes når eMule åpner tekstfiler som logger eller generert tekstutdata.\r\n\r\nBruk en full bane hvis editoren ikke er på PATH. Standard er notepad.exe."
    IDS_TWEAKS_TT_HIGHRES_TIMER                                "Ber om en høyoppløselig Windows-timer mens eMule kjører.\r\n\r\nDette kan gjøre timingen jevnere på enkelte systemer, men det kan øke strømforbruket. Start eMule på nytt etter at du har endret den."
    IDS_TWEAKS_TT_ICH                                          "Aktiverer intelligent korrupsjonshåndtering for skadede nedlastede biter.\r\n\r\nAnbefalt: aktivert. Det hjelper å gjenopprette gode data inne i ødelagte deler i stedet for å laste ned på nytt mer enn nødvendig."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS                         "Kontrollerer om medieforhåndsvisning tilbys før de normale sikkerhetskontrollene for forhåndsvisning er fullt ut tilfredsstilt.\r\n\r\nHøyere nivåer gjør forhåndsvisning tilgjengelig tidligere, men mislykkede eller misvisende forhåndsvisninger blir mer sannsynlig."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_DISABLED                "Bruk de vanlige konservative forhåndsvisningsreglene."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_ALLOW                   "Tillat forhåndsvisning med mindre tilgjengelige blokker etter at de vanlige metadataene og spillersjekkene er bestått."
    IDS_TWEAKS_TT_PREVIEW_SMALL_BLOCKS_FORCE                   "Tilby forhåndsvisning selv når den første blokken mangler.\r\n\r\nBruk kun med spillere som tåler ufullstendige medier, for eksempel VLC."
    IDS_TWEAKS_TT_BEEP_ON_ERROR                                "Spiller av systemfeillyden når eMule rapporterer viktige feil.\r\n\r\nNyttig for uovervåket feilsøking. Deaktiver den hvis hørbare varsler ville være distraherende."
    IDS_TWEAKS_TT_SHOW_COPY_ED2K_LINK_CMD                      "Endrer filens kontekstmenyer for å vise en direkte Kopier ed2k Link-kommando i stedet for standard Vis ed2k Link-handling.\r\n\r\nAktiver det hvis kopiering av lenker er din normale arbeidsflyt."
    IDS_TWEAKS_TT_SPARSE_PART_FILES                            "Bruker sparsomme filer for delfiler når filsystemet støtter dem.\r\n\r\nRecommended: aktivert på NTFS for å redusere disktildeling på forhånd. Deaktiver bare hvis sparsom filoppførsel forårsaker et filsystemspesifikt problem."
    IDS_TWEAKS_TT_FULL_ALLOC                                   "Forhåndstildeler hele målfilstørrelsen på disken når nedlastinger starter.\r\n\r\nKan redusere fragmentering, men det reserverer plass umiddelbart og koster mer diskarbeid. La det være av med mindre du foretrekker full forhåndstildeling."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_CONFIG                   "Minimum ledig plass reservert på volumet som er vert for eMules konfigurasjonsfiler.\r\n\r\nHard minimum: 1 GiB. Hvis dette volumet faller under den effektive grensen, stopper eMule alle nedlastinger og lagrer umiddelbart .part.met-filer.\r\nHvis konfig deler et volum med temp eller innkommende, vinner den største grensen på det volumet."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_TEMP                     "Minimum ledig plass reservert på hvert volum som er vert for midlertidige filer.\r\n\r\nHard minimum: 5 GiB. Hvis et beskyttet volum faller under den effektive grensen, stopper eMule alle nedlastinger og lagrer umiddelbart .part.met-filer.\r\nHvis midlertidig deler et volum med konfigurasjon eller innkommende, vinner den største grensen på det volumet."
    IDS_TWEAKS_TT_MIN_FREE_DISK_SPACE_INCOMING                 "Minimum ledig plass reservert på hvert volum som er vert for innkommende filer, inkludert kategorispesifikke innkommende kataloger.\r\n\r\nHårdt minimum: 5 GiB. Hvis innkommende deler et volum med config eller temp, vinner den største grensen på det volumet og alle nedlastinger stoppes når den brytes."
    IDS_TWEAKS_TT_PERF_LOG                                     "Skriver periodiske nyttelast- og overhead-eksempler for eksterne grafiske verktøy. Kun\r\n\r\nOperator/debug-funksjon. La det være av med mindre du aktivt bruker de genererte filene."
    IDS_TWEAKS_TT_COMMIT                                       "Kontrollerer hvor aggressivt eMule tvinger Windows til å skylle ut lagrede fildata til disken.\r\n\r\nSafere innstillinger reduserer risikoen for krasjtap, men koster mer disk I/O. 'Bare ved avstengning' er den balanserte standarden."
    IDS_TWEAKS_TT_COMMIT_NEVER                                 "Lukk filer normalt uten å tvinge en diskspyling på OS-nivå.\r\n\r\nRaskeste og letteste på disk I/O, men mest avhengig av Windows-spyling senere."
    IDS_TWEAKS_TT_COMMIT_ON_SHUTDOWN                           "Tving en disk på OS-nivå bare mens eMule lukkes.\r\n\r\nAnbefalt standard. Det forbedrer utholdenhetssikkerheten ved ren utgang uten å tvinge frem ekstra spyler under hver lagring."
    IDS_TWEAKS_TT_COMMIT_ALWAYS                                "Tving en diskflush på OS-nivå på hver lagringsbane som bruker eMules commit-close helper.\r\n\r\nSikker mot krasj eller tap av metadata, men det forårsaker mest disk I/O."
    IDS_TWEAKS_TT_EXTRACT_META_DATA                            "Kontrollerer om eMule trekker ut metadata som tagger og medievarighet fra filer.\r\n\r\nNyttig for rikere filinformasjon, men det legger til bakgrunnsfilinspeksjon. Deaktiver den hvis du vil ha den letteste skanningen."
    IDS_TWEAKS_TT_GEO_LOCATION_ENABLED                         "Løser peer IPs til posisjonsdata på landnivå for visning.\r\n\r\nRent informativt. Deaktiver den hvis du ikke bryr deg om landsflagg eller ikke vil ha bakgrunnsoppdateringer."
    IDS_TWEAKS_TT_CLOSE_U_PN_P_PORTS                           "Lukker rutertilordninger ved ren utgang når automatisk NAT-tilordning ble brukt.\r\n\r\nAnbefalt: aktivert. Deaktiver den bare hvis du med vilje vil ha kartleggingene igjen."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE                          "Velger hvordan eMule utfører automatisk NAT-tilordning.\r\n\r\nAnbefalt: Automatisk. Som prøver UPnP IGD først og faller tilbake til PCP/NAT-PMP om nødvendig."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_AUTOMATIC                "Anbefalt modus. Prøv UPnP IGD først, og fall deretter tilbake til PCP/NAT-PMP hvis kartleggingen mislykkes."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_IGD_ONLY                 "Bruk kun UPnP IGD-kartlegging. Velg dette hvis du vil ha strengt klassisk UPnP-oppførsel."
    IDS_TWEAKS_TT_U_PN_P_BACKEND_MODE_PCP_NAT_PMP_ONLY         "Bruk kun PCP/NAT-PMP-kartlegging. Velg dette bare hvis rutermiljøet ditt klart foretrekker det."
    IDS_TWEAKS_TT_FILE_BUFFER_TIME_LIMIT                       "Maksimal alder på bufrede fildata før eMule tømmer dem til disk.\r\n\r\nLavere verdier reduserer data som er i faresonen under krasj. Høyere verdier kan redusere diskavgang. Standarden er vanligvis et godt kompromiss."
    IDS_TWEAKS_TT_FILE_BUFFER_SIZE                             "Størrelsen på skrivebufferen per fil som brukes før nedlastingsdata ble tømt til disk.\r\n\r\nStørre buffere kan redusere diskaktiviteten, men de øker minnebruken og forsinket skriving. Hold moderate verdier med mindre du stiller inn for et spesifikt lagringsoppsett."
    IDS_TWEAKS_TT_QUEUE_SIZE                                   "Målstørrelsen på opplastingsventekøen.\r\n\r\nHøyere verdier lar flere klienter vente, men de legger til minnebruk og administrasjonskostnader. Standardverdier anbefales for de fleste brukere."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LISTS                      "Egendefinert dato/klokkeslett-format brukt i listevisninger.\r\n\r\nLa det stå tomt for å bruke normal standardformatering. Endre den bare hvis du vil ha en spesifikk egendefinert tidsstempelstil."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT                             "Egendefinert dato/klokkeslett-format brukt av generelle fil- og peer-detaljvisninger.\r\n\r\nBruker CTime-formateringstokener. Hold den ikke tom; ugyldige tokens kan produsere forvirrende tidsstempler."
    IDS_TWEAKS_TT_DATE_TIME_FORMAT4_LOG                        "Egendefinert dato/tidsformat brukt i logglinjer og logglignende statusutdata.\r\n\r\nBruker CTime-formateringstokener. Hold det kortfattet slik at logglinjer forblir lesbare."
    IDS_TWEAKS_TT_ICON_FLASH_ON_NEW_MESSAGE                    "Blinker ikonet når en ny chat-melding kommer.\r\n\r\nRent en varslingspreferanse. Aktiver den hvis du vil at meldinger skal skille seg ut mens eMule er minimert."
    IDS_TWEAKS_TT_INSPECT_ALL_FILE_TYPES                       "Kjør også den dyre MediaInfo-stilen inspeksjonsstien for filtyper som ikke allerede er klassifisert som lyd eller video.\r\n\r\nAktiver den hvis du vil ha fyldigere filinformasjonsundersøkelse for uvanlige eller feilmerkede filer. La det være av for å inspisere bare sannsynlige lyd-/videofiler og redusere bakgrunnsinspeksjonsarbeidet."
    IDS_TWEAKS_TT_RE_BAR_TOOLBAR                               "Bruker den eldre hovedverktøylinjebeholderen i armeringsjern i stedet for den enklere vanlige verktøylinjeoppsettet.\r\n\r\nFor det meste en UI-layoutpreferanse. La den være aktivert bare hvis du foretrekker den eldre verktøylinjepresentasjonen."
    IDS_TWEAKS_TT_SHOW_UP_DOWN_ICON_IN_TASKBAR                 "Viser det kombinerte opplastings-/nedlastingshastighetsikonet i oppgavelinjens varslingsområde.\r\n\r\nRent visuelt. Deaktiver den hvis du vil ha et renere brettområde."
    IDS_ALWAYS_SHOW_TRAY_ICON                                  "Vis alltid skuffikon"
    IDS_TWEAKS_TT_ALWAYS_SHOW_TRAY_ICON                        "Holder eMule-ikonet synlig i Windows-varslingsområdet mens eMule kjører.\r\n\r\nClassic skuffballongvarsler og minimer-til-skuff kan fortsatt tvinge skuffikonet synlig når dette er deaktivert."
    IDS_TWEAKS_TT_SHOW_VERTICAL_HOUR_MARKERS                   "Tegner timebaserte guidemarkører i langtidsstatistikkgrafene.\r\n\r\nNyttig for å lese tidsbaserte trafikkmønstre. Deaktiver den hvis du foretrekker mindre grafrot."
    IDS_TWEAKS_TT_FORCE_SPEEDS_TO_KB                           "Tvinger hastighetsskjermer til å bruke enheter i KB/s-stil i stedet for å automatisk skalere til større enheter.\r\n\r\nAktiver det hvis du foretrekker faste kjente enheter. La den være av for mer lesbare skjermer med stor hastighet."
    IDS_TWEAKS_TT_REARRANGE_KAD_SEARCH_KEYWORDS                "Omordner Kad søkeordsøkeord for å prøve en mer nyttig søkeform først.\r\n\r\nAvansert justering av søkeatferd. La den stå som standard med mindre du stiller inn Kad søkeatferd bevisst."
    IDS_TWEAKS_TT_MESSAGE_FROM_VALID_SOURCES_ONLY              "Godtar kun meldinger fra jevnaldrende som allerede ser ut som gyldige kilder for overføringene dine.\r\n\r\nSterkere personvern-/spambeskyttelse, men det kan blokkere uønsket kontakt. Aktiver den hvis du ønsker en strengere meldingspolicy."
    IDS_TWEAKS_TT_MAX_CHAT_HISTORY_LINES                       "Maksimalt antall historielinjer beholdt per chat eller IRC kanalvisning.\r\n\r\nHøyere verdier beholder mer kontekst, men bruker mer minne og kan gjøre travle chatter tregere å vise."
    IDS_TWEAKS_TT_MAX_MESSAGE_SESSIONS                         "Maksimalt antall peer-meldingsøkter beholdes samtidig.\r\n\r\nHøyere verdier holder flere samtaler tilgjengelige, men de øker minnebruken. Standarden er konservativ."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP                            "Kontrollerer oppretting av krasjdumper når eMule møter et uhåndtert krasj.\r\n\r\nCrash-dumper hjelper til med å diagnostisere harde feil, men kan inneholde prosessminne. Del dem kun med pålitelige utviklere."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_DISABLED                   "Ikke lag krasjdumpfiler."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_PROMPT                     "Spør før du skriver en krasjdump når en krasj oppstår."
    IDS_TWEAKS_TT_CREATE_CRASH_DUMP_ALWAYS                     "Lag en krasjdump automatisk når en krasj oppstår.\r\n\r\nBest for feilsøking av repeterbare krasj på en klarert maskin."
    IDS_TWEAKS_TT_MAX_LOG_FILE_SIZE                            "Maksimal størrelse på hver loggfil på disken i KiB.\r\n\r\nBruk 0 for ingen rotasjonsgrense. Svært store verdier holder mer historikk, men bruker mer diskplass."
    IDS_TWEAKS_TT_MAX_LOG_BUFFER                               "Maksimal loggvisningsbuffer i minnet i KiB.\r\n\r\nHøyere verdier holder mer synlig logghistorikk, men bruker mer minne og kan bremse svært travle loggvisninger."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT                              "Koding som brukes for nyåpnede loggfiler på disken.\r\n\r\nEndring av dette mens loggene allerede er åpne fortsetter, men det nye formatet brukes etter at loggfilen er gjenåpnet eller eMule starter på nytt."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UNICODE                      "Skriv logger som UTF-16 Unicode. Dette er den gamle standarden og bevarer Windows-teksten bredt."
    IDS_TWEAKS_TT_LOG_FILE_FORMAT_UTF8                         "Skriv logger som UTF-8. Nyttig for verktøy som forventer moderne UTF-8-tekstfiler."
    IDS_TWEAKS_TT_LOG2_DISK                                    "Skriver den vanlige applikasjonsloggen til disken i stedet for å bare holde den i minnet.\r\n\r\nNyttig for feilsøking og langvarig uovervåket bruk, men den legger til diskskriving. La det være av med mindre du vil ha vedvarende logger."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT                         "Utdataformat for ytelseslogging prøver.\r\n\r\nCSV er enklest å inspisere manuelt. MRTG skriver sidevognfiler for grafiske verktøy som forventer MRTG-inndata."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_CSV                     "Skriv én CSV ytelsesloggfil med tidsstemplet nyttelast og overhead-eksempler."
    IDS_TWEAKS_TT_PERF_LOG_FILE_FORMAT_MRTG                    "Skriv MRTG-lignende data og overhead-sidevognfiler hentet fra den konfigurerte basisbanen."
    IDS_TWEAKS_TT_PERF_LOG_FILE                                "Grunnfilbane for ytelseslogging.\r\n\r\nLa den stå tom for å bruke standardfilen i eMules konfigurasjonskatalog. MRTG-modus henter _data- og _overhead-filer fra denne banen."
    IDS_TWEAKS_TT_PERF_LOG_INTERVAL                            "Samplingsintervall for ytelseslogging i minutter.\r\n\r\nKorte intervaller skaper finere grafer, men mer diskskriving. Bruk 1..1440."
    IDS_TWEAKS_TT_VERBOSE_GROUP                                "Ekstra diagnostiske loggingskontroller for dyp feilsøking.\r\n\r\nDisse alternativene er for feilsøking, ikke normal drift. La dem være av med mindre du undersøker et spesifikt problem."
    IDS_TWEAKS_TT_RESTORE_LAST_MAIN_WND_DLG                    "Gjenoppretter den sist valgte hovedvindusiden ved oppstart.\r\n\r\nAktiver den hvis du vil at eMule skal gjenåpnes der du slapp."
    IDS_TWEAKS_TT_RESTORE_LAST_LOG_PANE                        "Gjenoppretter den sist valgte loggruten ved oppstart.\r\n\r\nRent et praktisk alternativ for brukere som bruker tid i loggvisningene."
    IDS_TWEAKS_TT_KEEP_UNAVAILABLE_FIXED_SHARED_DIRS           "Beholder manuelt konfigurerte delte kataloger i listen selv når de for øyeblikket ikke er tilgjengelige.\r\n\r\nNyttig for flyttbar eller av og til manglende lagring. Deaktiver den hvis du vil at manglende mapper skal beskjæres aggressivt."
    IDS_TWEAKS_TT_PARTIALLY_PURGE_OLD_KNOWN_FILES              "Tillater mer aggressiv opprydding av foreldede oppføringer i historikken med kjente filer.\r\n\r\nKan redusere rot over tid, men den glemmer også gammel filhistorikk raskere. La standarden være med mindre du vil ha en slankere historie."
    IDS_TWEAKS_TT_DETECT_TCP_ERROR_FLOODER                     "Oppdager gjentatte TCP-feilutbrudd som kan indikere fornærmende eller ødelagte peers.\r\n\r\nAnbefalt: aktivert. Deaktiver den bare hvis du diagnostiserer falske positiver."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_INTERVAL_MINUTES           "Tidsvindu brukt for TCP feil-flom deteksjon.\r\n\r\nKortere vinduer reagerer raskere; lengre vinduer er mindre følsomme. Standardverdier anbefales."
    IDS_TWEAKS_TT_TCP_ERROR_FLOODER_THRESHOLD                  "Antall TCP feil innenfor intervallet som utløser flomhåndtering.\r\n\r\nLavere verdier er strengere. Øk den bare hvis miljøet ditt produserer ufarlige hyppige TCP-feil."
    IDS_TWEAKS_TT_SHAREE_MULE                                  "Kontrollerer hvordan eMule lagrer og deler per-brukertilstand på denne Windows-maskinen.\r\n\r\nForlat gjeldende modus med mindre du med vilje endrer hvordan flere lokale brukere deler konfigurasjon og data."
    IDS_TWEAKS_TT_TCP_GROUP                                    "Avanserte TCP-tilkoblingsburst-, tidsavbrudd- og keepalive-kontroller.\r\n\r\nDisse innstillingene påvirker tilkoblingsatferd i stedet for overføringsgrenser. Standardverdier anbefales med mindre du diagnostiserer problemer med nettverksoppsett."
    IDS_TWEAKS_TT_SEARCH_GROUP                                 "Avanserte grenser for hvor bredt og hvor lenge eMule søker på eD2K og Kad.\r\n\r\nHøyere verdier kan gi flere resultater, men de legger også til mer nettverkstrafikk og brukergrensesnittstøy."
    IDS_TWEAKS_TT_SEARCH_ED2K_GROUP                            "Serverbaserte eD2K søkegrenser.\r\n\r\nBruk konservative verdier med mindre du bevisst ønsker dypere serversøk."
    IDS_TWEAKS_TT_SEARCH_KAD_GROUP                             "Kad søkebredde og levetidskontroller.\r\n\r\nHøyere verdier holder distribuerte søk i live lenger og kan finne flere resultater, men de koster mer bakgrunnsaktivitet."
    IDS_TWEAKS_TT_BROADBAND                                    "Avansert opplastingsplassresirkulering og køpoengspolicy for opplastingsadferd i bredbåndsstil.\r\n\r\nDisse innstillingene er for bevisst justering. La dem stå på standardverdiene med mindre du justerer rettferdighet for opplasting eller omsetning av spilleautomater."
    IDS_TWEAKS_TT_UPLOAD_POLICY_MAX_UPLOAD_CLIENTS             "Myk hette for samtidig aktive opplastingsklienter under bredbåndsplanleggeren.\r\n\r\nHøyere verdier sprer båndbredde over flere jevnaldrende, men gjør hvert spor tynnere. Lavere verdier holder færre, sterkere spor."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_THRESHOLD                 "Brøkdel av målopplastingshastigheten per spor under som et spor anses som tregt.\r\n\r\nLavere verdier tolererer svakere spor lenger. Høyere verdier resirkulerer underpresterende spilleautomater mer aggressivt."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_GRACE                     "Hvor lenge en spilleautomat kan forbli under den langsomme terskelen før eMule vurderer å resirkulere den.\r\n\r\nLengre nåde er mer tålmodig med svake jevnaldrende; kortere nåde snur over svake spor tidligere."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SLOW_WARMUP                    "Oppvarmingsperiode for et nytt opplastingsspor før deteksjon av sakte spor starter.\r\n\r\nDette unngår å straffe nye opplastinger for oppstartsstøy og opptrappingstid."
    IDS_TWEAKS_TT_UPLOAD_POLICY_ZERO_RATE_GRACE                "Utsettelsesperiode for spilleautomater som i hovedsak ikke leverer opplastingsdata i det hele tatt.\r\n\r\nLavere verdier reagerer raskere på døde eller stoppede spor."
    IDS_TWEAKS_TT_UPLOAD_POLICY_COOLDOWN                       "Hvor lenge en resirkulert langsom spilleautomat forblir straffet i køscoring før den kan konkurrere normalt igjen.\r\n\r\nLengre nedkjøling reduserer umiddelbar gjenvalg av nylig svake klienter."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BOOST                "Legger til ekstra køpoengsum for klienter som ber om filer med lavt historisk opplastingsforhold.\r\n\r\nBruk den hvis du vil favorisere filer som har mottatt relativt lite opplasting så langt."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_THRESHOLD            "Opplastingsgradsavskjæring under som kø-poengøkningen med lavt forhold gjelder.\r\n\r\nLavere verdier begrenser boosten til sterkere underserverte filer."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_RATIO_BONUS                "Ytterligere effektiv køpoengsum gis når boosten med lavt forhold utløses.\r\n\r\nHøyere verdier gjør at boosten har større betydning for opplastingsbestilling."
    IDS_TWEAKS_TT_UPLOAD_POLICY_LOW_ID_DIVISOR                 "Straffedeler brukt på LowID-klienter under opplastingskøscoring.\r\n\r\nHøyere verdier reduserer LowID-prioritet mer aggressivt. Sett 1 for å deaktivere den ekstra LowID-straffen."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER               "Begrenser hvor mye én opplastingsøkt kan overføre før eMule vurderer å rotere det sporet.\r\n\r\nRotasjon skjer bare når en annen klient faktisk trenger sporet."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_DISABLED      "Ikke resirkuler opplastingsøkter basert på overført nyttelastbeløp."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT       "Begrens hver opplastingsøkt til en prosentandel av den forespurte filstørrelsen."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_PERCENT_VALUE "Prosentandel brukt når øktoverføringsgrensen er konfigurert som en andel av filstørrelsen."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B          "Begrens hver opplastingsøkt til et fast MiB-beløp uavhengig av filstørrelse."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TRANSFER_MI_B_VALUE    "Absolutt MiB-beløp som brukes når øktoverføringsgrensen er konfigurert som en fast størrelse."
    IDS_TWEAKS_TT_UPLOAD_POLICY_SESSION_TIME_LIMIT             "Maksimal varighet på én opplastingsøkt før eMule vurderer å rotere sporet.\r\n\r\nSett 0 for å deaktivere den tidsbaserte grensen."
    IDS_TWEAKS_TT_A4_AF_SAVE_CPU                               "Reduserer gjentatte A4AF (Sped For Another File) kildesjekker for å spare CPU-tid.\r\n\r\nNyttig på travle klienter, men det kan gjøre det mindre ivrig å bytte kilde til samme klient."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_NEVER                      "Ikke pakk ut metadata fra filer.\r\n\r\nLetteste alternativet. Bruk den hvis du ikke vil ha metadatasøking i bakgrunnen."
    IDS_TWEAKS_TT_EXTRACT_META_DATA_ID3_LIB                    "Trekk ut metadata kun gjennom ID3-biblioteksbanen for MPEG-lydfiler.\r\n\r\nBalansert standard for grunnleggende musikktagger uten bredere medieinspeksjon."
    IDS_TWEAKS_TT_PREVIEW_ON_ICON_DBL_CLK                      "Dobbeltklikk på et filikon åpner en forhåndsvisning i stedet fo\r\n\r\nr den vanlige standardhandlingen."
    IDS_TWEAKS_TT_EXTRA_PREVIEW_WITH_MENU                      "Viser forhåndsvisningskommandoer gjennom en dedikert handlingsmeny for forhåndsvisning i sted\r\n\r\net for bare å avsløre den enklere direkte forhåndsvisningshandlingen."
    IDS_TWEAKS_TT_SHOW_ACTIVE_DOWNLOADS_BOLD                   "Tegner aktivt overføre nedlastinger med fet skrift i nedlastingslisten.\r\n\r\nRent visuelt. Aktiver den hvis du vil at aktive elementer skal skille seg tydeligere ut."
    IDS_TWEAKS_TT_USE_SYSTEM_FONT_FOR_MAIN_CONTROLS            "Bruker den vanlige Windows UI-fonten for hovedkontroller og listevisninger i stedet for eMules egendefinerte skriftoppsett.\r\n\r\nNyttig hvis du foretrekker tekst som ser naturlig ut eller trenger bedre kompatibilitet med systemfontinnstillingene."
    IDS_TWEAKS_TT_FILTER_LANI_PS                               "Ignorerer server- og klientadresser fra private/LAN-områder.\r\n\r\nAnbefalt: aktivert. Dette unngår å prøve å bruke ikke-rutbare peer-adresser fra det offentlige nettverket."
    IDS_TWEAKS_TT_GEO_LOCATION_CHECK_DAYS                      "Hvor ofte eMule sjekker for oppdatert geolokasjonsdatabaseinnhold.\r\n\r\nSett 0 for å deaktivere automatiske oppdateringskontroller. Større verdier reduserer bakgrunnsoppdateringsaktiviteten."
    IDS_TWEAKS_TT_VERBOSE                                      "Hovedbryter for de detaljerte loggingskontrollene nedenfor.\r\n\r\nDeaktiver den for normal bruk. Aktiver det bare mens du undersøker et spesifikt problem."
    IDS_TWEAKS_TT_FULL_VERBOSE                                 "Registrerer det fulleste tilgjengelige, detaljerte sporet når detaljert logging er aktivert.\r\n\r\nDette kan bli svært støyende og bør kun brukes til fokusert feilsøking."
    IDS_TWEAKS_TT_LOG_LEVEL                                    "Verbositetsterskel for diagnostisk loggutgang.\r\n\r\nHøyere nivåer registrerer flere detaljer, men skaper mer støy."
    IDS_TWEAKS_TT_DEBUG2_DISK                                  "Skriver detaljert diagnostisk utdata til disken i stedet for å holde den forbigående.\r\n\r\nNyttig når du trenger en vedvarende feilsøkingssporing, men det øker diskaktiviteten."
    IDS_TWEAKS_TT_DEBUG_SOURCE_EXCHANGE                        "Logger kildeutvekslingsrelaterte pakker og beslutninger.\r\n\r\nSpesialisert diagnostisk alternativ. Aktiver det bare under feilsøking av kildeoppdagelse."
    IDS_TWEAKS_TT_LOG_BANNED_CLIENTS                           "Registrerer når jevnaldrende er utestengt og hvorfor.\r\n\r\nNyttig for misbruk eller falsk-positiv diagnose, men for mye støy for normal drift."
    IDS_TWEAKS_TT_LOG_RATING_DESC_RECEIVED                     "Poster mottatt filkommentarer, beskrivelser og vurderinger.\r\n\r\nNyttig for feilsøking av metadataflyt, men er vanligvis ikke nødvendig."
    IDS_TWEAKS_TT_LOG_SECURE_IDENT                             "Registrerer sikker-ident-verifisering og relaterte identitetskontroller.\r\n\r\nNyttig for feilsøking av tillit/autentisering."
    IDS_TWEAKS_TT_LOG_FILTERED_I_PS                            "Registrerer når IP filtrerer eller ignorerer logikk mister peer- eller serveradresser.\r\n\r\nNyttig for å diagnostisere hvorfor noen peers blir avvist."
    IDS_TWEAKS_TT_LOG_FILE_SAVING                              "Registrerer lagring av vedvarende data som kjente filer, kreditter og relatert tilstand.\r\n\r\nNyttig for vedvarende feilsøking, men unødvendig for normal bruk."
    IDS_TWEAKS_TT_LOG_A4_AF                                    "Registrerer A4AF (Sped For Another File) kildetildelingsaktivitet.\r\n\r\nSpesialisert nedlastingsbehandlingsdiagnosealternativ."
    IDS_TWEAKS_TT_LOG_UL_DL_EVENTS                             "Registrerer livssyklusendringer for opplastingsspor og nedlastingshendelser.\r\n\r\nNyttig ved diagnostisering av køavgang, sporrotasjon eller overganger til overføringstilstand."
    IDS_TWEAKS_TT_U_PN_P                                       "Automatiske ruterportkartleggingsinnstillinger for innkommende tilkobling.\r\n\r\nDe fleste brukere bør la denne gruppen stå på automatiske standardinnstillinger med mindre rutermiljøet krever noe spesifikt."
    IDS_TWEAKS_TT_SHAREE_MULE_MULTI_USER                       "Hver Windows-bruker får en separat eMule-konfigurasjon og separat nedlastingstilstand.\r\n\r\nConfig lever under Local AppData, og nedlastinger bruker den brukerens egen nedlastingsmappe. Passer best for delte PC-er der brukere ikke bør dele eMule-data."
    IDS_TWEAKS_TT_SHAREE_MULE_PUBLIC_USER                      "Alle Windows-brukere deler samme eMule-konfigurasjon og nedlastinger.\r\n\r\nConfig lever under ProgramData, og nedlastinger bruker offentlige nedlastinger. Bruk dette bare hvis maskinen med hensikt deler én felles eMule-tilstand."
    IDS_TWEAKS_TT_SHAREE_MULE_OLD_STYLE                        "Behold konfigurasjon og nedlastinger i programkatalogen ved å bruke den eldre eldre layouten. Kun\r\n\r\nLegacy kompatibilitetsmodus. Det er vanligvis det minst ønskelige valget på moderne Windows."
    IDS_CONNECTION_TT_AUTOCONNECT                              "Starter automatisk de aktiverte nettverkene når eMule starter.\r\n\r\nRecommended: aktivert for normal uovervåket bruk. Deaktiver den bare hvis du vil koble til manuelt hver økt."
    IDS_CONNECTION_TT_RECONN                                   "Prøver servertilkoblinger på nytt etter frakobling eller mislykkede forsøk.\r\n\r\nAnbefalt: aktivert hvis du bruker eD2K-servernettverket. Det har ingen effekt når servernettverk er deaktivert."
    IDS_CONNECTION_TT_SHOWOVERHEAD                             "Viser protokolloverhead separat i overføringshastigheter og statistikk.\r\n\r\nAktiver det hvis du vil ha et mer ærlig syn på trådtrafikk. La det være hvis du foretrekker enklere tall med kun nyttelast."
    IDS_CONNECTION_TT_PORT                                     "Hoved TCP-port som brukes for innkommende klienttilkoblinger.\r\n\r\nEndre den bare når du med vilje rekonfigurerer brannmur- eller ruterregler. Etter å ha endret den, test tilkoblingen på nytt."
    IDS_CONNECTION_TT_UDPPORT                                  "UDP-port som brukes for Kad og andre UDP-assisterte funksjoner.\r\n\r\nAnbefalt: hold den aktivert og tilgjengelig med mindre du med vilje ønsker å deaktivere UDP-basert nettverk."
    IDS_CONNECTION_TT_MAXSOURCEPERFILE                         "Hard grense for hvor mange eksterne kilder eMule beholder per nedlasting.\r\n\r\nHøyere verdier kan forbedre tilgjengeligheten for sjeldne filer, men koster mer minne og kildeadministrasjonstrafikk. Bruk moderate verdier med mindre du har en spesifikk grunn til å øke den."
    IDS_CONNECTION_TT_MAXCON                                   "Øvre grense for samtidige tilkoblinger eMule kan holde åpen.\r\n\r\nHøyere verdier er ikke automatisk bedre. La dette være nær den innstilte standarden med mindre du diagnostiserer en spesifikk nettverksbegrensning."
    IDS_CONNECTION_TT_DOWNLOAD_CAP                             "Din konfigurerte nedstrømskapasitet i KiB/s. eMule bruker dette som en øvre referanse for glidebrytere og båndbreddeavgjørelser.\r\n\r\nSett den nær din reelle brukbare linjehastighet, ikke markedsføringsmaksimum."
    IDS_CONNECTION_TT_UPLOAD_CAP                               "Din konfigurerte oppstrømskapasitet i KiB/s. eMule bruker dette som en øvre referanse for opplastingskontroll.\r\n\r\nSett den nær den reelle brukbare vedvarende opplastingshastigheten til linjen din."
    IDS_CONNECTION_TT_NETWORK_ED2_K                            "Aktiverer det klassiske eD2K-servernettverket.\r\n\r\nLa det være aktivert hvis du fortsatt bruker serverbasert kildeoppdagelse. Deaktiver den bare hvis du med vilje ønsker kun Kad-operasjon."
    IDS_CONNECTION_TT_NETWORK_KADEMLIA                         "Aktiverer Kad distribuert nettverk.\r\n\r\nAnbefalt: aktivert for moderne bruk. Det krever at UDP-porten forblir aktivert."
    IDS_CONNECTION_TT_PREF_UPNPONSTART                         "Forsøker automatisk NAT-porttilordning ved oppstart for de konfigurerte TCP- og UDP-portene.\r\n\r\nAnbefalt: aktivert når ruteren støtter UPnP eller PCP/NAT-PMP. Deaktiver den hvis du videresender porter manuelt."
    IDS_CONNECTION_TT_RANDOMIZE_PORTS_ON_STARTUP               "Velger nye TCP- og UDP-lytteporter ved oppstart før automatisk portkartlegging kjører.\r\n\r\nAlternativet bruker eMules eksisterende tilfeldige portområde og lar UDP være deaktivert når UDP-porten er deaktivert."
    IDS_CONNECTION_TT_UDPDISABLE                               "Deaktiverer eMules UDP-port og deaktiverer derfor UDP-avhengige funksjoner som Kad-nettverk.\r\n\r\nAnbefalt: la dette være av med mindre du bare må kjøre TCP for et veldig spesifikt nettverksmiljø."
    IDS_CONNECTION_TT_STARTTEST                                "Starter den eksterne tilkoblingstesten for de gjeldende konfigurerte TCP- og UDP-portene.\r\n\r\nBruk den etter å ha endret porter, bindingsinnstillinger eller rutertilordningsregler."
    IDS_CONNECTION_TT_BIND_INTERFACE                           "Valgfritt Windows nettverksgrensesnittnavn brukt for P2P socket binding.\r\n\r\nMatch er etter brukervennlig grensesnittnavn, ikke adapternummer. Endringer trer i kraft etter omstart."
    IDS_CONNECTION_TT_BIND_ADDRESS                             "Valgfri IPv4-adresse brukt for P2P-socketbinding.\r\n\r\nLa den stå tom for å bruke den første IPv4 på det valgte grensesnittet, eller standard rutingvalg når ingen grensesnitt er valgt."
    IDS_CONNECTION_TT_STARTUP_BIND_BLOCK                       "Holder P2P-nettverk frakoblet for økten hvis det konfigurerte bindingsmålet ikke kan løses ved oppstart.\r\n\r\nBare tilgjengelig når et bindingsgrensesnitt er valgt. Anbefales når du eksplisitt binder deg til et navngitt grensesnitt og ikke ønsker stille fallback."
    IDS_WEBSERVER_TT_WEBBINDADDR                               "Lokal bindingsadresse for de innebygde WebServer og REST API.\r\n\r\nLa den stå tom eller som 0.0.0.0 for å lytte på alle grensesnitt. Angi en spesifikk IPv4 bare hvis du med vilje vil begrense hvor tjenesten lytter."
    IDS_WEBSERVER_TT_WSAPIKEY                                  "Rentekst REST API nøkkel brukt av klienter i X-API-Key header.\r\n\r\nAnbefalt: behold den genererte tilfeldige verdien med mindre du trenger et spesifikt token. Alle med denne nøkkelen har full API-tilgang."
    IDS_WEBSERVER_TT_WSUPNP                                    "Inkluderer WebServer-porten i automatisk NAT-kartlegging når UPnP eller PCP/NAT-PMP er aktivert.\r\n\r\nAktiver den bare hvis du med vilje vil at Web UI eller REST API skal nås gjennom ruterkartleggingen."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD                          "Maksimal enkeltfilopplastingsstørrelse akseptert av WebServer i MiB.\r\n\r\nBruk en liten verdi for normal fjernkontroll. Øk den bare hvis pålitelige nettklienter trenger å laste opp større filer."
    IDS_WEBSERVER_TT_WS_MAXFILEUPLOAD_LBL                      "Maksimal enkeltfilopplastingsstørrelse akseptert av WebServer i MiB.\r\n\r\nBruk en liten verdi for normal fjernkontroll. Øk den bare hvis pålitelige nettklienter trenger å laste opp større filer."
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS                             "Valgfri semikolon-separert IPv4-tillatelsesliste for WebServer-klienter.\r\n\r\nLa stå tomt for å tillate enhver ekstern adresse som kan nå WebServer. Eksempel: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWEDIPS_LBL                         "Valgfri semikolon-separert IPv4-tillatelsesliste for WebServer-klienter.\r\n\r\nLa stå tomt for å tillate enhver ekstern adresse som kan nå WebServer. Eksempel: 127.0.0.1;192.168.1.50"
    IDS_WEBSERVER_TT_WS_ALLOWHILEVFUNC                         "Tillater administrative netthandlinger på høyt nivå som kan endre kjøretidstilstand mer aggressivt.\r\n\r\nAnbefalt: hold dette av med mindre du eksplisitt trenger disse handlingene fra pålitelige admin-klienter."
    IDS_WEBSERVER_TT_WEB_HTTPS                                 "Betjener Web UI og REST API over HTTPS ved å bruke det konfigurerte sertifikatet og nøkkelen.\r\n\r\nAnbefalt: aktivert når du eksponerer WebServer utenfor den lokale maskinen."
    IDS_NOTIFY_TT_CB_TBN_USESOUND                              "Spiller av en egendefinert WAV-fil for oppgavelinjevarsler.\r\n\r\nBruk denne hvis du vil ha et hørbart varsel. La den være av hvis stille popup-vinduer eller tale er nok."
    IDS_NOTIFY_TT_CB_TBN_USESPEECH                             "Bruker tekst-til-tale for oppgavelinjevarsler når en talemotor er tilgjengelig.\r\n\r\nNyttig på uovervåkede systemer der talevarsler er lettere å legge merke til enn lyder."
    IDS_NOTIFY_TT_CB_TBN_POP_ALWAYS                            "Viser en popup for hver innkommende chat-melding i stedet for bare den første.\r\n\r\nAktiver den hvis du ikke vil at oppfølgende chat-meldinger skal være stille."
    IDS_NOTIFY_TT_CB_TBN_USEWINDOWSTOAST                       "Bruker Windows-toast-varsler i stedet for den egendefinerte eMule-popup-vinduet.\r\n\r\nHvis Windows avviser en toast-varsling, faller eMule tilbake til den egendefinerte popup-vinduet."
    IDS_NOTIFY_TT_TBN_DISPLAYMODE                              "Velger hvordan eMule viser aktiverte popup-varsler.\r\n\r\nWindows toast er standard. Hvis Windows avviser et toastvarsel, inkludert når eMule kjører som administrator, faller eMule tilbake til den klassiske brettballongen."
    IDS_NOTIFY_TT_CB_ENABLENOTIFICATIONS                       "Aktiverer utgående e-postvarsler for de konfigurerte hendelsene.\r\n\r\nAktiver det bare hvis du allerede har konfigurert en fungerende SMTP-server og adresser."
    IDS_NOTIFY_TT_SMTPSERVER                                   "Åpner SMTP-serverkonfigurasjonen som brukes av e-postvarslinger.\r\n\r\nDu trenger dette bare hvis e-postvarsler er aktivert."
    IDS_BIND_STARTUP_INTERFACE_NOT_FOUND_FMT                   "Nettverk er deaktivert for denne økten fordi det valgte bindingsgrensesnittet ikke lenger er tilgjengelig: %s"
    IDS_BIND_STARTUP_INTERFACE_AMBIGUOUS_FMT                   "Nettverk er deaktivert for denne økten fordi navnet på det valgte bindingsgrensesnittet samsvarer med flere live-adaptere: %s"
    IDS_BIND_STARTUP_INTERFACE_NO_ADDRESS_FMT                  "Nettverk er deaktivert for denne økten fordi det valgte bindingsgrensesnittet ikke har noen brukbar IPv4-adresse: %s"
    IDS_BIND_STARTUP_INTERFACE_ADDRESS_MISSING_FMT             "Nettverk er deaktivert for denne økten fordi den valgte bindingen IP ikke lenger er til stede på det valgte grensesnittet: %s"
    IDS_BIND_STARTUP_ADDRESS_MISSING_FMT                       "Nettverk er deaktivert for denne økten fordi den valgte bindingen IP ikke lenger er tilstede på noe live-grensesnitt: %s"
    IDS_BIND_EXIT_INTERFACE_CHANGED_FMT                        "Avslutter eMule fordi det valgte bindingsgrensesnittet endret adresse fra %s til %s: %s"
    IDS_BIND_EXIT_INTERFACE_UNAVAILABLE                        "Avslutter eMule fordi det valgte bindingsgrensesnittet ikke lenger er tilgjengelig."
    IDS_BIND_STARTUP_DISABLED_PREFIX                           "Nettverk er deaktivert for denne økten"
    IDS_BIND_EXIT_PREFIX                                       "Avslutter eMule"
    IDS_STATUS_BIND_IP_COMPACT_LABEL                           "B"
    IDS_STATUS_PUBLIC_IP_COMPACT_LABEL                         "P"
    IDS_STATUS_ANY_COMPACT                                     "Noen"
    IDS_STATUS_UNKNOWN_COMPACT                                 "?"
    IDS_STATUS_NETWORK_ADDRESS_TEXT_FMT                        "%s:%s|%s:%s"
    IDS_PPG_DIRECTORIES_TT_INCFILES                            "Hoved innkommende katalog for fullførte nedlastinger.\r\n\r\nBruk en stabil lokal bane med nok ledig plass. Unngå midlertidige eller flyttbare steder med mindre du virkelig vil ha ferdige filer der."
    IDS_PPG_DIRECTORIES_TT_TEMPFILES                           "Arbeidskatalogliste for delfiler, hashes og overføringstilstand.\r\n\r\nDisse banene må forbli tilgjengelige mens nedlastinger kjører. Raske lokale disker anbefales over flyttbare eller upålitelige nettverksbaner."
    IDS_PPG_DIRECTORIES_TT_SHARESELECTOR                       "Velger hvilke lokale mapper eMule deler med andre klienter.\r\n\r\nDel kun katalogene du har tenkt å publisere. Unngå brede røtter som en hel stasjon."
    IDS_PPG_DISPLAY_TT_MINTRAY                                 "Minimerer eMule til skuffen i stedet for å la den stå på oppgavelinjen.\r\n\r\nNyttig for oppsett som alltid er på. La det være av hvis du foretrekker normal oppgavelinjeadferd."
    IDS_PPG_DISPLAY_TT_TOOLTIPDELAY                            "Forsink før UI-verktøytips vises.\r\n\r\nLavere verdier føles raskere, høyere verdier reduserer utilsiktede popup-vinduer. Standardområdet er vanligvis et godt kompromiss."
    IDS_PPG_DISPLAY_TT_SHOWRATEONTITLE                         "Viser gjeldende opp- og nedlastingshastigheter i hovedvinduets tittel.\r\n\r\nNyttig når eMule forblir i bakgrunnen og du fortsatt vil ha et raskt blikk."
    IDS_PPG_DISPLAY_TT_STORESEARCHES                           "Beholder nylige søkeord slik at de kan gjenbrukes senere.\r\n\r\nAnbefalt: aktivert med mindre du spesifikt vil ikke ha beholdt søkehistorikk."
    IDS_PPG_DISPLAY_TT_WIN7_TASKBARGOODIES                     "Aktiverer fremdrift på oppgavelinjen for Win\r\n\r\ndows og relatert skallintegrasjon der dette støttes."
    IDS_PPG_FILES_TT_PF_TIMECALC                               "Bruker den mer detaljerte beregningen av gjenværende tid for nedlastinger.\r\n\r\nAnbefalt: aktivert hvis du vil ha jevnere ETA-anslag. Deaktiver den bare hvis du foretrekker den eldre enklere beregningen."
    IDS_PPG_FILES_TT_PREVIEWPRIO                               "Prioriterer filmforhåndsvisningsbiter slik at delvis nedlastede medier blir forhåndsvisningsbare tidligere.\r\n\r\nNyttig for videonedlastinger. La det være hvis du foretrekker nøytral delbestilling."
    IDS_PPG_FILES_TT_WATCHCB                                   "Ser på utklippstavlen for ed2k-lenker og tilbyr å håndtere dem.\r\n\r\nPraktisk hvis du legger til nedlastinger fra nettlesere mye. Deaktiver den hvis du ikke vil at eMule skal se på utklippstavlen."
    IDS_PPG_FILES_TT_FNCLEANUP                                 "Rydder opp i nedlastede filnavn automatisk i henhold til de konfigurerte reglene.\r\n\r\nRecommended: aktivert hvis du vil ha mer konsistente endelige filnavn uten manuell opprydding."
    IDS_PPG_FILES_TT_STARTNEXTFILE                             "Starter den neste filen i kø automatisk når\r\n\r\nen annen nedlasting avsluttes eller stopper."
    IDS_PPG_FILES_TT_RUNONFILECOMPLETE                         "Kjører en kjørbar fil etter at en fil er fullført og beholdt.\r\n\r\nDette er deaktivert som standard. Programmet lanseres direkte uten Windows-skallet."
    IDS_PPG_FILES_TT_FILECOMPLETEARGS                          "Støttede tokens: %F full bane, %D katalog, %N filnavn, %H fil hash, %S størrelse byte, %C kategori.\r\n\r\n%F og %D blir automatisk. Miljøvariabler utvides ikke."
    IDS_PPG_GENERAL_TT_ONLINESIG                               "Skriver den eldre statusfilen onlinesig.dat for eksterne sider, skript eller widgets som leser eMule-status.\r\n\r\nDet forbedrer ikke overføringshastighet eller nettverksbygging. La den være av med mindre du aktivt bruker den filen et sted."
    IDS_PPG_GENERAL_TT_BRINGTOFOREGROUND                       "Tar eMule i forgrunnen når en håndtert ed2k-lenke eller lignende ekstern handling retter seg mot appen.\r\n\r\nAktiver det hvis du vil at lenkeklikk skal avsløre eMule umiddelbart. La det være av hvis du foretrekker bakgrunnshåndtering."
    IDS_PPG_GENERAL_TT_CHECK4_UPDATE                           "Sjekker GitHub Utgivelser ved oppstart når det konfigurerte intervallet har gått ut og varsler kun når en nyere eMuleBB-pakke er tilgjengelig.\r\n\r\nLa den være av for en rolig oppstart, eller aktiver den hvis du vil ha en periodisk oppdateringssjekk."
    IDS_PPG_GENERAL_TT_PREVENTSTANDBY                          "Blokkerer systemets hvilemodus mens eMuleBB er tilkoblet eller overfører, så lange nedlastinger, opplastinger, Kad og serverøkter blir ikke avbrutt.\r\n\r\nSkjermen kan fortsatt slås av normalt. Deaktivering av dette alternativet gjenoppretter umiddelbart den normale søvnpolicyen for Windows."
    IDS_PPG_GENERAL_TT_WEBSVEDIT                               "Redigerer den konfigurerte webtjenestelisten som brukes av hjelpehandlinger som nettoppslag fra brukergrensesnittet.\r\n\r\nDu trenger normalt bare dette hvis du vil tilpasse eller reparere disse eksterne oppslagsoppføringene."
    IDS_PPG_GENERAL_TT_ED2_KFIX                                "Reparerer Windows ed2k-koblingsregistreringen slik at nettleser- og ed2k-koblinger åpnes i eMule igjen.\r\n\r\nBruk den når ed2k-koblinger slutter å starte eMule eller ble stjålet av en annen klient."
    IDS_PPG_GENERAL_TT_STARTMIN                                "Starter eMule minimert i stedet for å åpne hovedvinduet umiddelbart.\r\n\r\nNyttig for uovervåket oppstart. La det være hvis du vanligvis vil inspisere brukergrensesnittet med en gang."
    IDS_PPG_GENERAL_TT_STARTWIN                                "Registrerer eMule for å starte med Windows for gjeldende bruker.\r\n\r\nAktiver det bare på maskiner der eMule er ment å kjøre vedvarende i bakgrunnen."
    IDS_PPG_IRC_TT_IRC_USECHANFILTER                           "Bruker kanalnavnet og minimumsbrukerfilteret når du ber om IRC-kanallisten.\r\n\r\nAktiver det hvis du vil at listen begrenses automatisk. Deaktiver den for alltid å hente hele kanallisten."
    IDS_PPG_IRC_TT_IRC_USEPERFORM                              "Kjører utfør-skriptet etter tilkobling til IRC.\r\n\r\nBruk det for automatiske sammenføyninger eller IRC-kommandoer. La det være av hvis du ikke vedlikeholder et perform-script."
    IDS_PPG_IRC_TT_IRC_NAME_BOX                                "Filtertekst for IRC-kanallisten.\r\n\r\nKun kanaler som samsvarer med denne teksten beholdes når kanalfilteret er aktivert."
    IDS_PPG_IRC_TT_IRC_MINUSER_BOX                             "Minimum antall brukere for kanaler vist av IRC kanallistefilteret.\r\n\r\nØv det for å skjule små kanaler. Bruk 0 for å beholde kanaler uavhengig av størrelse."
    IDS_PPG_MESSAGES_TT_MSGONLYFRIENDS                         "Godtar kun direktemeldinger fra brukere på vennelisten din.\r\n\r\nAnbefales hvis du ønsker et veldig stille chatoppsett. La det være hvis du fortsatt vil ha meldinger fra vanlige kunder."
    IDS_PPG_MESSAGES_TT_ADVSPAMFILTER                          "Aktiverer den sterkere spamfilterbanen for meldinger.\r\n\r\nRecommended: aktivert for normal bruk av offentlige nettverk. Det fungerer sammen med chat captchas for strengere filtrering."
    IDS_PPG_MESSAGES_TT_USECAPTCHAS                            "Krever en captcha-utfordring før ukjente klienter kan fullføre en chat-samtale.\r\n\r\nNyttig mot chat-spam. Brukes best sammen med det avanserte spamfilteret."
    IDS_PPG_MESSAGES_TT_COMMENTFILTER                          "Blokkerer filkommentarer som inneholder de konfigurerte filterbegrepene.\r\n\r\nBruk en '|' skille mellom ledd. Bra for kjente spamord eller plagsomme mønstre."
    IDS_PPG_PROXY_TT_ENABLEPROXY                               "Ruter støttede utgående tilkoblinger gjennom den konfigurerte proxyen.\r\n\r\nAktiver det bare hvis du med vilje kjører eMule bak en proxy. Direkte tilkoblinger er enklere og vanligvis raskere."
    IDS_PPG_PROXY_TT_PROXYTYPE                                 "Velger proxy-protokollen som forventes av proxy-serveren.\r\n\r\nBruk den eksakte typen oppgitt av proxy-operatøren; feil type betyr vanligvis umiddelbare tilkoblingsfeil."
    IDS_PPG_PROXY_TT_PROXYNAME                                 "Vertsnavnet eller IP-adressen til proxy-serveren.\r\n\r\nAngi nøyaktig endepunktet gitt av proxy-tjenesten. En feil vert betyr at all proxy-trafikk vil mislykkes."
    IDS_PPG_PROXY_TT_PROXYPORT                                 "Lytteporten til proxy-serveren.\r\n\r\nBruk den nøyaktige porten som kreves av proxyen. Vanlige SOCKS-standarder er ikke garantert å være korrekte."
    IDS_PPG_PROXY_TT_ENABLEAUTH                                "Sender proxy-brukernavn og -passord-legitimasjon når proxyen krever autentisering.\r\n\r\nAktiver det bare hvis proxy-tjenesten din faktisk bruker påloggingsinformasjon."
    IDS_PPG_PROXY_TT_USERNAME_A                                "Proxy-konto brukernavn.\r\n\r\nLa den stå tom med mindre proxy-tjeneren eksplisitt krever autentisert tilgang."
    IDS_PPG_SCHEDULER_TT_ENABLE                                "Aktiverer planleggeren slik at tidsbaserte regler kan endre innstillinger automatisk.\r\n\r\nLa den være av med mindre du aktivt bruker planlagt båndbredde, tilkobling eller kategoriendringer."
    IDS_PPG_SCHEDULER_TT_CHECKNOENDTIME                        "Kjører den valgte tidsplanoppføringen uten stopptid.\r\n\r\nBruk den for enveis tilstandsendringer som skal forbli aktive til en annen tidsplan overstyrer dem."
    IDS_PPG_SCHEDULER_TT_APPLY                                 "Bruker de redigerte detaljene på den valgte tidsplanoppføringen.\r\n\r\nBruk dette etter å ha endret dag, klokkeslett eller handlingsliste for den raden."
    IDS_PPG_SECURITY_TT_USESECIDENT                            "Bruker sikker identifikasjon når støttet for å gjøre klientkredittidentiteter vanskeligere å forfalske.\r\n\r\nAnbefalt: aktivert. Å deaktivere den reduserer bare identitetstilliten og er sjelden nyttig."
    IDS_PPG_SECURITY_TT_FILTERSERVERBYIPFILTER                 "Bruker IP-filteret på den synlige serverlisten slik at filtrerte servere skjules eller fjernes.\r\n\r\nAnbefalt: aktivert hvis du stoler på IP-filteret for serverhygiene så vel som peer-filtrering."
    IDS_PPG_SECURITY_TT_UPDATEURL                              "Kilde-URL som brukes når du laster ned oppdaterte IP-filterlister.\r\n\r\nBruk kun en pålitelig leverandør. Automatiske oppdateringer gjenbruker denne nettadressen og beholder det eksisterende filteret hvis nedlastingen er ugyldig."
    IDS_PPG_SECURITY_TT_AUTOUPDATE_IPFILTER                    "Sjekker den konfigurerte IP-filter URL-adressen automatisk etter oppstart når oppdateringsintervallet er forfallent.\r\n\r\nAnbefalt: deaktivert med mindre du stoler på leverandøren og vil at filteret skal oppdateres uten manuell handling."
    IDS_PPG_SECURITY_TT_IPFILTERPERIOD                         "Antall dager mellom forsøk på automatisk IP-filteroppdatering.\r\n\r\nTillatt område: 1 til 365 dager. Mislykkede forsøk telles fortsatt for å unngå gjentatte forsøk når en leverandør er utilgjengelig."
    IDS_PPG_SECURITY_TT_SEESHARE1                              "Lar alle bla gjennom de delte filene dine når den eksterne klienten støtter det.\r\n\r\nDet mest tillatelige alternativet. Bruk den bare hvis du er komfortabel med å eksponere den delte listen din bredt."
    IDS_PPG_SECURITY_TT_SEESHARE2                              "Tillater kun venner å bla gjennom dine delte filer.\r\n\r\nBalansert personvernvalg hvis du fortsatt vil ha støtte for eksplisitt pålitelige kontakter."
    IDS_PPG_SECURITY_TT_SEESHARE3                              "Hindrer eksterne klienter fr\r\n\r\na å bla gjennom listen over delte filer."
    IDS_PPG_SECURITY_TT_ENABLEOBFUSCATION                      "Foretrekker protokollobfuskering når den eksterne siden også støtter det.\r\n\r\nRecommended: aktivert. Det kan hjelpe på restriktive nettverk uten å tvinge frem en policy som bare er tilsløring."
    IDS_PPG_SECURITY_TT_ONLYOBFUSCATED                         "Krever obfuskerte tilkoblinger i stedet for å akseptere vanlige.\r\n\r\nBruk dette bare hvis nettverksmiljøet ditt virkelig trenger det. Det kan redusere tilkobling og rekkevidde til andre."
    IDS_PPG_SECURITY_TT_SEARCHSPAMFILTER                       "Filtrerer åpenbar spam fra søkeresultater før de fyller ut brukergrensesnittet.\r\n\r\nAnbefalt: aktivert for normal bruk av offentlige nettverk."
    IDS_PPG_SECURITY_TT_CHECK_FILE_OPEN                        "Sjekker nedlastede filer for åpen/låst tilstand før operasjoner som krever eksklusiv tilgang.\r\n\r\nAnbefalt: aktivert med mindre du har en spesifikk grunn til å hoppe over sikkerhetskontrollen."
    IDS_PPG_SERVER_TT_AUTOSERVER                               "Oppdaterer automatisk serverlisten fra tilkoblede klienter og andre pålitelige kilder.\r\n\r\nConvenient, men det lar også listen drifte over tid. Deaktiver den hvis du foretrekker en tett kurert statisk serverliste."
    IDS_PPG_SERVER_TT_UPDATESERVERCONNECT                      "Lar tilkoblede servere annonsere for flere servere i listen din.\r\n\r\nPraktisk, men det kan utvide listen med oppføringer med lav verdi. Deaktiver den hvis du foretrekker strengere manuell kurering."
    IDS_PPG_SERVER_TT_UPDATESERVERCLIENT                       "Lar klienter bidra med serveradresser til serverlisten din.\r\n\r\nDe fleste brukere bør behandle dette med forsiktighet. Deaktiver den hvis du vil ha tettere kontroll over serverlistekvaliteten."
    IDS_PPG_SERVER_TT_SAFESERVERCONNECT                        "Bruker en mer forsiktig server-tilkoblingsstrategi i stedet for å haste gjennom mange kandidater.\r\n\r\nAnbefalt: aktivert for stabilitet. Deaktiver den bare hvis du med vilje vil ha en mer aggressiv tilnærming."
    IDS_PPG_SERVER_TT_SMARTIDCHECK                             "Utfører den smarte LowID-kontrollen før du bestemmer deg for at tilgjengeligheten din på serversiden er dårlig.\r\n\r\nAnbefalt: aktivert. Den unngår noen falske LowID-konklusjoner under forbigående nettverksforhold."
    IDS_PPG_SERVER_TT_SCORE                                    "Bruker serverprioriteter når du velger og bestiller servere.\r\n\r\nRecommended: aktivert hvis du opprettholder et foretrukket undersett av servere og ønsker at eMule skal favorisere dem."
    IDS_PPG_SERVER_TT_SERVERRETRIES                            "Hvor mange mislykkede tilkoblingsforsøk en server kan akkumulere før eMule behandler den som død.\r\n\r\nLavere verdier beskjærer dårlige servere raskere; høyere verdier er mer tilgivende for forbigående avbrudd."
    IDS_PPG_SERVER_TT_AUTOCONNECTSTATICONLY                    "Begrenser automatiske servertilkoblingsforsøk til servere merket som statisk.\r\n\r\nAktiver det hvis du opprettholder en liten klarert statisk liste og ikke vil ha automatisk rotasjon over hele serverlisten."
    IDS_PPG_SERVER_TT_MANUALSERVERHIGHPRIO                     "Gir manuelt tilførte servere en høyere prioritet skjevhet enn vanlige oppdagede oppføringer.\r\n\r\nAktiver det hvis du opprettholder et håndplukket serversett og ønsker disse tilleggene favorisert."
    IDS_PPG_STATS_TT_FILL_GRAPHS                               "Fyller grafområdene i stedet for å bare tegne linjer.\r\n\r\nRent visuelt. Deaktiver den hvis du foretrekker en lettere, mindre opptatt statistikkvisning."
    IDS_PPG_STATS_TT_SLIDER                                    "Oppdateringsintervall for direktetrafikkgrafen.\r\n\r\nLavere verdier føles mer responsive, men koster mer brukergrensesnittarbeid. Moderate verdier er vanligvis best."
    IDS_PPG_STATS_TT_SLIDER2                                   "Oppdateringsintervall for statistikktreet og sammendragsverdier.\r\n\r\nLavere verdier oppdateres oftere, men koster mer brukergrensesnitt. Øk den hvis du vil ha roligere oppdateringer."
    IDS_PPG_STATS_TT_SLIDER3                                   "Gjennomsnittsvindu brukt av grafene.\r\n\r\nKorte vinduer viser pigger tydelig; lengre vinduer jevner ut skjermen og understreker trender."
    IDS_PPG_STATS_TT_COLORSELECTOR                             "Velger hvilken statistikkelementfarge du redigerer.\r\n\r\nBruk den bare hvis du tilpasser grafpaletten."
    IDS_PPG_STATS_TT_CGRAPHSCALE                               "Manuell Y-akseskala for koblingsgrafen.\r\n\r\nHev den hvis grafen klipper høye verdier; lavere verdier gir flere detaljer ved beskjedne tilkoblingstall."
