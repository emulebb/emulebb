    IDS_COPY_ED2K_LINKS_TO_CLIPBOARD_KAD                       "Kopjo lidhjet eD2K në kujtesën e fragmenteve (Kad)"
    IDS_SHUTTING_DOWN_EMULE                                    "Fikja e eMuleBB"
    IDS_FRIEND_AUTHENTICATING                                  "Shoku që vërteton"
